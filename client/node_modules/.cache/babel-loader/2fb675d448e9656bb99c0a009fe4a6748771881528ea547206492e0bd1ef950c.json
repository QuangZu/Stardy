{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport AdminLayout from '@/components/admin/AdminLayout.vue';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport { getAdminStats } from '@/api/Stats.js';\nexport default {\n  name: 'StatsAdmin',\n  components: {\n    AdminLayout,\n    AdminHeader\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      stats: {\n        totalUsers: 0,\n        totalAdmins: 0,\n        avgLevel: 0,\n        avgStreak: 0\n      }\n    };\n  },\n  mounted() {\n    this.fetchStats();\n  },\n  methods: {\n    async fetchStats() {\n      try {\n        this.stats = await getAdminStats();\n      } catch (error) {\n        console.error('Error fetching stats:', error);\n      }\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminLayout","AdminHeader","getAdminStats","name","components","data","currentUser","JSON","parse","localStorage","getItem","stats","totalUsers","totalAdmins","avgLevel","avgStreak","mounted","fetchStats","methods","error","console","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\StatsAdmin.vue"],"sourcesContent":["<template>\r\n  <AdminLayout>\r\n    <AdminHeader \r\n      title=\"Statistics\" \r\n      icon-class=\"fas fa-chart-bar\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n\r\n    <!-- Dashboard Content -->\r\n    <div class=\"space-y-6\">\r\n      <!-- Stats Overview Cards -->\r\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\r\n        <!-- Total Users Card -->\r\n        <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md transition-shadow duration-200\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <p class=\"text-sm font-medium text-gray-600 dark:text-gray-400\">Total Users</p>\r\n              <p class=\"text-3xl font-bold text-gray-900 dark:text-white mt-2\">{{ stats.totalUsers }}</p>\r\n              <div class=\"flex items-center mt-2\">\r\n                <span class=\"text-sm text-green-600 dark:text-green-400 font-medium\">+12%</span>\r\n                <span class=\"text-sm text-gray-500 dark:text-gray-400 ml-2\">from last month</span>\r\n              </div>\r\n            </div>\r\n            <div class=\"w-12 h-12 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-users text-blue-600 dark:text-blue-400 text-xl\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Total Admins Card -->\r\n        <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md transition-shadow duration-200\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <p class=\"text-sm font-medium text-gray-600 dark:text-gray-400\">Administrators</p>\r\n              <p class=\"text-3xl font-bold text-gray-900 dark:text-white mt-2\">{{ stats.totalAdmins }}</p>\r\n              <div class=\"flex items-center mt-2\">\r\n                <span class=\"text-sm text-blue-600 dark:text-blue-400 font-medium\">Active</span>\r\n                <span class=\"text-sm text-gray-500 dark:text-gray-400 ml-2\">all online</span>\r\n              </div>\r\n            </div>\r\n            <div class=\"w-12 h-12 bg-purple-100 dark:bg-purple-900/20 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-user-shield text-purple-600 dark:text-purple-400 text-xl\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Average Level Card -->\r\n        <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md transition-shadow duration-200\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <p class=\"text-sm font-medium text-gray-600 dark:text-gray-400\">Average Level</p>\r\n              <p class=\"text-3xl font-bold text-gray-900 dark:text-white mt-2\">{{ stats.avgLevel }}</p>\r\n              <div class=\"flex items-center mt-2\">\r\n                <span class=\"text-sm text-green-600 dark:text-green-400 font-medium\">+5.2%</span>\r\n                <span class=\"text-sm text-gray-500 dark:text-gray-400 ml-2\">improvement</span>\r\n              </div>\r\n            </div>\r\n            <div class=\"w-12 h-12 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-chart-line text-green-600 dark:text-green-400 text-xl\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Average Streak Card -->\r\n        <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md transition-shadow duration-200\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <p class=\"text-sm font-medium text-gray-600 dark:text-gray-400\">Average Streak</p>\r\n              <p class=\"text-3xl font-bold text-gray-900 dark:text-white mt-2\">{{ stats.avgStreak }}</p>\r\n              <div class=\"flex items-center mt-2\">\r\n                <span class=\"text-sm text-orange-600 dark:text-orange-400 font-medium\">🔥 Hot</span>\r\n                <span class=\"text-sm text-gray-500 dark:text-gray-400 ml-2\">streak active</span>\r\n              </div>\r\n            </div>\r\n            <div class=\"w-12 h-12 bg-orange-100 dark:bg-orange-900/20 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-fire text-orange-600 dark:text-orange-400 text-xl\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Charts Section -->\r\n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n        <!-- User Growth Chart -->\r\n        <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6\">\r\n          <div class=\"flex items-center justify-between mb-6\">\r\n            <h3 class=\"text-lg font-semibold text-gray-900 dark:text-white\">User Growth</h3>\r\n            <div class=\"flex space-x-2\">\r\n              <button class=\"px-3 py-1 text-sm bg-blue-100 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400 rounded-lg font-medium\">7D</button>\r\n              <button class=\"px-3 py-1 text-sm text-gray-500 dark:text-gray-400 rounded-lg font-medium hover:bg-gray-100 dark:hover:bg-gray-700\">30D</button>\r\n              <button class=\"px-3 py-1 text-sm text-gray-500 dark:text-gray-400 rounded-lg font-medium hover:bg-gray-100 dark:hover:bg-gray-700\">90D</button>\r\n            </div>\r\n          </div>\r\n          <div class=\"h-64 flex items-center justify-center bg-gray-50 dark:bg-gray-700 rounded-lg\">\r\n            <p class=\"text-gray-500 dark:text-gray-400\">Chart visualization would go here</p>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Activity Overview -->\r\n        <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6\">\r\n          <h3 class=\"text-lg font-semibold text-gray-900 dark:text-white mb-6\">Recent Activity</h3>\r\n          <div class=\"space-y-4\">\r\n            <div class=\"flex items-center space-x-3 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg\">\r\n              <div class=\"w-8 h-8 bg-green-100 dark:bg-green-900/20 rounded-full flex items-center justify-center\">\r\n                <i class=\"fas fa-user-plus text-green-600 dark:text-green-400 text-sm\"></i>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <p class=\"text-sm font-medium text-gray-900 dark:text-white\">New user registered</p>\r\n                <p class=\"text-xs text-gray-500 dark:text-gray-400\">2 minutes ago</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"flex items-center space-x-3 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg\">\r\n              <div class=\"w-8 h-8 bg-blue-100 dark:bg-blue-900/20 rounded-full flex items-center justify-center\">\r\n                <i class=\"fas fa-clipboard-check text-blue-600 dark:text-blue-400 text-sm\"></i>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <p class=\"text-sm font-medium text-gray-900 dark:text-white\">Exam completed</p>\r\n                <p class=\"text-xs text-gray-500 dark:text-gray-400\">5 minutes ago</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"flex items-center space-x-3 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg\">\r\n              <div class=\"w-8 h-8 bg-purple-100 dark:bg-purple-900/20 rounded-full flex items-center justify-center\">\r\n                <i class=\"fas fa-question-circle text-purple-600 dark:text-purple-400 text-sm\"></i>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <p class=\"text-sm font-medium text-gray-900 dark:text-white\">New question added</p>\r\n                <p class=\"text-xs text-gray-500 dark:text-gray-400\">10 minutes ago</p>\r\n              </div>\r\n            </div>\r\n            <div class=\"flex items-center space-x-3 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg\">\r\n              <div class=\"w-8 h-8 bg-orange-100 dark:bg-orange-900/20 rounded-full flex items-center justify-center\">\r\n                <i class=\"fas fa-book text-orange-600 dark:text-orange-400 text-sm\"></i>\r\n              </div>\r\n              <div class=\"flex-1\">\r\n                <p class=\"text-sm font-medium text-gray-900 dark:text-white\">Subject updated</p>\r\n                <p class=\"text-xs text-gray-500 dark:text-gray-400\">15 minutes ago</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Quick Actions -->\r\n      <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6\">\r\n        <h3 class=\"text-lg font-semibold text-gray-900 dark:text-white mb-6\">Quick Actions</h3>\r\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4\">\r\n          <router-link to=\"/admin/accounts\" class=\"flex items-center space-x-3 p-4 bg-blue-50 dark:bg-blue-900/10 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/20 transition-colors duration-200\">\r\n            <div class=\"w-10 h-10 bg-blue-100 dark:bg-blue-900/20 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-users text-blue-600 dark:text-blue-400\"></i>\r\n            </div>\r\n            <div>\r\n              <p class=\"text-sm font-medium text-gray-900 dark:text-white\">Manage Users</p>\r\n              <p class=\"text-xs text-gray-500 dark:text-gray-400\">View and edit accounts</p>\r\n            </div>\r\n          </router-link>\r\n          <router-link to=\"/admin/subjects\" class=\"flex items-center space-x-3 p-4 bg-green-50 dark:bg-green-900/10 rounded-lg hover:bg-green-100 dark:hover:bg-green-900/20 transition-colors duration-200\">\r\n            <div class=\"w-10 h-10 bg-green-100 dark:bg-green-900/20 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-book text-green-600 dark:text-green-400\"></i>\r\n            </div>\r\n            <div>\r\n              <p class=\"text-sm font-medium text-gray-900 dark:text-white\">Manage Subjects</p>\r\n              <p class=\"text-xs text-gray-500 dark:text-gray-400\">Add and edit subjects</p>\r\n            </div>\r\n          </router-link>\r\n          <router-link to=\"/admin/questions\" class=\"flex items-center space-x-3 p-4 bg-purple-50 dark:bg-purple-900/10 rounded-lg hover:bg-purple-100 dark:hover:bg-purple-900/20 transition-colors duration-200\">\r\n            <div class=\"w-10 h-10 bg-purple-100 dark:bg-purple-900/20 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-question-circle text-purple-600 dark:text-purple-400\"></i>\r\n            </div>\r\n            <div>\r\n              <p class=\"text-sm font-medium text-gray-900 dark:text-white\">Manage Questions</p>\r\n              <p class=\"text-xs text-gray-500 dark:text-gray-400\">Create and edit Q&A</p>\r\n            </div>\r\n          </router-link>\r\n          <router-link to=\"/admin/exams\" class=\"flex items-center space-x-3 p-4 bg-orange-50 dark:bg-orange-900/10 rounded-lg hover:bg-orange-100 dark:hover:bg-orange-900/20 transition-colors duration-200\">\r\n            <div class=\"w-10 h-10 bg-orange-100 dark:bg-orange-900/20 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-clipboard-list text-orange-600 dark:text-orange-400\"></i>\r\n            </div>\r\n            <div>\r\n              <p class=\"text-sm font-medium text-gray-900 dark:text-white\">Manage Exams</p>\r\n              <p class=\"text-xs text-gray-500 dark:text-gray-400\">Create and schedule exams</p>\r\n            </div>\r\n          </router-link>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </AdminLayout>\r\n</template>\r\n\r\n<script>\r\nimport AdminLayout from '@/components/admin/AdminLayout.vue'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\nimport { getAdminStats } from '@/api/Stats.js'\r\n\r\nexport default {\r\n  name: 'StatsAdmin',\r\n  components: {\r\n    AdminLayout,\r\n    AdminHeader\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      stats: {\r\n        totalUsers: 0,\r\n        totalAdmins: 0,\r\n        avgLevel: 0,\r\n        avgStreak: 0\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchStats()\r\n  },\r\n  methods: {\r\n    async fetchStats() {\r\n      try {\r\n        this.stats = await getAdminStats()\r\n      } catch (error) {\r\n        console.error('Error fetching stats:', error)\r\n      }\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";AA8LA,OAAOA,WAAU,MAAO,oCAAmC;AAC3D,OAAOC,WAAU,MAAO,oCAAmC;AAC3D,SAASC,aAAY,QAAS,gBAAe;AAE7C,eAAe;EACbC,IAAI,EAAE,YAAY;EAClBC,UAAU,EAAE;IACVJ,WAAW;IACXC;EACF,CAAC;EACDI,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,KAAK,EAAE;QACLC,UAAU,EAAE,CAAC;QACbC,WAAW,EAAE,CAAC;QACdC,QAAQ,EAAE,CAAC;QACXC,SAAS,EAAE;MACb;IACF;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,UAAU,CAAC;EAClB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,UAAUA,CAAA,EAAG;MACjB,IAAI;QACF,IAAI,CAACN,KAAI,GAAI,MAAMT,aAAa,CAAC;MACnC,EAAE,OAAOiB,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,uBAAuB,EAAEA,KAAK;MAC9C;IACF,CAAC;IACDE,MAAMA,CAAA,EAAG;MACPZ,YAAY,CAACa,UAAU,CAAC,OAAO;MAC/Bb,YAAY,CAACa,UAAU,CAAC,MAAM;MAC9B,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,QAAQ;IAC5B;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}