{"ast":null,"code":"import Chatbot from './components/Chatbot.vue';\nimport { checkAuthStatus } from './api/Auth.js';\nexport default {\n  name: 'App',\n  components: {\n    Chatbot\n  },\n  data() {\n    return {\n      isAuthenticated: false\n    };\n  },\n  computed: {\n    showChatbot() {\n      // Show chatbot on all pages except login and register\n      const hiddenRoutes = ['/login', '/register', '/'];\n      return !hiddenRoutes.includes(this.$route.path) && this.isAuthenticated;\n    }\n  },\n  async mounted() {\n    await this.checkAuthentication();\n  },\n  watch: {\n    '$route'() {\n      // Check authentication when route changes\n      this.checkAuthentication();\n    }\n  },\n  methods: {\n    async checkAuthentication() {\n      try {\n        const authResponse = await checkAuthStatus();\n        this.isAuthenticated = authResponse.success && authResponse.isAuthenticated;\n      } catch (error) {\n        console.error('Error checking authentication:', error);\n        this.isAuthenticated = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["Chatbot","checkAuthStatus","name","components","data","isAuthenticated","computed","showChatbot","hiddenRoutes","includes","$route","path","mounted","checkAuthentication","watch","methods","authResponse","success","error","console"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\App.vue"],"sourcesContent":["<template>\n  <div id=\"app\" class=\"min-h-screen gradient-bg text-white relative overflow-x-hidden\">\n    <!-- Persistent Animated Background -->    \n    <transition name=\"page\" mode=\"out-in\">\n      <router-view />\n    </transition>\n    \n    <!-- Global AI Chatbot -->\n    <Chatbot v-if=\"showChatbot\" />\n  </div>\n</template>\n\n<script>\nimport Chatbot from './components/Chatbot.vue';\nimport { checkAuthStatus } from './api/Auth.js';\n\nexport default {\n  name: 'App',\n  components: {\n    Chatbot\n  },\n  data() {\n    return {\n      isAuthenticated: false\n    }\n  },\n  computed: {\n    showChatbot() {\n      // Show chatbot on all pages except login and register\n      const hiddenRoutes = ['/login', '/register', '/'];\n      return !hiddenRoutes.includes(this.$route.path) && this.isAuthenticated;\n    }\n  },\n  async mounted() {\n    await this.checkAuthentication();\n  },\n  watch: {\n    '$route'() {\n      // Check authentication when route changes\n      this.checkAuthentication();\n    }\n  },\n  methods: {\n    async checkAuthentication() {\n      try {\n        const authResponse = await checkAuthStatus();\n        this.isAuthenticated = authResponse.success && authResponse.isAuthenticated;\n      } catch (error) {\n        console.error('Error checking authentication:', error);\n        this.isAuthenticated = false;\n      }\n    }\n  }\n}\n</script>\n\n<style>\n@import url('https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css');\n@import './styles/animations.css';\n@import './styles/navigation.css';\n@import './styles/background.css';\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  line-height: 1.6;\n  color: #333;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n#app {\n  min-height: 100vh;\n}\n\n/* Smooth Page Transitions */\n.page-enter-active, .page-leave-active {\n  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);\n}\n\n.page-enter-from {\n  opacity: 0;\n  transform: translateY(20px);\n}\n\n.page-leave-to {\n  opacity: 0;\n  transform: translateY(-20px);\n}\n\n.page-enter-to, .page-leave-from {\n  opacity: 1;\n  transform: translateY(0);\n}\n</style>"],"mappings":"AAaA,OAAOA,OAAM,MAAO,0BAA0B;AAC9C,SAASC,eAAc,QAAS,eAAe;AAE/C,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IACVH;EACF,CAAC;EACDI,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,eAAe,EAAE;IACnB;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,WAAWA,CAAA,EAAG;MACZ;MACA,MAAMC,YAAW,GAAI,C