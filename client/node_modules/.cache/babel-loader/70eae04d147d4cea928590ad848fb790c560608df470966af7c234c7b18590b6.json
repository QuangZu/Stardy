{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/web.dom-exception.stack.js\";\nimport { getAccount } from '../api/Account.js';\nexport default {\n  name: 'Progress',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      selectedTimeframe: 'week',\n      progressStats: {\n        totalXP: 0,\n        xpThisWeek: 0,\n        currentStreak: 0,\n        streakStatus: 'Keep it up!',\n        totalStudyTime: 0,\n        studyTimeThisWeek: 0,\n        completedLessons: 0,\n        completionRate: 0\n      },\n      subjectProgress: [],\n      recentAchievements: [],\n      learningGoals: [],\n      loading: true,\n      error: null\n    };\n  },\n  async mounted() {\n    await this.loadProgressData();\n  },\n  methods: {\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    async loadProgressData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        this.userId = userId;\n\n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n\n        // Load progress statistics\n        this.progressStats = {\n          totalXP: accountData.experience || 2450,\n          xpThisWeek: 320,\n          currentStreak: accountData.currentStreak || 7,\n          streakStatus: 'Keep it up!',\n          totalStudyTime: 45,\n          studyTimeThisWeek: 8,\n          completedLessons: accountData.completedLessons?.length || 23,\n          completionRate: 78\n        };\n\n        // Load subject progress\n        this.subjectProgress = [{\n          id: 1,\n          name: 'Mathematics',\n          icon: 'fas fa-calculator',\n          progress: 85\n        }, {\n          id: 2,\n          name: 'Physics',\n          icon: 'fas fa-atom',\n          progress: 72\n        }, {\n          id: 3,\n          name: 'Chemistry',\n          icon: 'fas fa-flask',\n          progress: 68\n        }, {\n          id: 4,\n          name: 'Biology',\n          icon: 'fas fa-dna',\n          progress: 45\n        }, {\n          id: 5,\n          name: 'Computer Science',\n          icon: 'fas fa-laptop-code',\n          progress: 90\n        }];\n\n        // Load recent achievements\n        this.recentAchievements = [{\n          id: 1,\n          title: 'Week Warrior',\n          description: 'Studied for 7 consecutive days',\n          icon: 'fas fa-fire',\n          dateEarned: '2 days ago'\n        }, {\n          id: 2,\n          title: 'Math Master',\n          description: 'Completed 50 math problems',\n          icon: 'fas fa-calculator',\n          dateEarned: '1 week ago'\n        }, {\n          id: 3,\n          title: 'Quick Learner',\n          description: 'Finished a lesson in under 10 minutes',\n          icon: 'fas fa-bolt',\n          dateEarned: '2 weeks ago'\n        }];\n\n        // Load learning goals\n        this.learningGoals = [{\n          id: 1,\n          title: 'Complete Calculus Course',\n          description: 'Finish all calculus modules before exam',\n          progress: 75,\n          deadline: 'Dec 15, 2024'\n        }, {\n          id: 2,\n          title: 'Physics Lab Completion',\n          description: 'Complete all required physics lab experiments',\n          progress: 60,\n          deadline: 'Jan 10, 2025'\n        }, {\n          id: 3,\n          title: 'Programming Project',\n          description: 'Build a full-stack web application',\n          progress: 40,\n          deadline: 'Feb 1, 2025'\n        }];\n      } catch (error) {\n        console.error('Error loading progress data:', error);\n        this.error = 'Failed to load progress data';\n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    updateCharts() {\n      console.log('Updating charts for timeframe:', this.selectedTimeframe);\n      // Here you would update the chart data based on the selected timeframe\n    },\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["getAccount","name","data","userName","userLevel","userId","selectedTimeframe","progressStats","totalXP","xpThisWeek","currentStreak","streakStatus","totalStudyTime","studyTimeThisWeek","completedLessons","completionRate","subjectProgress","recentAchievements","learningGoals","loading","error","mounted","loadProgressData","methods","getUserIdFromToken","token","localStorage","getItem","payload","JSON","parse","atob","split","id","console","Error","accountData","username","currentLevel","experience","length","icon","progress","title","description","dateEarned","deadline","message","includes","response","status","removeItem","$router","push","updateCharts","log","logout"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Progress.vue"],"sourcesContent":["<template>\n  <div class=\"progress-container space-background\">\n    <!-- Space Particles -->\n    <div class=\"space-particles\">\n      <div v-for=\"i in 20\" :key=\"i\" class=\"particle\" \n           :style=\"{\n             left: Math.random() * 100 + '%',\n             top: Math.random() * 100 + '%',\n             animationDelay: Math.random() * 3 + 's',\n             width: (Math.random() * 4 + 2) + 'px',\n             height: (Math.random() * 4 + 2) + 'px'\n           }\"></div>\n    </div>\n    <!-- Loading State -->\n    <div v-if=\"loading\" class=\"loading-container\">\n      <div class=\"loading-spinner\"><i class=\"fas fa-spinner fa-spin\"></i></div>\n      <p>Loading your progress...</p>\n    </div>\n    \n    <!-- Error State -->\n    <div v-else-if=\"error\" class=\"error-container\">\n      <div class=\"error-icon\"><i class=\"fas fa-exclamation-triangle\"></i></div>\n      <p>{{ error }}</p>\n      <button @click=\"loadProgressData\" class=\"retry-btn\">Try Again</button>\n    </div>\n    \n    <!-- Main Progress Content -->\n    <template v-else>\n      <!-- Sidebar -->\n      <div class=\"sidebar space-sidebar\">\n        <div class=\"sidebar-header\">\n          <div class=\"logo\">\n            <h2><i class=\"fas fa-star space-glow\"></i> Stardy</h2>\n          </div>\n          <router-link to=\"/profile\" class=\"nav-link\">\n          <div class=\"user-profile\">\n            <div class=\"avatar\">\n              <img src=\"https://via.placeholder.com/40\" alt=\"User Avatar\" />\n            </div>\n            <div class=\"user-info\">\n              <h4 class=\"space-text-primary\">{{ userName }}</h4>\n              <p class=\"space-text-secondary\">Level {{ userLevel }}</p>\n            </div>\n          </div>\n          </router-link>\n        </div>\n        \n        <nav class=\"sidebar-nav\">\n          <ul>\n            <li class=\"nav-item\">\n              <router-link to=\"/dashboard\" class=\"nav-link\">\n                <i class=\"fas fa-home icon\"></i>\n                Dashboard\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/learning\" class=\"nav-link\">\n                <i class=\"fas fa-book icon\"></i>\n                Learning\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/schedule\" class=\"nav-link\">\n                <i class=\"fas fa-calendar icon\"></i>\n                Schedule\n              </router-link>\n            </li>\n            <li class=\"nav-item active\">\n              <router-link to=\"/progress\" class=\"nav-link\">\n                <i class=\"fas fa-chart-line icon\"></i>\n                Progress\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/exams\" class=\"nav-link\">\n                <i class=\"fas fa-clipboard-check icon\"></i>\n                Exams\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/notes\" class=\"nav-link\">\n                <i class=\"fas fa-sticky-note icon\"></i>\n                Notes\n              </router-link>\n            </li>\n            <li class=\"nav-item active\">\n              <router-link to=\"/ai-tutor\" class=\"nav-link\">\n                <i class=\"icon fas fa-robot\"></i>\n                <span>AI Tutor</span>\n              </router-link>\n            </li>\n          </ul>\n        </nav>\n        \n        <div class=\"sidebar-footer\">\n          <button @click=\"logout\" class=\"logout-btn\">\n            <i class=\"icon fas fa-sign-out-alt\"></i>\n            <span>Logout</span>\n          </button>\n        </div>\n      </div>\n      \n      <!-- Main Content -->\n      <div class=\"main-content\">\n        <header class=\"progress-header\">\n          <div class=\"header-content space-glow\">\n            <h1><i class=\"fas fa-chart-line\"></i> Learning Progress</h1>\n            <p>Track your learning journey and achievements</p>\n          </div>\n          <div class=\"time-filter\">\n            <select v-model=\"selectedTimeframe\" @change=\"updateCharts\" class=\"timeframe-select\">\n              <option value=\"week\">This Week</option>\n              <option value=\"month\">This Month</option>\n              <option value=\"quarter\">This Quarter</option>\n              <option value=\"year\">This Year</option>\n            </select>\n          </div>\n        </header>\n        \n        <!-- Progress Overview -->\n        <div class=\"progress-overview\">\n          <div class=\"overview-cards\">\n            <div class=\"overview-card\">\n              <div class=\"card-icon\"><i class=\"fas fa-trophy\"></i></div>\n              <div class=\"card-content\">\n                <h3>{{ progressStats.totalXP }}</h3>\n                <p>Total XP Earned</p>\n                <span class=\"change positive\">+{{ progressStats.xpThisWeek }} this week</span>\n              </div>\n            </div>\n            <div class=\"overview-card\">\n              <div class=\"card-icon\"><i class=\"fas fa-fire\"></i></div>\n              <div class=\"card-content\">\n                <h3>{{ progressStats.currentStreak }}</h3>\n                <p>Day Streak</p>\n                <span class=\"change positive\">{{ progressStats.streakStatus }}</span>\n              </div>\n            </div>\n            <div class=\"overview-card\">\n              <div class=\"card-icon\"><i class=\"fas fa-clock\"></i></div>\n              <div class=\"card-content\">\n                <h3>{{ progressStats.totalStudyTime }}h</h3>\n                <p>Study Time</p>\n                <span class=\"change positive\">+{{ progressStats.studyTimeThisWeek }}h this week</span>\n              </div>\n            </div>\n            <div class=\"overview-card\">\n              <div class=\"card-icon\"><i class=\"fas fa-check-circle\"></i></div>\n              <div class=\"card-content\">\n                <h3>{{ progressStats.completedLessons }}</h3>\n                <p>Lessons Completed</p>\n                <span class=\"change positive\">{{ progressStats.completionRate }}% completion rate</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- Charts Section -->\n        <div class=\"charts-section\">\n          <div class=\"charts-grid\">\n            <!-- Study Time Chart -->\n            <div class=\"chart-card\">\n              <h3><i class=\"fas fa-chart-area\"></i> Study Time Trend</h3>\n              <div class=\"chart-placeholder\">\n                <div class=\"mock-chart\">\n                  <div class=\"chart-bars\">\n                    <div class=\"bar\" style=\"height: 60%\"></div>\n                    <div class=\"bar\" style=\"height: 80%\"></div>\n                    <div class=\"bar\" style=\"height: 45%\"></div>\n                    <div class=\"bar\" style=\"height: 90%\"></div>\n                    <div class=\"bar\" style=\"height: 70%\"></div>\n                    <div class=\"bar\" style=\"height: 85%\"></div>\n                    <div class=\"bar\" style=\"height: 95%\"></div>\n                  </div>\n                  <div class=\"chart-labels\">\n                    <span>Mon</span>\n                    <span>Tue</span>\n                    <span>Wed</span>\n                    <span>Thu</span>\n                    <span>Fri</span>\n                    <span>Sat</span>\n                    <span>Sun</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n            \n            <!-- Subject Progress Chart -->\n            <div class=\"chart-card\">\n              <h3><i class=\"fas fa-chart-pie\"></i> Subject Progress</h3>\n              <div class=\"subject-progress-list\">\n                <div v-for=\"subject in subjectProgress\" :key=\"subject.id\" class=\"subject-progress-item\">\n                  <div class=\"subject-info\">\n                    <i :class=\"subject.icon\"></i>\n                    <span>{{ subject.name }}</span>\n                  </div>\n                  <div class=\"progress-bar\">\n                    <div class=\"progress-fill\" :style=\"{ width: subject.progress + '%' }\"></div>\n                  </div>\n                  <span class=\"progress-percentage\">{{ subject.progress }}%</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- Achievements Section -->\n        <div class=\"achievements-section\">\n          <h2><i class=\"fas fa-medal\"></i> Recent Achievements</h2>\n          <div class=\"achievements-grid\">\n            <div v-for=\"achievement in recentAchievements\" :key=\"achievement.id\" class=\"achievement-card\">\n              <div class=\"achievement-icon\">\n                <i :class=\"achievement.icon\"></i>\n              </div>\n              <div class=\"achievement-content\">\n                <h4>{{ achievement.title }}</h4>\n                <p>{{ achievement.description }}</p>\n                <span class=\"achievement-date\">{{ achievement.dateEarned }}</span>\n              </div>\n              <div class=\"achievement-badge\">\n                <i class=\"fas fa-star\"></i>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- Goals Section -->\n        <div class=\"goals-section\">\n          <h2><i class=\"fas fa-target\"></i> Learning Goals</h2>\n          <div class=\"goals-grid\">\n            <div v-for=\"goal in learningGoals\" :key=\"goal.id\" class=\"goal-card\">\n              <div class=\"goal-header\">\n                <h4>{{ goal.title }}</h4>\n                <span class=\"goal-deadline\">{{ goal.deadline }}</span>\n              </div>\n              <p>{{ goal.description }}</p>\n              <div class=\"goal-progress\">\n                <div class=\"progress-bar\">\n                  <div class=\"progress-fill\" :style=\"{ width: goal.progress + '%' }\"></div>\n                </div>\n                <span class=\"progress-text\">{{ goal.progress }}% Complete</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </template>\n  </div>\n</template>\n\n<script>\nimport { getAccount } from '../api/Account.js';\n\nexport default {\n  name: 'Progress',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      selectedTimeframe: 'week',\n      progressStats: {\n        totalXP: 0,\n        xpThisWeek: 0,\n        currentStreak: 0,\n        streakStatus: 'Keep it up!',\n        totalStudyTime: 0,\n        studyTimeThisWeek: 0,\n        completedLessons: 0,\n        completionRate: 0\n      },\n      subjectProgress: [],\n      recentAchievements: [],\n      learningGoals: [],\n      loading: true,\n      error: null\n    }\n  },\n  async mounted() {\n    await this.loadProgressData();\n  },\n  methods: {\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    \n    async loadProgressData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        \n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        \n        this.userId = userId;\n        \n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n        \n        // Load progress statistics\n        this.progressStats = {\n          totalXP: accountData.experience || 2450,\n          xpThisWeek: 320,\n          currentStreak: accountData.currentStreak || 7,\n          streakStatus: 'Keep it up!',\n          totalStudyTime: 45,\n          studyTimeThisWeek: 8,\n          completedLessons: accountData.completedLessons?.length || 23,\n          completionRate: 78\n        };\n        \n        // Load subject progress\n        this.subjectProgress = [\n          { id: 1, name: 'Mathematics', icon: 'fas fa-calculator', progress: 85 },\n          { id: 2, name: 'Physics', icon: 'fas fa-atom', progress: 72 },\n          { id: 3, name: 'Chemistry', icon: 'fas fa-flask', progress: 68 },\n          { id: 4, name: 'Biology', icon: 'fas fa-dna', progress: 45 },\n          { id: 5, name: 'Computer Science', icon: 'fas fa-laptop-code', progress: 90 }\n        ];\n        \n        // Load recent achievements\n        this.recentAchievements = [\n          {\n            id: 1,\n            title: 'Week Warrior',\n            description: 'Studied for 7 consecutive days',\n            icon: 'fas fa-fire',\n            dateEarned: '2 days ago'\n          },\n          {\n            id: 2,\n            title: 'Math Master',\n            description: 'Completed 50 math problems',\n            icon: 'fas fa-calculator',\n            dateEarned: '1 week ago'\n          },\n          {\n            id: 3,\n            title: 'Quick Learner',\n            description: 'Finished a lesson in under 10 minutes',\n            icon: 'fas fa-bolt',\n            dateEarned: '2 weeks ago'\n          }\n        ];\n        \n        // Load learning goals\n        this.learningGoals = [\n          {\n            id: 1,\n            title: 'Complete Calculus Course',\n            description: 'Finish all calculus modules before exam',\n            progress: 75,\n            deadline: 'Dec 15, 2024'\n          },\n          {\n            id: 2,\n            title: 'Physics Lab Completion',\n            description: 'Complete all required physics lab experiments',\n            progress: 60,\n            deadline: 'Jan 10, 2025'\n          },\n          {\n            id: 3,\n            title: 'Programming Project',\n            description: 'Build a full-stack web application',\n            progress: 40,\n            deadline: 'Feb 1, 2025'\n          }\n        ];\n        \n      } catch (error) {\n        console.error('Error loading progress data:', error);\n        this.error = 'Failed to load progress data';\n        \n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    \n    updateCharts() {\n      console.log('Updating charts for timeframe:', this.selectedTimeframe);\n      // Here you would update the chart data based on the selected timeframe\n    },\n    \n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n}\n</script>\n\n<style scoped>\n.progress-container {\n  display: flex;\n  min-height: 100vh;\n  position: relative;\n}\n\n/* Sidebar Styles */\n.sidebar {\n  width: 280px;\n  background: rgba(255, 255, 255, 0.1);\n  backdrop-filter: blur(10px);\n  border-right: 1px solid rgba(255, 255, 255, 0.2);\n  display: flex;\n  flex-direction: column;\n  position: fixed;\n  height: 100vh;\n  overflow-y: auto;\n}\n\n.sidebar-header {\n  padding: 2rem 1.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.logo h2 {\n  color: white;\n  margin: 0 0 1.5rem 0;\n  font-size: 1.5rem;\n  font-weight: bold;\n}\n\n/* Clean Profile Styles - Remove Outer Layer */\n.user-profile {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  padding: 0; /* Remove padding to eliminate outer layer */\n  background: none; /* Remove background */\n  border: none; /* Remove any borders */\n  border-radius: 0; /* Remove border radius */\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  cursor: pointer;\n  position: relative;\n  overflow: visible; /* Change from hidden to visible */\n}\n\n/* Remove the background overlay */\n.user-profile::before {\n  display: none; /* Completely remove the background effect */\n}\n\n/* Remove the shine effect */\n.user-profile::after {\n  display: none; /* Remove the sweep animation */\n}\n\n/* Keep enhanced avatar hover effect */\n.avatar {\n  position: relative;\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  z-index: 2;\n}\n\n.avatar::before {\n  content: '';\n  position: absolute;\n  top: -3px;\n  left: -3px;\n  right: -3px;\n  bottom: -3px;\n  background: linear-gradient(45deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.1));\n  border-radius: 50%;\n  opacity: 0;\n  transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  z-index: -1;\n}\n\n.user-profile:hover .avatar::before {\n  opacity: 1;\n}\n\n.user-profile:hover .avatar {\n  transform: scale(1.05);\n}\n\n.avatar img {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  border: 2px solid rgba(255, 255, 255, 0.3);\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  position: relative;\n  z-index: 3;\n}\n\n.user-profile:hover .avatar img {\n  border-color: rgba(255, 255, 255, 0.6);\n  box-shadow: 0 4px 20px rgba(255, 255, 255, 0.2);\n}\n\n/* Keep enhanced text hover effects */\n.user-info {\n  position: relative;\n  z-index: 2;\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.user-profile:hover .user-info {\n  transform: translateX(2px);\n}\n\n.user-info h4 {\n  color: white;\n  margin: 0;\n  font-size: 0.9rem;\n  font-weight: 600;\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.user-profile:hover .user-info h4 {\n  color: #ffffff;\n  text-shadow: 0 2px 8px rgba(255, 255, 255, 0.3);\n}\n\n.user-info p {\n  color: rgba(255, 255, 255, 0.7);\n  margin: 0;\n  font-size: 0.8rem;\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.user-profile:hover .user-info p {\n  color: rgba(255, 255, 255, 0.9);\n}\n\n/* Keep active state for better feedback */\n.user-profile:active {\n  transform: scale(0.98);\n}\n\n/* Keep focus styles for accessibility */\n.user-profile:focus-visible {\n  outline: 2px solid rgba(255, 255, 255, 0.5);\n  outline-offset: 2px;\n}\n\n/* Optional: If you want a subtle hover effect only on the avatar */\n.user-profile:hover .avatar {\n  transform: scale(1.08);\n}\n\n/* Optional: Add a subtle glow effect only to text on hover */\n.user-profile:hover .user-info h4 {\n  text-shadow: 0 0 10px rgba(255, 255, 255, 0.4);\n}\n\n/* Responsive adjustments */\n@media (max-width: 768px) {\n  .user-profile {\n    padding: 0; /* Keep no padding on mobile */\n  }\n  \n  .avatar img {\n    width: 36px;\n    height: 36px;\n  }\n  \n  .user-info h4 {\n    font-size: 0.85rem;\n  }\n  \n  .user-info p {\n    font-size: 0.75rem;\n  }\n}\n\n.sidebar-nav {\n  flex: 1;\n  padding: 1rem 0;\n}\n\n.sidebar-nav ul {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n}\n\n/* Navigation styles now centralized in navigation.css */\n\n.sidebar-footer {\n  padding: 1.5rem;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.logout-btn {\n  width: 100%;\n  padding: 0.75rem;\n  background: rgba(255, 255, 255, 0.1);\n  border: 1px solid rgba(255, 255, 255, 0.3);\n  border-radius: 8px;\n  color: white;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n  justify-content: center;\n}\n\n.logout-btn:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n/* Main Content */\n.main-content {\n  flex: 1;\n  margin-left: 280px;\n  padding: 2rem;\n  overflow-y: auto;\n}\n\n.progress-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 2rem;\n}\n\n.header-content h1 {\n  color: white;\n  margin: 0;\n  font-size: 2rem;\n  display: flex;\n  align-items: center;\n  gap: 0.5rem;\n}\n\n.header-content p {\n  color: rgba(255, 255, 255, 0.8);\n  margin: 0.5rem 0 0 0;\n}\n\n.timeframe-select {\n  padding: 0.5rem 1rem;\n  background: rgba(255, 255, 255, 0.1);\n  border: 1px solid rgba(255, 255, 255, 0.3);\n  border-radius: 8px;\n  color: white;\n  font-size: 0.9rem;\n}\n\n/* Progress Overview */\n.progress-overview {\n  margin-bottom: 2rem;\n}\n\n.overview-cards {\n  dis