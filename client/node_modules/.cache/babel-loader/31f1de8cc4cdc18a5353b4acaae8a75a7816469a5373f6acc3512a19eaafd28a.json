{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'AdminSidebar',\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}')\n    };\n  },\n  methods: {\n    isActive(path) {\n      return this.$route.path === path;\n    },\n    handleLogout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["name","data","currentUser","JSON","parse","localStorage","getItem","methods","isActive","path","$route","handleLogout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\components\\admin\\AdminSidebar.vue"],"sourcesContent":["<template>\n  <aside class=\"fixed top-0 left-0 z-50 w-[280px] h-screen bg-white dark:bg-gray-900 border-r border-gray-200 dark:border-gray-800 transition-transform duration-300 ease-in-out\">\n    <!-- Logo Section -->\n    <div class=\"flex items-center justify-center py-6 px-6 border-b border-gray-200 dark:border-gray-800\">\n      <div class=\"flex items-center space-x-3\">\n        <div class=\"w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg flex items-center justify-center\">\n          <i class=\"fas fa-shield-alt text-white text-lg\"></i>\n        </div>\n        <div>\n          <h1 class=\"text-xl font-bold text-gray-900 dark:text-white\">Admin Panel</h1>\n          <p class=\"text-xs text-gray-500 dark:text-gray-400\">Management System</p>\n        </div>\n      </div>\n    </div>\n\n    <!-- User Profile Section -->\n    <div class=\"px-6 py-4 border-b border-gray-200 dark:border-gray-800\">\n      <div class=\"flex items-center space-x-3\">\n        <div class=\"w-10 h-10 bg-gradient-to-br from-green-400 to-blue-500 rounded-full flex items-center justify-center\">\n          <i class=\"fas fa-user-shield text-white text-sm\"></i>\n        </div>\n        <div class=\"flex-1 min-w-0\">\n          <p class=\"text-sm font-medium text-gray-900 dark:text-white truncate\">\n            {{ currentUser.username || 'Admin User' }}\n          </p>\n          <p class=\"text-xs text-gray-500 dark:text-gray-400 truncate\">\n            {{ currentUser.email || 'admin@example.com' }}\n          </p>\n        </div>\n        <div class=\"w-2 h-2 bg-green-400 rounded-full\"></div>\n      </div>\n    </div>\n\n    <!-- Navigation Menu -->\n    <nav class=\"flex-1 px-4 py-6 space-y-2 overflow-y-auto\">\n      <!-- Dashboard Section -->\n      <div class=\"mb-6\">\n        <h3 class=\"px-3 mb-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider\">\n          Dashboard\n        </h3>\n        <router-link\n          to=\"/admin/stats\"\n          class=\"menu-item\"\n          :class=\"isActive('/admin/stats') ? 'menu-item-active' : 'menu-item-inactive'\"\n        >\n          <i class=\"fas fa-chart-bar w-5 h-5\"></i>\n          <span>Statistics</span>\n        </router-link>\n      </div>\n\n      <!-- Management Section -->\n      <div class=\"mb-6\">\n        <h3 class=\"px-3 mb-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider\">\n          Management\n        </h3>\n        <router-link\n          to=\"/admin/accounts\"\n          class=\"menu-item\"\n          :class=\"isActive('/admin/accounts') ? 'menu-item-active' : 'menu-item-inactive'\"\n        >\n          <i class=\"fas fa-users w-5 h-5\"></i>\n          <span>Accounts</span>\n        </router-link>\n        <router-link\n          to=\"/admin/subjects\"\n          class=\"menu-item\"\n          :class=\"isActive('/admin/subjects') ? 'menu-item-active' : 'menu-item-inactive'\"\n        >\n          <i class=\"fas fa-book w-5 h-5\"></i>\n          <span>Subjects</span>\n        </router-link>\n        <router-link\n          to=\"/admin/questions\"\n          class=\"menu-item\"\n          :class=\"isActive('/admin/questions') ? 'menu-item-active' : 'menu-item-inactive'\"\n        >\n          <i class=\"fas fa-question-circle w-5 h-5\"></i>\n          <span>Questions</span>\n        </router-link>\n        <router-link\n          to=\"/admin/exams\"\n          class=\"menu-item\"\n          :class=\"isActive('/admin/exams') ? 'menu-item-active' : 'menu-item-inactive'\"\n        >\n          <i class=\"fas fa-clipboard-list w-5 h-5\"></i>\n          <span>Exams</span>\n        </router-link>\n      </div>\n\n      <!-- AI & Analytics Section -->\n      <div class=\"mb-6\">\n        <h3 class=\"px-3 mb-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider\">\n          AI & Analytics\n        </h3>\n        <router-link\n          to=\"/admin/ai-health\"\n          class=\"menu-item\"\n          :class=\"isActive('/admin/ai-health') ? 'menu-item-active' : 'menu-item-inactive'\"\n        >\n          <i class=\"fas fa-brain w-5 h-5\"></i>\n          <span>AI Health</span>\n        </router-link>\n      </div>\n\n      <!-- System Section -->\n      <div class=\"mb-6\">\n        <h3 class=\"px-3 mb-3 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider\">\n          System\n        </h3>\n        <router-link\n          to=\"/admin/system\"\n          class=\"menu-item\"\n          :class=\"isActive('/admin/system') ? 'menu-item-active' : 'menu-item-inactive'\"\n        >\n          <i class=\"fas fa-cog w-5 h-5\"></i>\n          <span>Settings</span>\n        </router-link>\n      </div>\n    </nav>\n\n    <!-- Logout Section -->\n    <div class=\"p-4 border-t border-gray-200 dark:border-gray-800\">\n      <button\n        @click=\"handleLogout\"\n        class=\"w-full flex items-center space-x-3 px-3 py-2 text-sm font-medium text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors duration-200\"\n      >\n        <i class=\"fas fa-sign-out-alt w-5 h-5\"></i>\n        <span>Logout</span>\n      </button>\n    </div>\n  </aside>\n</template>\n\n<script>\nexport default {\n  name: 'AdminSidebar',\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}')\n    }\n  },\n  methods: {\n    isActive(path) {\n      return this.$route.path === path\n    },\n    handleLogout() {\n      localStorage.removeItem('token')\n      localStorage.removeItem('user')\n      this.$router.push('/login')\n    }\n  }\n}\n</script>\n\n<style scoped>\n.menu-item {\n  @apply flex items-center space-x-3 px-3 py-2.5 text-sm font-medium rounded-lg transition-all duration-200;\n}\n\n.menu-item-active {\n  @apply bg-blue-50 text-blue-700 border-r-2 border-blue-500;\n}\n\n.menu-item-inactive {\n  @apply text-gray-700 hover:bg-gray-100 hover:text-gray-900;\n}\n\n.dark .menu-item-active {\n  @apply bg-blue-900/20 text-blue-400 border-blue-400;\n}\n\n.dark .menu-item-inactive {\n  @apply text-gray-300 hover:bg-gray-800 hover:text-white;\n}\n\n/* Custom scrollbar */\n::-webkit-scrollbar {\n  width: 4px;\n}\n\n::-webkit-scrollbar-track {\n  background: transparent;\n}\n\n::-webkit-scrollbar-thumb {\n  background: #d1d5db;\n  border-radius: 2px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: #9ca3af;\n}\n\n.dark ::-webkit-scrollbar-thumb {\n  background: #4b5563;\n}\n\n.dark ::-webkit-scrollbar-thumb:hover {\n  background: #6b7280;\n}\n</style>"],"mappings":";AAsIA,eAAe;EACbA,IAAI,EAAE,cAAc;EACpBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI;IAC9D;EACF,CAAC;EACDC,OAAO,EAAE;IACPC,QAAQA,CAACC,IAAI,EAAE;MACb,OAAO,IAAI,CAACC,MAAM,CAACD,IAAG,KAAMA,IAAG;IACjC,CAAC;IACDE,YAAYA,CAAA,EAAG;MACbN,YAAY,CAACO,UAAU,CAAC,OAAO;MAC/BP,YAAY,CAACO,UAAU,CAAC,MAAM;MAC9B,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,QAAQ;IAC5B;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}