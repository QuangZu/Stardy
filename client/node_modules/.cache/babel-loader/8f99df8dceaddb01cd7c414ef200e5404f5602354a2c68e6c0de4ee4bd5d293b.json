{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { checkUserRole } from '../api/Account.js';\nexport default {\n  name: 'RoleBasedRouter',\n  data() {\n    return {\n      loading: true,\n      error: null,\n      userRole: null\n    };\n  },\n  async mounted() {\n    await this.checkUserAccess();\n  },\n  methods: {\n    async checkUserAccess() {\n      try {\n        this.loading = true;\n        this.error = null;\n\n        // Check if user is logged in\n        const token = localStorage.getItem('token');\n        if (!token) {\n          this.$router.push('/login');\n          return;\n        }\n\n        // Check user role\n        const roleData = await checkUserRole();\n        this.userRole = roleData.role;\n\n        // Redirect based on role\n        if (roleData.isAdmin) {\n          this.$router.push('/admin');\n        } else {\n          this.$router.push('/client');\n        }\n      } catch (error) {\n        console.error('Role check failed:', error);\n        if (error.response?.status === 401) {\n          // Token is invalid or expired\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        } else {\n          this.error = 'Failed to verify access permissions. Please try again.';\n        }\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};","map":{"version":3,"names":["checkUserRole","name","data","loading","error","userRole","mounted","checkUserAccess","methods","token","localStorage","getItem","$router","push","roleData","role","isAdmin","console","response","status","removeItem"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\components\\RoleBasedRouter.vue"],"sourcesContent":["<template>\n  <div class=\"role-router\">\n    <div v-if=\"loading\" class=\"loading-container\">\n      <div class=\"spinner\"></div>\n      <p>Checking access permissions...</p>\n    </div>\n    \n    <div v-else-if=\"error\" class=\"error-container\">\n      <h2>Access Error</h2>\n      <p>{{ error }}</p>\n      <button @click=\"$router.push('/login')\" class=\"btn btn-primary\">\n        Go to Login\n      </button>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { checkUserRole } from '../api/Account.js';\n\nexport default {\n  name: 'RoleBasedRouter',\n  data() {\n    return {\n      loading: true,\n      error: null,\n      userRole: null\n    };\n  },\n  async mounted() {\n    await this.checkUserAccess();\n  },\n  methods: {\n    async checkUserAccess() {\n      try {\n        this.loading = true;\n        this.error = null;\n        \n        // Check if user is logged in\n        const token = localStorage.getItem('token');\n        if (!token) {\n          this.$router.push('/login');\n          return;\n        }\n        \n        // Check user role\n        const roleData = await checkUserRole();\n        this.userRole = roleData.role;\n        \n        // Redirect based on role\n        if (roleData.isAdmin) {\n          this.$router.push('/admin');\n        } else {\n          this.$router.push('/client');\n        }\n        \n      } catch (error) {\n        console.error('Role check failed:', error);\n        \n        if (error.response?.status === 401) {\n          // Token is invalid or expired\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        } else {\n          this.error = 'Failed to verify access permissions. Please try again.';\n        }\n      } finally {\n        this.loading = false;\n      }\n    }\n  }\n};\n</script>\n\n<style scoped>\n.role-router {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n}\n\n.loading-container, .error-container {\n  text-align: center;\n  background: white;\n  padding: 2rem;\n  border-radius: 10px;\n  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);\n  max-width: 400px;\n  width: 90%;\n}\n\n.spinner {\n  width: 40px;\n  height: 40px;\n  border: 4px solid #f3f3f3;\n  border-top: 4px solid #667eea;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n  margin: 0 auto 1rem;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.error-container h2 {\n  color: #e74c3c;\n  margin-bottom: 1rem;\n}\n\n.error-container p {\n  color: #666;\n  margin-bottom: 1.5rem;\n}\n\n.btn {\n  padding: 0.75rem 1.5rem;\n  border: none;\n  border-radius: 5px;\n  cursor: pointer;\n  font-size: 1rem;\n  transition: background-color 0.3s;\n}\n\n.btn-primary {\n  background-color: #667eea;\n  color: white;\n}\n\n.btn-primary:hover {\n  background-color: #5a6fd8;\n}\n</style>"],"mappings":";AAkBA,SAASA,aAAY,QAAS,mBAAmB;AAEjD,eAAe;EACbC,IAAI,EAAE,iBAAiB;EACvBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAE,IAAI;MACbC,KAAK,EAAE,IAAI;MACXC,QAAQ,EAAE;IACZ,CAAC;EACH,CAAC;EACD,MAAMC,OAAOA,CAAA,EAAG;IACd,MAAM,IAAI,CAACC,eAAe,CAAC,CAAC;EAC9B,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,eAAeA,CAAA,EAAG;MACtB,IAAI;QACF,IAAI,CAACJ,OAAM,GAAI,IAAI;QACnB,IAAI,CAACC,KAAI,GAAI,IAAI;;QAEjB;QACA,MAAMK,KAAI,GAAIC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;QAC3C,IAAI,CAACF,KAAK,EAAE;UACV,IAAI,CAACG,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;UAC3B;QACF;;QAEA;QACA,MAAMC,QAAO,GAAI,MAAMd,aAAa,CAAC,CAAC;QACtC,IAAI,CAACK,QAAO,GAAIS,QAAQ,CAACC,IAAI;;QAE7B;QACA,IAAID,QAAQ,CAACE,OAAO,EAAE;UACpB,IAAI,CAACJ,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;QAC7B,OAAO;UACL,IAAI,CAACD,OAAO,CAACC,IAAI,CAAC,SAAS,CAAC;QAC9B;MAEF,EAAE,OAAOT,KAAK,EAAE;QACda,OAAO,CAACb,KAAK,CAAC,oBAAoB,EAAEA,KAAK,CAAC;QAE1C,IAAIA,KAAK,CAACc,QAAQ,EAAEC,MAAK,KAAM,GAAG,EAAE;UAClC;UACAT,YAAY,CAACU,UAAU,CAAC,OAAO,CAAC;UAChC,IAAI,CAACR,OAAO,CAACC,IAAI,CAAC,QAAQ,CAAC;QAC7B,OAAO;UACL,IAAI,CAACT,KAAI,GAAI,wDAAwD;QACvE;MACF,UAAU;QACR,IAAI,CAACD,OAAM,GAAI,KAAK;MACtB;IACF;EACF;AACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}