{"ast":null,"code":"import AdminSidebar from '@/components/admin/AdminSidebar.vue';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport { getAllSubjects, createSubject, deleteSubject } from '@/api/Subject.js';\nexport default {\n  name: 'SubjectsAdmin',\n  components: {\n    AdminSidebar,\n    AdminHeader\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      subjects: [],\n      searchQuery: '',\n      showCreateSubjectModal: false,\n      newSubject: {\n        name: '',\n        category: '',\n        icon: 'fas fa-book'\n      },\n      isLoading: false,\n      // Categories matching the backend enum\n      categories: [{\n        value: 'primary',\n        label: 'Primary'\n      }, {\n        value: 'secondary',\n        label: 'Secondary'\n      }, {\n        value: 'senior secondary',\n        label: 'Senior Secondary'\n      }, {\n        value: 'university',\n        label: 'University'\n      }, {\n        value: 'special',\n        label: 'Special'\n      }]\n    };\n  },\n  computed: {\n    filteredSubjects() {\n      if (!this.subjects || !Array.isArray(this.subjects)) return [];\n      if (!this.searchQuery) return this.subjects;\n      return this.subjects.filter(subject => subject && subject.name && subject.category && (subject.name.toLowerCase().includes(this.searchQuery.toLowerCase()) || subject.category.toLowerCase().includes(this.searchQuery.toLowerCase())));\n    }\n  },\n  mounted() {\n    this.fetchSubjects();\n  },\n  methods: {\n    async fetchSubjects() {\n      this.isLoading = true;\n      try {\n        this.subjects = await getAllSubjects();\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n      } finally {\n        this.isLoading = false;\n      }\n    },\n    async createSubject() {\n      console.log('Creating subject with data:', this.newSubject); // Add this line\n      try {\n        await createSubject(this.newSubject);\n        await this.fetchSubjects();\n        this.showCreateSubjectModal = false;\n        this.newSubject = {\n          name: '',\n          category: '',\n          icon: 'fas fa-book'\n        };\n      } catch (error) {\n        console.error('Error creating subject:', error);\n        alert('Error creating subject: ' + error.message); // Add this line for user feedback\n      }\n    },\n    editSubject(subject) {\n      // Implementation for edit functionality\n      console.log('Edit subject:', subject);\n    },\n    async deleteSubject(subjectId) {\n      if (confirm('Are you sure you want to delete this subject?')) {\n        try {\n          await deleteSubject(subjectId);\n          await this.fetchSubjects();\n        } catch (error) {\n          console.error('Error deleting subject:', error);\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminSidebar","AdminHeader","getAllSubjects","createSubject","deleteSubject","name","components","data","currentUser","JSON","parse","localStorage","getItem","subjects","searchQuery","showCreateSubjectModal","newSubject","category","icon","isLoading","categories","value","label","computed","filteredSubjects","Array","isArray","filter","subject","toLowerCase","includes","mounted","fetchSubjects","methods","error","console","log","alert","message","editSubject","subjectId","confirm","formatDate","date","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\SubjectsAdmin.vue"],"sourcesContent":["<template>\n  <div class=\"admin-page\">\n    <AdminSidebar />\n\n    <AdminHeader \n      title=\"Subjects\" \n      icon-class=\"fas fa-book\" \n      :current-user=\"currentUser\" \n      @logout=\"logout\" \n    />\n    <main class=\"admin-content\">\n      <!-- Content Area -->\n    <div class=\"space-y-6\">\n      <!-- Header Section -->\n      <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6\">\n        <div class=\"flex flex-col sm:flex-row sm:items-center sm:justify-between space-y-4 sm:space-y-0\">\n          <div>\n            <h2 class=\"text-section-header text-gray-900 dark:text-white\">Subjects Management</h2>\n            <p class=\"text-body text-gray-600 dark:text-gray-400 mt-1\">Manage educational subjects and categories</p>\n          </div>\n          <div class=\"flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-3\">\n            <!-- Search Bar -->\n            <div class=\"relative\">\n              <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\n                <i class=\"fas fa-search text-gray-400 text-sm\"></i>\n              </div>\n              <input \n                v-model=\"searchQuery\" \n                type=\"text\" \n                placeholder=\"Search subjects...\"\n                class=\"w-full sm:w-64 pl-10 pr-4 py-2 text-body border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent\"\n              >\n            </div>\n            <!-- Add Subject Button -->\n            <button \n              @click=\"showCreateSubjectModal = true\" \n              class=\"btn-primary inline-flex items-center\"\n            >\n              <i class=\"fas fa-plus mr-2\"></i>\n              Add Subject\n            </button>\n          </div>\n        </div>\n      </div>\n\n      <!-- Subjects Table -->\n      <div class=\"chart-container overflow-hidden\">\n        <div class=\"overflow-x-auto\">\n          <table class=\"w-full\">\n            <thead class=\"bg-gray-50 dark:bg-gray-700\">\n              <tr>\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">ID</th>\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Name</th>\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Category</th>\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Icon</th>\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Created</th>\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Actions</th>\n              </tr>\n            </thead>\n            <tbody class=\"bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700\">\n              <tr v-if=\"isLoading\">\n                <td colspan=\"7\" class=\"px-6 py-12 text-center text-gray-500 dark:text-gray-400\">\n                  <div class=\"flex justify-center items-center\">\n                    <i class=\"fas fa-spinner fa-spin mr-2\"></i>\n                    <span>Loading subjects...</span>\n                  </div>\n                </td>\n              </tr>\n              <template v-else-if=\"filteredSubjects.length > 0\">\n                <tr v-for=\"subject in filteredSubjects\" :key=\"subject._id\" class=\"hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200\">\n                  <td class=\"px-6 py-4 whitespace-nowrap text-body font-mono text-gray-500 dark:text-gray-400\">\n                    {{ subject._id ? subject._id.slice(-6) : 'N/A' }}\n                  </td>\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\n                    <div class=\"text-body font-medium text-gray-900 dark:text-white\">{{ subject.name || 'N/A' }}</div>\n                  </td>\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\n                    <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200\">\n                      {{ subject.category || 'N/A' }}\n                    </span>\n                  </td>\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\n                    <i :class=\"subject.icon || 'fas fa-book'\" class=\"text-gray-600 dark:text-gray-400\"></i>\n                  </td>\n                  <td class=\"px-6 py-4 whitespace-nowrap text-body text-gray-500 dark:text-gray-400\">\n                    {{ formatDate(subject.createdAt) }}\n                  </td>\n                  <td class=\"px-6 py-4 whitespace-nowrap text-body font-medium\">\n                    <div class=\"flex space-x-2\">\n                      <button \n                        @click=\"editSubject(subject)\" \n                        class=\"inline-flex items-center p-2 text-primary hover:bg-blue-100 dark:hover:bg-blue-900/20 rounded-lg transition-colors duration-200\"\n                        title=\"Edit Subject\"\n                      >\n                        <i class=\"fas fa-edit text-sm\"></i>\n                      </button>\n                      <button \n                        @click=\"deleteSubject(subject._id)\" \n                        class=\"inline-flex items-center p-2 text-error hover:bg-red-100 dark:hover:bg-red-900/20 rounded-lg transition-colors duration-200\"\n                        title=\"Delete Subject\"\n                      >\n                        <i class=\"fas fa-trash text-sm\"></i>\n                      </button>\n                    </div>\n                  </td>\n                </tr>\n              </template>\n              <tr v-else>\n                <td colspan=\"7\" class=\"px-6 py-12 text-center\">\n                  <div class=\"flex flex-col items-center\">\n                    <i class=\"fas fa-book text-4xl text-gray-300 dark:text-gray-600 mb-4\"></i>\n                    <p class=\"text-gray-500 dark:text-gray-400 text-lg font-medium\">No subjects found</p>\n                    <p class=\"text-gray-400 dark:text-gray-500 text-sm mt-1\">Get started by creating your first subject</p>\n                  </div>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n    </div>\n\n    <!-- Create Subject Modal -->\n    <div v-if=\"showCreateSubjectModal\" class=\"modal-overlay\" @click=\"showCreateSubjectModal = false\">\n      <div class=\"modal-content\" @click.stop>\n        <div class=\"modal-header\">\n          <h3>Create New Subject</h3>\n          <button @click=\"showCreateSubjectModal = false\" class=\"modal-close\">\n            <i class=\"fas fa-times\"></i>\n          </button>\n        </div>\n        <div class=\"modal-body\">\n          <form @submit.prevent=\"createSubject\">\n            <div class=\"form-group\">\n              <label for=\"subjectName\">Subject Name</label>\n              <input \n                id=\"subjectName\"\n                v-model=\"newSubject.name\" \n                type=\"text\" \n                required\n                class=\"form-input\"\n                placeholder=\"Enter subject name\"\n              >\n            </div>\n            <div class=\"form-group\">\n              <label for=\"subjectCategory\">Category</label>\n              <select id=\"subjectCategory\" v-model=\"newSubject.category\" class=\"form-input\" required>\n                <option value=\"\">Select a category</option>\n                <option value=\"primary\">Primary</option>\n                <option value=\"secondary\">Secondary</option>\n                <option value=\"senior secondary\">Senior Secondary</option>\n                <option value=\"university\">University</option>\n                <option value=\"special\">Special</option>\n              </select>\n            </div>\n            <div class=\"form-group\">\n              <label for=\"subjectIcon\">Icon (Font Awesome class)</label>\n              <input \n                id=\"subjectIcon\"\n                v-model=\"newSubject.icon\" \n                type=\"text\" \n                class=\"form-input\"\n                placeholder=\"e.g., fas fa-code\"\n              >\n            </div>\n          </form>\n        </div>\n        <div class=\"modal-footer\">\n          <button type=\"button\" @click=\"showCreateSubjectModal = false\" class=\"btn-secondary\">\n            Cancel\n          </button>\n          <button type=\"submit\" @click=\"createSubject\" class=\"btn-primary\">\n            Create Subject\n          </button>\n        </div>\n      </div>\n    </div>\n    </main>\n  </div>\n</template>\n\n<script>\nimport AdminSidebar from '@/components/admin/AdminSidebar.vue'\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\nimport { getAllSubjects, createSubject, deleteSubject } from '@/api/Subject.js'\n\nexport default {\n  name: 'SubjectsAdmin',\n  components: {\n    AdminSidebar,\n    AdminHeader\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      subjects: [],\n      searchQuery: '',\n      showCreateSubjectModal: false,\n      newSubject: {\n        name: '',\n        category: '',\n        icon: 'fas fa-book'\n      },\n      isLoading: false,\n      // Categories matching the backend enum\n      categories: [\n        { value: 'primary', label: 'Primary' },\n        { value: 'secondary', label: 'Secondary' },\n        { value: 'senior secondary', label: 'Senior Secondary' },\n        { value: 'university', label: 'University' },\n        { value: 'special', label: 'Special' }\n      ]\n    }\n  },\n  computed: {\n    filteredSubjects() {\n      if (!this.subjects || !Array.isArray(this.subjects)) return []\n      if (!this.searchQuery) return this.subjects\n      return this.subjects.filter(subject => \n        subject && subject.name && subject.category &&\n        (subject.name.toLowerCase().includes(this.searchQuery.toLowerCase()) ||\n        subject.category.toLowerCase().includes(this.searchQuery.toLowerCase()))\n      )\n    }\n  },\n  mounted() {\n    this.fetchSubjects()\n  },\n  methods: {\n    async fetchSubjects() {\n      this.isLoading = true;\n      try {\n        this.subjects = await getAllSubjects()\n      } catch (error) {\n        console.error('Error fetching subjects:', error)\n      } finally {\n        this.isLoading = false;\n      }\n    },\n    async createSubject() {\n      console.log('Creating subject with data:', this.newSubject); // Add this line\n      try {\n        await createSubject(this.newSubject)\n        await this.fetchSubjects()\n        this.showCreateSubjectModal = false\n        this.newSubject = { \n          name: '', \n          category: '', \n          icon: 'fas fa-book'\n        }\n      } catch (error) {\n        console.error('Error creating subject:', error)\n        alert('Error creating subject: ' + error.message) // Add this line for user feedback\n      }\n    },\n    editSubject(subject) {\n      // Implementation for edit functionality\n      console.log('Edit subject:', subject)\n    },\n    async deleteSubject(subjectId) {\n      if (confirm('Are you sure you want to delete this subject?')) {\n        try {\n          await deleteSubject(subjectId)\n          await this.fetchSubjects()\n        } catch (error) {\n          console.error('Error deleting subject:', error)\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString()\n    },\n    logout() {\n      localStorage.removeItem('token')\n      localStorage.removeItem('user')\n      this.$router.push('/login')\n    }\n  }\n}\n</script>\n\n<style scoped>\n@import '@/styles/admin/design-system.css';\n@import '@/styles/admin/admin-modal.css';\n</style>"],"mappings":"AAsLA,OAAOA,YAAW,MAAO,qCAAoC;AAC7D,OAAOC,WAAU,MAAO,oCAAmC;AAC3D,SAASC,cAAc,EAAEC,aAAa,EAAEC,aAAY,QAAS,kBAAiB;AAE9E,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACVN,YAAY;IACZC;EACF,CAAC;EACDM,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,QAAQ,EAAE,EAAE;MACZC,WAAW,EAAE,EAAE;MACfC,sBAAsB,EAAE,KAAK;MAC7BC,UAAU,EAAE;QACVX,IAAI,EAAE,EAAE;QACRY,QAAQ,EAAE,EAAE;QACZC,IAAI,EAAE;MACR,CAAC;MACDC,SAAS,EAAE,KAAK;MAChB;MACAC,UAAU,EAAE,CACV;QAAEC,KAAK,EAAE,SAAS;QAAEC,KAAK,EAAE;MAAU,CAAC,EACtC;QAAED,KAAK,EAAE,WAAW;QAAEC,KAAK,EAAE;MAAY,CAAC,EAC1C;QAAED,KAAK,EAAE,kBAAkB;QAAEC,KAAK,EAAE;MAAmB,CAAC,EACxD;QAAED,KAAK,EAAE,YAAY;QAAEC,KAAK,EAAE;MAAa,CAAC,EAC5C;QAAED,KAAK,EAAE,SAAS;QAAEC,KAAK,EAAE;MAAU;IAEzC;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,gBAAgBA,CAAA,EAAG;MACjB,IAAI,CAAC,IAAI,CAACX,QAAO,IAAK,CAACY,KAAK,CAACC,OAAO,CAAC,IAAI,CAACb,QAAQ,CAAC,EAAE,OAAO,EAAC;MAC7D,IAAI,CAAC,IAAI,CAACC,WAAW,EAAE,OAAO,IAAI,CAACD,QAAO;MAC1C,OAAO,IAAI,CAACA,QAAQ,CAACc,MAAM,CAACC,OAAM,IAChCA,OAAM,IAAKA,OAAO,CAACvB,IAAG,IAAKuB,OAAO,CAACX,QAAO,KACzCW,OAAO,CAACvB,IAAI,CAACwB,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAAChB,WAAW,CAACe,WAAW,CAAC,CAAC,KACnED,OAAO,CAACX,QAAQ,CAACY,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAAChB,WAAW,CAACe,WAAW,CAAC,CAAC,CAAC,CACzE;IACF;EACF,CAAC;EACDE,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,aAAa,CAAC;EACrB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,aAAaA,CAAA,EAAG;MACpB,IAAI,CAACb,SAAQ,GAAI,IAAI;MACrB,IAAI;QACF,IAAI,CAACN,QAAO,GAAI,MAAMX,cAAc,CAAC;MACvC,EAAE,OAAOgC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,0BAA0B,EAAEA,KAAK;MACjD,UAAU;QACR,IAAI,CAACf,SAAQ,GAAI,KAAK;MACxB;IACF,CAAC;IACD,MAAMhB,aAAaA,CAAA,EAAG;MACpBgC,OAAO,CAACC,GAAG,CAAC,6BAA6B,EAAE,IAAI,CAACpB,UAAU,CAAC,EAAE;MAC7D,IAAI;QACF,MAAMb,aAAa,CAAC,IAAI,CAACa,UAAU;QACnC,MAAM,IAAI,CAACgB,aAAa,CAAC;QACzB,IAAI,CAACjB,sBAAqB,GAAI,KAAI;QAClC,IAAI,CAACC,UAAS,GAAI;UAChBX,IAAI,EAAE,EA