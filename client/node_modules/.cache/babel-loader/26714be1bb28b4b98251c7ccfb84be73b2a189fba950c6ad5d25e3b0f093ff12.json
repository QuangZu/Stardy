{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport '@/styles/admin/admin.css';\nimport '@/styles/admin/admin-modal.css';\nexport default {\n  name: 'UsersAdmin',\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      accounts: [],\n      searchQuery: '',\n      showCreateUserModal: false,\n      showEditModal: false,\n      editingUser: {},\n      newUser: {\n        username: '',\n        email: '',\n        password: '',\n        role: 'user'\n      },\n      loading: false\n    };\n  },\n  computed: {\n    filteredUsers() {\n      if (!this.searchQuery) return this.accounts;\n      return this.accounts.filter(user => user.username.toLowerCase().includes(this.searchQuery.toLowerCase()) || user.email.toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchAccounts();\n  },\n  methods: {\n    async fetchAccounts() {\n      try {\n        this.loading = true;\n        const response = await fetch('/api/admin/accounts', {\n          headers: {\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          }\n        });\n        if (response.ok) {\n          this.accounts = await response.json();\n        }\n      } catch (error) {\n        console.error('Error fetching accounts:', error);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async createUser() {\n      try {\n        const response = await fetch('/api/admin/accounts', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          },\n          body: JSON.stringify(this.newUser)\n        });\n        if (response.ok) {\n          await this.fetchUsers();\n          this.showCreateUserModal = false;\n          this.newUser = {\n            username: '',\n            email: '',\n            password: '',\n            role: 'user'\n          };\n        }\n      } catch (error) {\n        console.error('Error creating user:', error);\n      }\n    },\n    editUser(user) {\n      this.editingUser = {\n        ...user\n      };\n      this.showEditModal = true;\n    },\n    async saveUser() {\n      try {\n        const response = await fetch(`/api/admin/accounts/${this.editingUser._id}`, {\n          method: 'PUT',\n          headers: {\n            'Content-Type': 'application/json',\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          },\n          body: JSON.stringify(this.editingUser)\n        });\n        if (response.ok) {\n          await this.fetchaccounts();\n          this.closeEditModal();\n        }\n      } catch (error) {\n        console.error('Error updating user:', error);\n      }\n    },\n    async deleteUser(userId) {\n      if (confirm('Are you sure you want to delete this user?')) {\n        try {\n          const response = await fetch(`/api/admin/accounts/${userId}`, {\n            method: 'DELETE',\n            headers: {\n              'Authorization': `Bearer ${localStorage.getItem('token')}`\n            }\n          });\n          if (response.ok) {\n            await this.fetchUsers();\n          }\n        } catch (error) {\n          console.error('Error deleting user:', error);\n        }\n      }\n    },\n    closeEditModal() {\n      this.showEditModal = false;\n      this.editingUser = {};\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["name","data","currentUser","JSON","parse","localStorage","getItem","accounts","searchQuery","showCreateUserModal","showEditModal","editingUser","newUser","username","email","password","role","loading","computed","filteredUsers","filter","user","toLowerCase","includes","mounted","fetchAccounts","methods","response","fetch","headers","ok","json","error","console","createUser","method","body","stringify","fetchUsers","editUser","saveUser","_id","fetchaccounts","closeEditModal","deleteUser","userId","confirm","formatDate","date","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\AccountsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-dashboard admin-space-background\">\r\n    <!-- Animated particles -->\r\n    <div class=\"admin-particles\"></div>\r\n    \r\n    <!-- Header -->\r\n    <div class=\"admin-header\">\r\n      <h1 class=\"admin-title\">\r\n        <i class=\"fas fa-users\"></i>\r\n        User Management\r\n      </h1>\r\n      <div class=\"admin-user-info\">\r\n        <span>Welcome, {{ currentUser.username }}</span>\r\n        <button @click=\"logout\" class=\"logout-btn\">\r\n          <i class=\"fas fa-sign-out-alt\"></i>\r\n          Logout\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Navigation Tabs -->\r\n    <div class=\"admin-nav\">\r\n      <router-link to=\"/admin/accounts\" class=\"nav-tab active\">\r\n        <i class=\"fas fa-users\"></i>\r\n        Users\r\n      </router-link>\r\n      <router-link to=\"/admin/subjects\" class=\"nav-tab\">\r\n        <i class=\"fas fa-book\"></i>\r\n        Subjects\r\n      </router-link>\r\n      <router-link to=\"/admin/questions\" class=\"nav-tab\">\r\n        <i class=\"fas fa-question-circle\"></i>\r\n        Questions\r\n      </router-link>\r\n      <router-link to=\"/admin/exams\" class=\"nav-tab\">\r\n        <i class=\"fas fa-clipboard-list\"></i>\r\n        Exams\r\n      </router-link>\r\n      <router-link to=\"/admin/ai-health\" class=\"nav-tab\">\r\n        <i class=\"fas fa-robot\"></i>\r\n        AI Health\r\n      </router-link>\r\n      <router-link to=\"/admin/stats\" class=\"nav-tab\">\r\n        <i class=\"fas fa-chart-bar\"></i>\r\n        Statistics\r\n      </router-link>\r\n      <router-link to=\"/admin/system\" class=\"nav-tab\">\r\n        <i class=\"fas fa-cog\"></i>\r\n        System\r\n      </router-link>\r\n    </div>\r\n\r\n    <!-- Content Area -->\r\n    <div class=\"admin-content\">\r\n      <div class=\"tab-content\">\r\n        <div class=\"content-header\">\r\n          <h2>User Management</h2>\r\n          <div class=\"header-actions\">\r\n            <div class=\"search-bar\">\r\n              <input \r\n                v-model=\"searchQuery\" \r\n                type=\"text\" \r\n                placeholder=\"Search accounts...\"\r\n                class=\"search-input\"\r\n              >\r\n              <i class=\"fas fa-search search-icon\"></i>\r\n            </div>\r\n            <button @click=\"showCreateUserModal = true\" class=\"btn-create\">\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add User\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Users Table -->\r\n        <div class=\"table-container\">\r\n          <table class=\"admin-table\">\r\n            <thead>\r\n              <tr>\r\n                <th>ID</th>\r\n                <th>Username</th>\r\n                <th>Email</th>\r\n                <th>Role</th>\r\n                <th>Level</th>\r\n                <th>Experience</th>\r\n                <th>Streak</th>\r\n                <th>Created</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"user in filteredUsers\" :key=\"user._id\">\r\n                <td>{{ user._id.slice(-6) }}</td>\r\n                <td>{{ user.username }}</td>\r\n                <td>{{ user.email }}</td>\r\n                <td>\r\n                  <span :class=\"['role-badge', user.role]\">\r\n                    {{ user.role.toUpperCase() }}\r\n                  </span>\r\n                </td>\r\n                <td>{{ user.currentLevel }}</td>\r\n                <td>{{ user.experience }}</td>\r\n                <td>{{ user.streak }}</td>\r\n                <td>{{ formatDate(user.createdAt) }}</td>\r\n                <td>\r\n                  <div class=\"action-buttons\">\r\n                    <button @click=\"editUser(user)\" class=\"btn-edit\">\r\n                      <i class=\"fas fa-edit\"></i>\r\n                    </button>\r\n                    <button @click=\"deleteUser(user._id)\" class=\"btn-delete\">\r\n                      <i class=\"fas fa-trash\"></i>\r\n                    </button>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Create User Modal -->\r\n    <div v-if=\"showCreateUserModal\" class=\"modal-overlay\" @click=\"showCreateUserModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Create New User</h3>\r\n          <button @click=\"showCreateUserModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Username</label>\r\n            <input v-model=\"newUser.username\" type=\"text\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Email</label>\r\n            <input v-model=\"newUser.email\" type=\"email\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Password</label>\r\n            <input v-model=\"newUser.password\" type=\"password\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Role</label>\r\n            <select v-model=\"newUser.role\" class=\"form-select\">\r\n              <option value=\"user\">User</option>\r\n              <option value=\"admin\">Admin</option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showCreateUserModal = false\" class=\"btn-cancel\">Cancel</button>\r\n          <button @click=\"createUser\" class=\"btn-save\">Create User</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Edit User Modal -->\r\n    <div v-if=\"showEditModal\" class=\"modal-overlay\" @click=\"closeEditModal\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Edit User</h3>\r\n          <button @click=\"closeEditModal\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Username</label>\r\n            <input v-model=\"editingUser.username\" type=\"text\" class=\"form-input\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Email</label>\r\n            <input v-model=\"editingUser.email\" type=\"email\" class=\"form-input\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Role</label>\r\n            <select v-model=\"editingUser.role\" class=\"form-select\">\r\n              <option value=\"user\">User</option>\r\n              <option value=\"admin\">Admin</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Level</label>\r\n            <input v-model=\"editingUser.currentLevel\" type=\"number\" min=\"1\" class=\"form-input\">\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"closeEditModal\" class=\"btn-cancel\">Cancel</button>\r\n          <button @click=\"saveUser\" class=\"btn-save\">Save Changes</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport '@/styles/admin/admin.css'\r\nimport '@/styles/admin/admin-modal.css'\r\n\r\nexport default {\r\n  name: 'UsersAdmin',\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      accounts: [],\r\n      searchQuery: '',\r\n      showCreateUserModal: false,\r\n      showEditModal: false,\r\n      editingUser: {},\r\n      newUser: {\r\n        username: '',\r\n        email: '',\r\n        password: '',\r\n        role: 'user'\r\n      },\r\n      loading: false\r\n    }\r\n  },\r\n  computed: {\r\n    filteredUsers() {\r\n      if (!this.searchQuery) return this.accounts\r\n      return this.accounts.filter(user => \r\n        user.username.toLowerCase().includes(this.searchQuery.toLowerCase()) ||\r\n        user.email.toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchAccounts()\r\n  },\r\n  methods: {\r\n    async fetchAccounts() {\r\n      try {\r\n        this.loading = true\r\n        const response = await fetch('/api/admin/accounts', {\r\n          headers: {\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          }\r\n        })\r\n        if (response.ok) {\r\n          this.accounts = await response.json()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error fetching accounts:', error)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    async createUser() {\r\n      try {\r\n        const response = await fetch('/api/admin/accounts', {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          },\r\n          body: JSON.stringify(this.newUser)\r\n        })\r\n        if (response.ok) {\r\n          await this.fetchUsers()\r\n          this.showCreateUserModal = false\r\n          this.newUser = { username: '', email: '', password: '', role: 'user' }\r\n        }\r\n      } catch (error) {\r\n        console.error('Error creating user:', error)\r\n      }\r\n    },\r\n    editUser(user) {\r\n      this.editingUser = { ...user }\r\n      this.showEditModal = true\r\n    },\r\n    async saveUser() {\r\n      try {\r\n        const response = await fetch(`/api/admin/accounts/${this.editingUser._id}`, {\r\n          method: 'PUT',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          },\r\n          body: JSON.stringify(this.editingUser)\r\n        })\r\n        if (response.ok) {\r\n          await this.fetchaccounts()\r\n          this.closeEditModal()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error updating user:', error)\r\n      }\r\n    },\r\n    async deleteUser(userId) {\r\n      if (confirm('Are you sure you want to delete this user?')) {\r\n        try {\r\n          const response = await fetch(`/api/admin/accounts/${userId}`, {\r\n            method: 'DELETE',\r\n            headers: {\r\n              'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n            }\r\n          })\r\n          if (response.ok) {\r\n            await this.fetchUsers()\r\n          }\r\n        } catch (error) {\r\n          console.error('Error deleting user:', error)\r\n        }\r\n      }\r\n    },\r\n    closeEditModal() {\r\n      this.showEditModal = false\r\n      this.editingUser = {}\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;AAsMA,OAAO,0BAAyB;AA