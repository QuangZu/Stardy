{"ast":null,"code":"export default {\n  name: 'App',\n  data() {\n    return {\n      isLoading: false,\n      isTransitioning: false\n    };\n  },\n  watch: {\n    '$route'() {\n      this.handleRouteChange();\n    }\n  },\n  methods: {\n    handleRouteChange() {\n      this.isTransitioning = true;\n\n      // Reset panels after animation\n      setTimeout(() => {\n        this.isTransitioning = false;\n      }, 1200);\n    },\n    beforeEnter(el) {\n      el.style.opacity = '0';\n      el.style.transform = 'translateY(30px) scale(0.95)';\n    },\n    enter(el, done) {\n      // Delay entrance for smoother transition\n      setTimeout(() => {\n        el.style.transition = 'all 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n        el.style.opacity = '1';\n        el.style.transform = 'translateY(0) scale(1)';\n        setTimeout(done, 800);\n      }, 400);\n    },\n    leave(el, done) {\n      el.style.transition = 'all 400ms cubic-bezier(0.55, 0.055, 0.675, 0.19)';\n      el.style.opacity = '0';\n      el.style.transform = 'translateY(-30px) scale(0.95)';\n      setTimeout(done, 400);\n    },\n    showLoader() {\n      this.isLoading = true;\n\n      // Hide loader after 2 seconds\n      setTimeout(() => {\n        this.isLoading = false;\n      }, 2000);\n    }\n  },\n  mounted() {\n    // Show loader on initial load\n    this.showLoader();\n  }\n};","map":{"version":3,"names":["name","data","isLoading","isTransitioning","watch","$route","handleRouteChange","methods","setTimeout","beforeEnter","el","style","opacity","transform","enter","done","transition","leave","showLoader","mounted"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <!-- Page Loader -->\n    <div v-if=\"isLoading\" class=\"page-loader\">\n      <div class=\"loader-content\">\n        <div class=\"loader-logo\">\n          <span class=\"logo-icon\">📚</span>\n          <span class=\"brand-name\">Stardy</span>\n        </div>\n        <div class=\"loader-bar\">\n          <div class=\"loader-progress\"></div>\n        </div>\n        <div class=\"loader-text\">Loading...</div>\n      </div>\n    </div>\n\n    <!-- Page Transition Panels -->\n    <div class=\"transition-panels\">\n      <div class=\"panel panel-1\" :class=\"{ active: isTransitioning }\"></div>\n      <div class=\"panel panel-2\" :class=\"{ active: isTransitioning }\"></div>\n      <div class=\"panel panel-3\" :class=\"{ active: isTransitioning }\"></div>\n      <div class=\"panel panel-4\" :class=\"{ active: isTransitioning }\"></div>\n    </div>\n\n    <!-- Main Content -->\n    <transition \n      name=\"page\" \n      mode=\"out-in\"\n      @before-enter=\"beforeEnter\"\n      @enter=\"enter\"\n      @leave=\"leave\"\n    >\n      <router-view :key=\"$route.fullPath\" />\n    </transition>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'App',\n  data() {\n    return {\n      isLoading: false,\n      isTransitioning: false\n    }\n  },\n  watch: {\n    '$route'() {\n      this.handleRouteChange();\n    }\n  },\n  methods: {\n    handleRouteChange() {\n      this.isTransitioning = true;\n      \n      // Reset panels after animation\n      setTimeout(() => {\n        this.isTransitioning = false;\n      }, 1200);\n    },\n    \n    beforeEnter(el) {\n      el.style.opacity = '0';\n      el.style.transform = 'translateY(30px) scale(0.95)';\n    },\n    \n    enter(el, done) {\n      // Delay entrance for smoother transition\n      setTimeout(() => {\n        el.style.transition = 'all 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94)';\n        el.style.opacity = '1';\n        el.style.transform = 'translateY(0) scale(1)';\n        \n        setTimeout(done, 800);\n      }, 400);\n    },\n    \n    leave(el, done) {\n      el.style.transition = 'all 400ms cubic-bezier(0.55, 0.055, 0.675, 0.19)';\n      el.style.opacity = '0';\n      el.style.transform = 'translateY(-30px) scale(0.95)';\n      \n      setTimeout(done, 400);\n    },\n    \n    showLoader() {\n      this.isLoading = true;\n      \n      // Hide loader after 2 seconds\n      setTimeout(() => {\n        this.isLoading = false;\n      }, 2000);\n    }\n  },\n  \n  mounted() {\n    // Show loader on initial load\n    this.showLoader();\n  }\n}\n</script>\n\n<style>\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  line-height: 1.6;\n  color: #333;\n  overflow-x: hidden;\n}\n\n#app {\n  min-height: 100vh;\n  position: relative;\n}\n\n/* Page Loader */\n.page-loader {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 9999;\n  animation: loaderFadeOut 0.5s ease-out 1.5s forwards;\n}\n\n.loader-content {\n  text-align: center;\n  color: white;\n}\n\n.loader-logo {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: 0.5rem;\n  font-size: 2rem;\n  font-weight: bold;\n  margin-bottom: 2rem;\n  animation: logoFloat 2s ease-in-out infinite;\n}\n\n.logo-icon {\n  font-size: 2.5rem;\n  animation: iconSpin 2s linear infinite;\n}\n\n.loader-bar {\n  width: 200px;\n  height: 4px;\n  background: rgba(255, 255, 255, 0.3);\n  border-radius: 2px;\n  margin: 0 auto 1rem;\n  overflow: hidden;\n}\n\n.loader-progress {\n  width: 0;\n  height: 100%;\n  background: linear-gradient(90deg, #a8b5ff, #ffffff);\n  border-radius: 2px;\n  animation: progressBar 2s ease-out forwards;\n}\n\n.loader-text {\n  font-size: 1.1rem;\n  opacity: 0.9;\n  animation: textPulse 1.5s ease-in-out infinite;\n}\n\n@keyframes loaderFadeOut {\n  to {\n    opacity: 0;\n    visibility: hidden;\n  }\n}\n\n@keyframes logoFloat {\n  0%, 100% { transform: translateY(0); }\n  50% { transform: translateY(-10px); }\n}\n\n@keyframes iconSpin {\n  from { transform: rotate(0deg); }\n  to { transform: rotate(360deg); }\n}\n\n@keyframes progressBar {\n  to { width: 100%; }\n}\n\n@keyframes textPulse {\n  0%, 100% { opacity: 0.9; }\n  50% { opacity: 0.6; }\n}\n\n/* Pure CSS Panels Transition */\n.transition-panels {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  pointer-events: none;\n  z-index: 1000;\n}\n\n.panel {\n  position: absolute;\n  width: 25%;\n  height: 100%;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  transform: translateY(-100%);\n  transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n}\n\n.panel-1 {\n  left: 0;\n  transition-delay: 0ms;\n}\n\n.panel-2 {\n  left: 25%;\n  transition-delay: 100ms;\n}\n\n.panel-3 {\n  left: 50%;\n  transition-delay: 200ms;\n}\n\n.panel-4 {\n  left: 75%;\n  transition-delay: 300ms;\n}\n\n.panel.active {\n  transform: translateY(0);\n  animation: panelSlide 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;\n}\n\n@keyframes panelSlide {\n  0% {\n    transform: translateY(-100%);\n  }\n  50% {\n    transform: translateY(0);\n  }\n  100% {\n    transform: translateY(100%);\n  }\n}\n\n/* Enhanced Page Transitions */\n.page-enter-active {\n  transition: all 800ms cubic-bezier(0.25, 0.46, 0.45, 0.94);\n  transition-delay: 400ms;\n}\n\n.page-leave-active {\n  transition: all 400ms cubic-bezier(0.55, 0.055, 0.675, 0.19);\n}\n\n.page-enter-from {\n  opacity: 0;\n  transform: translateY(30px) scale(0.95);\n  filter: blur(5px);\n}\n\n.page-leave-to {\n  opacity: 0;\n  transform: translateY(-30px) scale(0.95);\n  filter: blur(5px);\n}\n\n.page-enter-to, .page-leave-from {\n  opacity: 1;\n  transform: translateY(0) scale(1);\n  filter: blur(0);\n}\n\n/* GSAP-style cubic bezier for special pages */\n.login-transition-enter-active,\n.register-transition-enter-active {\n  transition: all 1000ms cubic-bezier(0.77, 0, 0.175, 1);\n}\n\n.login-transition-leave-active,\n.register-transition-leave-active {\n  transition: all 600ms cubic-bezier(0.77, 0, 0.175, 1);\n}\n\n.login-transition-enter-from,\n.register-transition-enter-from {\n  opacity: 0;\n  transform: translateX(100px) rotateY(15deg);\n  filter: blur(10px);\n}\n\n.login-transition-leave-to,\n.register-transition-leave-to {\n  opacity: 0;\n  transform: translateX(-100px) rotateY(-15deg);\n  filter: blur(10px);\n}\n</style>"],"mappings":"AAsCA,eAAe;EACbA,IAAI,EAAE,KAAK;EACXC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,SAAS,EAAE,KAAK;MAChBC,eAAe,EAAE;IACnB;EACF,CAAC;EACDC,KAAK,EAAE;IACL,QAAQC,CAAA,EAAG;MACT,IAAI,CAACC,iBAAiB,CAAC,CAAC;IAC1B;EACF,CAAC;EACDC,OAAO,EAAE;IACPD,iBAAiBA,CAAA,EAAG;MAClB,IAAI,CAACH,eAAc,GAAI,IAAI;;MAE3B;MACAK,UAAU,CAAC,MAAM;QACf,IAAI,CAACL,eAAc,GAAI,KAAK;MAC9B,CAAC,EAAE,IAAI,CAAC;IACV,CAAC;IAEDM,WAAWA,CAACC,EAAE,EAAE;MACdA,EAAE,CAACC,KAAK,CAACC,OAAM,GAAI,GAAG;MACtBF,EAAE,CAACC,KAAK,CAACE,SAAQ,GAAI,8BAA8B;IACrD,CAAC;IAEDC,KAAKA,CAACJ,EAAE,EAAEK,IAAI,EAAE;MACd;MACAP,UAAU,CAAC,MAAM;QACfE,EAAE,CAACC,KAAK,CAACK,UAAS,GAAI,gDAAgD;QACtEN,EAAE,CAACC,KAAK,CAACC,OAAM,GAAI,GAAG;QACtBF,EAAE,CAACC,KAAK,CAACE,SAAQ,GAAI,wBAAwB;QAE7CL,UAAU,CAACO,IAAI,EAAE,GAAG,CAAC;MACvB,CAAC,EAAE,GAAG,CAAC;IACT,CAAC;IAEDE,KAAKA,CAACP,EAAE,EAAEK,IAAI,EAAE;MACdL,EAAE,CAACC,KAAK,CAACK,UAAS,GAAI,kDAAkD;MACxEN,EAAE,CAACC,KAAK,CAACC,OAAM,GAAI,GAAG;MACtBF,EAAE,CAACC,KAAK,CAACE,SAAQ,GAAI,+BAA+B;MAEpDL,UAAU,CAACO,IAAI,EAAE,GAAG,CAAC;IACvB,CAAC;IAEDG,UAAUA,CAAA,EAAG;MACX,IAAI,CAAChB,SAAQ,GAAI,IAAI;;MAErB;MACAM,UAAU,CAAC,MAAM;QACf,IAAI,CAACN,SAAQ,GAAI,KAAK;MACxB,CAAC,EAAE,IAAI,CAAC;IACV;EACF,CAAC;EAEDiB,OAAOA,CAAA,EAAG;IACR;IACA,IAAI,CAACD,UAAU,CAAC,CAAC;EACnB;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}