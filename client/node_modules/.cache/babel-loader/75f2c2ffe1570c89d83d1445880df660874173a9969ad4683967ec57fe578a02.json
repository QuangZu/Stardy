{"ast":null,"code":"import AdminSidebar from '@/components/admin/AdminSidebar.vue';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport { useNotification } from '@/composables/useNotification';\nimport { getAllAccounts, createAccount, updateAccount, deleteAccount } from '@/api/Account.js';\nexport default {\n  name: 'AccountsAdmin',\n  components: {\n    AdminSidebar,\n    AdminHeader\n  },\n  setup() {\n    const {\n      showSuccess,\n      showError,\n      showInfo,\n      showWarning\n    } = useNotification();\n    return {\n      showSuccess,\n      showError,\n      showInfo,\n      showWarning\n    };\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      accounts: [],\n      searchQuery: '',\n      showCreateAccountModal: false,\n      showEditAccountModal: false,\n      showDeleteModal: false,\n      accountToDeleteId: null,\n      newAccount: {\n        username: '',\n        email: '',\n        password: '',\n        role: 'user',\n        currentLevel: 1,\n        experience: 0,\n        streak: 0\n      },\n      editingAccount: {\n        _id: '',\n        username: '',\n        email: '',\n        role: 'user',\n        currentLevel: 1,\n        experience: 0,\n        streak: 0\n      }\n    };\n  },\n  computed: {\n    filteredAccounts() {\n      if (!this.searchQuery) return this.accounts || [];\n      return (this.accounts || []).filter(account => (account.username || '').toLowerCase().includes(this.searchQuery.toLowerCase()) || (account.email || '').toLowerCase().includes(this.searchQuery.toLowerCase()) || (account.role || '').toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchAccounts();\n  },\n  methods: {\n    async fetchAccounts() {\n      try {\n        const response = await getAllAccounts();\n        this.accounts = response.data || response || [];\n      } catch (error) {\n        console.error('Error fetching accounts:', error);\n        this.showError('Error', 'Failed to fetch accounts. Please try again.');\n        this.accounts = [];\n      }\n    },\n    getRoleBadgeClass(role) {\n      return role === 'admin' ? 'role-badge admin' : 'role-badge user';\n    },\n    async createAccount() {\n      try {\n        const {\n          username,\n          password,\n          email,\n          role,\n          currentLevel,\n          experience,\n          streak\n        } = this.newAccount;\n        await createAccount(username, password, email, {\n          role,\n          currentLevel,\n          experience,\n          streak\n        });\n        await this.fetchAccounts();\n        this.showCreateAccountModal = false;\n        this.newAccount = {\n          username: '',\n          email: '',\n          password: '',\n          role: 'user',\n          currentLevel: 1,\n          experience: 0,\n          streak: 0\n        };\n        this.showSuccess('Success', 'Account created successfully!');\n      } catch (error) {\n        console.error('Error creating account:', error);\n        this.showError('Error', 'Failed to create account. Please try again.');\n      }\n    },\n    editAccount(account) {\n      this.editingAccount = {\n        ...account\n      };\n      this.showEditAccountModal = true;\n    },\n    async updateAccount() {\n      try {\n        const updateData = {\n          username: this.editingAccount.username,\n          email: this.editingAccount.email,\n          role: this.editingAccount.role,\n          currentLevel: this.editingAccount.currentLevel,\n          experience: this.editingAccount.experience,\n          streak: this.editingAccount.streak\n        };\n        await updateAccount(this.editingAccount._id, updateData);\n        await this.fetchAccounts();\n        this.showEditAccountModal = false;\n        this.showSuccess('Success', 'Account updated successfully!');\n      } catch (error) {\n        console.error('Error updating account:', error);\n        this.showError('Error', 'Failed to update account. Please try again.');\n      }\n    },\n    confirmDeleteAccount(accountId) {\n      this.accountToDeleteId = accountId;\n      this.showDeleteModal = true;\n    },\n    async deleteAccount() {\n      try {\n        await deleteAccount(this.accountToDeleteId);\n        await this.fetchAccounts();\n        this.showDeleteModal = false;\n        this.accountToDeleteId = null;\n        this.showSuccess('Success', 'Account deleted successfully!');\n      } catch (error) {\n        console.error('Error deleting account:', error);\n        this.showError('Error', 'Failed to delete account. Please try again.');\n      }\n    },\n    formatDate(timestamp) {\n      if (!timestamp) return 'N/A';\n      return new Date(timestamp).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminSidebar","AdminHeader","useNotification","getAllAccounts","createAccount","updateAccount","deleteAccount","name","components","setup","showSuccess","showError","showInfo","showWarning","data","currentUser","JSON","parse","localStorage","getItem","accounts","searchQuery","showCreateAccountModal","showEditAccountModal","showDeleteModal","accountToDeleteId","newAccount","username","email","password","role","currentLevel","experience","streak","editingAccount","_id","computed","filteredAccounts","filter","account","toLowerCase","includes","mounted","fetchAccounts","methods","response","error","console","getRoleBadgeClass","editAccount","updateData","confirmDeleteAccount","accountId","formatDate","timestamp","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\AccountsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-page\">\r\n    <!-- Sidebar -->\r\n    <AdminSidebar />\r\n    \r\n    <!-- Header -->\r\n    <AdminHeader \r\n      title=\"Accounts\" \r\n      icon-class=\"fas fa-users\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n\r\n    <!-- Main Content -->\r\n    <main class=\"admin-content\">\r\n      <div class=\"p-6\">\r\n        <!-- Header Section -->\r\n        <div class=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6\">\r\n          <div>\r\n            <h1 class=\"text-section-header text-gray-900\">Account Management</h1>\r\n            <p class=\"text-body text-gray-600 mt-1\">Create and manage user accounts</p>\r\n          </div>\r\n          <div class=\"flex flex-col sm:flex-row gap-3\">\r\n            <div class=\"relative\">\r\n              <input\r\n                v-model=\"searchQuery\"\r\n                type=\"text\"\r\n                placeholder=\"Search accounts...\"\r\n                class=\"w-full sm:w-64 pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-body\"\r\n              >\r\n              <i class=\"fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400\"></i>\r\n            </div>\r\n            <button\r\n              @click=\"showCreateAccountModal = true\"\r\n              class=\"btn-primary flex items-center gap-2\"\r\n            >\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add Account\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Accounts Table -->\r\n        <div class=\"chart-container overflow-hidden\">\r\n          <div class=\"overflow-x-auto\">\r\n            <table class=\"w-full\">\r\n              <thead class=\"bg-gray-50\">\r\n                <tr>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">User</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Email</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Role</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Level</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Created</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Actions</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody class=\"bg-white divide-y divide-gray-200\">\r\n                <tr v-for=\"account in filteredAccounts\" :key=\"account._id\" class=\"hover:bg-gray-50 transition-colors duration-150\">\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"flex items-center\">\r\n                      <div class=\"w-10 h-10 bg-gradient-to-br from-purple-400 to-pink-500 rounded-lg flex items-center justify-center mr-3\">\r\n                        <i class=\"fas fa-user text-white\"></i>\r\n                      </div>\r\n                      <div>\r\n                        <div class=\"text-body font-medium text-gray-900\">{{ account.username || 'N/A' }}</div>\r\n                        <div class=\"text-small text-gray-500\">ID: {{ account._id ? account._id.slice(-6) : 'N/A' }}</div>\r\n                      </div>\r\n                    </div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"text-body text-gray-900\">{{ account.email || 'N/A' }}</div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <span :class=\"getRoleBadgeClass(account.role)\" class=\"inline-flex px-2 py-1 text-small font-semibold rounded-full\">\r\n                      {{ account.role || 'user' }}\r\n                    </span>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"text-body text-gray-900\">Level {{ account.currentLevel || 1 }}</div>\r\n                    <div class=\"text-small text-gray-500\">XP: {{ account.experience || 0 }}</div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"text-body text-gray-900\">{{ formatDate(account.createdAt) }}</div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap text-body font-medium\">\r\n                    <div class=\"flex space-x-2\">\r\n                      <button\r\n                        @click=\"editAccount(account)\"\r\n                        class=\"text-primary hover:text-blue-900 transition-colors duration-150\"\r\n                        title=\"Edit Account\"\r\n                      >\r\n                        <i class=\"fas fa-edit\"></i>\r\n                      </button>\r\n                      <button\r\n                        @click=\"confirmDeleteAccount(account._id)\"\r\n                        class=\"text-error hover:text-red-900 transition-colors duration-150\"\r\n                        title=\"Delete Account\"\r\n                      >\r\n                        <i class=\"fas fa-trash\"></i>\r\n                      </button>\r\n                    </div>\r\n                  </td>\r\n                </tr>\r\n                <tr v-if=\"filteredAccounts.length === 0\">\r\n                  <td colspan=\"6\" class=\"px-6 py-4 text-center text-gray-500\">\r\n                    No accounts found. Create a new account to get started.\r\n                  </td>\r\n                </tr>\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </main>\r\n\r\n    <!-- Create Account Modal -->\r\n    <div v-if=\"showCreateAccountModal\" class=\"modal-overlay\" @click=\"showCreateAccountModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Create New Account</h3>\r\n          <button @click=\"showCreateAccountModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <form @submit.prevent=\"createAccount\">\r\n            <div class=\"form-group\">\r\n              <label for=\"username\">Username</label>\r\n              <input id=\"username\" v-model=\"newAccount.username\" type=\"text\" class=\"form-input\" required>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"email\">Email</label>\r\n              <input id=\"email\" v-model=\"newAccount.email\" type=\"email\" class=\"form-input\" required>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"password\">Password</label>\r\n              <input id=\"password\" v-model=\"newAccount.password\" type=\"password\" class=\"form-input\" required>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"role\">Role</label>\r\n              <select id=\"role\" v-model=\"newAccount.role\" class=\"form-select\">\r\n                <option value=\"user\">User</option>\r\n                <option value=\"admin\">Admin</option>\r\n              </select>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"level\">Starting Level</label>\r\n              <input id=\"level\" v-model.number=\"newAccount.currentLevel\" type=\"number\" min=\"1\" class=\"form-input\">\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"experience\">Starting Experience</label>\r\n              <input id=\"experience\" v-model.number=\"newAccount.experience\" type=\"number\" min=\"0\" class=\"form-input\">\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"streak\">Starting Streak</label>\r\n              <input id=\"streak\" v-model.number=\"newAccount.streak\" type=\"number\" min=\"0\" class=\"form-input\">\r\n            </div>\r\n          </form>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showCreateAccountModal = false\" class=\"btn-cancel\">\r\n            Cancel\r\n          </button>\r\n          <button type=\"submit\" @click=\"createAccount\" class=\"btn-save\">\r\n            Create Account\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Edit Account Modal -->\r\n    <div v-if=\"showEditAccountModal\" class=\"modal-overlay\" @click=\"showEditAccountModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Edit Account</h3>\r\n          <button @click=\"showEditAccountModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <form @submit.prevent=\"updateAccount\">\r\n            <div class=\"form-group\">\r\n              <label for=\"editUsername\">Username</label>\r\n              <input id=\"editUsername\" v-model=\"editingAccount.username\" type=\"text\" class=\"form-input\" required>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"editEmail\">Email</label>\r\n              <input id=\"editEmail\" v-model=\"editingAccount.email\" type=\"email\" class=\"form-input\" required>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"editRole\">Role</label>\r\n              <select id=\"editRole\" v-model=\"editingAccount.role\" class=\"form-select\">\r\n                <option value=\"user\">User</option>\r\n                <option value=\"admin\">Admin</option>\r\n              </select>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"editLevel\">Level</label>\r\n              <input id=\"editLevel\" v-model.number=\"editingAccount.currentLevel\" type=\"number\" min=\"1\" class=\"form-input\">\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"editExperience\">Experience</label>\r\n              <input id=\"editExperience\" v-model.number=\"editingAccount.experience\" type=\"number\" min=\"0\" class=\"form-input\">\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"editStreak\">Streak</label>\r\n              <input id=\"editStreak\" v-model.number=\"editingAccount.streak\" type=\"number\" min=\"0\" class=\"form-input\">\r\n            </div>\r\n          </form>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showEditAccountModal = false\" class=\"btn-cancel\">\r\n            Cancel\r\n          </button>\r\n          <button type=\"submit\" @click=\"updateAccount\" class=\"btn-save\">\r\n            Update Account\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Delete Confirmation Modal -->\r\n    <div v-if=\"showDeleteModal\" class=\"modal-overlay\" @click=\"showDeleteModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Confirm Delete</h3>\r\n          <button @click=\"showDeleteModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <p class=\"text-body text-gray-700 mb-4\">Are you sure you want to delete this account? This action cannot be undone.</p>\r\n          <p class=\"text-small text-error\">Warning: Deleting an account will remove all associated data including progress, exams, and schedules.</p>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showDeleteModal = false\" class=\"btn-cancel\">\r\n            Cancel\r\n          </button>\r\n          <button @click=\"deleteAccount\" class=\"btn-save bg-error hover:bg-red-700\">\r\n            Delete Account\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AdminSidebar from '@/components/admin/AdminSidebar.vue'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\nimport { useNotification } from '@/composables/useNotification'\r\nimport { getAllAccounts, createAccount, updateAccount, deleteAccount } from '@/api/Account.js'\r\n\r\nexport default {\r\n  name: 'AccountsAdmin',\r\n  components: {\r\n    AdminSidebar,\r\n    AdminHeader\r\n  },\r\n  setup() {\r\n    const { showSuccess, showError, showInfo, showWarning } = useNotification()\r\n    return {\r\n      showSuccess,\r\n      showError,\r\n      showInfo,\r\n      showWarning\r\n    }\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      accounts: [],\r\n      searchQuery: '',\r\n      showCreateAccountModal: false,\r\n      showEditAccountModal: false,\r\n      showDeleteModal: false,\r\n      accountToDeleteId: null,\r\n      newAccount: {\r\n        username: '',\r\n        email: '',\r\n        password: '',\r\n        role: 'user',\r\n        currentLevel: 1,\r\n        experience: 0,\r\n        streak: 0\r\n      },\r\n      editingAccount: {\r\n        _id: '',\r\n        username: '',\r\n        email: '',\r\n        role: 'user',\r\n        currentLevel: 1,\r\n        experience: 0,\r\n        streak: 0\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredAccounts() {\r\n      if (!this.searchQuery) return this.accounts || []\r\n      return (this.accounts || []).filter(account => \r\n        (account.username || '').toLowerCase().includes(this.searchQuery.toLowerCase()) ||\r\n        (account.email || '').toLowerCase().includes(this.searchQuery.toLowerCase()) ||\r\n        (account.role || '').toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchAccounts()\r\n  },\r\n  methods: {\r\n    async fetchAccounts() {\r\n      try {\r\n        const response = await getAllAccounts()\r\n        this.accounts = response.data || response || []\r\n      } catch (error) {\r\n        console.error('Error fetching accounts:', error)\r\n        this.showError('Error', 'Failed to fetch accounts. Please try again.')\r\n        this.accounts = []\r\n      }\r\n    },\r\n    getRoleBadgeClass(role) {\r\n      return role === 'admin' ? 'role-badge admin' : 'role-badge user'\r\n    },\r\n    async createAccount() {\r\n      try {\r\n        const { username, password, email, role, currentLevel, experience, streak } = this.newAccount\r\n        await createAccount(username, password, email, { role, currentLevel, experience, streak })\r\n        await this.fetchAccounts()\r\n        this.showCreateAccountModal = false\r\n        this.newAccount = {\r\n          username: '',\r\n          email: '',\r\n          password: '',\r\n          role: 'user',\r\n          currentLevel: 1,\r\n          experience: 0,\r\n          streak: 0\r\n        }\r\n        this.showSuccess('Success', 'Account created successfully!')\r\n      } catch (error) {\r\n        console.error('Error creating account:', error)\r\n        this.showError('Error', 'Failed to create account. Please try again.')\r\n      }\r\n    },\r\n    editAccount(account) {\r\n      this.editingAccount = { ...account }\r\n      this.showEditAccountModal = true\r\n    },\r\n    async updateAccount() {\r\n      try {\r\n        const updateData = {\r\n          username: this.editingAccount.username,\r\n          email: this.editingAccount.email,\r\n          role: this.editingAccount.role,\r\n          currentLevel: this.editingAccount.currentLevel,\r\n          experience: this.editingAccount.experience,\r\n          streak: this.editingAccount.streak\r\n        }\r\n        await updateAccount(this.editingAccount._id, updateData)\r\n        await this.fetchAccounts()\r\n        this.showEditAccountModal = false\r\n        this.showSuccess('Success', 'Account updated successfully!')\r\n      } catch (error) {\r\n        console.error('Error updating account:', error)\r\n        this.showError('Error', 'Failed to update account. Please try again.')\r\n      }\r\n    },\r\n    confirmDeleteAccount(accountId) {\r\n      this.accountToDeleteId = accountId\r\n      this.showDeleteModal = true\r\n    },\r\n    async deleteAccount() {\r\n      try {\r\n        await deleteAccount(this.accountToDeleteId)\r\n        await this.fetchAccounts()\r\n        this.showDeleteModal = false\r\n        this.accountToDeleteId = null\r\n        this.showSuccess('Success', 'Account deleted successfully!')\r\n      } catch (error) {\r\n        console.error('Error deleting account:', error)\r\n        this.showError('Error', 'Failed to delete account. Please try again.')\r\n      }\r\n    },\r\n    formatDate(timestamp) {\r\n      if (!timestamp) return 'N/A'\r\n      return new Date(timestamp).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@import '@/styles/admin/admin-modal.css';\r\n@import '@/styles/admin/design-system.css';\r\n</style>"],"mappings":"AAwPA,OAAOA,YAAW,MAAO,qCAAoC;AAC7D,OAAOC,WAAU,MAAO,oCAAmC;AAC3D,SAASC,eAAc,QAAS,+BAA8B;AAC9D,SAASC,cAAc,EAAEC,aAAa,EAAEC,aAAa,EAAEC,aAAY,QAAS,kBAAiB;AAE7F,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACVR,YAAY;IACZC;EACF,CAAC;EACDQ,KAAKA,CAAA,EAAG;IACN,MAAM;MAAEC,WAAW;MAAEC,SAAS;MAAEC,QAAQ;MAAEC;IAAY,IAAIX,eAAe,CAAC;IAC1E,OAAO;MACLQ,WAAW;MACXC,SAAS;MACTC,QAAQ;MACRC;IACF;EACF,CAAC;EACDC,IA