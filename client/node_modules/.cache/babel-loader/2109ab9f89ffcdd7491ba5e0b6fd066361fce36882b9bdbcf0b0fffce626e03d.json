{"ast":null,"code":"import AdminSidebar from '@/components/admin/AdminSidebar.vue';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nexport default {\n  name: 'SystemAdmin',\n  components: {\n    AdminSidebar,\n    AdminHeader\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      showSystemModal: false,\n      systemSettings: {\n        maintenanceMode: false,\n        maxUsers: 1000,\n        sessionTimeout: 60\n      }\n    };\n  },\n  methods: {\n    async updateSystemSettings() {\n      try {\n        // API call to update system settings would go here\n        console.log('Updating system settings:', this.systemSettings);\n        this.showSystemModal = false;\n      } catch (error) {\n        console.error('Error updating system settings:', error);\n      }\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminSidebar","AdminHeader","name","components","data","currentUser","JSON","parse","localStorage","getItem","showSystemModal","systemSettings","maintenanceMode","maxUsers","sessionTimeout","methods","updateSystemSettings","console","log","error","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\SystemAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-page\">\r\n    <!-- Sidebar -->\r\n    <AdminSidebar />\r\n    \r\n    <!-- Header -->\r\n    <AdminHeader \r\n      title=\"System Settings\" \r\n      icon-class=\"fas fa-cog\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n\r\n    <!-- Main Content -->\r\n    <main class=\"admin-content\">\r\n    <div class=\"p-6\">\r\n      <!-- Header Section -->\r\n      <div class=\"flex justify-between items-center mb-6\">\r\n        <div>\r\n          <h1 class=\"text-section-header text-gray-900\">System Settings</h1>\r\n          <p class=\"text-body text-gray-600 mt-1\">Monitor system health and configure settings</p>\r\n        </div>\r\n        <button @click=\"showSystemModal = true\" class=\"btn-primary\">\r\n          <i class=\"fas fa-cog mr-2\"></i>\r\n          System Settings\r\n        </button>\r\n      </div>\r\n\r\n      <!-- System Status Cards -->\r\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\r\n        <div class=\"metric-card\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <h3 class=\"text-body font-medium text-gray-700\">Server Status</h3>\r\n              <div class=\"flex items-center mt-2\">\r\n                <div class=\"w-3 h-3 bg-success rounded-full mr-2\"></div>\r\n                <span class=\"text-dashboard-metric text-success\">Online</span>\r\n              </div>\r\n            </div>\r\n            <div class=\"w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-server text-success text-xl\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"metric-card\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <h3 class=\"text-body font-medium text-gray-700\">Database</h3>\r\n              <div class=\"flex items-center mt-2\">\r\n                <div class=\"w-3 h-3 bg-success rounded-full mr-2\"></div>\r\n                <span class=\"text-dashboard-metric text-success\">Connected</span>\r\n              </div>\r\n            </div>\r\n            <div class=\"w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-database text-primary text-xl\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"metric-card\">\r\n          <div class=\"flex items-center justify-between\">\r\n            <div>\r\n              <h3 class=\"text-body font-medium text-gray-700\">Last Updated</h3>\r\n              <p class=\"text-small text-gray-500 mt-2\">{{ new Date().toLocaleString() }}</p>\r\n            </div>\r\n            <div class=\"w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center\">\r\n              <i class=\"fas fa-clock text-purple-600 text-xl\"></i>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Additional System Information -->\r\n      <div class=\"mt-8\">\r\n        <div class=\"chart-container\">\r\n          <h3 class=\"text-section-header text-gray-900 mb-4\">System Health</h3>\r\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n            <div class=\"space-y-4\">\r\n              <div class=\"flex justify-between items-center\">\r\n                <span class=\"text-body text-gray-700\">CPU Usage</span>\r\n                <span class=\"text-body font-medium text-gray-900\">45%</span>\r\n              </div>\r\n              <div class=\"w-full bg-gray-200 rounded-full h-2\">\r\n                <div class=\"bg-primary h-2 rounded-full\" style=\"width: 45%\"></div>\r\n              </div>\r\n            </div>\r\n            <div class=\"space-y-4\">\r\n              <div class=\"flex justify-between items-center\">\r\n                <span class=\"text-body text-gray-700\">Memory Usage</span>\r\n                <span class=\"text-body font-medium text-gray-900\">62%</span>\r\n              </div>\r\n              <div class=\"w-full bg-gray-200 rounded-full h-2\">\r\n                <div class=\"bg-warning h-2 rounded-full\" style=\"width: 62%\"></div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    </main>\r\n\r\n    <!-- System Settings Modal -->\r\n    <div v-if=\"showSystemModal\" class=\"modal-overlay\" @click=\"showSystemModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>System Settings</h3>\r\n          <button @click=\"showSystemModal = false\" class=\"modal-close\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <form @submit.prevent=\"updateSystemSettings\">\r\n            <div class=\"form-group\">\r\n              <label for=\"maintenanceMode\">Maintenance Mode</label>\r\n              <select id=\"maintenanceMode\" v-model=\"systemSettings.maintenanceMode\" class=\"form-input\">\r\n                <option value=\"false\">Disabled</option>\r\n                <option value=\"true\">Enabled</option>\r\n              </select>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"maxUsers\">Maximum Users</label>\r\n              <input id=\"maxUsers\" type=\"number\" v-model=\"systemSettings.maxUsers\" class=\"form-input\" min=\"1\">\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"sessionTimeout\">Session Timeout (minutes)</label>\r\n              <input id=\"sessionTimeout\" type=\"number\" v-model=\"systemSettings.sessionTimeout\" class=\"form-input\" min=\"5\" max=\"1440\">\r\n            </div>\r\n          </form>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showSystemModal = false\" class=\"btn-secondary\">Cancel</button>\r\n          <button @click=\"updateSystemSettings\" class=\"btn-primary\">Save Settings</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AdminSidebar from '@/components/admin/AdminSidebar.vue'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\n\r\nexport default {\r\n  name: 'SystemAdmin',\r\n  components: {\r\n    AdminSidebar,\r\n    AdminHeader\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      showSystemModal: false,\r\n      systemSettings: {\r\n        maintenanceMode: false,\r\n        maxUsers: 1000,\r\n        sessionTimeout: 60\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    async updateSystemSettings() {\r\n      try {\r\n        // API call to update system settings would go here\r\n        console.log('Updating system settings:', this.systemSettings)\r\n        this.showSystemModal = false\r\n      } catch (error) {\r\n        console.error('Error updating system settings:', error)\r\n      }\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@import '@/styles/admin/admin-modal.css';\r\n@import '@/styles/admin/design-system.css';\r\n</style>"],"mappings":"AA4IA,OAAOA,YAAW,MAAO,qCAAoC;AAC7D,OAAOC,WAAU,MAAO,oCAAmC;AAE3D,eAAe;EACbC,IAAI,EAAE,aAAa;EACnBC,UAAU,EAAE;IACVH,YAAY;IACZC;EACF,CAAC;EACDG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,eAAe,EAAE,KAAK;MACtBC,cAAc,EAAE;QACdC,eAAe,EAAE,KAAK;QACtBC,QAAQ,EAAE,IAAI;QACdC,cAAc,EAAE;MAClB;IACF;EACF,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,oBAAoBA,CAAA,EAAG;MAC3B,IAAI;QACF;QACAC,OAAO,CAACC,GAAG,CAAC,2BAA2B,EAAE,IAAI,CAACP,cAAc;QAC5D,IAAI,CAACD,eAAc,GAAI,KAAI;MAC7B,EAAE,OAAOS,KAAK,EAAE;QACdF,OAAO,CAACE,KAAK,CAAC,iCAAiC,EAAEA,KAAK;MACxD;IACF,CAAC;IACDC,MAAMA,CAAA,EAAG;MACPZ,YAAY,CAACa,UAAU,CAAC,OAAO;MAC/Bb,YAAY,CAACa,UAAU,CAAC,MAAM;MAC9B,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,QAAQ;IAC5B;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}