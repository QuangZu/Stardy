{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/web.dom-exception.stack.js\";\nimport { getAccount } from '../api/Account.js';\nimport { getUserProgress } from '../api/UserProgress.js';\nexport default {\n  name: 'Dashboard',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userEmail: '',\n      userId: null,\n      userStats: {\n        experience: 0,\n        streak: 0,\n        completedQuestions: 0,\n        achievements: 0\n      },\n      recentActivities: [{\n        id: 1,\n        iconClass: 'fas fa-check-circle',\n        title: 'Completed Math Quiz',\n        description: 'Scored 95% on Algebra fundamentals',\n        time: '2 hours ago'\n      }, {\n        id: 2,\n        iconClass: 'fas fa-trophy',\n        title: 'Achievement Unlocked',\n        description: 'Earned \"Week Warrior\" badge',\n        time: '1 day ago'\n      }, {\n        id: 3,\n        iconClass: 'fas fa-book-open',\n        title: 'Started New Course',\n        description: 'Began Advanced Physics module',\n        time: '2 days ago'\n      }],\n      loading: true,\n      error: null\n    };\n  },\n  async mounted() {\n    await this.loadUserData();\n  },\n  methods: {\n    // Helper function to decode JWT token and get user ID\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n\n        // Decode JWT token (simple base64 decode for payload)\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    async loadUserData() {\n      try {\n        this.loading = true;\n        this.error = null;\n\n        // Get user ID from JWT token\n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        this.userId = userId;\n\n        // Fetch user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.name;\n        this.userEmail = accountData.email;\n        this.userLevel = accountData.currentLevel || 1;\n\n        // Update user stats from account data\n        this.userStats.experience = accountData.experience || 0;\n        this.userStats.completedQuestions = accountData.completedQuestions?.length || 0;\n        this.userStats.achievements = accountData.achievements?.length || 0;\n\n        // Fetch user progress data\n        try {\n          const progressData = await getUserProgress(userId);\n          if (progressData && progressData.studyStreak) {\n            this.userStats.streak = progressData.studyStreak.currentStreak || 0;\n          }\n\n          // Update recent activities based on progress data\n          if (progressData && progressData.examHistory) {\n            this.updateRecentActivities(progressData);\n          }\n        } catch (progressError) {\n          console.warn('Could not load user progress:', progressError);\n          // Continue without progress data\n        }\n      } catch (error) {\n        console.error('Error loading user data:', error);\n        this.error = 'Failed to load user data';\n\n        // If token is invalid, redirect to login\n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    updateRecentActivities(progressData) {\n      const activities = [];\n\n      // Add recent exam completions\n      if (progressData.examHistory && progressData.examHistory.length > 0) {\n        const recentExams = progressData.examHistory.sort((a, b) => new Date(b.dateTaken) - new Date(a.dateTaken)).slice(0, 2);\n        recentExams.forEach(exam => {\n          activities.push({\n            id: `exam-${exam.examId}`,\n            iconClass: exam.passed ? 'fas fa-check-circle' : 'fas fa-file-alt',\n            title: exam.passed ? 'Exam Passed!' : 'Exam Completed',\n            description: `Scored ${exam.score}% ${exam.passed ? '- Well done!' : '- Keep practicing!'}`,\n            time: this.formatTimeAgo(exam.dateTaken)\n          });\n        });\n      }\n\n      // Add study streak info\n      if (progressData.studyStreak && progressData.studyStreak.currentStreak > 0) {\n        activities.push({\n          id: 'streak',\n          iconClass: 'fas fa-fire',\n          title: 'Study Streak Active',\n          description: `${progressData.studyStreak.currentStreak} days in a row!`,\n          time: this.formatTimeAgo(progressData.studyStreak.lastStudyDate)\n        });\n      }\n\n      // Update recent activities if we have new data\n      if (activities.length > 0) {\n        this.recentActivities = [...activities, ...this.recentActivities].slice(0, 5);\n      }\n    },\n    formatTimeAgo(dateString) {\n      if (!dateString) return 'Recently';\n      const date = new Date(dateString);\n      const now = new Date();\n      const diffInHours = Math.floor((now - date) / (1000 * 60 * 60));\n      if (diffInHours < 1) return 'Just now';\n      if (diffInHours < 24) return `${diffInHours} hour${diffInHours > 1 ? 's' : ''} ago`;\n      const diffInDays = Math.floor(diffInHours / 24);\n      if (diffInDays < 7) return `${diffInDays} day${diffInDays > 1 ? 's' : ''} ago`;\n      return date.toLocaleDateString();\n    },\n    startLearning() {\n      this.$router.push('/learning');\n    },\n    takeExam() {\n      this.$router.push('/exams');\n    },\n    askAI() {\n      this.$router.push('/ai-tutor');\n    },\n    viewProgress() {\n      this.$router.push('/progress');\n    },\n    logout() {\n      // Clear authentication token\n      localStorage.removeItem('token');\n      // Redirect to login\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["getAccount","getUserProgress","name","data","userName","userLevel","userEmail","userId","userStats","experience","streak","completedQuestions","achievements","recentActivities","id","iconClass","title","description","time","loading","error","mounted","loadUserData","methods","getUserIdFromToken","token","localStorage","getItem","payload","JSON","parse","atob","split","console","Error","accountData","email","currentLevel","length","progressData","studyStreak","currentStreak","examHistory","updateRecentActivities","progressError","warn","message","includes","response","status","removeItem","$router","push","activities","recentExams","sort","a","b","Date","dateTaken","slice","forEach","exam","examId","passed","score","formatTimeAgo","lastStudyDate","dateString","date","now","diffInHours","Math","floor","diffInDays","toLocaleDateString","startLearning","takeExam","askAI","viewProgress","logout"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Dashboard.vue"],"sourcesContent":["<template>\r\n  <div class=\"dashboard-container\">\r\n    <!-- Loading State -->\r\n    <div v-if=\"loading\" class=\"loading-container\">\r\n      <div class=\"loading-spinner\"><i class=\"fas fa-spinner fa-spin\"></i></div>\r\n      <p>Loading your dashboard...</p>\r\n    </div>\r\n    \r\n    <!-- Error State -->\r\n    <div v-else-if=\"error\" class=\"error-container\">\r\n      <div class=\"error-icon\"><i class=\"fas fa-exclamation-triangle\"></i></div>\r\n      <p>{{ error }}</p>\r\n      <button @click=\"loadUserData\" class=\"retry-btn\">Try Again</button>\r\n    </div>\r\n    \r\n    <!-- Main Dashboard Content -->\r\n    <template v-else>\r\n      <!-- Sidebar -->\r\n      <div class=\"sidebar\">\r\n        <div class=\"sidebar-header\">\r\n          <div class=\"logo\">\r\n            <h2><i class=\"fas fa-star\"></i> Stardy</h2>\r\n          </div>\r\n          <div class=\"user-profile\">\r\n            <div class=\"avatar\">\r\n              <img src=\"https://via.placeholder.com/40\" alt=\"User Avatar\" />\r\n            </div>\r\n            <div class=\"user-info\">\r\n              <h4>{{ userName }}</h4>\r\n              <p>Level {{ userLevel }}</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <nav class=\"sidebar-nav\">\r\n          <ul>\r\n            <li class=\"nav-item active\">\r\n              <router-link to=\"/dashboard\" class=\"nav-link\">\r\n                <i class=\"icon fas fa-home\"></i>\r\n                <span>Dashboard</span>\r\n              </router-link>\r\n            </li>\r\n            <li class=\"nav-item\">\r\n              <router-link to=\"/learning\" class=\"nav-link\">\r\n                <i class=\"icon fas fa-book\"></i>\r\n                <span>Learning</span>\r\n              </router-link>\r\n            </li>\r\n            <li class=\"nav-item\">\r\n              <router-link to=\"/exams\" class=\"nav-link\">\r\n                <i class=\"icon fas fa-file-alt\"></i>\r\n                <span>Exams</span>\r\n              </router-link>\r\n            </li>\r\n            <li class=\"nav-item\">\r\n              <router-link to=\"/subjects\" class=\"nav-link\">\r\n                <i class=\"icon fas fa-graduation-cap\"></i>\r\n                <span>Subjects</span>\r\n              </router-link>\r\n            </li>\r\n            <li class=\"nav-item\">\r\n              <router-link to=\"/progress\" class=\"nav-link\">\r\n                <i class=\"icon fas fa-chart-line\"></i>\r\n                <span>Progress</span>\r\n              </router-link>\r\n            </li>\r\n            <li class=\"nav-item\">\r\n              <router-link to=\"/ai-tutor\" class=\"nav-link\">\r\n                <i class=\"icon fas fa-robot\"></i>\r\n                <span>AI Tutor</span>\r\n              </router-link>\r\n            </li>\r\n          </ul>\r\n        </nav>\r\n        \r\n        <div class=\"sidebar-footer\">\r\n          <button @click=\"logout\" class=\"logout-btn\">\r\n            <i class=\"icon fas fa-sign-out-alt\"></i>\r\n            <span>Logout</span>\r\n          </button>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Main Content -->\r\n      <div class=\"main-content\">\r\n        <header class=\"dashboard-header\">\r\n          <div class=\"header-content\">\r\n            <h1>Welcome back, {{ userName }}! <i class=\"fas fa-hand-paper\"></i></h1>\r\n            <p>Ready to continue your learning journey?</p>\r\n          </div>\r\n          <div class=\"header-actions\">\r\n            <button class=\"notification-btn\">\r\n              <i class=\"icon fas fa-bell\"></i>\r\n              <span class=\"notification-badge\">3</span>\r\n            </button>\r\n          </div>\r\n        </header>\r\n        \r\n        <!-- Stats Cards -->\r\n        <div class=\"stats-grid\">\r\n          <div class=\"stat-card\">\r\n            <div class=\"stat-icon\"><i class=\"fas fa-chart-line\"></i></div>\r\n            <div class=\"stat-content\">\r\n              <h3>{{ userStats.experience }}</h3>\r\n              <p>Total XP</p>\r\n            </div>\r\n          </div>\r\n          <div class=\"stat-card\">\r\n            <div class=\"stat-icon\"><i class=\"fas fa-fire\"></i></div>\r\n            <div class=\"stat-content\">\r\n              <h3>{{ userStats.streak }}</h3>\r\n              <p>Day Streak</p>\r\n            </div>\r\n          </div>\r\n          <div class=\"stat-card\">\r\n            <div class=\"stat-icon\"><i class=\"fas fa-check-circle\"></i></div>\r\n            <div class=\"stat-content\">\r\n              <h3>{{ userStats.completedQuestions }}</h3>\r\n              <p>Questions Solved</p>\r\n            </div>\r\n          </div>\r\n          <div class=\"stat-card\">\r\n            <div class=\"stat-icon\"><i class=\"fas fa-trophy\"></i></div>\r\n            <div class=\"stat-content\">\r\n              <h3>{{ userStats.achievements }}</h3>\r\n              <p>Achievements</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- Subject and Level Information -->\r\n        <div class=\"subject-level-section\">\r\n          <div class=\"section-row\">\r\n            <!-- Current Level Progress -->\r\n            <div class=\"level-progress-card\">\r\n              <h2><i class=\"fas fa-star\"></i> Level Progress</h2>\r\n              <div class=\"level-info\">\r\n                <div class=\"current-level\">\r\n                  <span class=\"level-number\">{{ userLevel }}</span>\r\n                  <span class=\"level-label\">Current Level</span>\r\n                </div>\r\n                <div class=\"progress-bar\">\r\n                  <div class=\"progress-fill\" :style=\"{ width: levelProgress + '%' }\"></div>\r\n                </div>\r\n                <div class=\"progress-text\">\r\n                  <span>{{ userStats.experience }} / {{ nextLevelXP }} XP</span>\r\n                  <span class=\"next-level\">Level {{ userLevel + 1 }}</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            \r\n            <!-- Current Subjects -->\r\n            <div class=\"subjects-card\">\r\n              <h2><i class=\"fas fa-graduation-cap\"></i> Your Subjects</h2>\r\n              <div class=\"subjects-grid\">\r\n                <div class=\"subject-item\" v-for=\"subject in currentSubjects\" :key=\"subject.id\" @click=\"goToSubject(subject.id)\">\r\n                  <div class=\"subject-icon\">\r\n                    <i :class=\"subject.iconClass\"></i>\r\n                  </div>\r\n                  <div class=\"subject-info\">\r\n                    <h4>{{ subject.name }}</h4>\r\n                    <p>{{ subject.progress }}% Complete</p>\r\n                    <div class=\"subject-progress\">\r\n                      <div class=\"subject-progress-fill\" :style=\"{ width: subject.progress + '%' }\"></div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n              <button class=\"view-all-subjects\" @click=\"viewAllSubjects\">\r\n                <i class=\"fas fa-plus\"></i> View All Subjects\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- Quick Actions -->\r\n        <div class=\"quick-actions\">\r\n          <h2>Quick Actions</h2>\r\n          <div class=\"actions-grid\">\r\n            <div class=\"action-card\" @click=\"startLearning\">\r\n              <div class=\"action-icon\"><i class=\"fas fa-rocket\"></i></div>\r\n              <h3>Start Learning</h3>\r\n              <p>Continue where you left off</p>\r\n            </div>\r\n            <div class=\"action-card\" @click=\"takeExam\">\r\n              <div class=\"action-icon\"><i class=\"fas fa-file-alt\"></i></div>\r\n              <h3>Take Exam</h3>\r\n              <p>Test your knowledge</p>\r\n            </div>\r\n            <div class=\"action-card\" @click=\"askAI\">\r\n              <div class=\"action-icon\"><i class=\"fas fa-robot\"></i></div>\r\n              <h3>Ask AI Tutor</h3>\r\n              <p>Get instant help</p>\r\n            </div>\r\n            <div class=\"action-card\" @click=\"viewProgress\">\r\n              <div class=\"action-icon\"><i class=\"fas fa-chart-bar\"></i></div>\r\n              <h3>View Progress</h3>\r\n              <p>Track your improvement</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        \r\n        <!-- Recent Activity -->\r\n        <div class=\"recent-activity\">\r\n          <h2>Recent Activity</h2>\r\n          <div class=\"activity-list\">\r\n            <div class=\"activity-item\" v-for=\"activity in recentActivities\" :key=\"activity.id\">\r\n              <div class=\"activity-icon\"><i :class=\"activity.iconClass\"></i></div>\r\n              <div class=\"activity-content\">\r\n                <h4>{{ activity.title }}</h4>\r\n                <p>{{ activity.description }}</p>\r\n                <span class=\"activity-time\">{{ activity.time }}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </template>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { getAccount } from '../api/Account.js';\r\nimport { getUserProgress } from '../api/UserProgress.js';\r\n\r\nexport default {\r\n  name: 'Dashboard',\r\n  data() {\r\n    return {\r\n      userName: 'Loading...',\r\n      userLevel: 1,\r\n      userEmail: '',\r\n      userId: null,\r\n      userStats: {\r\n        experience: 0,\r\n        streak: 0,\r\n        completedQuestions: 0,\r\n        achievements: 0\r\n      },\r\n      recentActivities: [\r\n        {\r\n          id: 1,\r\n          iconClass: 'fas fa-check-circle',\r\n          title: 'Completed Math Quiz',\r\n          description: 'Scored 95% on Algebra fundamentals',\r\n          time: '2 hours ago'\r\n        },\r\n        {\r\n          id: 2,\r\n          iconClass: 'fas fa-trophy',\r\n          title: 'Achievement Unlocked',\r\n          description: 'Earned \"Week Warrior\" badge',\r\n          time: '1 day ago'\r\n        },\r\n        {\r\n          id: 3,\r\n          iconClass: 'fas fa-book-open',\r\n          title: 'Started New Course',\r\n          description: 'Began Advanced Physics module',\r\n          time: '2 days ago'\r\n        }\r\n      ],\r\n      loading: true,\r\n      error: null\r\n    }\r\n  },\r\n  async mounted() {\r\n    await this.loadUserData();\r\n  },\r\n  methods: {\r\n    // Helper function to decode JWT token and get user ID\r\n    getUserIdFromToken() {\r\n      try {\r\n        const token = localStorage.getItem('token');\r\n        if (!token) return null;\r\n        \r\n        // Decode JWT token (simple base64 decode for payload)\r\n        const payload = JSON.parse(atob(token.split('.')[1]));\r\n        return payload.id;\r\n      } catch (error) {\r\n        console.error('Error decoding token:', error);\r\n        return null;\r\n      }\r\n    },\r\n    \r\n    async loadUserData() {\r\n      try {\r\n        this.loading = true;\r\n        this.error = null;\r\n        \r\n        // Get user ID from JWT token\r\n        const userId = this.getUserIdFromToken();\r\n        if (!userId) {\r\n          throw new Error('No valid user token found');\r\n        }\r\n        \r\n        this.userId = userId;\r\n        \r\n        // Fetch user account data\r\n        const accountData = await getAccount(userId);\r\n        this.userName = accountData.name;\r\n        this.userEmail = accountData.email;\r\n        this.userLevel = accountData.currentLevel || 1;\r\n        \r\n        // Update user stats from account data\r\n        this.userStats.experience = accountData.experience || 0;\r\n        this.userStats.completedQuestions = accountData.completedQuestions?.length || 0;\r\n        this.userStats.achievements = accountData.achievements?.length || 0;\r\n        \r\n        // Fetch user progress data\r\n        try {\r\n          const progressData = await getUserProgress(userId);\r\n          if (progressData && progressData.studyStreak) {\r\n            this.userStats.streak = progressData.studyStreak.currentStreak || 0;\r\n          }\r\n          \r\n          // Update recent activities based on progress data\r\n          if (progressData && progressData.examHistory) {\r\n            this.updateRecentActivities(progressData);\r\n          }\r\n        } catch (progressError) {\r\n          console.warn('Could not load user progress:', progressError);\r\n          // Continue without progress data\r\n        }\r\n        \r\n      } catch (error) {\r\n        console.error('Error loading user data:', error);\r\n        this.error = 'Failed to load user data';\r\n        \r\n        // If token is invalid, redirect to login\r\n        if (error.message.includes('token') || error.response?.status === 401) {\r\n          localStorage.removeItem('token');\r\n          this.$router.push('/login');\r\n        }\r\n      } finally {\r\n        this.loading = false;\r\n      }\r\n    },\r\n    \r\n    updateRecentActivities(progressData) {\r\n      const activities = [];\r\n      \r\n      // Add recent exam completions\r\n      if (progressData.examHistory && progressData.examHistory.length > 0) {\r\n        const recentExams = progressData.examHistory\r\n          .sort((a, b) => new Date(b.dateTaken) - new Date(a.dateTaken))\r\n          .slice(0, 2);\r\n          \r\n        recentExams.forEach(exam => {\r\n          activities.push({\r\n            id: `exam-${exam.examId}`,\r\n            iconClass: exam.passed ? 'fas fa-check-circle' : 'fas fa-file-alt',\r\n            title: exam.passed ? 'Exam Passed!' : 'Exam Completed',\r\n            description: `Scored ${exam.score}% ${exam.passed ? '- Well done!' : '- Keep practicing!'}`,\r\n            time: this.formatTimeAgo(exam.dateTaken)\r\n          });\r\n        });\r\n      }\r\n      \r\n      // Add study streak info\r\n      if (progressData.studyStreak && progressData.studyStreak.currentStreak > 0) {\r\n        activities.push({\r\n          id: 'streak',\r\n          iconClass: 'fas fa-fire',\r\n          title: 'Study Streak Active',\r\n          description: `${progressData.studyStreak.currentStreak} days in a row!`,\r\n          time: this.formatTimeAgo(progressData.studyStreak.lastStudyDate)\r\n        });\r\n      }\r\n      \r\n      // Update recent activities if we have new data\r\n      if (activities.length > 0) {\r\n        this.recentActivities = [...activities, ...this.recentActivities].slice(0, 5);\r\n      }\r\n    },\r\n    \r\n    formatTimeAgo(dateString) {\r\n      if (!dateString) return 'Recently';\r\n      \r\n      const date = new Date(dateString);\r\n      const now = new Date();\r\n      const diffInHours = Math.floor((now - date) / (1000 * 60 * 60));\r\n      \r\n      if (diffInHours < 1) return 'Just now';\r\n      if (diffInHours < 24) return `${diffInHours} hour${diffInHours > 1 ? 's' : ''} ago`;\r\n      \r\n      const diffInDays = Math.floor(diffInHours / 24);\r\n      if (diffInDays < 7) return `${diffInDays} day${diffInDays > 1 ? 's' : ''} ago`;\r\n      \r\n      return date.toLocaleDateString();\r\n    },\r\n    \r\n    startLearning() {\r\n      this.$router.push('/learning');\r\n    },\r\n    takeExam() {\r\n      this.$router.push('/exams');\r\n    },\r\n    askAI() {\r\n      this.$router.push('/ai-tutor');\r\n    },\r\n    viewProgress() {\r\n      this.$router.push('/progress');\r\n    },\r\n    logout() {\r\n      // Clear authentication token\r\n      localStorage.removeItem('token');\r\n      // Redirect to login\r\n      this.$router.push('/login');\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.dashboard-container {\r\n  display: flex;\r\n  min-height: 100vh;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n}\r\n\r\n/* Sidebar Styles */\r\n.sidebar {\r\n  width: 280px;\r\n  background: rgba(255, 255, 255, 0.1);\r\n  backdrop-filter: blur(10px);\r\n  border-right: 1px solid rgba(255, 255, 255, 0.2);\r\n  display: flex;\r\n  flex-direction: column;\r\n  position: fixed;\r\n  height: 100vh;\r\n  overflow-y: auto;\r\n}\r\n\r\n.sidebar-header {\r\n  padding: 2rem 1.5rem;\r\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\r\n}\r\n\r\n.logo h2 {\r\n  color: white;\r\n  margin: 0 0 1.5rem 0;\r\n  font-size: 1.5rem;\r\n  font-weight: bold;\r\n}\r\n\r\n.user-profile {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.75rem;\r\n}\r\n\r\n.avatar img {\r\n  width: 40px;\r\n  height: 40px;\r\n  border-radius: 50%;\r\n  border: 2px solid rgba(255, 255, 255, 0.3);\r\n}\r\n\r\n.user-info h4 {\r\n  color: white;\r\n  margin: 0;\r\n  font-size: 0.