{"ast":null,"code":"import AdminSidebar from '@/components/admin/AdminSidebar.vue';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport { useNotification } from '@/composables/useNotification';\nimport { getAllQAs, createQA, updateQA, deleteQA } from '@/api/QA.js';\nimport { getAllSubjects } from '@/api/Subject.js';\nexport default {\n  name: 'QuestionsAdmin',\n  components: {\n    AdminSidebar,\n    AdminHeader\n  },\n  setup() {\n    const {\n      showSuccess,\n      showError,\n      showInfo,\n      showWarning\n    } = useNotification();\n    return {\n      showSuccess,\n      showError,\n      showInfo,\n      showWarning\n    };\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      questions: [],\n      subjects: [],\n      searchQuery: '',\n      showCreateQuestionModal: false,\n      showEditQuestionModal: false,\n      newQuestion: {\n        question: '',\n        answer: '',\n        subjectId: '',\n        levelId: 1\n      },\n      editingQuestion: {\n        _id: '',\n        question: '',\n        answer: '',\n        subjectId: '',\n        levelId: 1\n      }\n    };\n  },\n  computed: {\n    filteredQuestions() {\n      if (!this.searchQuery) return this.questions || [];\n      return (this.questions || []).filter(question => (question.question || '').toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchQuestions();\n    this.fetchSubjects();\n  },\n  methods: {\n    async fetchQuestions() {\n      try {\n        this.questions = await getAllQAs();\n      } catch (error) {\n        console.error('Error fetching questions:', error);\n        this.showError('Error', 'Failed to fetch questions. Please try again.');\n      }\n    },\n    async fetchSubjects() {\n      try {\n        const response = await getAllSubjects();\n        this.subjects = response.data || response || [];\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n        this.showWarning('Warning', 'Failed to fetch subjects. Some features may be limited.');\n        this.subjects = [];\n      }\n    },\n    getSubjectName(subjectId) {\n      const subject = this.subjects.find(s => s._id === subjectId);\n      return subject ? subject.name : 'Unknown';\n    },\n    async createQuestion() {\n      try {\n        await createQA(this.newQuestion);\n        await this.fetchQuestions();\n        this.showCreateQuestionModal = false;\n        this.newQuestion = {\n          question: '',\n          answer: '',\n          subjectId: '',\n          levelId: 1\n        };\n        this.showSuccess('Success', 'Question created successfully!');\n      } catch (error) {\n        console.error('Error creating question:', error);\n        this.showError('Error', 'Failed to create question. Please try again.');\n      }\n    },\n    editQuestion(question) {\n      this.editingQuestion = {\n        ...question\n      };\n      this.showEditQuestionModal = true;\n    },\n    async updateQuestion() {\n      try {\n        await updateQA(this.editingQuestion._id, this.editingQuestion);\n        await this.fetchQuestions();\n        this.showEditQuestionModal = false;\n        this.editingQuestion = {\n          _id: '',\n          question: '',\n          answer: '',\n          subjectId: '',\n          levelId: 1\n        };\n        this.showSuccess('Success', 'Question updated successfully!');\n      } catch (error) {\n        console.error('Error updating question:', error);\n        this.showError('Error', 'Failed to update question. Please try again.');\n      }\n    },\n    async deleteQuestion(questionId) {\n      if (confirm('Are you sure you want to delete this question?')) {\n        try {\n          await deleteQA(questionId);\n          await this.fetchQuestions();\n          this.showSuccess('Success', 'Question deleted successfully!');\n        } catch (error) {\n          console.error('Error deleting question:', error);\n          this.showError('Error', 'Failed to delete question. Please try again.');\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminSidebar","AdminHeader","useNotification","getAllQAs","createQA","updateQA","deleteQA","getAllSubjects","name","components","setup","showSuccess","showError","showInfo","showWarning","data","currentUser","JSON","parse","localStorage","getItem","questions","subjects","searchQuery","showCreateQuestionModal","showEditQuestionModal","newQuestion","question","answer","subjectId","levelId","editingQuestion","_id","computed","filteredQuestions","filter","toLowerCase","includes","mounted","fetchQuestions","fetchSubjects","methods","error","console","response","getSubjectName","subject","find","s","createQuestion","editQuestion","updateQuestion","deleteQuestion","questionId","confirm","formatDate","date","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\QuestionsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-page\">\r\n    <!-- Sidebar -->\r\n    <AdminSidebar />\r\n    \r\n    <!-- Header -->\r\n    <AdminHeader \r\n      title=\"Questions\" \r\n      icon-class=\"fas fa-question-circle\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n\r\n    <!-- Main Content -->\r\n    <main class=\"admin-content\">\r\n      <div class=\"p-6\">\r\n        <!-- Header Section -->\r\n        <div class=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6\">\r\n          <div>\r\n            <h1 class=\"text-section-header text-gray-900\">Question Management</h1>\r\n            <p class=\"text-body text-gray-600 mt-1\">Create and manage questions</p>\r\n          </div>\r\n          <div class=\"flex flex-col sm:flex-row gap-3\">\r\n            <div class=\"relative\">\r\n              <input\r\n                v-model=\"searchQuery\"\r\n                type=\"text\"\r\n                placeholder=\"Search questions...\"\r\n                class=\"w-full sm:w-64 pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-body\"\r\n              >\r\n              <i class=\"fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400\"></i>\r\n            </div>\r\n            <button\r\n              @click=\"showCreateQuestionModal = true\"\r\n              class=\"btn-primary flex items-center gap-2\"\r\n            >\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add Question\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Questions Table -->\r\n        <div class=\"chart-container overflow-hidden\">\r\n          <div class=\"overflow-x-auto\">\r\n            <table class=\"w-full\">\r\n              <thead class=\"bg-gray-50\">\r\n                <tr>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Question</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Subject</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Level</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Created</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Actions</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody class=\"bg-white divide-y divide-gray-200\">\r\n                <tr v-for=\"question in filteredQuestions\" :key=\"question._id\" class=\"hover:bg-gray-50 transition-colors duration-150\">\r\n                  <td class=\"px-6 py-4\">\r\n                    <div class=\"flex items-center\">\r\n                      <div class=\"w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mr-3\">\r\n                        <i class=\"fas fa-question text-purple-600\"></i>\r\n                      </div>\r\n                      <div>\r\n                        <div class=\"text-body font-medium text-gray-900\">{{ question.question }}</div>\r\n                        <div class=\"text-small text-gray-500\">ID: {{ question._id ? question._id.slice(-6) : 'N/A' }}</div>\r\n                      </div>\r\n                    </div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"text-body text-gray-900\">{{ getSubjectName(question.subjectId) }}</div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <span class=\"inline-flex px-2 py-1 text-small font-semibold rounded-full bg-blue-100 text-blue-800\">\r\n                      Level {{ question.levelId }}\r\n                    </span>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"text-body text-gray-900\">{{ formatDate(question.createdAt) }}</div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap text-body font-medium\">\r\n                    <div class=\"flex space-x-2\">\r\n                      <button\r\n                        @click=\"editQuestion(question)\"\r\n                        class=\"text-primary hover:text-blue-900 transition-colors duration-150\"\r\n                        title=\"Edit Question\"\r\n                      >\r\n                        <i class=\"fas fa-edit\"></i>\r\n                      </button>\r\n                      <button\r\n                        @click=\"deleteQuestion(question._id)\"\r\n                        class=\"text-error hover:text-red-900 transition-colors duration-150\"\r\n                        title=\"Delete Question\"\r\n                      >\r\n                        <i class=\"fas fa-trash\"></i>\r\n                      </button>\r\n                    </div>\r\n                  </td>\r\n                </tr>\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Create Question Modal -->\r\n      <div v-if=\"showCreateQuestionModal\" class=\"modal-overlay\" @click=\"showCreateQuestionModal = false\">\r\n        <div class=\"modal-content\" @click.stop>\r\n          <div class=\"modal-header\">\r\n            <h3>Create New Question</h3>\r\n            <button @click=\"showCreateQuestionModal = false\" class=\"close-btn\">\r\n              <i class=\"fas fa-times\"></i>\r\n            </button>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <form @submit.prevent=\"createQuestion\">\r\n              <div class=\"form-group\">\r\n                <label>Question</label>\r\n                <textarea\r\n                  v-model=\"newQuestion.question\"\r\n                  required\r\n                  class=\"form-textarea\"\r\n                  placeholder=\"Enter question text\"\r\n                  rows=\"3\"\r\n                ></textarea>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Answer</label>\r\n                <textarea\r\n                  v-model=\"newQuestion.answer\"\r\n                  required\r\n                  class=\"form-textarea\"\r\n                  placeholder=\"Enter answer text\"\r\n                  rows=\"3\"\r\n                ></textarea>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Subject</label>\r\n                <select\r\n                  v-model=\"newQuestion.subjectId\"\r\n                  required\r\n                  class=\"form-select\"\r\n                >\r\n                  <option value=\"\">Select a subject</option>\r\n                  <option v-for=\"subject in subjects\" :key=\"subject._id\" :value=\"subject._id\">\r\n                    {{ subject.name }}\r\n                  </option>\r\n                </select>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Level</label>\r\n                <input\r\n                  v-model=\"newQuestion.levelId\"\r\n                  type=\"number\"\r\n                  min=\"1\"\r\n                  max=\"10\"\r\n                  required\r\n                  class=\"form-input\"\r\n                  placeholder=\"Enter level (1-10)\"\r\n                >\r\n              </div>\r\n            </form>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button type=\"button\" @click=\"showCreateQuestionModal = false\" class=\"btn-cancel\">\r\n              Cancel\r\n            </button>\r\n            <button type=\"submit\" @click=\"createQuestion\" class=\"btn-save\">\r\n              Create Question\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Edit Question Modal -->\r\n      <div v-if=\"showEditQuestionModal\" class=\"modal-overlay\" @click=\"showEditQuestionModal = false\">\r\n        <div class=\"modal-content\" @click.stop>\r\n          <div class=\"modal-header\">\r\n            <h3>Edit Question</h3>\r\n            <button @click=\"showEditQuestionModal = false\" class=\"close-btn\">\r\n              <i class=\"fas fa-times\"></i>\r\n            </button>\r\n          </div>\r\n          <div class=\"modal-body\">\r\n            <form @submit.prevent=\"updateQuestion\">\r\n              <div class=\"form-group\">\r\n                <label>Question</label>\r\n                <textarea\r\n                  v-model=\"editingQuestion.question\"\r\n                  required\r\n                  class=\"form-textarea\"\r\n                  placeholder=\"Enter question text\"\r\n                  rows=\"3\"\r\n                ></textarea>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Answer</label>\r\n                <textarea\r\n                  v-model=\"editingQuestion.answer\"\r\n                  required\r\n                  class=\"form-textarea\"\r\n                  placeholder=\"Enter answer text\"\r\n                  rows=\"3\"\r\n                ></textarea>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Subject</label>\r\n                <select\r\n                  v-model=\"editingQuestion.subjectId\"\r\n                  required\r\n                  class=\"form-select\"\r\n                >\r\n                  <option value=\"\">Select a subject</option>\r\n                  <option v-for=\"subject in subjects\" :key=\"subject._id\" :value=\"subject._id\">\r\n                    {{ subject.name }}\r\n                  </option>\r\n                </select>\r\n              </div>\r\n              <div class=\"form-group\">\r\n                <label>Level</label>\r\n                <input\r\n                  v-model=\"editingQuestion.levelId\"\r\n                  type=\"number\"\r\n                  min=\"1\"\r\n                  max=\"10\"\r\n                  required\r\n                  class=\"form-input\"\r\n                  placeholder=\"Enter level (1-10)\"\r\n                >\r\n              </div>\r\n            </form>\r\n          </div>\r\n          <div class=\"modal-footer\">\r\n            <button type=\"button\" @click=\"showEditQuestionModal = false\" class=\"btn-cancel\">\r\n              Cancel\r\n            </button>\r\n            <button type=\"submit\" @click=\"updateQuestion\" class=\"btn-save\">\r\n              Update Question\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </main>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AdminSidebar from '@/components/admin/AdminSidebar.vue'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\nimport { useNotification } from '@/composables/useNotification'\r\nimport { getAllQAs, createQA, updateQA, deleteQA } from '@/api/QA.js'\r\nimport { getAllSubjects } from '@/api/Subject.js'\r\n\r\nexport default {\r\n  name: 'QuestionsAdmin',\r\n  components: {\r\n    AdminSidebar,\r\n    AdminHeader\r\n  },\r\n  setup() {\r\n    const { showSuccess, showError, showInfo, showWarning } = useNotification()\r\n    return {\r\n      showSuccess,\r\n      showError,\r\n      showInfo,\r\n      showWarning\r\n    }\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      questions: [],\r\n      subjects: [],\r\n      searchQuery: '',\r\n      showCreateQuestionModal: false,\r\n      showEditQuestionModal: false,\r\n      newQuestion: {\r\n        question: '',\r\n        answer: '',\r\n        subjectId: '',\r\n        levelId: 1\r\n      },\r\n      editingQuestion: {\r\n        _id: '',\r\n        question: '',\r\n        answer: '',\r\n        subjectId: '',\r\n        levelId: 1\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredQuestions() {\r\n      if (!this.searchQuery) return this.questions || []\r\n      return (this.questions || []).filter(question => \r\n        (question.question || '').toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchQuestions()\r\n    this.fetchSubjects()\r\n  },\r\n  methods: {\r\n    async fetchQuestions() {\r\n      try {\r\n        this.questions = await getAllQAs()\r\n      } catch (error) {\r\n        console.error('Error fetching questions:', error)\r\n        this.showError('Error', 'Failed to fetch questions. Please try again.')\r\n      }\r\n    },\r\n    async fetchSubjects() {\r\n      try {\r\n        const response = await getAllSubjects()\r\n        this.subjects = response.data || response || [];\r\n      } catch (error) {\r\n        console.error('Error fetching subjects:', error);\r\n        this.showWarning('Warning', 'Failed to fetch subjects. Some features may be limited.');\r\n        this.subjects = [];\r\n      }\r\n    },\r\n    getSubjectName(subjectId) {\r\n      const subject = this.subjects.find(s => s._id === subjectId)\r\n      return subject ? subject.name : 'Unknown'\r\n    },\r\n    async createQuestion() {\r\n      try {\r\n        await createQA(this.newQuestion)\r\n        await this.fetchQuestions()\r\n        this.showCreateQuestionModal = false\r\n        this.newQuestion = { question: '', answer: '', subjectId: '', levelId: 1 }\r\n        this.showSuccess('Success', 'Question created successfully!')\r\n      } catch (error) {\r\n        console.error('Error creating question:', error)\r\n        this.showError('Error', 'Failed to create question. Please try again.')\r\n      }\r\n    },\r\n    editQuestion(question) {\r\n      this.editingQuestion = { ...question }\r\n      this.showEditQuestionModal = true\r\n    },\r\n    async updateQuestion() {\r\n      try {\r\n        await updateQA(this.editingQuestion._id, this.editingQuestion)\r\n        await this.fetchQuestions()\r\n        this.showEditQuestionModal = false\r\n        this.editingQuestion = { _id: '', question: '', answer: '', subjectId: '', levelId: 1 }\r\n        this.showSuccess('Success', 'Question updated successfully!')\r\n      } catch (error) {\r\n        console.error('Error updating question:', error)\r\n        this.showError('Error', 'Failed to update question. Please try again.')\r\n      }\r\n    },\r\n    async deleteQuestion(questionId) {\r\n      if (confirm('Are you sure you want to delete this question?')) {\r\n        try {\r\n          await deleteQA(questionId)\r\n          await this.fetchQuestions()\r\n          this.showSuccess('Success', 'Question deleted successfully!')\r\n        } catch (error) {\r\n          console.error('Error deleting question:', error)\r\n          this.showError('Error', 'Failed to delete question. Please try again.')\r\n        }\r\n      }\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@import '@/styles/admin/design-system.css';\r\n@import '@/styles/admin/admin-modal.css';\r\n</style>"],"mappings":"AAsPA,OAAOA,YAAW,MAAO,qCAAoC;AAC7D,OAAOC,WAAU,MAAO,oCAAmC;AAC3D,SAASC,eAAc,QAAS,+BAA8B;AAC9D,SAASC,SAAS,EAAEC,QAAQ,EAAEC,QAAQ,EAAEC,QAAO,QAAS,aAAY;AACpE,SAASC,cAAa,QAAS,kBAAiB;AAEhD,eAAe;EACbC,IAAI,EAAE,gBAAgB;EACtBC,UAAU,EAAE;IACVT,YAAY;IACZC;EACF,CAAC;EACDS,KAAKA,CAAA,EAAG;IACN,MAAM;MAAEC,WAAW;MAAEC,SAAS;MAAEC,QAAQ;MAAEC;IAAY,IAAIZ,eAAe,CAAC;IAC1E,OAAO;MACLS,WAAW;MACXC,SAAS;MACTC,QAAQ;MACRC;IACF;EACF,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,SAAS,EAAE,EAAE;MACbC,QAAQ,EAAE,EAAE;MACZC,WAAW,EAAE,EAAE;MACfC,uBAAuB,EAAE,KAAK;MAC9BC,qBAAqB,EAAE,KAAK;MAC5BC,WAAW,EAAE;QACXC,QAAQ,EAAE,EAAE;QACZC,MAAM,EAAE,EAAE;QACVC,SAAS,EAAE,EAAE;QACbC,OAAO,EAAE;MACX,CAAC;MACDC,eAAe,EAAE;QACfC,GAAG,EAAE,EAAE;QACPL,QAAQ,EAAE,EAAE;QACZC,MAAM,EAAE,EAAE;QACVC,SAAS,EAAE,EAAE;QACbC,OAAO,EAAE;MACX;IACF;EACF,CAAC;EACDG,QAAQ,EAAE;IACRC,iBAAiBA,CAAA,EAAG;MAClB,IAAI,CAAC,IAAI,CAACX,WAAW,EAAE,OAAO,IAAI,CAACF,SAAQ,IAAK,EAAC;MACjD,OAAO,CAAC,IAAI,CAACA,SAAQ,IAAK,EAAE,EAAEc,MAAM,CAACR,QAAO,IAC1C,CAACA,QAAQ,CAACA,QAAO,IAAK,EAAE,EAAES,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAACd,WAAW,CAACa,WAAW,CAAC,CAAC,CACjF;IACF;EACF,CAAC;EACDE,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,cAAc,CAAC;IACpB,IAAI,CAACC,aAAa,CAAC;EACrB,C