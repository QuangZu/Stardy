{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.reduce.js\";\nimport \"core-js/modules/web.dom-exception.stack.js\";\nimport { getAllAccounts, updateAccount, deleteAccount } from '../api/Account.js';\nexport default {\n  name: 'Admin',\n  data() {\n    return {\n      currentUser: {\n        username: 'admin',\n        role: 'admin'\n      },\n      activeTab: 'users',\n      searchQuery: '',\n      loading: false,\n      showEditModal: false,\n      users: [],\n      editingUser: {},\n      tabs: [{\n        id: 'users',\n        name: 'Users',\n        icon: 'fas fa-users'\n      }, {\n        id: 'stats',\n        name: 'Statistics',\n        icon: 'fas fa-chart-bar'\n      }, {\n        id: 'system',\n        name: 'System',\n        icon: 'fas fa-cog'\n      }],\n      stats: {\n        totalUsers: 0,\n        totalAdmins: 0,\n        avgLevel: 0,\n        avgStreak: 0\n      }\n    };\n  },\n  computed: {\n    filteredUsers() {\n      if (!this.searchQuery) return this.users;\n      return this.users.filter(user => user.username.toLowerCase().includes(this.searchQuery.toLowerCase()) || user.email.toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  async mounted() {\n    await this.checkAdminAccess();\n    await this.loadUsers();\n    this.calculateStats();\n  },\n  methods: {\n    async checkAdminAccess() {\n      const token = localStorage.getItem('token');\n      if (!token) {\n        this.$router.push('/login');\n        return;\n      }\n      try {\n        // Decode token to get user info\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        this.currentUser.username = payload.username;\n\n        // Check if user is admin\n        if (payload.role !== 'admin') {\n          this.$router.push('/dashboard');\n          return;\n        }\n      } catch (error) {\n        console.error('Token validation error:', error);\n        this.$router.push('/login');\n      }\n    },\n    async loadUsers() {\n      this.loading = true;\n      try {\n        const response = await getAllAccounts();\n        this.users = response.data || [];\n      } catch (error) {\n        console.error('Error loading users:', error);\n        alert('Failed to load users');\n      } finally {\n        this.loading = false;\n      }\n    },\n    calculateStats() {\n      this.stats.totalUsers = this.users.filter(u => u.role === 'user').length;\n      this.stats.totalAdmins = this.users.filter(u => u.role === 'admin').length;\n      if (this.users.length > 0) {\n        this.stats.avgLevel = Math.round(this.users.reduce((sum, u) => sum + u.currentLevel, 0) / this.users.length);\n        this.stats.avgStreak = Math.round(this.users.reduce((sum, u) => sum + u.streak, 0) / this.users.length);\n      }\n    },\n    editUser(user) {\n      this.editingUser = {\n        ...user\n      };\n      this.showEditModal = true;\n    },\n    closeEditModal() {\n      this.showEditModal = false;\n      this.editingUser = {};\n    },\n    async saveUser() {\n      try {\n        await updateAccount(this.editingUser._id, this.editingUser);\n        await this.loadUsers();\n        this.calculateStats();\n        this.closeEditModal();\n        alert('User updated successfully');\n      } catch (error) {\n        console.error('Error updating user:', error);\n        alert('Failed to update user');\n      }\n    },\n    async deleteUser(userId) {\n      if (!confirm('Are you sure you want to delete this user?')) return;\n      try {\n        await deleteAccount(userId);\n        await this.loadUsers();\n        this.calculateStats();\n        alert('User deleted successfully');\n      } catch (error) {\n        console.error('Error deleting user:', error);\n        alert('Failed to delete user');\n      }\n    },\n    formatDate(dateString) {\n      return new Date(dateString).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["getAllAccounts","updateAccount","deleteAccount","name","data","currentUser","username","role","activeTab","searchQuery","loading","showEditModal","users","editingUser","tabs","id","icon","stats","totalUsers","totalAdmins","avgLevel","avgStreak","computed","filteredUsers","filter","user","toLowerCase","includes","email","mounted","checkAdminAccess","loadUsers","calculateStats","methods","token","localStorage","getItem","$router","push","payload","JSON","parse","atob","split","error","console","response","alert","u","length","Math","round","reduce","sum","currentLevel","streak","editUser","closeEditModal","saveUser","_id","deleteUser","userId","confirm","formatDate","dateString","Date","toLocaleDateString","logout","removeItem"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Admin.vue"],"sourcesContent":["<template>\n  <div class=\"admin-dashboard admin-space-background\">\n    <!-- Animated particles -->\n    <div class=\"admin-particles\"></div>\n    \n    <!-- Header -->\n    <div class=\"admin-header\">\n      <h1 class=\"admin-title\">\n        <i class=\"fas fa-shield-alt\"></i>\n        Admin Dashboard\n      </h1>\n      <div class=\"admin-user-info\">\n        <span>Welcome, {{ currentUser.username }}</span>\n        <button @click=\"logout\" class=\"logout-btn\">\n          <i class=\"fas fa-sign-out-alt\"></i>\n          Logout\n        </button>\n      </div>\n    </div>\n\n    <!-- Navigation Tabs -->\n    <div class=\"admin-nav\">\n      <button \n        v-for=\"tab in tabs\" \n        :key=\"tab.id\"\n        @click=\"activeTab = tab.id\"\n        :class=\"['nav-tab', { active: activeTab === tab.id }]\"\n      >\n        <i :class=\"tab.icon\"></i>\n        {{ tab.name }}\n      </button>\n    </div>\n\n    <!-- Content Area -->\n    <div class=\"admin-content\">\n      <!-- Users Management -->\n      <div v-if=\"activeTab === 'users'\" class=\"tab-content\">\n        <div class=\"content-header\">\n          <h2>User Management</h2>\n          <div class=\"search-bar\">\n            <input \n              v-model=\"searchQuery\" \n              type=\"text\" \n              placeholder=\"Search users...\"\n              class=\"search-input\"\n            >\n            <i class=\"fas fa-search search-icon\"></i>\n          </div>\n        </div>\n\n        <!-- Users Table -->\n        <div class=\"table-container\">\n          <table class=\"admin-table\">\n            <thead>\n              <tr>\n                <th>ID</th>\n                <th>Username</th>\n                <th>Email</th>\n                <th>Role</th>\n                <th>Level</th>\n                <th>Experience</th>\n                <th>Streak</th>\n                <th>Created</th>\n                <th>Actions</th>\n              </tr>\n            </thead>\n            <tbody>\n              <tr v-for=\"user in filteredUsers\" :key=\"user._id\">\n                <td>{{ user._id.slice(-6) }}</td>\n                <td>{{ user.username }}</td>\n                <td>{{ user.email }}</td>\n                <td>\n                  <span :class=\"['role-badge', user.role]\">\n                    {{ user.role.toUpperCase() }}\n                  </span>\n                </td>\n                <td>{{ user.currentLevel }}</td>\n                <td>{{ user.experience }}</td>\n                <td>{{ user.streak }}</td>\n                <td>{{ formatDate(user.createdAt) }}</td>\n                <td>\n                  <div class=\"action-buttons\">\n                    <button @click=\"editUser(user)\" class=\"btn-edit\">\n                      <i class=\"fas fa-edit\"></i>\n                    </button>\n                    <button @click=\"deleteUser(user._id)\" class=\"btn-delete\">\n                      <i class=\"fas fa-trash\"></i>\n                    </button>\n                  </div>\n                </td>\n              </tr>\n            </tbody>\n          </table>\n        </div>\n      </div>\n\n      <!-- Statistics -->\n      <div v-if=\"activeTab === 'stats'\" class=\"tab-content\">\n        <h2>System Statistics</h2>\n        <div class=\"stats-grid\">\n          <div class=\"stat-card\">\n            <div class=\"stat-icon\">\n              <i class=\"fas fa-users\"></i>\n            </div>\n            <div class=\"stat-info\">\n              <h3>{{ stats.totalUsers }}</h3>\n              <p>Total Users</p>\n            </div>\n          </div>\n          <div class=\"stat-card\">\n            <div class=\"stat-icon\">\n              <i class=\"fas fa-user-shield\"></i>\n            </div>\n            <div class=\"stat-info\">\n              <h3>{{ stats.totalAdmins }}</h3>\n              <p>Administrators</p>\n            </div>\n          </div>\n          <div class=\"stat-card\">\n            <div class=\"stat-icon\">\n              <i class=\"fas fa-chart-line\"></i>\n            </div>\n            <div class=\"stat-info\">\n              <h3>{{ stats.avgLevel }}</h3>\n              <p>Average Level</p>\n            </div>\n          </div>\n          <div class=\"stat-card\">\n            <div class=\"stat-icon\">\n              <i class=\"fas fa-fire\"></i>\n            </div>\n            <div class=\"stat-info\">\n              <h3>{{ stats.avgStreak }}</h3>\n              <p>Average Streak</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- System Info -->\n      <div v-if=\"activeTab === 'system'\" class=\"tab-content\">\n        <h2>System Information</h2>\n        <div class=\"system-info\">\n          <div class=\"info-card\">\n            <h3>Server Status</h3>\n            <p class=\"status-online\">🟢 Online</p>\n          </div>\n          <div class=\"info-card\">\n            <h3>Database</h3>\n            <p class=\"status-online\">🟢 Connected</p>\n          </div>\n          <div class=\"info-card\">\n            <h3>Last Updated</h3>\n            <p>{{ new Date().toLocaleString() }}</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Edit User Modal -->\n    <div v-if=\"showEditModal\" class=\"modal-overlay\" @click=\"closeEditModal\">\n      <div class=\"modal-content\" @click.stop>\n        <div class=\"modal-header\">\n          <h3>Edit User</h3>\n          <button @click=\"closeEditModal\" class=\"close-btn\">\n            <i class=\"fas fa-times\"></i>\n          </button>\n        </div>\n        <div class=\"modal-body\">\n          <div class=\"form-group\">\n            <label>Username</label>\n            <input v-model=\"editingUser.username\" type=\"text\" class=\"form-input\">\n          </div>\n          <div class=\"form-group\">\n            <label>Email</label>\n            <input v-model=\"editingUser.email\" type=\"email\" class=\"form-input\">\n          </div>\n          <div class=\"form-group\">\n            <label>Role</label>\n            <select v-model=\"editingUser.role\" class=\"form-select\">\n              <option value=\"user\">User</option>\n              <option value=\"admin\">Admin</option>\n            </select>\n          </div>\n          <div class=\"form-group\">\n            <label>Level</label>\n            <input v-model=\"editingUser.currentLevel\" type=\"number\" min=\"1\" class=\"form-input\">\n          </div>\n        </div>\n        <div class=\"modal-footer\">\n          <button @click=\"closeEditModal\" class=\"btn-cancel\">Cancel</button>\n          <button @click=\"saveUser\" class=\"btn-save\">Save Changes</button>\n        </div>\n      </div>\n    </div>\n\n    <!-- Loading Overlay -->\n    <div v-if=\"loading\" class=\"loading-overlay\">\n      <div class=\"loading-spinner\">\n        <i class=\"fas fa-spinner fa-spin\"></i>\n        <p>Loading...</p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { getAllAccounts, updateAccount, deleteAccount } from '../api/Account.js';\n\nexport default {\n  name: 'Admin',\n  data() {\n    return {\n      currentUser: {\n        username: 'admin',\n        role: 'admin'\n      },\n      activeTab: 'users',\n      searchQuery: '',\n      loading: false,\n      showEditModal: false,\n      users: [],\n      editingUser: {},\n      tabs: [\n        { id: 'users', name: 'Users', icon: 'fas fa-users' },\n        { id: 'stats', name: 'Statistics', icon: 'fas fa-chart-bar' },\n        { id: 'system', name: 'System', icon: 'fas fa-cog' }\n      ],\n      stats: {\n        totalUsers: 0,\n        totalAdmins: 0,\n        avgLevel: 0,\n        avgStreak: 0\n      }\n    };\n  },\n  computed: {\n    filteredUsers() {\n      if (!this.searchQuery) return this.users;\n      return this.users.filter(user => \n        user.username.toLowerCase().includes(this.searchQuery.toLowerCase()) ||\n        user.email.toLowerCase().includes(this.searchQuery.toLowerCase())\n      );\n    }\n  },\n  async mounted() {\n    await this.checkAdminAccess();\n    await this.loadUsers();\n    this.calculateStats();\n  },\n  methods: {\n    async checkAdminAccess() {\n      const token = localStorage.getItem('token');\n      if (!token) {\n        this.$router.push('/login');\n        return;\n      }\n\n      try {\n        // Decode token to get user info\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        this.currentUser.username = payload.username;\n        \n        // Check if user is admin\n        if (payload.role !== 'admin') {\n          this.$router.push('/dashboard');\n          return;\n        }\n      } catch (error) {\n        console.error('Token validation error:', error);\n        this.$router.push('/login');\n      }\n    },\n\n    async loadUsers() {\n      this.loading = true;\n      try {\n        const response = await getAllAccounts();\n        this.users = response.data || [];\n      } catch (error) {\n        console.error('Error loading users:', error);\n        alert('Failed to load users');\n      } finally {\n        this.loading = false;\n      }\n    },\n\n    calculateStats() {\n      this.stats.totalUsers = this.users.filter(u => u.role === 'user').length;\n      this.stats.totalAdmins = this.users.filter(u => u.role === 'admin').length;\n      \n      if (this.users.length > 0) {\n        this.stats.avgLevel = Math.round(\n          this.users.reduce((sum, u) => sum + u.currentLevel, 0) / this.users.length\n        );\n        this.stats.avgStreak = Math.round(\n          this.users.reduce((sum, u) => sum + u.streak, 0) / this.users.length\n        );\n      }\n    },\n\n    editUser(user) {\n      this.editingUser = { ...user };\n      this.showEditModal = true;\n    },\n\n    closeEditModal() {\n      this.showEditModal = false;\n      this.editingUser = {};\n    },\n\n    async saveUser() {\n      try {\n        await updateAccount(this.editingUser._id, this.editingUser);\n        await this.loadUsers();\n        this.calculateStats();\n        this.closeEditModal();\n        alert('User updated successfully');\n      } catch (error) {\n        console.error('Error updating user:', error);\n        alert('Failed to update user');\n      }\n    },\n\n    async deleteUser(userId) {\n      if (!confirm('Are you sure you want to delete this user?')) return;\n      \n      try {\n        await deleteAccount(userId);\n        await this.loadUsers();\n        this.calculateStats();\n        alert('User deleted successfully');\n      } catch (error) {\n        console.error('Error deleting user:', error);\n        alert('Failed to delete user');\n      }\n    },\n\n    formatDate(dateString) {\n      return new Date(dateString).toLocaleDateString();\n    },\n\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n};\n</script>\n\n<style scoped>\n.admin-dashboard {\n  min-height: 100vh;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n}\n\n.admin-header {\n  background: rgba(255, 255, 255, 0.1);\n  backdrop-filter: blur(10px);\n  padding: 1rem 2rem;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.2);\n}\n\n.admin-title {\n  color: white;\n  margin: 0;\n  font-size: 1.8rem;\n  font-weight: 600;\n}\n\n.admin-title i {\n  margin-right: 0.5rem;\n  color: #ffd700;\n}\n\n.admin-user-info {\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n  color: white;\n}\n\n.logout-btn {\n  background: rgba(255, 255, 255, 0.2);\n  border: none;\n  color: white;\n  padding: 0.5rem 1rem;\n  border-radius: 5px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n\n.logout-btn:hover {\n  background: rgba(255, 255, 255, 0.3);\n}\n\n.admin-nav {\n  background: rgba(255, 255, 255, 0.1);\n  padding: 1rem 2rem;\n  display: flex;\n  gap: 1rem;\n}\n\n.nav-tab {\n  background: transparent;\n  border: 2px solid rgba(255, 255, 255, 0.3);\n  color: white;\n  padding: 0.75rem 1.5rem;\n  border-radius: 25px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  font-weight: 500;\n}\n\n.nav-tab:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n.nav-tab.active {\n  background: white;\n  color: #667eea;\n  border-color: white;\n}\n\n.nav-tab i {\n  margin-right: 0.5rem;\n}\n\n.admin-content {\n  padding: 2rem;\n}\n\n.tab-content {\n  background: white;\n  border-radius: 15px;\n  padding: 2rem;\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n}\n\n.content-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: 2rem;\n}\n\n.content-header h2 {\n  margin: 0;\n  color: #333;\n}\n\n.search-bar {\n  position: relative;\n}\n\n.search-input {\n  padding: 0.75rem 1rem 0.75rem 2.5rem;\n  border: 2px solid #e1e5e9;\n  border-radius: 25px;\n  width: 300px;\n  font-size: 1rem;\n}\n\n.search-icon {\n  position: absolute;\n  left: 1rem;\n  top: 50%;\n  transform: translateY(-50%);\n  color: #666;\n}\n\n.table-container {\n  overflow-x: auto;\n}\n\n.admin-table {\n  width: 100%;\n  border-collapse: collapse;\n  margin-top: 1rem;\n}\n\n.admin-table th,\n.admin-table td {\n  padding: 1rem;\n  text-align: left;\n  border-bottom: 1px solid #e1e5e9;\n}\n\n.admin-table th {\n  background: #f8f9fa;\n  font-weight: 600;\n  color: #333;\n}\n\n.role-badge {\n  padding: 0.25rem 0.75rem;\n  border-radius: 15px;\n  font-size: 0.8rem;\n  font-weight: 600;\n}\n\n.role-badge.admin {\n  background: #ff6b6b;\n  color: white;\n}\n\n.role-badge.user {\n  background: #4ecdc4;\n  color: white;\n}\n\n.action-buttons {\n  display: flex;\n  gap: 0.5rem;\n}\n\n.btn-edit,\n.btn-delete {\n  padding: 0.5rem;\n  border: none;\n  border-radius: 5px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n\n.btn-edit {\n  background: #4ecdc4;\n  color: white;\n}\n\n.btn-delete {\n  background: #ff6b6b;\n  color: white;\n}\n\n.btn-edit:hover,\n.btn-delete:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n}\n\n.stats-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\n  gap: 2rem;\n  margin-top: 2rem;\n}\n\n.stat-card {\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  color: white;\n  padding: 2rem;\n  border-radius: 15px;\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);\n}\n\n.stat-icon {\n  font-size: 2.5rem;\n  opacity: 0.8;\n}\n\n.stat-info h3 {\n  margin: 0;\n  font-size: 2rem;\n  font-weight: 700;\n}\n\n.stat-info p {\n  margin: 0.5rem 0 0 0;\n  opacity: 0.9;\n}\n\n.system-info {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n  gap: 2rem;\n  margin-top: 2rem;\n}\n\n.info-card {\n  background: #f8f9fa;\n  padding: 2rem;\n  border-radius: 10px;\n  border-left: 4px solid #667eea;\n}\n\n.info-card h3 {\n  margin: 0 0 1rem 0;\n  color: #333;\n}\n\n.status-online {\n  color: #28a745;\n  font-weight: 600;\n}\n\n.modal-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(0, 0, 0, 0.5);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  z-index: 1000;\n}\n\n.modal-content {\n  background: white;\n  border-radius: 15px;\n  width: 90%;\n  max-width: 500px;\n  max-height: 90vh;\n  overflow-y: auto;\n}\n\n.modal-header {\n  padding: 1.5rem;\n  border-bottom: 1px solid #e1e5e9;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.modal-header h3 {\n  margin: 0;\n  color: #333;\n}\n\n.close-btn {\n  background: none;\n  border: none;\n  font-size: 1.5rem;\n  cursor: pointer;\n  color: #666;\n}\n\n.modal-body {\n  padding: 1.5rem;\n}\n\n.form-group {\n  margin-bottom: 1.5rem;\n}\n\n.form-group label {\n  display: block;\n  margin-bottom: 0.5rem;\n  font-weight: 600;\n  color: #333;\n}\n\n.form-input,\n.form-select {\n  width: 100%;\n  padding: 0.75rem;\n  border: 2px solid #e1e5e9;\n  border-radius: 5px;\n  font-size: 1rem;\n}\n\n.modal-footer {\n  padding: 1.5rem;\n  border-top: 1px solid #e1e5e9;\n  display: flex;\n  justify-content: flex-end;\n  gap: 1rem;\n}\n\n.btn-cancel,\n.btn-save {\n  padding: 0.75rem 1.5rem;\n  border: none;\n  border-radius: 5px;\n  cursor: pointer;\n  font-weight: 600;\n  transition: all 0.3s ease;\n}\n\n.btn-cancel {\n  background: #6c757d;\n  color: white;\n}\n\n.btn-save {\n  background: #28a745;\n  color: white;\n}\n\n.btn-cancel:hover,\n.btn-save:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\n}\n\n.loading-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background: rgba(255, 255, 255, 0.9);\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  z-index: 2000;\n}\n\n.loading-spinner {\n  text-align: center;\n  color: #667eea;\n}\n\n.loading-spinner i {