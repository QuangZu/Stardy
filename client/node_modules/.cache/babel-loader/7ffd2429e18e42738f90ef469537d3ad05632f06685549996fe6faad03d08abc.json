{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport AdminLayout from '@/components/admin/AdminLayout.vue';\nimport { getAllExams, createExam, deleteExam } from '@/api/Exam.js';\nimport { getAllSubjects } from '@/api/Subject.js';\nexport default {\n  name: 'ExamsAdmin',\n  components: {\n    AdminLayout\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      exams: [],\n      subjects: [],\n      searchQuery: '',\n      showCreateExamModal: false,\n      newExam: {\n        title: '',\n        subjectId: '',\n        difficulty: 'easy',\n        duration: 60\n      }\n    };\n  },\n  computed: {\n    filteredExams() {\n      if (!this.searchQuery) return this.exams || [];\n      return (this.exams || []).filter(exam => (exam.title || '').toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchExams();\n    this.fetchSubjects();\n  },\n  methods: {\n    async fetchExams() {\n      try {\n        this.exams = await getAllExams();\n      } catch (error) {\n        console.error('Error fetching exams:', error);\n      }\n    },\n    async fetchSubjects() {\n      try {\n        this.subjects = await getAllSubjects();\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n      }\n    },\n    getSubjectName(subjectId) {\n      const subject = this.subjects.find(s => s._id === subjectId);\n      return subject ? subject.name : 'Unknown';\n    },\n    async createExam() {\n      try {\n        await createExam(this.newExam);\n        await this.fetchExams();\n        this.showCreateExamModal = false;\n        this.newExam = {\n          title: '',\n          subjectId: '',\n          difficulty: 'easy',\n          duration: 60\n        };\n      } catch (error) {\n        console.error('Error creating exam:', error);\n      }\n    },\n    editExam(exam) {\n      console.log('Edit exam:', exam);\n    },\n    async deleteExam(examId) {\n      if (confirm('Are you sure you want to delete this exam?')) {\n        try {\n          await deleteExam(examId);\n          await this.fetchExams();\n        } catch (error) {\n          console.error('Error deleting exam:', error);\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    getDifficultyBadgeClass(difficulty) {\n      const classes = {\n        'easy': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-200',\n        'medium': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200',\n        'hard': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-200'\n      };\n      return classes[difficulty] || 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200';\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminLayout","getAllExams","createExam","deleteExam","getAllSubjects","name","components","data","currentUser","JSON","parse","localStorage","getItem","exams","subjects","searchQuery","showCreateExamModal","newExam","title","subjectId","difficulty","duration","computed","filteredExams","filter","exam","toLowerCase","includes","mounted","fetchExams","fetchSubjects","methods","error","console","getSubjectName","subject","find","s","_id","editExam","log","examId","confirm","formatDate","date","Date","toLocaleDateString","getDifficultyBadgeClass","classes","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\ExamsAdmin.vue"],"sourcesContent":["<template>\r\n  <AdminLayout>\r\n    <div class=\"p-6\">\r\n      <!-- Header Section -->\r\n      <div class=\"mb-8\">\r\n        <div class=\"flex flex-col sm:flex-row sm:items-center sm:justify-between\">\r\n          <div>\r\n            <h1 class=\"text-2xl font-bold text-gray-900 dark:text-white\">Exam Management</h1>\r\n            <p class=\"mt-2 text-sm text-gray-700 dark:text-gray-300\">Create and manage exams for different subjects</p>\r\n          </div>\r\n          <div class=\"mt-4 sm:mt-0 flex flex-col sm:flex-row gap-3\">\r\n            <div class=\"relative\">\r\n              <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\r\n                <svg class=\"h-5 w-5 text-gray-400\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" />\r\n                </svg>\r\n              </div>\r\n              <input\r\n                v-model=\"searchQuery\"\r\n                type=\"text\"\r\n                placeholder=\"Search exams...\"\r\n                class=\"block w-full pl-10 pr-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md leading-5 bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm\"\r\n              >\r\n            </div>\r\n            <button\r\n              @click=\"showCreateExamModal = true\"\r\n              class=\"inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:focus:ring-offset-gray-800\"\r\n            >\r\n              <svg class=\"-ml-1 mr-2 h-5 w-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 6v6m0 0v6m0-6h6m-6 0H6\" />\r\n              </svg>\r\n              Add Exam\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Exams Table -->\r\n      <div class=\"bg-white dark:bg-gray-800 shadow-sm rounded-lg overflow-hidden\">\r\n        <div class=\"overflow-x-auto\">\r\n          <table class=\"min-w-full divide-y divide-gray-200 dark:divide-gray-700\">\r\n            <thead class=\"bg-gray-50 dark:bg-gray-700\">\r\n              <tr>\r\n                <th scope=\"col\" class=\"px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">ID</th>\r\n                <th scope=\"col\" class=\"px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Exam Details</th>\r\n                <th scope=\"col\" class=\"px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Subject</th>\r\n                <th scope=\"col\" class=\"px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Difficulty</th>\r\n                <th scope=\"col\" class=\"px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Info</th>\r\n                <th scope=\"col\" class=\"px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Created</th>\r\n                <th scope=\"col\" class=\"relative px-6 py-3\"><span class=\"sr-only\">Actions</span></th>\r\n              </tr>\r\n            </thead>\r\n            <tbody class=\"bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700\">\r\n              <tr v-for=\"exam in filteredExams\" :key=\"exam._id\" class=\"hover:bg-gray-50 dark:hover:bg-gray-700\">\r\n                <td class=\"px-6 py-4 whitespace-nowrap text-sm font-mono text-gray-900 dark:text-gray-100\">\r\n                  {{ exam._id ? exam._id.slice(-6) : 'N/A' }}\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                  <div class=\"flex items-center\">\r\n                    <div class=\"flex-shrink-0 h-10 w-10\">\r\n                      <div class=\"h-10 w-10 rounded-lg bg-gradient-to-r from-green-500 to-blue-600 flex items-center justify-center\">\r\n                        <svg class=\"h-5 w-5 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" />\r\n                        </svg>\r\n                      </div>\r\n                    </div>\r\n                    <div class=\"ml-4\">\r\n                      <div class=\"text-sm font-medium text-gray-900 dark:text-white\">{{ exam.title || 'N/A' }}</div>\r\n                      <div class=\"text-sm text-gray-500 dark:text-gray-400\">{{ exam.questions ? exam.questions.length : 0 }} questions</div>\r\n                    </div>\r\n                  </div>\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                  <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 dark:bg-purple-900/20 text-purple-800 dark:text-purple-200\">\r\n                    {{ getSubjectName(exam.subjectId) }}\r\n                  </span>\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                  <span :class=\"getDifficultyBadgeClass(exam.difficulty)\">\r\n                    {{ (exam.difficulty || 'easy').toUpperCase() }}\r\n                  </span>\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-gray-100\">\r\n                  <div class=\"flex items-center space-x-4\">\r\n                    <div class=\"flex items-center space-x-1\">\r\n                      <svg class=\"h-4 w-4 text-gray-400\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" />\r\n                      </svg>\r\n                      <span class=\"text-xs text-gray-500 dark:text-gray-400\">{{ exam.duration || 60 }}m</span>\r\n                    </div>\r\n                  </div>\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400\">\r\n                  {{ formatDate(exam.createdAt) }}\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap text-right text-sm font-medium\">\r\n                  <div class=\"flex items-center space-x-2\">\r\n                    <button\r\n                      @click=\"editExam(exam)\"\r\n                      class=\"text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300 p-1 rounded-md hover:bg-blue-50 dark:hover:bg-blue-900/20\"\r\n                      title=\"Edit exam\"\r\n                    >\r\n                      <svg class=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z\" />\r\n                      </svg>\r\n                    </button>\r\n                    <button\r\n                      @click=\"deleteExam(exam._id)\"\r\n                      class=\"text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300 p-1 rounded-md hover:bg-red-50 dark:hover:bg-red-900/20\"\r\n                      title=\"Delete exam\"\r\n                    >\r\n                      <svg class=\"h-4 w-4\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\" />\r\n                      </svg>\r\n                    </button>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Create Exam Modal -->\r\n    <div v-if=\"showCreateExamModal\" class=\"fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50\" @click=\"showCreateExamModal = false\">\r\n      <div class=\"relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white dark:bg-gray-800\" @click.stop>\r\n        <div class=\"flex items-center justify-between mb-4\">\r\n          <h3 class=\"text-lg font-medium text-gray-900 dark:text-white\">Create New Exam</h3>\r\n          <button @click=\"showCreateExamModal = false\" class=\"text-gray-400 hover:text-gray-600 dark:hover:text-gray-300\">\r\n            <svg class=\"h-6 w-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\r\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M6 18L18 6M6 6l12 12\" />\r\n            </svg>\r\n          </button>\r\n        </div>\r\n        <div class=\"space-y-4\">\r\n          <div>\r\n            <label class=\"block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1\">Title</label>\r\n            <input v-model=\"newExam.title\" type=\"text\" class=\"w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white\" required>\r\n          </div>\r\n          <div>\r\n            <label class=\"block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1\">Subject</label>\r\n            <select v-model=\"newExam.subjectId\" class=\"w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white\" required>\r\n              <option value=\"\">Select Subject</option>\r\n              <option v-for=\"subject in subjects\" :key=\"subject._id\" :value=\"subject._id\">\r\n                {{ subject.name }}\r\n              </option>\r\n            </select>\r\n          </div>\r\n          <div>\r\n            <label class=\"block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1\">Difficulty</label>\r\n            <select v-model=\"newExam.difficulty\" class=\"w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white\">\r\n              <option value=\"easy\">Easy</option>\r\n              <option value=\"medium\">Medium</option>\r\n              <option value=\"hard\">Hard</option>\r\n            </select>\r\n          </div>\r\n          <div>\r\n            <label class=\"block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1\">Duration (minutes)</label>\r\n            <input v-model=\"newExam.duration\" type=\"number\" min=\"1\" class=\"w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:text-white\" required>\r\n          </div>\r\n        </div>\r\n        <div class=\"flex justify-end space-x-3 mt-6\">\r\n          <button @click=\"showCreateExamModal = false\" class=\"px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500\">\r\n            Cancel\r\n          </button>\r\n          <button @click=\"createExam\" class=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500\">\r\n            Create Exam\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </AdminLayout>\r\n</template>\r\n\r\n<script>\r\nimport AdminLayout from '@/components/admin/AdminLayout.vue'\r\nimport { getAllExams, createExam, deleteExam } from '@/api/Exam.js'\r\nimport { getAllSubjects } from '@/api/Subject.js'\r\n\r\nexport default {\r\n  name: 'ExamsAdmin',\r\n  components: {\r\n    AdminLayout\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      exams: [],\r\n      subjects: [],\r\n      searchQuery: '',\r\n      showCreateExamModal: false,\r\n      newExam: {\r\n        title: '',\r\n        subjectId: '',\r\n        difficulty: 'easy',\r\n        duration: 60\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredExams() {\r\n      if (!this.searchQuery) return this.exams || []\r\n      return (this.exams || []).filter(exam => \r\n        (exam.title || '').toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchExams()\r\n    this.fetchSubjects()\r\n  },\r\n  methods: {\r\n    async fetchExams() {\r\n      try {\r\n        this.exams = await getAllExams()\r\n      } catch (error) {\r\n        console.error('Error fetching exams:', error)\r\n      }\r\n    },\r\n    async fetchSubjects() {\r\n      try {\r\n        this.subjects = await getAllSubjects()\r\n      } catch (error) {\r\n        console.error('Error fetching subjects:', error)\r\n      }\r\n    },\r\n    getSubjectName(subjectId) {\r\n      const subject = this.subjects.find(s => s._id === subjectId)\r\n      return subject ? subject.name : 'Unknown'\r\n    },\r\n    async createExam() {\r\n      try {\r\n        await createExam(this.newExam)\r\n        await this.fetchExams()\r\n        this.showCreateExamModal = false\r\n        this.newExam = { title: '', subjectId: '', difficulty: 'easy', duration: 60 }\r\n      } catch (error) {\r\n        console.error('Error creating exam:', error)\r\n      }\r\n    },\r\n    editExam(exam) {\r\n      console.log('Edit exam:', exam)\r\n    },\r\n    async deleteExam(examId) {\r\n      if (confirm('Are you sure you want to delete this exam?')) {\r\n        try {\r\n          await deleteExam(examId)\r\n          await this.fetchExams()\r\n        } catch (error) {\r\n          console.error('Error deleting exam:', error)\r\n        }\r\n      }\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    getDifficultyBadgeClass(difficulty) {\r\n      const classes = {\r\n        'easy': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-200',\r\n        'medium': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200',\r\n        'hard': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-200'\r\n      }\r\n      return classes[difficulty] || 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200'\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }