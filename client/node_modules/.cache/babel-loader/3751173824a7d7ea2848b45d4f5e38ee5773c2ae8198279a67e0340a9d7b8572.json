{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/web.dom-exception.stack.js\";\nimport { getAccount } from '../api/Account.js';\nexport default {\n  name: 'Learning',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      learningStats: {\n        currentStreak: 0,\n        todayTime: 0,\n        completedLessons: 0\n      },\n      continueLearning: [],\n      subjects: [],\n      recommendedLessons: [],\n      learningPaths: [],\n      loading: true,\n      error: null\n    };\n  },\n  async mounted() {\n    await this.loadLearningData();\n  },\n  methods: {\n    getParticleSize(index) {\n      const sizes = ['small', 'medium', 'large'];\n      return sizes[index % 3];\n    },\n    getParticleColor(index) {\n      const colors = ['blue', 'purple', 'pink', 'cyan'];\n      return colors[index % 4];\n    },\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    async loadLearningData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        this.userId = userId;\n\n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n\n        // Load learning statistics\n        this.learningStats = {\n          currentStreak: accountData.currentStreak || 0,\n          todayTime: accountData.todayStudyTime || 0,\n          completedLessons: accountData.completedLessons || 0\n        };\n\n        // Load continue learning data\n        this.continueLearning = [{\n          id: 1,\n          title: 'JavaScript Fundamentals',\n          subject: 'Programming',\n          progress: 65,\n          duration: 25,\n          difficulty: 'Beginner'\n        }, {\n          id: 2,\n          title: 'Database Design Principles',\n          subject: 'Database',\n          progress: 40,\n          duration: 30,\n          difficulty: 'Intermediate'\n        }];\n\n        // Load subjects\n        this.subjects = [{\n          id: 1,\n          name: 'Programming',\n          icon: 'fas fa-code',\n          lessonCount: 45,\n          progress: 60,\n          level: 2\n        }, {\n          id: 2,\n          name: 'Database',\n          icon: 'fas fa-database',\n          lessonCount: 32,\n          progress: 35,\n          level: 1\n        }, {\n          id: 3,\n          name: 'Web Development',\n          icon: 'fas fa-globe',\n          lessonCount: 38,\n          progress: 45,\n          level: 2\n        }, {\n          id: 4,\n          name: 'Data Structures',\n          icon: 'fas fa-sitemap',\n          lessonCount: 28,\n          progress: 20,\n          level: 1\n        }];\n\n        // Load recommended lessons\n        this.recommendedLessons = [{\n          id: 1,\n          title: 'Introduction to React Hooks',\n          subject: 'Web Development',\n          description: 'Learn the fundamentals of React Hooks and how to use them effectively in your applications.',\n          thumbnail: 'https://via.placeholder.com/300x200',\n          duration: 35,\n          difficulty: 'Intermediate',\n          type: 'Video',\n          bookmarked: false\n        }, {\n          id: 2,\n          title: 'SQL Query Optimization',\n          subject: 'Database',\n          description: 'Master advanced SQL techniques to optimize your database queries for better performance.',\n          thumbnail: 'https://via.placeholder.com/300x200',\n          duration: 45,\n          difficulty: 'Advanced',\n          type: 'Interactive',\n          bookmarked: true\n        }, {\n          id: 3,\n          title: 'Python Data Analysis',\n          subject: 'Programming',\n          description: 'Explore data analysis techniques using Python libraries like Pandas and NumPy.',\n          thumbnail: 'https://via.placeholder.com/300x200',\n          duration: 50,\n          difficulty: 'Intermediate',\n          type: 'Project',\n          bookmarked: false\n        }];\n\n        // Load learning paths\n        this.learningPaths = [{\n          id: 1,\n          name: 'Full Stack Developer',\n          description: 'Complete path to become a full stack web developer',\n          icon: 'fas fa-layer-group',\n          level: 'Beginner to Advanced',\n          totalLessons: 120,\n          completedLessons: 45,\n          progress: 38\n        }, {\n          id: 2,\n          name: 'Database Administrator',\n          description: 'Master database management and administration',\n          icon: 'fas fa-server',\n          level: 'Intermediate',\n          totalLessons: 85,\n          completedLessons: 12,\n          progress: 14\n        }, {\n          id: 3,\n          name: 'Data Scientist',\n          description: 'Learn data science and machine learning fundamentals',\n          icon: 'fas fa-chart-bar',\n          level: 'Advanced',\n          totalLessons: 95,\n          completedLessons: 0,\n          progress: 0\n        }];\n      } catch (error) {\n        console.error('Error loading learning data:', error);\n        this.error = 'Failed to load learning content';\n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    startLesson(lesson) {\n      console.log('Starting lesson:', lesson.title);\n      // Here you would navigate to the lesson or open a lesson modal\n      alert(`Starting lesson: ${lesson.title}`);\n    },\n    viewSubject(subject) {\n      console.log('Viewing subject:', subject.name);\n      // Here you would navigate to the subject page\n      this.$router.push(`/subjects/${subject.id}`);\n    },\n    bookmarkLesson(lesson) {\n      lesson.bookmarked = !lesson.bookmarked;\n      console.log('Bookmarked lesson:', lesson.title, lesson.bookmarked);\n    },\n    startPath(path) {\n      console.log('Starting learning path:', path.name);\n      // Here you would navigate to the learning path\n      alert(`Starting learning path: ${path.name}`);\n    },\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["getAccount","name","data","userName","userLevel","userId","learningStats","currentStreak","todayTime","completedLessons","continueLearning","subjects","recommendedLessons","learningPaths","loading","error","mounted","loadLearningData","methods","getParticleSize","index","sizes","getParticleColor","colors","getUserIdFromToken","token","localStorage","getItem","payload","JSON","parse","atob","split","id","console","Error","accountData","username","currentLevel","todayStudyTime","title","subject","progress","duration","difficulty","icon","lessonCount","level","description","thumbnail","type","bookmarked","totalLessons","message","includes","response","status","removeItem","$router","push","startLesson","lesson","log","alert","viewSubject","bookmarkLesson","startPath","path","logout"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Learning.vue"],"sourcesContent":["<template>\n  <div class=\"learning-container space-background\">\n    <!-- Space Particles -->\n    <div class=\"space-particles\">\n      <div v-for=\"i in 20\" :key=\"i\" \n           :class=\"`particle particle-${i} ${getParticleSize(i)} ${getParticleColor(i)}`\">\n      </div>\n    </div>\n    <!-- Loading State -->\n    <div v-if=\"loading\" class=\"loading-container\">\n      <div class=\"loading-spinner\"><i class=\"fas fa-spinner fa-spin\"></i></div>\n      <p>Loading learning content...</p>\n    </div>\n    \n    <!-- Error State -->\n    <div v-else-if=\"error\" class=\"error-container\">\n      <div class=\"error-icon\"><i class=\"fas fa-exclamation-triangle\"></i></div>\n      <p>{{ error }}</p>\n      <button @click=\"loadLearningData\" class=\"retry-btn\">Try Again</button>\n    </div>\n    \n      <!-- Sidebar -->\n      <div class=\"sidebar space-sidebar\">\n        <div class=\"sidebar-header\">\n          <div class=\"logo\">\n            <h2><i class=\"fas fa-star space-glow\"></i> Stardy</h2>\n          </div>\n          <router-link to=\"/profile\" class=\"nav-link\">\n          <div class=\"user-profile\">\n            <div class=\"avatar\">\n              <img src=\"../assets/astronaunt.jpg\" alt=\"User Avatar\" />\n            </div>\n            <div class=\"user-info\">\n              <h4 class=\"space-text-primary\">{{ userName }}</h4>\n              <p class=\"space-text-secondary\">Level {{ userLevel }}</p>\n            </div>\n          </div>\n          </router-link>\n        </div>\n        \n        <nav class=\"sidebar-nav\">\n          <ul>\n            <li class=\"nav-item\">\n              <router-link to=\"/dashboard\" class=\"nav-link\">\n                <i class=\"icon fas fa-home\"></i>\n                <span>Dashboard</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item active\">\n              <router-link to=\"/learning\" class=\"nav-link\">\n                <i class=\"icon fas fa-book\"></i>\n                <span>Learning</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/exams\" class=\"nav-link\">\n                <i class=\"icon fas fa-file-alt\"></i>\n                <span>Exams</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/schedule\" class=\"nav-link\">\n                <i class=\"icon fas fa-calendar\"></i>\n                <span>Schedule</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/progress\" class=\"nav-link\">\n                <i class=\"icon fas fa-chart-line\"></i>\n                <span>Progress</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/notes\" class=\"nav-link\">\n                <i class=\"icon fas fa-sticky-note\"></i>\n                <span>Notes</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/ai-tutor\" class=\"nav-link\">\n                <i class=\"icon fas fa-robot\"></i>\n                <span>AI Tutor</span>\n              </router-link>\n            </li>\n          </ul>\n        </nav>\n        \n        <div class=\"sidebar-footer\">\n          <button @click=\"logout\" class=\"logout-btn\">\n            <i class=\"icon fas fa-sign-out-alt\"></i>\n            <span>Logout</span>\n          </button>\n        </div>\n      </div>\n      \n      <!-- Main Content -->\n      <div class=\"main-content\">\n        <header class=\"learning-header\">\n          <div class=\"header-content\">\n            <h1 class=\"space-text-primary space-glow\"><i class=\"fas fa-book\"></i> Learning Center</h1>\n            <p>Continue your learning journey and master new skills</p>\n          </div>\n          <div class=\"learning-stats\">\n            <div class=\"stat-item\">\n              <i class=\"fas fa-fire\"></i>\n              <span>{{ learningStats.currentStreak }} day streak</span>\n            </div>\n            <div class=\"stat-item\">\n              <i class=\"fas fa-clock\"></i>\n              <span>{{ learningStats.todayTime }} min today</span>\n            </div>\n            <div class=\"stat-item\">\n              <i class=\"fas fa-trophy\"></i>\n              <span>{{ learningStats.completedLessons }} lessons completed</span>\n            </div>\n          </div>\n        </header>\n        \n        <!-- Learning Sections -->\n        <div class=\"learning-sections\">\n          <!-- Continue Learning -->\n          <div class=\"learning-section\">\n            <h2><i class=\"fas fa-play-circle\"></i> Continue Learning</h2>\n            <div class=\"continue-learning-grid\">\n              <div v-for=\"lesson in continueLearning\" :key=\"lesson.id\" class=\"lesson-card continue-card\">\n                <div class=\"lesson-progress\">\n                  <div class=\"progress-bar\">\n                    <div class=\"progress-fill\" :style=\"{ width: lesson.progress + '%' }\"></div>\n                  </div>\n                  <span class=\"progress-text\">{{ lesson.progress }}%</span>\n                </div>\n                <div class=\"lesson-content\">\n                  <h3>{{ lesson.title }}</h3>\n                  <p>{{ lesson.subject }}</p>\n                  <div class=\"lesson-meta\">\n                    <span><i class=\"fas fa-clock\"></i> {{ lesson.duration }} min</span>\n                    <span><i class=\"fas fa-star\"></i> {{ lesson.difficulty }}</span>\n                  </div>\n                </div>\n                <button @click=\"startLesson(lesson)\" class=\"continue-btn\">\n                  <i class=\"fas fa-play\"></i> Continue\n                </button>\n              </div>\n            </div>\n          </div>\n          \n          <!-- Subject Categories -->\n          <div class=\"learning-section\">\n            <h2><i class=\"fas fa-graduation-cap\"></i> Browse by Subject</h2>\n            <div class=\"subjects-grid\">\n              <div v-for=\"subject in subjects\" :key=\"subject.id\" class=\"subject-card\" @click=\"viewSubject(subject)\">\n                <div class=\"subject-icon\">\n                  <i :class=\"subject.icon\"></i>\n                </div>\n                <div class=\"subject-info\">\n                  <h3>{{ subject.name }}</h3>\n                  <p>{{ subject.lessonCount }} lessons</p>\n                  <div class=\"subject-progress\">\n                    <div class=\"progress-bar\">\n                      <div class=\"progress-fill\" :style=\"{ width: subject.progress + '%' }\"></div>\n                    </div>\n                    <span>{{ subject.progress }}% complete</span>\n                  </div>\n                </div>\n                <div class=\"subject-level\">\n                  <span class=\"level-badge\">Level {{ subject.level }}</span>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <!-- Recommended Lessons -->\n          <div class=\"learning-section\">\n            <h2><i class=\"fas fa-lightbulb\"></i> Recommended for You</h2>\n            <div class=\"lessons-grid\">\n              <div v-for=\"lesson in recommendedLessons\" :key=\"lesson.id\" class=\"lesson-card\">\n                <div class=\"lesson-thumbnail\">\n                  <img :src=\"lesson.thumbnail\" :alt=\"lesson.title\" />\n                  <div class=\"lesson-duration\">\n                    <i class=\"fas fa-play\"></i> {{ lesson.duration }} min\n                  </div>\n                </div>\n                <div class=\"lesson-content\">\n                  <div class=\"lesson-subject\">{{ lesson.subject }}</div>\n                  <h3>{{ lesson.title }}</h3>\n                  <p>{{ lesson.description }}</p>\n                  <div class=\"lesson-meta\">\n                    <span class=\"difficulty\" :class=\"lesson.difficulty.toLowerCase()\">\n                      <i class=\"fas fa-star\"></i> {{ lesson.difficulty }}\n                    </span>\n                    <span class=\"lesson-type\">\n                      <i class=\"fas fa-bookmark\"></i> {{ lesson.type }}\n                    </span>\n                  </div>\n                </div>\n                <div class=\"lesson-actions\">\n                  <button @click=\"startLesson(lesson)\" class=\"start-btn\">\n                    <i class=\"fas fa-play\"></i> Start Learning\n                  </button>\n                  <button @click=\"bookmarkLesson(lesson)\" class=\"bookmark-btn\" :class=\"{ bookmarked: lesson.bookmarked }\">\n                    <i class=\"fas fa-bookmark\"></i>\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <!-- Learning Paths -->\n          <div class=\"learning-section\">\n            <h2><i class=\"fas fa-route\"></i> Learning Paths</h2>\n            <div class=\"paths-grid\">\n              <div v-for=\"path in learningPaths\" :key=\"path.id\" class=\"path-card\">\n                <div class=\"path-header\">\n                  <div class=\"path-icon\">\n                    <i :class=\"path.icon\"></i>\n                  </div>\n                  <div class=\"path-info\">\n                    <h3>{{ path.name }}</h3>\n                    <p>{{ path.description }}</p>\n                  </div>\n                  <div class=\"path-level\">\n                    <span class=\"level-badge\">{{ path.level }}</span>\n                  </div>\n                </div>\n                <div class=\"path-progress\">\n                  <div class=\"progress-info\">\n                    <span>{{ path.completedLessons }}/{{ path.totalLessons }} lessons</span>\n                    <span>{{ path.progress }}%</span>\n                  </div>\n                  <div class=\"progress-bar\">\n                    <div class=\"progress-fill\" :style=\"{ width: path.progress + '%' }\"></div>\n                  </div>\n                </div>\n                <div class=\"path-actions\">\n                  <button @click=\"startPath(path)\" class=\"path-btn\">\n                    <i class=\"fas fa-arrow-right\"></i> {{ path.progress > 0 ? 'Continue Path' : 'Start Path' }}\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n  </div>\n</template>\n\n<script>\nimport { getAccount } from '../api/Account.js';\n\nexport default {\n  name: 'Learning',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      learningStats: {\n        currentStreak: 0,\n        todayTime: 0,\n        completedLessons: 0\n      },\n      continueLearning: [],\n      subjects: [],\n      recommendedLessons: [],\n      learningPaths: [],\n      loading: true,\n      error: null\n    }\n  },\n  async mounted() {\n    await this.loadLearningData();\n  },\n  methods: {\n    getParticleSize(index) {\n      const sizes = ['small', 'medium', 'large'];\n      return sizes[index % 3];\n    },\n    getParticleColor(index) {\n      const colors = ['blue', 'purple', 'pink', 'cyan'];\n      return colors[index % 4];\n    },\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    \n    async loadLearningData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        \n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        \n        this.userId = userId;\n        \n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n        \n        // Load learning statistics\n        this.learningStats = {\n          currentStreak: accountData.currentStreak || 0,\n          todayTime: accountData.todayStudyTime || 0,\n          completedLessons: accountData.completedLessons || 0\n        };\n        \n        // Load continue learning data\n        this.continueLearning = [\n          {\n            id: 1,\n            title: 'JavaScript Fundamentals',\n            subject: 'Programming',\n            progress: 65,\n            duration: 25,\n            difficulty: 'Beginner'\n          },\n          {\n            id: 2,\n            title: 'Database Design Principles',\n            subject: 'Database',\n            progress: 40,\n            duration: 30,\n            difficulty: 'Intermediate'\n          }\n        ];\n        \n        // Load subjects\n        this.subjects = [\n          {\n            id: 1,\n            name: 'Programming',\n            icon: 'fas fa-code',\n            lessonCount: 45,\n            progress: 60,\n            level: 2\n          },\n          {\n            id: 2,\n            name: 'Database',\n            icon: 'fas fa-database',\n            lessonCount: 32,\n            progress: 35,\n            level: 1\n          },\n          {\n            id: 3,\n            name: 'Web Development',\n            icon: 'fas fa-globe',\n            lessonCount: 38,\n            progress: 45,\n            level: 2\n          },\n          {\n            id: 4,\n            name: 'Data Structures',\n            icon: 'fas fa-sitemap',\n            lessonCount: 28,\n            progress: 20,\n            level: 1\n          }\n        ];\n        \n        // Load recommended lessons\n        this.recommendedLessons = [\n          {\n            id: 1,\n            title: 'Introduction to React Hooks',\n            subject: 'Web Development',\n            description: 'Learn the fundamentals of React Hooks and how to use them effectively in your applications.',\n            thumbnail: 'https://via.placeholder.com/300x200',\n            duration: 35,\n            difficulty: 'Intermediate',\n            type: 'Video',\n            bookmarked: false\n          },\n          {\n            id: 2,\n            title: 'SQL Query Optimization',\n            subject: 'Database',\n            description: 'Master advanced SQL techniques to optimize your database queries for better performance.',\n            thumbnail: 'https://via.placeholder.com/300x200',\n            duration: 45,\n            difficulty: 'Advanced',\n            type: 'Interactive',\n            bookmarked: true\n          },\n          {\n            id: 3,\n            title: 'Python Data Analysis',\n            subject: 'Programming',\n            description: 'Explore data analysis techniques using Python libraries like Pandas and NumPy.',\n            thumbnail: 'https://via.placeholder.com/300x200',\n            duration: 50,\n            difficulty: 'Intermediate',\n            type: 'Project',\n            bookmarked: false\n          }\n        ];\n        \n        // Load learning paths\n        this.learningPaths = [\n          {\n            id: 1,\n            name: 'Full Stack Developer',\n            description: 'Complete path to become a full stack web developer',\n            icon: 'fas fa-layer-group',\n            level: 'Beginner to Advanced',\n            totalLessons: 120,\n            completedLessons: 45,\n            progress: 38\n          },\n          {\n            id: 2,\n            name: 'Database Administrator',\n            description: 'Master database management and administration',\n            icon: 'fas fa-server',\n            level: 'Intermediate',\n            totalLessons: 85,\n            completedLessons: 12,\n            progress: 14\n          },\n          {\n            id: 3,\n            name: 'Data Scientist',\n            description: 'Learn data science and machine learning fundamentals',\n            icon: 'fas fa-chart-bar',\n            level: 'Advanced',\n            totalLessons: 95,\n            completedLessons: 0,\n            progress: 0\n          }\n        ];\n        \n      } catch (error) {\n        console.error('Error loading learning data:', error);\n        this.error = 'Failed to load learning content';\n        \n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    \n    startLesson(lesson) {\n      console.log('Starting lesson:', lesson.title);\n      // Here you would navigate to the lesson or open a lesson modal\n      alert(`Starting lesson: ${lesson.title}`);\n    },\n    \n    viewSubject(subject) {\n      console.log('Viewing subject:', subject.name);\n      // Here you would navigate to the subject page\n      this.$router.push(`/subjects/${subject.id}`);\n    },\n    \n    bookmarkLesson(lesson) {\n      lesson.bookmarked = !lesson.bookmarked;\n      console.log('Bookmarked lesson:', lesson.title, lesson.bookmarked);\n    },\n    \n    startPath(path) {\n      console.log('Starting learning path:', path.name);\n      // Here you would navigate to the learning path\n      alert(`Starting learning path: ${path.name}`);\n    },\n    \n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n}\n</script>\n\n<style scoped>\n.learning-container {\n  display: flex;\n  min-height: 100vh;\n  position: relative;\n}\n\n/* Sidebar Styles */\n.sidebar {\n  width: 280px;\n  display: flex;\n  flex-direction: column;\n  position: fixed;\n  height: 100vh;\n  z-index: 100;\n}\n\n.sidebar-header {\n  padding: 2rem 1.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n\n.user-profile {\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n  margin-top: 1.5rem;\n  padding: 1rem;\n  border-radius: 12px;\n  transition: all 0.3s ease;\n  text-decoration: none;\n}\n\n/* Remove the background overlay */\n.user-profile::before {\n  display: none; /* Completely remove the background effect */\n}\n\n/* Remove the shine effect */\n.user-profile::after {\n  display: none; /* Remove the sweep animation */\n}\n\n/* Keep enhanced avatar hover effect */\n.avatar {\n  position: relative;\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  z-index: 2;\n}\n\n.avatar::before {\n  content: '';\n  position: absolute;\n  top: -3px;\n  left: -3px;\n  right: -3px;\n  bottom: -3px;\n  background: linear-gradient(45deg, rgba(255, 255, 255, 0.3), rgba(255, 255, 255, 0.1));\n  border-radius: 50%;\n  opacity: 0;\n  transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  z-index: -1;\n}\n\n.user-profile:hover .avatar::before {\n  opacity: 1;\n}\n\n.user-profile:hover .avatar {\n  transform: scale(1.05);\n}\n\n.avatar img {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  border: 2px solid rgba(255, 255, 255, 0.3);\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  position: relative;\n  z-index: 3;\n}\n\n.user-profile:hover .avatar img {\n  border-color: rgba(255, 255, 255, 0.6);\n  box-shadow: 0 4px 20px rgba(255, 255, 255, 0.2);\n}\n\n/* Keep enhanced text hover effects */\n.user-info {\n  position: relative;\n  z-index: 2;\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.user-profile:hover .user-info {\n  transform: translateX(2px);\n}\n\n.user-info h4 {\n  color: white;\n  margin: 0;\n  font-size: 0.9rem;\n  font-weight: 600;\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.user-profile:hover .user-info h4 {\n  color: #ffffff;\n  text-shadow: 0 2px 8px rgba(255, 255, 255, 0.3);\n}\n\n.user-info p {\n  color: rgba(255, 255, 255, 0.7);\n  margin: 0;\n  font-size: 0.8rem;\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n}\n\n.user-profile:hover .user-info p {\n  color: rgba(255, 255, 255, 0.9);\n}\n\n/* Keep active state for better feedback */\n.user-