er-link to=\"/\" class=\"nav-link\" @click=\"moveUnderline($event)\">Home</router-link>\r\n          <router-link to=\"/about\" class=\"nav-link\" @click=\"moveUnderline($event)\">About</router-link>\r\n          <router-link to=\"/careers\" class=\"nav-link\" @click=\"moveUnderline($event)\">Careers</router-link>\r\n          <router-link to=\"/contact\" class=\"nav-link\" @click=\"moveUnderline($event)\">Contact</router-link>\r\n        </nav>\r\n        <div class=\"nav-auth\">\r\n          <button class=\"sign-in-btn\">Sign In</button>\r\n        </div>\r\n      </div>\r\n    </header>\r\n\r\n    <!-- About Content -->\r\n    <main class=\"about-content\">\r\n      <div class=\"container\">\r\n        <div class=\"about-hero fade-in-up\">\r\n          <h1>About Stardy</h1>\r\n          <p class=\"hero-subtitle\">Empowering students to achieve their academic goals through innovative study tools</p>\r\n        </div>\r\n        \r\n        <div class=\"about-sections\">\r\n          <section class=\"mission-section fade-in-up\">\r\n            <h2>Our Mission</h2>\r\n            <p>We believe that every student deserves access to powerful, intuitive study tools that make learning more effective and enjoyable. Stardy combines cutting-edge technology with proven educational methodologies to create the ultimate study companion.</p>\r\n          </section>\r\n          \r\n          <section class=\"values-section fade-in-up\">\r\n            <h2>Our Values</h2>\r\n            <div class=\"values-grid\">\r\n              <div class=\"value-card\">\r\n                <div class=\"value-icon\">🎯</div>\r\n                <h3>Focus</h3>\r\n                <p>We help students maintain focus and achieve their academic goals through structured learning paths.</p>\r\n              </div>\r\n              <div class=\"value-card\">\r\n                <div class=\"value-icon\">🚀</div>\r\n                <h3>Innovation</h3>\r\n                <p>We continuously innovate to provide the most effective and modern study tools available.</p>\r\n              </div>\r\n              <div class=\"value-card\">\r\n                <div class=\"value-icon\">🤝</div>\r\n                <h3>Community</h3>\r\n                <p>We foster a supportive learning community where students can grow and succeed together.</p>\r\n              </div>\r\n            </div>\r\n          </section>\r\n        </div>\r\n      </div>\r\n    </main>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'AboutView',\r\n  mounted() {\r\n    this.initializeUnderline();\r\n    this.observeAnimations();\r\n  },\r\n  methods: {\r\n    moveUnderline(event) {\r\n      const underline = document.querySelector('.nav-underline');\r\n      const link = event.target;\r\n      const linkRect = link.getBoundingClientRect();\r\n      const navRect = link.parentElement.getBoundingClientRect();\r\n      \r\n      underline.style.left = (linkRect.left - navRect.left) + 'px';\r\n      underline.style.width = linkRect.width + 'px';\r\n    },\r\n    \r\n    initializeUnderline() {\r\n      this.$nextTick(() => {\r\n        const activeLink = document.querySelector('.nav-link.router-link-active');\r\n        if (activeLink) {\r\n          this.moveUnderline({ target: activeLink });\r\n        }\r\n      });\r\n    },\r\n    \r\n    observeAnimations() {\r\n      const observer = new IntersectionObserver((entries) => {\r\n        entries.forEach(entry => {\r\n          if (entry.isIntersecting) {\r\n            entry.target.classList.add('animate');\r\n          }\r\n        });\r\n      }, { threshold: 0.1 });\r\n      \r\n      document.querySelectorAll('.fade-in-up').forEach(el => {\r\n        observer.observe(el);\r\n      });\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.about {\r\n  min-height: 100vh;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: white;\r\n  position: relative;\r\n  overflow-x: hidden;\r\n}\r\n\r\n/* Reuse the same animated background and navigation styles from Home.vue */\r\n.animated-background {\r\n  position: absolute;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  pointer-events: none;\r\n  z-index: 1;\r\n}\r\n\r\n.floating-shape {\r\n  position: absolute;\r\n  border-radius: 50%;\r\n  background: rgba(255, 255, 255, 0.1);\r\n  animation: float 6s ease-in-out infinite;\r\n}\r\n\r\n.shape-1 {\r\n  width: 80px;\r\n  height: 80px;\r\n  top: 20%;\r\n  left: 10%;\r\n  animation-delay: 0s;\r\n}\r\n\r\n.shape-2 {\r\n  width: 120px;\r\n  height: 120px;\r\n  top: 60%;\r\n  right: 15%;\r\n  animation-delay: 2s;\r\n}\r\n\r\n.shape-3 {\r\n  width: 60px;\r\n  height: 60px;\r\n  top: 80%;\r\n  left: 20%;\r\n  animation-delay: 4s;\r\n}\r\n\r\n@keyframes float {\r\n  0%, 100% { transform: translateY(0px) rotate(0deg); }\r\n  33% { transform: translateY(-20px) rotate(120deg); }\r\n  66% { transform: translateY(10px) rotate(240deg); }\r\n}\r\n\r\n/* Navigation styles (same as Home.vue) */\r\n.navbar {\r\n  padding: 1rem 0;\r\n  position: relative;\r\n  z-index: 100;\r\n}\r\n\r\n.nav-container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 0 2rem;\r\n}\r\n\r\n.nav-brand {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.5rem;\r\n  font-size: 1.5rem;\r\n  font-weight: bold;\r\n}\r\n\r\n.logo-icon {\r\n  font-size: 1.8rem;\r\n}\r\n\r\n.nav-menu {\r\n  display: flex;\r\n  gap: 2rem;\r\n  position: relative;\r\n}\r\n\r\n.nav-underline {\r\n  position: absolute;\r\n  bottom: -5px;\r\n  height: 2px;\r\n  background: white;\r\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n  border-radius: 1px;\r\n}\r\n\r\n.nav-link {\r\n  color: white;\r\n  text-decoration: none;\r\n  font-weight: 500;\r\n  transition: all 0.3s ease;\r\n  padding: 0.5rem 0;\r\n}\r\n\r\n.nav-link:hover {\r\n  transform: translateY(-2px);\r\n}\r\n\r\n.sign-in-btn {\r\n  background: rgba(255, 255, 255, 0.2);\r\n  border: 1px solid rgba(255, 255, 255, 0.3);\r\n  color: white;\r\n  padding: 0.5rem 1.5rem;\r\n  border-radius: 25px;\r\n  cursor: pointer;\r\n  font-weight: 500;\r\n  transition: all 0.3s ease;\r\n  backdrop-filter: blur(10px);\r\n}\r\n\r\n.sign-in-btn:hover {\r\n  background: rgba(255, 255, 255, 0.3);\r\n  transform: translateY(-2px);\r\n}\r\n\r\n/* About Content */\r\n.about-content {\r\n  position: relative;\r\n  z-index: 10;\r\n  padding: 4rem 0;\r\n}\r\n\r\n.container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 0 2rem;\r\n}\r\n\r\n.about-hero {\r\n  text-align: center;\r\n  margin-bottom: 4rem;\r\n}\r\n\r\n.about-hero h1 {\r\n  font-size: 3.5rem;\r\n  font-weight: bold;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.hero-subtitle {\r\n  font-size: 1.2rem;\r\n  opacity: 0.9;\r\n  max-width: 600px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.about-sections {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 4rem;\r\n}\r\n\r\n.mission-section, .values-section {\r\n  background: rgba(255, 255, 255, 0.1);\r\n  padding: 3rem;\r\n  border-radius: 16px;\r\n  backdrop-filter: blur(10px);\r\n  border: 1px solid rgba(255, 255, 255, 0.2);\r\n}\r\n\r\n.mission-section h2, .values-section h2 {\r\n  font-size: 2.5rem;\r\n  margin-bottom: 1.5rem;\r\n  text-align: center;\r\n}\r\n\r\n.mission-section p {\r\n  font-size: 1.1rem;\r\n  line-height: 1.8;\r\n  text-align: center;\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  opacity: 0.9;\r\n}\r\n\r\n.values-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n  gap: 2rem;\r\n  margin-top: 2rem;\r\n}\r\n\r\n.value-card {\r\n  background: rgba(255, 255, 255, 0.1);\r\n  padding: 2rem;\r\n  border-radius: 12px;\r\n  text-align: center;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.value-card:hover {\r\n  transform: translateY(-5px);\r\n  background: rgba(255, 255, 255, 0.15);\r\n}\r\n\r\n.value-icon {\r\n  font-size: 3rem;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.value-card h3 {\r\n  font-size: 1.5rem;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.value-card p {\r\n  opacity: 0.9;\r\n  line-height: 1.6;\r\n}\r\n\r\n/* Animation Classes */\r\n.fade-in-up {\r\n  opacity: 0;\r\n  transform: translateY(30px);\r\n  transition: all 0.8s ease;\r\n}\r\n\r\n.fade-in-up.animate {\r\n  opacity: 1;\r\n  transform: translateY(0);\r\n}\r\n\r\n/* Responsive */\r\n@media (max-width: 768px) {\r\n  .about-hero h1 {\r\n    font-size: 2.5rem;\r\n  }\r\n  \r\n  .nav-menu {\r\n    display: none;\r\n  }\r\n  \r\n  .values-grid {\r\n    grid-template-columns: 1fr;\r\n  }\r\n  \r\n  .mission-section, .values-section {\r\n    padding: 2rem;\r\n  }\r\n}\r\n</style>"],"mappings":";;EACOA,KAAK,EAAC;AAAO;;EASRA,KAAK,EAAC;AAAQ;;EACfA,KAAK,EAAC;AAAe;;EAKnBA,KAAK,EAAC;AAAU;;;uBAf3BC,mBAAA,CAiEM,OAjENC,UAiEM,GAhEJC,mBAAA,yBAA4B,E,4BAC5BC,mBAAA,CAIM;IAJDJ,KAAK,EAAC;EAAqB,IAC9BI,mBAAA,CAA0C;IAArCJ,KAAK,EAAC;EAAwB,IACnCI,mBAAA,CAA0C;IAArCJ,KAAK,EAAC;EAAwB,IACnCI,mBAAA,CAA0C;IAArCJ,KAAK,EAAC;EAAwB,G,qBAGrCG,mBAAA,uBAA0B,EAC1BC,mBAAA,CAiBS,UAjBTC,UAiBS,GAhBPD,mBAAA,CAeM,OAfNE,UAeM,G,0BAdJF,mBAAA,CAGM;IAHDJ,KAAK,EAAC;EAAW,IACpBI,mBAAA,CAAiC;IAA3BJ,KAAK,EAAC;EAAW,GAAC,IAAE,GAC1BI,mBAAA,CAAsC;IAAhCJ,KAAK,EAAC;EAAY,GAAC,QAAM,E,qBAEjCI,mBAAA,CAMM,OANNG,UAMM,G,0BALJH,mBAAA,CAAiC;IAA5BJ,KAAK,EAAC;EAAe,4BAC1BQ,YAAA,CAAsFC,sBAAA;IAAzEC,EAAE,EAAC,GAAG;IAACV,KAAK,EAAC,UAAU;IAAEW,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,QAAA,CAAAC,aAAa,CAACF,MAAM;;sBAAG,MAAID,MAAA,QAAAA,MAAA,O,iBAAJ,MAAI,E;;;MACxEJ,YAAA,CAA4FC,sBAAA;IAA/EC,EAAE,EAAC,QAAQ;IAACV,KAAK,EAAC,UAAU;IAAEW,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,QAAA,CAAAC,aAAa,CAACF,MAAM;;sBAAG,MAAKD,MAAA,QAAAA,MAAA,O,iBAAL,OAAK,E;;;MAC9EJ,YAAA,CAAgGC,sBAAA;IAAnFC,EAAE,EAAC,UAAU;IAACV,KAAK,EAAC,UAAU;IAAEW,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAAC,MAAA,IAAEC,QAAA,CAAAC,aAAa,CAACF,MAAM;;sBAAG,MAAOD,MAAA,QAAAA,MAAA,O,iBAAP,SAAO,E;;;MAClFJ,YAAA,CAAgGC,sBAAA;IAAnFC,EAAE,EAAC,UAAU;IAACV,KAAK,EAAC,UAAU;IAAEW,OAAK,EAAAC,MAAA,QAAAA,MAAA,MAAA