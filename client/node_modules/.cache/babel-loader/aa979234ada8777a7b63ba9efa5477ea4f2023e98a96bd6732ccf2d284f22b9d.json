{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport '@/styles/admin/admin.css';\nimport '@/styles/admin/admin-modal.css';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport AdminNavigation from '@/components/admin/AdminNavigation.vue';\nimport { getAllAccounts, createAccount, updateAccount, deleteAccount } from '@/api/Account.js';\nexport default {\n  name: 'AccountsAdmin',\n  components: {\n    AdminHeader,\n    AdminNavigation\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      accounts: [],\n      searchQuery: '',\n      showCreateAccountModal: false,\n      showEditModal: false,\n      editingAccount: {},\n      newAccount: {\n        username: '',\n        email: '',\n        password: '',\n        role: 'user'\n      },\n      loading: false\n    };\n  },\n  computed: {\n    filteredAccounts() {\n      if (!this.searchQuery) return this.accounts;\n      return this.accounts.filter(account => account.username.toLowerCase().includes(this.searchQuery.toLowerCase()) || account.email.toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchAccounts();\n  },\n  methods: {\n    async fetchAccounts() {\n      try {\n        this.loading = true;\n        this.accounts = await getAllAccounts();\n      } catch (error) {\n        console.error('Error fetching accounts:', error);\n      } finally {\n        this.loading = false;\n      }\n    },\n    async createAccount() {\n      try {\n        await createAccount(this.newAccount);\n        await this.fetchAccounts();\n        this.showCreateAccountModal = false;\n        this.newAccount = {\n          username: '',\n          email: '',\n          password: '',\n          role: 'user'\n        };\n      } catch (error) {\n        console.error('Error creating account:', error);\n      }\n    },\n    editAccount(account) {\n      this.editingAccount = {\n        ...account\n      };\n      this.showEditModal = true;\n    },\n    async saveAccount() {\n      try {\n        await updateAccount(this.editingAccount._id, this.editingAccount);\n        await this.fetchAccounts();\n        this.closeEditModal();\n      } catch (error) {\n        console.error('Error updating account:', error);\n      }\n    },\n    async deleteAccount(accountId) {\n      if (confirm('Are you sure you want to delete this account?')) {\n        try {\n          await deleteAccount(accountId);\n          await this.fetchAccounts();\n        } catch (error) {\n          console.error('Error deleting account:', error);\n        }\n      }\n    },\n    closeEditModal() {\n      this.showEditModal = false;\n      this.editingAccount = {};\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('account');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminHeader","AdminNavigation","getAllAccounts","createAccount","updateAccount","deleteAccount","name","components","data","currentUser","JSON","parse","localStorage","getItem","accounts","searchQuery","showCreateAccountModal","showEditModal","editingAccount","newAccount","username","email","password","role","loading","computed","filteredAccounts","filter","account","toLowerCase","includes","mounted","fetchAccounts","methods","error","console","editAccount","saveAccount","_id","closeEditModal","accountId","confirm","formatDate","date","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\AccountsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-layout\">\r\n    <!-- Sidebar Navigation -->\r\n    <AdminNavigation current-route=\"accounts\" />\r\n    \r\n    <!-- Main Content Area -->\r\n    <div class=\"admin-main-content admin-space-background\">\r\n      <!-- Animated particles -->\r\n      <div class=\"admin-particles\"></div>\r\n      \r\n      <!-- Header -->\r\n      <AdminHeader \r\n        title=\"Account Management\" \r\n        icon-class=\"fas fa-users\" \r\n        :current-user=\"currentUser\" \r\n        @logout=\"logout\" \r\n      />\r\n\r\n      <!-- Content Area -->\r\n      <div class=\"admin-content\">\r\n      <div class=\"tab-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Account Management</h2>\r\n          <div class=\"header-actions\">\r\n            <div class=\"search-bar\">\r\n              <input \r\n                v-model=\"searchQuery\" \r\n                type=\"text\" \r\n                placeholder=\"Search accounts...\"\r\n                class=\"search-input\"\r\n              >\r\n              <i class=\"fas fa-search search-icon\"></i>\r\n            </div>\r\n            <button @click=\"showCreateAccountModal = true\" class=\"btn-create\">\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add Account\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Accounts Table -->\r\n        <div class=\"table-container\">\r\n          <table class=\"admin-table\">\r\n            <thead>\r\n              <tr>\r\n                <th>ID</th>\r\n                <th>Username</th>\r\n                <th>Email</th>\r\n                <th>Role</th>\r\n                <th>Level</th>\r\n                <th>Experience</th>\r\n                <th>Streak</th>\r\n                <th>Created</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"account in filteredAccounts\" :key=\"account._id\">\r\n                <td>{{ account._id.slice(-6) }}</td>\r\n                <td>{{ account.username }}</td>\r\n                <td>{{ account.email }}</td>\r\n                <td>\r\n                  <span :class=\"['role-badge', account.role]\">\r\n                    {{ account.role.toUpperCase() }}\r\n                  </span>\r\n                </td>\r\n                <td>{{ account.currentLevel }}</td>\r\n                <td>{{ account.experience }}</td>\r\n                <td>{{ account.streak }}</td>\r\n                <td>{{ formatDate(account.createdAt) }}</td>\r\n                <td>\r\n                  <div class=\"action-buttons\">\r\n                    <button @click=\"editAccount(account)\" class=\"btn-edit\">\r\n                      <i class=\"fas fa-edit\"></i>\r\n                    </button>\r\n                    <button @click=\"deleteAccount(account._id)\" class=\"btn-delete\">\r\n                      <i class=\"fas fa-trash\"></i>\r\n                    </button>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Create Account Modal -->\r\n    <div v-if=\"showCreateAccountModal\" class=\"modal-overlay\" @click=\"showCreateAccountModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Create New Account</h3>\r\n          <button @click=\"showCreateAccountModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Username</label>\r\n            <input v-model=\"newAccount.username\" type=\"text\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Email</label>\r\n            <input v-model=\"newAccount.email\" type=\"email\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Password</label>\r\n            <input v-model=\"newAccount.password\" type=\"password\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Role</label>\r\n            <select v-model=\"newAccount.role\" class=\"form-select\">\r\n              <option value=\"user\">Account</option>\r\n              <option value=\"admin\">Admin</option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showCreateAccountModal = false\" class=\"btn-cancel\">Cancel</button>\r\n          <button @click=\"createAccount\" class=\"btn-save\">Create Account</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Edit Account Modal -->\r\n    <div v-if=\"showEditModal\" class=\"modal-overlay\" @click=\"closeEditModal\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Edit Account</h3>\r\n          <button @click=\"closeEditModal\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Username</label>\r\n            <input v-model=\"editingAccount.username\" type=\"text\" class=\"form-input\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Email</label>\r\n            <input v-model=\"editingAccount.email\" type=\"email\" class=\"form-input\">\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Role</label>\r\n            <select v-model=\"editingAccount.role\" class=\"form-select\">\r\n              <option value=\"user\">Account</option>\r\n              <option value=\"admin\">Admin</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Level</label>\r\n            <input v-model=\"editingAccount.currentLevel\" type=\"number\" min=\"1\" class=\"form-input\">\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"closeEditModal\" class=\"btn-cancel\">Cancel</button>\r\n          <button @click=\"saveAccount\" class=\"btn-save\">Save Changes</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport '@/styles/admin/admin.css'\r\nimport '@/styles/admin/admin-modal.css'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\nimport AdminNavigation from '@/components/admin/AdminNavigation.vue'\r\nimport { getAllAccounts, createAccount, updateAccount, deleteAccount } from '@/api/Account.js'\r\n\r\nexport default {\r\n  name: 'AccountsAdmin',\r\n  components: {\r\n    AdminHeader,\r\n    AdminNavigation\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      accounts: [],\r\n      searchQuery: '',\r\n      showCreateAccountModal: false,\r\n      showEditModal: false,\r\n      editingAccount: {},\r\n      newAccount: {\r\n        username: '',\r\n        email: '',\r\n        password: '',\r\n        role: 'user'\r\n      },\r\n      loading: false\r\n    }\r\n  },\r\n  computed: {\r\n    filteredAccounts() {\r\n      if (!this.searchQuery) return this.accounts\r\n      return this.accounts.filter(account => \r\n        account.username.toLowerCase().includes(this.searchQuery.toLowerCase()) ||\r\n        account.email.toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchAccounts()\r\n  },\r\n  methods: {\r\n    async fetchAccounts() {\r\n      try {\r\n        this.loading = true\r\n        this.accounts = await getAllAccounts()\r\n      } catch (error) {\r\n        console.error('Error fetching accounts:', error)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n    async createAccount() {\r\n      try {\r\n        await createAccount(this.newAccount)\r\n        await this.fetchAccounts()\r\n        this.showCreateAccountModal = false\r\n        this.newAccount = { username: '', email: '', password: '', role: 'user' }\r\n      } catch (error) {\r\n        console.error('Error creating account:', error)\r\n      }\r\n    },\r\n    editAccount(account) {\r\n      this.editingAccount = { ...account }\r\n      this.showEditModal = true\r\n    },\r\n    async saveAccount() {\r\n      try {\r\n        await updateAccount(this.editingAccount._id, this.editingAccount)\r\n        await this.fetchAccounts()\r\n        this.closeEditModal()\r\n      } catch (error) {\r\n        console.error('Error updating account:', error)\r\n      }\r\n    },\r\n    async deleteAccount(accountId) {\r\n      if (confirm('Are you sure you want to delete this account?')) {\r\n        try {\r\n          await deleteAccount(accountId)\r\n          await this.fetchAccounts()\r\n        } catch (error) {\r\n          console.error('Error deleting account:', error)\r\n        }\r\n      }\r\n    },\r\n    closeEditModal() {\r\n      this.showEditModal = false\r\n      this.editingAccount = {}\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('account')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* Admin Layout Styles */\r\n.admin-layout {\r\n  display: flex;\r\n  min-height: 100vh;\r\n}\r\n\r\n.admin-main-content {\r\n  flex: 1;\r\n  margin-left: 280px; /* Width of sidebar */\r\n  min-height: 100vh;\r\n  position: relative;\r\n}\r\n\r\n/* Responsive adjustments */\r\n@media (max-width: 768px) {\r\n  .admin-main-content {\r\n    margin-left: 0;\r\n  }\r\n}\r\n</style>"],"mappings":";;;AAqKA,OAAO,0BAAyB;AAChC,OAAO,gCAA+B;AACtC,OAAOA,WAAU,MAAO,oCAAmC;AAC3D,OAAOC,eAAc,MAAO,wCAAuC;AACnE,SAASC,cAAc,EAAEC,aAAa,EAAEC,aAA