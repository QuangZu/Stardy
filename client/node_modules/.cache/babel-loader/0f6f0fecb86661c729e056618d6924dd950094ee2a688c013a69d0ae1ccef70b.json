{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/web.dom-exception.stack.js\";\nimport { getAccount } from '../api/Account.js';\nimport { getAllNotes, createNote, updateNote, deleteNote } from '../api/Note.js';\nimport { getAllSubjects } from '../api/Subject.js';\nexport default {\n  name: 'Notes',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      searchQuery: '',\n      selectedCategory: '',\n      sortBy: 'date',\n      showCreateModal: false,\n      showEditModal: false,\n      noteForm: {\n        id: null,\n        title: '',\n        content: '',\n        category: ''\n      },\n      notes: [],\n      filteredNotes: [],\n      categories: [],\n      loading: true,\n      error: null\n    };\n  },\n  async mounted() {\n    await this.loadNotesData();\n  },\n  methods: {\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    async loadNotesData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        this.userId = userId;\n\n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n\n        // Load categories from subjects\n        try {\n          const subjectsData = await getAllSubjects();\n          this.categories = subjectsData.map(subject => ({\n            id: subject._id,\n            name: subject.name,\n            icon: this.getSubjectIcon(subject.name),\n            noteCount: 0 // Will be calculated after loading notes\n          }));\n          // Add General category\n          this.categories.push({\n            id: 'general',\n            name: 'General',\n            icon: 'fas fa-bookmark',\n            noteCount: 0\n          });\n        } catch (error) {\n          console.warn('Could not load subjects for categories:', error);\n          // Fallback categories\n          this.categories = [{\n            id: 'general',\n            name: 'General',\n            icon: 'fas fa-bookmark',\n            noteCount: 0\n          }];\n        }\n\n        // Load notes from API\n        try {\n          const notesData = await getAllNotes();\n          this.notes = notesData.map(note => ({\n            id: note._id,\n            title: note.title,\n            content: note.content,\n            category: 'General',\n            // TODO: Add category field to note model\n            isFavorite: false,\n            // TODO: Add favorite field to note model\n            createdAt: new Date(note.date_created || note.createdAt),\n            updatedAt: new Date(note.date_updated || note.updatedAt)\n          }));\n\n          // Update category note counts\n          this.updateCategoryNoteCounts();\n        } catch (error) {\n          console.warn('Could not load notes:', error);\n          this.notes = [];\n        }\n        this.filteredNotes = [...this.notes];\n        this.sortNotes();\n      } catch (error) {\n        console.error('Error loading notes data:', error);\n        this.error = 'Failed to load notes';\n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    filterNotes() {\n      let filtered = [...this.notes];\n\n      // Filter by search query\n      if (this.searchQuery) {\n        const query = this.searchQuery.toLowerCase();\n        filtered = filtered.filter(note => note.title.toLowerCase().includes(query) || note.content.toLowerCase().includes(query));\n      }\n\n      // Filter by category\n      if (this.selectedCategory) {\n        filtered = filtered.filter(note => note.category === this.selectedCategory);\n      }\n      this.filteredNotes = filtered;\n      this.sortNotes();\n    },\n    sortNotes() {\n      this.filteredNotes.sort((a, b) => {\n        switch (this.sortBy) {\n          case 'title':\n            return a.title.localeCompare(b.title);\n          case 'category':\n            return a.category.localeCompare(b.category);\n          case 'date':\n          default:\n            return new Date(b.updatedAt) - new Date(a.updatedAt);\n        }\n      });\n    },\n    openNote(note) {\n      this.noteForm = {\n        id: note.id,\n        title: note.title,\n        content: note.content,\n        category: note.category\n      };\n      this.showEditModal = true;\n    },\n    getSubjectIcon(subjectName) {\n      const iconMap = {\n        'Mathematics': 'fas fa-calculator',\n        'Math': 'fas fa-calculator',\n        'Physics': 'fas fa-atom',\n        'Chemistry': 'fas fa-flask',\n        'Biology': 'fas fa-dna',\n        'Computer Science': 'fas fa-laptop-code',\n        'Programming': 'fas fa-code',\n        'History': 'fas fa-landmark',\n        'Geography': 'fas fa-globe',\n        'Literature': 'fas fa-book',\n        'English': 'fas fa-language',\n        'Art': 'fas fa-palette',\n        'Music': 'fas fa-music',\n        'Science': 'fas fa-microscope'\n      };\n\n      // Exact match\n      if (iconMap[subjectName]) {\n        return iconMap[subjectName];\n      }\n\n      // Partial match\n      const lowerName = subjectName.toLowerCase();\n      for (const [key, icon] of Object.entries(iconMap)) {\n        if (lowerName.includes(key.toLowerCase()) || key.toLowerCase().includes(lowerName)) {\n          return icon;\n        }\n      }\n      return 'fas fa-book'; // Default icon\n    },\n    updateCategoryNoteCounts() {\n      this.categories.forEach(category => {\n        category.noteCount = this.notes.filter(note => note.category === category.name).length;\n      });\n    },\n    closeModal() {\n      this.showCreateModal = false;\n      this.showEditModal = false;\n      this.noteForm = {\n        id: null,\n        title: '',\n        content: '',\n        category: ''\n      };\n    },\n    saveNote() {\n      if (!this.noteForm.title.trim() || !this.noteForm.content.trim()) {\n        alert('Please fill in both title and content');\n        return;\n      }\n      if (this.showEditModal) {\n        // Update existing note\n        const noteIndex = this.notes.findIndex(n => n.id === this.noteForm.id);\n        if (noteIndex !== -1) {\n          this.notes[noteIndex] = {\n            ...this.notes[noteIndex],\n            title: this.noteForm.title,\n            content: this.noteForm.content,\n            category: this.noteForm.category,\n            updatedAt: new Date()\n          };\n        }\n      } else {\n        // Create new note\n        const newNote = {\n          id: Date.now(),\n          title: this.noteForm.title,\n          content: this.noteForm.content,\n          category: this.noteForm.category || 'General',\n          isFavorite: false,\n          createdAt: new Date(),\n          updatedAt: new Date()\n        };\n        this.notes.unshift(newNote);\n\n        // Update category count\n        const category = this.categories.find(c => c.name === newNote.category);\n        if (category) {\n          category.noteCount++;\n        }\n      }\n      this.filterNotes();\n      this.closeModal();\n    },\n    deleteNote(noteId) {\n      if (confirm('Are you sure you want to delete this note?')) {\n        const noteIndex = this.notes.findIndex(n => n.id === noteId);\n        if (noteIndex !== -1) {\n          const note = this.notes[noteIndex];\n          this.notes.splice(noteIndex, 1);\n\n          // Update category count\n          const category = this.categories.find(c => c.name === note.category);\n          if (category && category.noteCount > 0) {\n            category.noteCount--;\n          }\n          this.filterNotes();\n        }\n      }\n    },\n    toggleFavorite(note) {\n      note.isFavorite = !note.isFavorite;\n    },\n    truncateContent(content) {\n      return content.length > 150 ? content.substring(0, 150) + '...' : content;\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString('en-US', {\n        month: 'short',\n        day: 'numeric',\n        year: 'numeric'\n      });\n    },\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["getAccount","getAllNotes","createNote","updateNote","deleteNote","getAllSubjects","name","data","userName","userLevel","userId","searchQuery","selectedCategory","sortBy","showCreateModal","showEditModal","noteForm","id","title","content","category","notes","filteredNotes","categories","loading","error","mounted","loadNotesData","methods","getUserIdFromToken","token","localStorage","getItem","payload","JSON","parse","atob","split","console","Error","accountData","username","currentLevel","subjectsData","map","subject","_id","icon","getSubjectIcon","noteCount","push","warn","notesData","note","isFavorite","createdAt","Date","date_created","updatedAt","date_updated","updateCategoryNoteCounts","sortNotes","message","includes","response","status","removeItem","$router","filterNotes","filtered","query","toLowerCase","filter","sort","a","b","localeCompare","openNote","subjectName","iconMap","lowerName","key","Object","entries","forEach","length","closeModal","saveNote","trim","alert","noteIndex","findIndex","n","newNote","now","unshift","find","c","noteId","confirm","splice","toggleFavorite","truncateContent","substring","formatDate","date","toLocaleDateString","month","day","year","logout"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Notes.vue"],"sourcesContent":["<template>\n  <div class=\"notes-container\">\n    <!-- Loading State -->\n    <div v-if=\"loading\" class=\"loading-container\">\n      <div class=\"loading-spinner\"><i class=\"fas fa-spinner fa-spin\"></i></div>\n      <p>Loading your notes...</p>\n    </div>\n    \n    <!-- Error State -->\n    <div v-else-if=\"error\" class=\"error-container\">\n      <div class=\"error-icon\"><i class=\"fas fa-exclamation-triangle\"></i></div>\n      <p>{{ error }}</p>\n      <button @click=\"loadNotesData\" class=\"retry-btn\">Try Again</button>\n    </div>\n    \n    <!-- Main Notes Content -->\n    <template v-else>\n      <!-- Sidebar -->\n      <div class=\"sidebar\">\n        <div class=\"sidebar-header\">\n          <div class=\"logo\">\n            <h2><i class=\"fas fa-star\"></i> Stardy</h2>\n          </div>\n          <router-link to=\"/profile\" class=\"nav-link\">\n          <div class=\"user-profile\">\n            <div class=\"avatar\">\n              <img src=\"https://via.placeholder.com/40\" alt=\"User Avatar\" />\n            </div>\n            <div class=\"user-info\">\n              <h4>{{ userName }}</h4>\n              <p>Level {{ userLevel }}</p>\n            </div>\n          </div>\n          </router-link>\n        </div>\n        \n        <nav class=\"sidebar-nav\">\n          <ul>\n            <li class=\"nav-item\">\n              <router-link to=\"/dashboard\" class=\"nav-link\">\n                <i class=\"icon fas fa-home\"></i>\n                <span>Dashboard</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/learning\" class=\"nav-link\">\n                <i class=\"icon fas fa-book\"></i>\n                <span>Learning</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/exams\" class=\"nav-link\">\n                <i class=\"icon fas fa-file-alt\"></i>\n                <span>Exams</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/subjects\" class=\"nav-link\">\n                <i class=\"icon fas fa-graduation-cap\"></i>\n                <span>Subjects</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/progress\" class=\"nav-link\">\n                <i class=\"icon fas fa-chart-line\"></i>\n                <span>Progress</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item active\">\n              <router-link to=\"/notes\" class=\"nav-link\">\n                <i class=\"icon fas fa-sticky-note\"></i>\n                <span>Notes</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/ai-tutor\" class=\"nav-link\">\n                <i class=\"icon fas fa-robot\"></i>\n                <span>AI Tutor</span>\n              </router-link>\n            </li>\n          </ul>\n        </nav>\n        \n        <div class=\"sidebar-footer\">\n          <button @click=\"logout\" class=\"logout-btn\">\n            <i class=\"icon fas fa-sign-out-alt\"></i>\n            <span>Logout</span>\n          </button>\n        </div>\n      </div>\n      \n      <!-- Main Content -->\n      <div class=\"main-content\">\n        <header class=\"notes-header\">\n          <div class=\"header-content\">\n            <h1><i class=\"fas fa-sticky-note\"></i> My Notes</h1>\n            <p>Organize and manage your study notes</p>\n          </div>\n          <div class=\"header-actions\">\n            <button @click=\"showCreateModal = true\" class=\"create-note-btn\">\n              <i class=\"fas fa-plus\"></i> New Note\n            </button>\n          </div>\n        </header>\n        \n        <!-- Search and Filter Bar -->\n        <div class=\"search-filter-bar\">\n          <div class=\"search-box\">\n            <i class=\"fas fa-search\"></i>\n            <input \n              v-model=\"searchQuery\" \n              type=\"text\" \n              placeholder=\"Search notes...\"\n              @input=\"filterNotes\"\n            >\n          </div>\n          <div class=\"filter-options\">\n            <select v-model=\"selectedCategory\" @change=\"filterNotes\" class=\"category-filter\">\n              <option value=\"\">All Categories</option>\n              <option v-for=\"category in categories\" :key=\"category.id\" :value=\"category.name\">\n                {{ category.name }}\n              </option>\n            </select>\n            <select v-model=\"sortBy\" @change=\"sortNotes\" class=\"sort-filter\">\n              <option value=\"date\">Sort by Date</option>\n              <option value=\"title\">Sort by Title</option>\n              <option value=\"category\">Sort by Category</option>\n            </select>\n          </div>\n        </div>\n        \n        <!-- Notes Grid -->\n        <div class=\"notes-section\">\n          <div v-if=\"filteredNotes.length === 0\" class=\"empty-state\">\n            <i class=\"fas fa-sticky-note\"></i>\n            <h3>No notes found</h3>\n            <p>{{ searchQuery ? 'Try adjusting your search criteria' : 'Create your first note to get started!' }}</p>\n          </div>\n          \n          <div v-else class=\"notes-grid\">\n            <div \n              v-for=\"note in filteredNotes\" \n              :key=\"note.id\" \n              class=\"note-card\"\n              @click=\"openNote(note)\"\n            >\n              <div class=\"note-header\">\n                <h3>{{ note.title }}</h3>\n                <div class=\"note-actions\">\n                  <button @click.stop=\"toggleFavorite(note)\" class=\"favorite-btn\">\n                    <i :class=\"note.isFavorite ? 'fas fa-heart' : 'far fa-heart'\"></i>\n                  </button>\n                  <button @click.stop=\"deleteNote(note.id)\" class=\"delete-btn\">\n                    <i class=\"fas fa-trash\"></i>\n                  </button>\n                </div>\n              </div>\n              <div class=\"note-content\">\n                <p>{{ truncateContent(note.content) }}</p>\n              </div>\n              <div class=\"note-footer\">\n                <span class=\"note-category\">{{ note.category }}</span>\n                <span class=\"note-date\">{{ formatDate(note.updatedAt) }}</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- Categories Section -->\n        <div class=\"categories-section\">\n          <h2><i class=\"fas fa-tags\"></i> Categories</h2>\n          <div class=\"categories-grid\">\n            <div v-for=\"category in categories\" :key=\"category.id\" class=\"category-card\">\n              <div class=\"category-icon\">\n                <i :class=\"category.icon\"></i>\n              </div>\n              <div class=\"category-info\">\n                <h4>{{ category.name }}</h4>\n                <p>{{ category.noteCount }} notes</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </template>\n    \n    <!-- Create/Edit Note Modal -->\n    <div v-if=\"showCreateModal || showEditModal\" class=\"modal-overlay\" @click=\"closeModal\">\n      <div class=\"modal-content\" @click.stop>\n        <div class=\"modal-header\">\n          <h3>\n            <i class=\"fas fa-sticky-note\"></i>\n            {{ showEditModal ? 'Edit Note' : 'Create New Note' }}\n          </h3>\n          <button @click=\"closeModal\" class=\"close-btn\">\n            <i class=\"fas fa-times\"></i>\n          </button>\n        </div>\n        <div class=\"modal-body\">\n          <div class=\"form-group\">\n            <label>Title</label>\n            <input v-model=\"noteForm.title\" type=\"text\" placeholder=\"Enter note title...\">\n          </div>\n          <div class=\"form-group\">\n            <label>Category</label>\n            <select v-model=\"noteForm.category\">\n              <option value=\"\">Select category</option>\n              <option v-for=\"category in categories\" :key=\"category.id\" :value=\"category.name\">\n                {{ category.name }}\n              </option>\n            </select>\n          </div>\n          <div class=\"form-group\">\n            <label>Content</label>\n            <textarea \n              v-model=\"noteForm.content\" \n              placeholder=\"Write your note here...\"\n              rows=\"10\"\n            ></textarea>\n          </div>\n        </div>\n        <div class=\"modal-footer\">\n          <button @click=\"closeModal\" class=\"cancel-btn\">Cancel</button>\n          <button @click=\"saveNote\" class=\"save-btn\">\n            <i class=\"fas fa-save\"></i>\n            {{ showEditModal ? 'Update Note' : 'Create Note' }}\n          </button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { getAccount } from '../api/Account.js';\nimport { getAllNotes, createNote, updateNote, deleteNote } from '../api/Note.js';\nimport { getAllSubjects } from '../api/Subject.js';\n\nexport default {\n  name: 'Notes',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      searchQuery: '',\n      selectedCategory: '',\n      sortBy: 'date',\n      showCreateModal: false,\n      showEditModal: false,\n      noteForm: {\n        id: null,\n        title: '',\n        content: '',\n        category: ''\n      },\n      notes: [],\n      filteredNotes: [],\n      categories: [],\n      loading: true,\n      error: null\n    }\n  },\n  async mounted() {\n    await this.loadNotesData();\n  },\n  methods: {\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    \n    async loadNotesData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        \n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        \n        this.userId = userId;\n        \n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n        \n        // Load categories from subjects\n        try {\n          const subjectsData = await getAllSubjects();\n          this.categories = subjectsData.map(subject => ({\n            id: subject._id,\n            name: subject.name,\n            icon: this.getSubjectIcon(subject.name),\n            noteCount: 0 // Will be calculated after loading notes\n          }));\n          // Add General category\n          this.categories.push({\n            id: 'general',\n            name: 'General',\n            icon: 'fas fa-bookmark',\n            noteCount: 0\n          });\n        } catch (error) {\n          console.warn('Could not load subjects for categories:', error);\n          // Fallback categories\n          this.categories = [\n            { id: 'general', name: 'General', icon: 'fas fa-bookmark', noteCount: 0 }\n          ];\n        }\n        \n        // Load notes from API\n        try {\n          const notesData = await getAllNotes();\n          this.notes = notesData.map(note => ({\n            id: note._id,\n            title: note.title,\n            content: note.content,\n            category: 'General', // TODO: Add category field to note model\n            isFavorite: false, // TODO: Add favorite field to note model\n            createdAt: new Date(note.date_created || note.createdAt),\n            updatedAt: new Date(note.date_updated || note.updatedAt)\n          }));\n          \n          // Update category note counts\n          this.updateCategoryNoteCounts();\n        } catch (error) {\n          console.warn('Could not load notes:', error);\n          this.notes = [];\n        }\n        \n        this.filteredNotes = [...this.notes];\n        this.sortNotes();\n        \n      } catch (error) {\n        console.error('Error loading notes data:', error);\n        this.error = 'Failed to load notes';\n        \n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    \n    filterNotes() {\n      let filtered = [...this.notes];\n      \n      // Filter by search query\n      if (this.searchQuery) {\n        const query = this.searchQuery.toLowerCase();\n        filtered = filtered.filter(note => \n          note.title.toLowerCase().includes(query) ||\n          note.content.toLowerCase().includes(query)\n        );\n      }\n      \n      // Filter by category\n      if (this.selectedCategory) {\n        filtered = filtered.filter(note => note.category === this.selectedCategory);\n      }\n      \n      this.filteredNotes = filtered;\n      this.sortNotes();\n    },\n    \n    sortNotes() {\n      this.filteredNotes.sort((a, b) => {\n        switch (this.sortBy) {\n          case 'title':\n            return a.title.localeCompare(b.title);\n          case 'category':\n            return a.category.localeCompare(b.category);\n          case 'date':\n          default:\n            return new Date(b.updatedAt) - new Date(a.updatedAt);\n        }\n      });\n    },\n    \n    openNote(note) {\n      this.noteForm = {\n        id: note.id,\n        title: note.title,\n        content: note.content,\n        category: note.category\n      };\n      this.showEditModal = true;\n    },\n    \n    getSubjectIcon(subjectName) {\n      const iconMap = {\n        'Mathematics': 'fas fa-calculator',\n        'Math': 'fas fa-calculator',\n        'Physics': 'fas fa-atom',\n        'Chemistry': 'fas fa-flask',\n        'Biology': 'fas fa-dna',\n        'Computer Science': 'fas fa-laptop-code',\n        'Programming': 'fas fa-code',\n        'History': 'fas fa-landmark',\n        'Geography': 'fas fa-globe',\n        'Literature': 'fas fa-book',\n        'English': 'fas fa-language',\n        'Art': 'fas fa-palette',\n        'Music': 'fas fa-music',\n        'Science': 'fas fa-microscope'\n      };\n      \n      // Exact match\n      if (iconMap[subjectName]) {\n        return iconMap[subjectName];\n      }\n      \n      // Partial match\n      const lowerName = subjectName.toLowerCase();\n      for (const [key, icon] of Object.entries(iconMap)) {\n        if (lowerName.includes(key.toLowerCase()) || key.toLowerCase().includes(lowerName)) {\n          return icon;\n        }\n      }\n      \n      return 'fas fa-book'; // Default icon\n    },\n    \n    updateCategoryNoteCounts() {\n      this.categories.forEach(category => {\n        category.noteCount = this.notes.filter(note => note.category === category.name).length;\n      });\n    },\n    \n    closeModal() {\n      this.showCreateModal = false;\n      this.showEditModal = false;\n      this.noteForm = {\n        id: null,\n        title: '',\n        content: '',\n        category: ''\n      };\n    },\n    \n    saveNote() {\n      if (!this.noteForm.title.trim() || !this.noteForm.content.trim()) {\n        alert('Please fill in both title and content');\n        return;\n      }\n      \n      if (this.showEditModal) {\n        // Update existing note\n        const noteIndex = this.notes.findIndex(n => n.id === this.noteForm.id);\n        if (noteIndex !== -1) {\n          this.notes[noteIndex] = {\n            ...this.notes[noteIndex],\n            title: this.noteForm.title,\n            content: this.noteForm.content,\n            category: this.noteForm.category,\n            updatedAt: new Date()\n          };\n        }\n      } else {\n        // Create new note\n        const newNote = {\n          id: Date.now(),\n          title: this.noteForm.title,\n          content: this.noteForm.content,\n          category: this.noteForm.category || 'General',\n          isFavorite: false,\n          createdAt: new Date(),\n          updatedAt: new Date()\n        };\n        this.notes.unshift(newNote);\n        \n        // Update category count\n        const category = this.categories.find(c => c.name === newNote.category);\n        if (category) {\n          category.noteCount++;\n        }\n      }\n      \n      this.filterNotes();\n      this.closeModal();\n    },\n    \n    deleteNote(noteId) {\n      if (confirm('Are you sure you want to delete this note?')) {\n        const noteIndex = this.notes.findIndex(n => n.id === noteId);\n        if (noteIndex !== -1) {\n          const note = this.notes[noteIndex];\n          this.notes.splice(noteIndex, 1);\n          \n          // Update category count\n          const category = this.categories.find(c => c.name === note.category);\n          if (category && category.noteCount > 0) {\n            category.noteCount--;\n          }\n          \n          this.filterNotes();\n        }\n      }\n    },\n    \n    toggleFavorite(note) {\n      note.isFavorite = !note.isFavorite;\n    },\n    \n    truncateContent(content) {\n      return content.length > 150 ? content.substring(0, 150) + '...' : content;\n    },\n    \n    formatDate(date) {\n      return new Date(date).toLocaleDateString('en-US', {\n        month: 'short',\n        day: 'numeric',\n        year: 'numeric'\n      });\n    },\n    \n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n}\n</script>\n\n<style scoped>\n.notes-container {\n  display: flex;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n}\n\n/* Sidebar Styles */\n.sidebar {\n  width: 280px;\n  background: rgba(255, 255, 255, 0.1);\n  backdrop-filter: blur(10px);\n  border-right: 1px solid rgba(255, 255, 255, 0.2);\n  display: flex;\n  flex-direction: column;\n  position: fixed;\n  height: 100vh;\n  overflow-y: auto;\n}\n\n.sidebar-header {\n  padding: 2rem 1.5rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.logo h2 {\n  color: white;\n  margin: 0 0 1.5rem 0;\n  font-size: 1.5rem;\n  font-weight: bold;\n}\n\n/* Clean Profile Styles - Remove Outer Layer */\n.user-profile {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  padding: 0; /* Remove padding to eliminate outer layer */\n  background: none; /* Remove background */\n  border: none; /* Remove any borders */\n  border-radius: 0; /* Remove border radius */\n  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  cursor: pointer;\n  position: relative;\n  overflow: visible; /* Change from hidden to visible */\n}\n\n/* Remove the background overlay */\n.user-profile::before {\n  display: none; /* Completely remove the background effect */\n}\n\n/* Remove the shine effect */\n.user-profile::after {\n  display: none; /* Remove the sweep animation */\n}\n\n/* Keep enhanced avatar hover effect */\n.avatar {\n  position: relative;\n  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  z-index: 2;\n}\n\n.avatar::before {\n  content: '';\n  position: absolute;\n  top: -3px;\n  left: -3px;\n  right: -3px;\n  bottom: -3px;\n  background: linear-gradient(45deg, rgba(255