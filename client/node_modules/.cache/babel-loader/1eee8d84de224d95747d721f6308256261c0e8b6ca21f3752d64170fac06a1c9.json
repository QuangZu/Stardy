{"ast":null,"code":"import AdminSidebar from '@/components/admin/AdminSidebar.vue';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport { useNotification } from '@/composables/useNotification';\nimport { getAllSubjects, getSubjectCategories, createSubject, updateSubject, deleteSubject } from '@/api/Subject.js';\nexport default {\n  name: 'SubjectsAdmin',\n  components: {\n    AdminSidebar,\n    AdminHeader\n  },\n  setup() {\n    const {\n      showSuccess,\n      showError,\n      showInfo,\n      showWarning\n    } = useNotification();\n    return {\n      showSuccess,\n      showError,\n      showInfo,\n      showWarning\n    };\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      subjects: [],\n      categories: [],\n      searchQuery: '',\n      showCreateSubjectModal: false,\n      showEditSubjectModal: false,\n      showDeleteModal: false,\n      subjectToDeleteId: null,\n      newSubject: {\n        name: '',\n        category: '',\n        icon: 'fas fa-book',\n        description: ''\n      },\n      editingSubject: {\n        _id: '',\n        name: '',\n        category: '',\n        icon: '',\n        description: ''\n      }\n    };\n  },\n  computed: {\n    filteredSubjects() {\n      if (!this.searchQuery) return this.subjects || [];\n      return (this.subjects || []).filter(subject => (subject.name || '').toLowerCase().includes(this.searchQuery.toLowerCase()) || (subject.category || '').toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchSubjects();\n    this.fetchCategories();\n  },\n  methods: {\n    async fetchSubjects() {\n      try {\n        const response = await getAllSubjects();\n        this.subjects = response.data || response || [];\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n        this.showError('Error', 'Failed to fetch subjects. Please try again.');\n        this.subjects = [];\n      }\n    },\n    async fetchCategories() {\n      try {\n        this.categories = await getSubjectCategories();\n      } catch (error) {\n        console.error('Error fetching categories:', error);\n        this.showWarning('Warning', 'Failed to fetch categories. Using default values.');\n        // Default categories as fallback\n        this.categories = [{\n          value: 'primary',\n          label: 'Primary'\n        }, {\n          value: 'secondary',\n          label: 'Secondary'\n        }, {\n          value: 'senior secondary',\n          label: 'Senior Secondary'\n        }, {\n          value: 'university',\n          label: 'University'\n        }, {\n          value: 'special',\n          label: 'Special'\n        }];\n      }\n    },\n    getCategoryLabel(categoryValue) {\n      const category = this.categories.find(c => c.value === categoryValue);\n      return category ? category.label : categoryValue || 'Unknown';\n    },\n    async createSubject() {\n      try {\n        await createSubject(this.newSubject);\n        await this.fetchSubjects();\n        this.showCreateSubjectModal = false;\n        this.newSubject = {\n          name: '',\n          category: '',\n          icon: 'fas fa-book',\n          description: ''\n        };\n        this.showSuccess('Success', 'Subject created successfully!');\n      } catch (error) {\n        console.error('Error creating subject:', error);\n        this.showError('Error', 'Failed to create subject. Please try again.');\n      }\n    },\n    editSubject(subject) {\n      this.editingSubject = {\n        ...subject\n      };\n      this.showEditSubjectModal = true;\n    },\n    async updateSubject() {\n      try {\n        await updateSubject(this.editingSubject._id, this.editingSubject);\n        await this.fetchSubjects();\n        this.showEditSubjectModal = false;\n        this.showSuccess('Success', 'Subject updated successfully!');\n      } catch (error) {\n        console.error('Error updating subject:', error);\n        this.showError('Error', 'Failed to update subject. Please try again.');\n      }\n    },\n    confirmDeleteSubject(subjectId) {\n      this.subjectToDeleteId = subjectId;\n      this.showDeleteModal = true;\n    },\n    async deleteSubject() {\n      try {\n        await deleteSubject(this.subjectToDeleteId);\n        await this.fetchSubjects();\n        this.showDeleteModal = false;\n        this.subjectToDeleteId = null;\n        this.showSuccess('Success', 'Subject deleted successfully!');\n      } catch (error) {\n        console.error('Error deleting subject:', error);\n        this.showError('Error', 'Failed to delete subject. Please try again.');\n      }\n    },\n    formatDate(timestamp) {\n      if (!timestamp) return 'N/A';\n      return new Date(timestamp).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminSidebar","AdminHeader","useNotification","getAllSubjects","getSubjectCategories","createSubject","updateSubject","deleteSubject","name","components","setup","showSuccess","showError","showInfo","showWarning","data","currentUser","JSON","parse","localStorage","getItem","subjects","categories","searchQuery","showCreateSubjectModal","showEditSubjectModal","showDeleteModal","subjectToDeleteId","newSubject","category","icon","description","editingSubject","_id","computed","filteredSubjects","filter","subject","toLowerCase","includes","mounted","fetchSubjects","fetchCategories","methods","response","error","console","value","label","getCategoryLabel","categoryValue","find","c","editSubject","confirmDeleteSubject","subjectId","formatDate","timestamp","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\SubjectsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-page\">\r\n    <!-- Sidebar -->\r\n    <AdminSidebar />\r\n    \r\n    <!-- Header -->\r\n    <AdminHeader \r\n      title=\"Subjects\" \r\n      icon-class=\"fas fa-book\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n\r\n    <!-- Main Content -->\r\n    <main class=\"admin-content\">\r\n      <div class=\"p-6\">\r\n        <!-- Header Section -->\r\n        <div class=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6\">\r\n          <div>\r\n            <h1 class=\"text-section-header text-gray-900\">Subject Management</h1>\r\n            <p class=\"text-body text-gray-600 mt-1\">Create and manage subjects</p>\r\n          </div>\r\n          <div class=\"flex flex-col sm:flex-row gap-3\">\r\n            <div class=\"relative\">\r\n              <input\r\n                v-model=\"searchQuery\"\r\n                type=\"text\"\r\n                placeholder=\"Search subjects...\"\r\n                class=\"w-full sm:w-64 pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent text-body\"\r\n              >\r\n              <i class=\"fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400\"></i>\r\n            </div>\r\n            <button\r\n              @click=\"showCreateSubjectModal = true\"\r\n              class=\"btn-primary flex items-center gap-2\"\r\n            >\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add Subject\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- Subjects Table -->\r\n        <div class=\"chart-container overflow-hidden\">\r\n          <div class=\"overflow-x-auto\">\r\n            <table class=\"w-full\">\r\n              <thead class=\"bg-gray-50\">\r\n                <tr>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Subject</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Category</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Icon</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Created</th>\r\n                  <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 uppercase tracking-wider\">Actions</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody class=\"bg-white divide-y divide-gray-200\">\r\n                <tr v-for=\"subject in filteredSubjects\" :key=\"subject._id\" class=\"hover:bg-gray-50 transition-colors duration-150\">\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"flex items-center\">\r\n                      <div class=\"w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3\">\r\n                        <i :class=\"subject.icon || 'fas fa-book'\" class=\"text-blue-600\"></i>\r\n                      </div>\r\n                      <div>\r\n                        <div class=\"text-body font-medium text-gray-900\">{{ subject.name || 'N/A' }}</div>\r\n                        <div class=\"text-small text-gray-500\">ID: {{ subject._id ? subject._id.slice(-6) : 'N/A' }}</div>\r\n                      </div>\r\n                    </div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"text-body text-gray-900\">{{ getCategoryLabel(subject.category) }}</div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"text-body text-gray-900\">\r\n                      <i :class=\"subject.icon || 'fas fa-book'\" class=\"text-blue-600\"></i>\r\n                      <span class=\"ml-2\">{{ subject.icon || 'fas fa-book' }}</span>\r\n                    </div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                    <div class=\"text-body text-gray-900\">{{ formatDate(subject.createdAt) }}</div>\r\n                  </td>\r\n                  <td class=\"px-6 py-4 whitespace-nowrap text-body font-medium\">\r\n                    <div class=\"flex space-x-2\">\r\n                      <button\r\n                        @click=\"editSubject(subject)\"\r\n                        class=\"text-primary hover:text-blue-900 transition-colors duration-150\"\r\n                        title=\"Edit Subject\"\r\n                      >\r\n                        <i class=\"fas fa-edit\"></i>\r\n                      </button>\r\n                      <button\r\n                        @click=\"confirmDeleteSubject(subject._id)\"\r\n                        class=\"text-error hover:text-red-900 transition-colors duration-150\"\r\n                        title=\"Delete Subject\"\r\n                      >\r\n                        <i class=\"fas fa-trash\"></i>\r\n                      </button>\r\n                    </div>\r\n                  </td>\r\n                </tr>\r\n                <tr v-if=\"filteredSubjects.length === 0\">\r\n                  <td colspan=\"5\" class=\"px-6 py-4 text-center text-gray-500\">\r\n                    No subjects found. Create a new subject to get started.\r\n                  </td>\r\n                </tr>\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </main>\r\n\r\n    <!-- Create Subject Modal -->\r\n    <div v-if=\"showCreateSubjectModal\" class=\"modal-overlay\" @click=\"showCreateSubjectModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Create New Subject</h3>\r\n          <button @click=\"showCreateSubjectModal = false\" class=\"modal-close\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <form @submit.prevent=\"createSubject\">\r\n            <div class=\"form-group\">\r\n              <label for=\"subjectName\">Subject Name</label>\r\n              <input id=\"subjectName\" v-model=\"newSubject.name\" type=\"text\" class=\"form-input\" required>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"subjectCategory\">Category</label>\r\n              <select id=\"subjectCategory\" v-model=\"newSubject.category\" class=\"form-input\" required>\r\n                <option value=\"\" disabled>Select a category</option>\r\n                <option v-for=\"category in categories\" :key=\"category.value\" :value=\"category.value\">\r\n                  {{ category.label }}\r\n                </option>\r\n              </select>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"subjectIcon\">Icon (FontAwesome class)</label>\r\n              <input id=\"subjectIcon\" v-model=\"newSubject.icon\" type=\"text\" class=\"form-input\" placeholder=\"fas fa-book\">\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"subjectDescription\">Description</label>\r\n              <textarea id=\"subjectDescription\" v-model=\"newSubject.description\" class=\"form-textarea\"></textarea>\r\n            </div>\r\n          </form>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showCreateSubjectModal = false\" class=\"btn-secondary\">Cancel</button>\r\n          <button @click=\"createSubject\" class=\"btn-primary\">Create Subject</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Edit Subject Modal -->\r\n    <div v-if=\"showEditSubjectModal\" class=\"modal-overlay\" @click=\"showEditSubjectModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Edit Subject</h3>\r\n          <button @click=\"showEditSubjectModal = false\" class=\"modal-close\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <form @submit.prevent=\"updateSubject\">\r\n            <div class=\"form-group\">\r\n              <label for=\"editSubjectName\">Subject Name</label>\r\n              <input id=\"editSubjectName\" v-model=\"editingSubject.name\" type=\"text\" class=\"form-input\" required>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"editSubjectCategory\">Category</label>\r\n              <select id=\"editSubjectCategory\" v-model=\"editingSubject.category\" class=\"form-input\" required>\r\n                <option value=\"\" disabled>Select a category</option>\r\n                <option v-for=\"category in categories\" :key=\"category.value\" :value=\"category.value\">\r\n                  {{ category.label }}\r\n                </option>\r\n              </select>\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"editSubjectIcon\">Icon (FontAwesome class)</label>\r\n              <input id=\"editSubjectIcon\" v-model=\"editingSubject.icon\" type=\"text\" class=\"form-input\" placeholder=\"fas fa-book\">\r\n            </div>\r\n            <div class=\"form-group\">\r\n              <label for=\"editSubjectDescription\">Description</label>\r\n              <textarea id=\"editSubjectDescription\" v-model=\"editingSubject.description\" class=\"form-textarea\"></textarea>\r\n            </div>\r\n          </form>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showEditSubjectModal = false\" class=\"btn-secondary\">Cancel</button>\r\n          <button @click=\"updateSubject\" class=\"btn-primary\">Update Subject</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Delete Confirmation Modal -->\r\n    <div v-if=\"showDeleteModal\" class=\"modal-overlay\" @click=\"showDeleteModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Confirm Delete</h3>\r\n          <button @click=\"showDeleteModal = false\" class=\"modal-close\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <p class=\"text-body text-gray-700 mb-4\">Are you sure you want to delete this subject? This action cannot be undone.</p>\r\n          <p class=\"text-small text-error\">Warning: Deleting a subject will also remove all associated exams and questions.</p>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showDeleteModal = false\" class=\"btn-secondary\">Cancel</button>\r\n          <button @click=\"deleteSubject\" class=\"btn-primary bg-error hover:bg-red-700\">Delete Subject</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AdminSidebar from '@/components/admin/AdminSidebar.vue'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\nimport { useNotification } from '@/composables/useNotification'\r\nimport { getAllSubjects, getSubjectCategories, createSubject, updateSubject, deleteSubject } from '@/api/Subject.js'\r\n\r\nexport default {\r\n  name: 'SubjectsAdmin',\r\n  components: {\r\n    AdminSidebar,\r\n    AdminHeader\r\n  },\r\n  setup() {\r\n    const { showSuccess, showError, showInfo, showWarning } = useNotification()\r\n    return {\r\n      showSuccess,\r\n      showError,\r\n      showInfo,\r\n      showWarning\r\n    }\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      subjects: [],\r\n      categories: [],\r\n      searchQuery: '',\r\n      showCreateSubjectModal: false,\r\n      showEditSubjectModal: false,\r\n      showDeleteModal: false,\r\n      subjectToDeleteId: null,\r\n      newSubject: {\r\n        name: '',\r\n        category: '',\r\n        icon: 'fas fa-book',\r\n        description: ''\r\n      },\r\n      editingSubject: {\r\n        _id: '',\r\n        name: '',\r\n        category: '',\r\n        icon: '',\r\n        description: ''\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredSubjects() {\r\n      if (!this.searchQuery) return this.subjects || []\r\n      return (this.subjects || []).filter(subject => \r\n        (subject.name || '').toLowerCase().includes(this.searchQuery.toLowerCase()) ||\r\n        (subject.category || '').toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchSubjects()\r\n    this.fetchCategories()\r\n  },\r\n  methods: {\r\n    async fetchSubjects() {\r\n      try {\r\n        const response = await getAllSubjects()\r\n        this.subjects = response.data || response || []\r\n      } catch (error) {\r\n        console.error('Error fetching subjects:', error)\r\n        this.showError('Error', 'Failed to fetch subjects. Please try again.')\r\n        this.subjects = []\r\n      }\r\n    },\r\n    async fetchCategories() {\r\n      try {\r\n        this.categories = await getSubjectCategories()\r\n      } catch (error) {\r\n        console.error('Error fetching categories:', error)\r\n        this.showWarning('Warning', 'Failed to fetch categories. Using default values.')\r\n        // Default categories as fallback\r\n        this.categories = [\r\n          { value: 'primary', label: 'Primary' },\r\n          { value: 'secondary', label: 'Secondary' },\r\n          { value: 'senior secondary', label: 'Senior Secondary' },\r\n          { value: 'university', label: 'University' },\r\n          { value: 'special', label: 'Special' }\r\n        ]\r\n      }\r\n    },\r\n    getCategoryLabel(categoryValue) {\r\n      const category = this.categories.find(c => c.value === categoryValue)\r\n      return category ? category.label : categoryValue || 'Unknown'\r\n    },\r\n    async createSubject() {\r\n      try {\r\n        await createSubject(this.newSubject)\r\n        await this.fetchSubjects()\r\n        this.showCreateSubjectModal = false\r\n        this.newSubject = { name: '', category: '', icon: 'fas fa-book', description: '' }\r\n        this.showSuccess('Success', 'Subject created successfully!')\r\n      } catch (error) {\r\n        console.error('Error creating subject:', error)\r\n        this.showError('Error', 'Failed to create subject. Please try again.')\r\n      }\r\n    },\r\n    editSubject(subject) {\r\n      this.editingSubject = { ...subject }\r\n      this.showEditSubjectModal = true\r\n    },\r\n    async updateSubject() {\r\n      try {\r\n        await updateSubject(this.editingSubject._id, this.editingSubject)\r\n        await this.fetchSubjects()\r\n        this.showEditSubjectModal = false\r\n        this.showSuccess('Success', 'Subject updated successfully!')\r\n      } catch (error) {\r\n        console.error('Error updating subject:', error)\r\n        this.showError('Error', 'Failed to update subject. Please try again.')\r\n      }\r\n    },\r\n    confirmDeleteSubject(subjectId) {\r\n      this.subjectToDeleteId = subjectId\r\n      this.showDeleteModal = true\r\n    },\r\n    async deleteSubject() {\r\n      try {\r\n        await deleteSubject(this.subjectToDeleteId)\r\n        await this.fetchSubjects()\r\n        this.showDeleteModal = false\r\n        this.subjectToDeleteId = null\r\n        this.showSuccess('Success', 'Subject deleted successfully!')\r\n      } catch (error) {\r\n        console.error('Error deleting subject:', error)\r\n        this.showError('Error', 'Failed to delete subject. Please try again.')\r\n      }\r\n    },\r\n    formatDate(timestamp) {\r\n      if (!timestamp) return 'N/A'\r\n      return new Date(timestamp).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@import '@/styles/admin/admin-modal.css';\r\n@import '@/styles/admin/design-system.css';\r\n</style>"],"mappings":"AAwNA,OAAOA,YAAW,MAAO,qCAAoC;AAC7D,OAAOC,WAAU,MAAO,oCAAmC;AAC3D,SAASC,eAAc,QAAS,+BAA8B;AAC9D,SAASC,cAAc,EAAEC,oBAAoB,EAAEC,aAAa,EAAEC,aAAa,EAAEC,aAAY,QAAS,kBAAiB;AAEnH,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACVT,YAAY;IACZC;EACF,CAAC;EACDS,KAAKA,CAAA,EAAG;IACN,MAAM;MAAEC,WAAW;MAAEC,SAAS;MAAEC,QAAQ;MAAEC;IAAY,IAAIZ,eAAe,CAAC;IAC1E,OAAO;MACLS,WAAW;MACXC,SAAS;MACTC,QAAQ;MACRC;IACF;EACF,CAAC;EACDC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,QAAQ,EAAE,EAAE;MACZC,UAAU,EAAE,EAAE;MACdC,WAAW,EAAE,EAAE;MACfC,sBAAsB,EAAE,KAAK;MAC7BC,oBAAoB,EAAE,KAAK;MAC3BC,eAAe,EAAE,KAAK;MACtBC,iBAAiB,EAAE,IAAI;MACvBC,UAAU,EAAE;QACVpB,IAAI,EAAE,EAAE;QACRqB,QAAQ,EAAE,EAAE;QACZC,IAAI,EAAE,aAAa;QACnBC,WAAW,EAAE;MACf,CAAC;MACDC,cAAc,EAAE;QACdC,GAAG,EAAE,EAAE;QACPzB,IAAI,EAAE,EAAE;QACRqB,QAAQ,EAAE,EAAE;QACZC,IAAI,EAAE,EAAE;QACRC,WAAW,EAAE;MACf;IACF;EACF,CAAC;EACDG,QAAQ,EAAE;IACRC,gBAAgBA,CAAA,EAAG;MACjB,IAAI,CAAC,IAAI,CAACZ,WAAW,EAAE,OAAO,IAAI,CAACF,QAAO,IAAK,EAAC;MAChD,OAAO,CAAC,IAAI,CAACA,QAAO,IAAK,EAAE,EAAEe,MAAM,CAACC,OAAM,IACxC,CAACA,OAAO,CAAC7B,IAAG,IAAK,EAAE,EAAE8B,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAAChB,WAAW,CAACe,WAAW,CAAC,CAAC,KAC1E,CAACD,OAAO,CAACR,QAAO,IAAK,EAAE,EAAES,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAAChB,WAAW,CAACe,WAAW,CAAC,CAAC,CAChF;IACF;EACF,CAAC;EACDE,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,aAAa,CAAC;IACnB,IAAI,CAACC,eAAe,CAAC;EACvB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMF,aAAaA,CAAA,EAAG;MACpB,IAAI;QACF,MAAMG,QAAO,GAAI,MAAMzC,cAAc,CAAC;QACtC,IAAI,CAACkB,QAAO,GAAIuB,QAAQ,CAAC7B,IAAG,IAAK6B,QAAO,IAAK,EAAC;MAChD,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,0BAA0B,EAAEA,KAAK;QAC/C,IAAI,CAACjC,SAAS,CAAC,OAAO,EAAE,6CAA6C;QACrE,I