{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/web.dom-exception.stack.js\";\nimport { getAccount } from '../api/Account.js';\nimport { getUserProgress } from '../api/UserProgress.js';\nimport { getAllSubjects } from '../api/Subject.js';\nimport { getAchievements } from '../api/Achievement.js';\nexport default {\n  name: 'Progress',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      selectedTimeframe: 'week',\n      progressStats: {\n        totalXP: 0,\n        xpThisWeek: 0,\n        currentStreak: 0,\n        streakStatus: 'Keep it up!',\n        totalStudyTime: 0,\n        studyTimeThisWeek: 0,\n        completedLessons: 0,\n        completionRate: 0\n      },\n      subjectProgress: [],\n      recentAchievements: [],\n      learningGoals: [],\n      loading: true,\n      error: null\n    };\n  },\n  async mounted() {\n    await this.loadProgressData();\n  },\n  methods: {\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    async loadProgressData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        this.userId = userId;\n\n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n\n        // Load progress statistics from UserProgress API\n        try {\n          const progressData = await getUserProgress(userId);\n          this.progressStats = {\n            totalXP: accountData.experience || 0,\n            xpThisWeek: progressData.weeklyXP || 0,\n            currentStreak: progressData.studyStreak || 0,\n            streakStatus: progressData.studyStreak > 0 ? 'Keep it up!' : 'Start your streak!',\n            totalStudyTime: progressData.totalStudyTime || 0,\n            studyTimeThisWeek: progressData.weeklyStudyTime || 0,\n            completedLessons: accountData.completedQuestions?.length || 0,\n            completionRate: progressData.completionRate || 0\n          };\n        } catch (error) {\n          console.warn('Could not load user progress data:', error);\n          this.progressStats = {\n            totalXP: accountData.experience || 0,\n            xpThisWeek: 0,\n            currentStreak: 0,\n            streakStatus: 'Start your streak!',\n            totalStudyTime: 0,\n            studyTimeThisWeek: 0,\n            completedLessons: 0,\n            completionRate: 0\n          };\n        }\n\n        // Load subject progress from API\n        try {\n          const subjectsData = await getAllSubjects();\n          this.subjectProgress = subjectsData.map(subject => ({\n            id: subject._id,\n            name: subject.name,\n            icon: this.getSubjectIcon(subject.name),\n            progress: Math.floor(Math.random() * 100) // TODO: Calculate actual progress from user data\n          }));\n        } catch (error) {\n          console.warn('Could not load subjects for progress:', error);\n          this.subjectProgress = [];\n        }\n\n        // Load recent achievements from API\n        try {\n          const achievementsData = await getAchievements();\n          this.recentAchievements = achievementsData.slice(0, 5).map(achievement => ({\n            id: achievement._id,\n            title: achievement.name,\n            description: achievement.description,\n            icon: this.getAchievementIcon(achievement.name),\n            dateEarned: this.formatTimeAgo(new Date(achievement.dateEarned || achievement.createdAt))\n          }));\n        } catch (error) {\n          console.warn('Could not load achievements:', error);\n          this.recentAchievements = [];\n        }\n\n        // Load learning goals (TODO: Create Goals API)\n        this.learningGoals = [{\n          id: 1,\n          title: 'Complete Calculus Course',\n          description: 'Finish all calculus modules before exam',\n          progress: 75,\n          deadline: 'Dec 15, 2024'\n        }, {\n          id: 2,\n          title: 'Physics Lab Completion',\n          description: 'Complete all required physics lab experiments',\n          progress: 60,\n          deadline: 'Jan 10, 2025'\n        }, {\n          id: 3,\n          title: 'Programming Project',\n          description: 'Build a full-stack web application',\n          progress: 40,\n          deadline: 'Feb 1, 2025'\n        }];\n      } catch (error) {\n        console.error('Error loading progress data:', error);\n        this.error = 'Failed to load progress data';\n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    getSubjectIcon(subjectName) {\n      const iconMap = {\n        'Mathematics': 'fas fa-calculator',\n        'Math': 'fas fa-calculator',\n        'Physics': 'fas fa-atom',\n        'Chemistry': 'fas fa-flask',\n        'Biology': 'fas fa-dna',\n        'Computer Science': 'fas fa-laptop-code',\n        'Programming': 'fas fa-code',\n        'History': 'fas fa-landmark',\n        'Geography': 'fas fa-globe',\n        'Literature': 'fas fa-book',\n        'English': 'fas fa-language',\n        'Art': 'fas fa-palette',\n        'Music': 'fas fa-music',\n        'Science': 'fas fa-microscope'\n      };\n\n      // Exact match\n      if (iconMap[subjectName]) {\n        return iconMap[subjectName];\n      }\n\n      // Partial match\n      const lowerName = subjectName.toLowerCase();\n      for (const [key, icon] of Object.entries(iconMap)) {\n        if (lowerName.includes(key.toLowerCase()) || key.toLowerCase().includes(lowerName)) {\n          return icon;\n        }\n      }\n      return 'fas fa-book'; // Default icon\n    },\n    getAchievementIcon(achievementName) {\n      const iconMap = {\n        'Week Warrior': 'fas fa-fire',\n        'Math Master': 'fas fa-calculator',\n        'Quick Learner': 'fas fa-bolt',\n        'First Steps': 'fas fa-baby',\n        'Streak Master': 'fas fa-fire',\n        'Problem Solver': 'fas fa-puzzle-piece',\n        'Knowledge Seeker': 'fas fa-search',\n        'Study Champion': 'fas fa-trophy'\n      };\n\n      // Exact match\n      if (iconMap[achievementName]) {\n        return iconMap[achievementName];\n      }\n\n      // Partial match based on keywords\n      const lowerName = achievementName.toLowerCase();\n      if (lowerName.includes('streak')) return 'fas fa-fire';\n      if (lowerName.includes('master') || lowerName.includes('champion')) return 'fas fa-trophy';\n      if (lowerName.includes('quick') || lowerName.includes('fast')) return 'fas fa-bolt';\n      if (lowerName.includes('first')) return 'fas fa-star';\n      return 'fas fa-medal'; // Default icon\n    },\n    formatTimeAgo(date) {\n      const now = new Date();\n      const diffInSeconds = Math.floor((now - date) / 1000);\n      if (diffInSeconds < 60) return 'Just now';\n      if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)} minutes ago`;\n      if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)} hours ago`;\n      if (diffInSeconds < 604800) return `${Math.floor(diffInSeconds / 86400)} days ago`;\n      if (diffInSeconds < 2592000) return `${Math.floor(diffInSeconds / 604800)} weeks ago`;\n      return date.toLocaleDateString();\n    },\n    updateCharts() {\n      console.log('Updating charts for timeframe:', this.selectedTimeframe);\n      // Here you would update the chart data based on the selected timeframe\n    },\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["getAccount","getUserProgress","getAllSubjects","getAchievements","name","data","userName","userLevel","userId","selectedTimeframe","progressStats","totalXP","xpThisWeek","currentStreak","streakStatus","totalStudyTime","studyTimeThisWeek","completedLessons","completionRate","subjectProgress","recentAchievements","learningGoals","loading","error","mounted","loadProgressData","methods","getUserIdFromToken","token","localStorage","getItem","payload","JSON","parse","atob","split","id","console","Error","accountData","username","currentLevel","progressData","experience","weeklyXP","studyStreak","weeklyStudyTime","completedQuestions","length","warn","subjectsData","map","subject","_id","icon","getSubjectIcon","progress","Math","floor","random","achievementsData","slice","achievement","title","description","getAchievementIcon","dateEarned","formatTimeAgo","Date","createdAt","deadline","message","includes","response","status","removeItem","$router","push","subjectName","iconMap","lowerName","toLowerCase","key","Object","entries","achievementName","date","now","diffInSeconds","toLocaleDateString","updateCharts","log","logout"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Progress.vue"],"sourcesContent":["<template>\n  <div class=\"progress-container\">\n    <!-- Loading State -->\n    <div v-if=\"loading\" class=\"loading-container\">\n      <div class=\"loading-spinner\"><i class=\"fas fa-spinner fa-spin\"></i></div>\n      <p>Loading your progress...</p>\n    </div>\n    \n    <!-- Error State -->\n    <div v-else-if=\"error\" class=\"error-container\">\n      <div class=\"error-icon\"><i class=\"fas fa-exclamation-triangle\"></i></div>\n      <p>{{ error }}</p>\n      <button @click=\"loadProgressData\" class=\"retry-btn\">Try Again</button>\n    </div>\n    \n    <!-- Main Progress Content -->\n    <template v-else>\n      <!-- Sidebar -->\n      <div class=\"sidebar\">\n        <div class=\"sidebar-header\">\n          <div class=\"logo\">\n            <h2><i class=\"fas fa-star\"></i> Stardy</h2>\n          </div>\n          <router-link to=\"/profile\" class=\"nav-link\">\n          <div class=\"user-profile\">\n            <div class=\"avatar\">\n              <img src=\"https://via.placeholder.com/40\" alt=\"User Avatar\" />\n            </div>\n            <div class=\"user-info\">\n              <h4>{{ userName }}</h4>\n              <p>Level {{ userLevel }}</p>\n            </div>\n          </div>\n          </router-link>\n        </div>\n        \n        <nav class=\"sidebar-nav\">\n          <ul>\n            <li class=\"nav-item\">\n              <router-link to=\"/dashboard\" class=\"nav-link\">\n                <i class=\"icon fas fa-home\"></i>\n                <span>Dashboard</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/learning\" class=\"nav-link\">\n                <i class=\"icon fas fa-book\"></i>\n                <span>Learning</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/exams\" class=\"nav-link\">\n                <i class=\"icon fas fa-file-alt\"></i>\n                <span>Exams</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/subjects\" class=\"nav-link\">\n                <i class=\"icon fas fa-graduation-cap\"></i>\n                <span>Subjects</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item active\">\n              <router-link to=\"/progress\" class=\"nav-link\">\n                <i class=\"icon fas fa-chart-line\"></i>\n                <span>Progress</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/notes\" class=\"nav-link\">\n                <i class=\"icon fas fa-sticky-note\"></i>\n                <span>Notes</span>\n              </router-link>\n            </li>\n            <li class=\"nav-item\">\n              <router-link to=\"/ai-tutor\" class=\"nav-link\">\n                <i class=\"icon fas fa-robot\"></i>\n                <span>AI Tutor</span>\n              </router-link>\n            </li>\n          </ul>\n        </nav>\n        \n        <div class=\"sidebar-footer\">\n          <button @click=\"logout\" class=\"logout-btn\">\n            <i class=\"icon fas fa-sign-out-alt\"></i>\n            <span>Logout</span>\n          </button>\n        </div>\n      </div>\n      \n      <!-- Main Content -->\n      <div class=\"main-content\">\n        <header class=\"progress-header\">\n          <div class=\"header-content\">\n            <h1><i class=\"fas fa-chart-line\"></i> Learning Progress</h1>\n            <p>Track your learning journey and achievements</p>\n          </div>\n          <div class=\"time-filter\">\n            <select v-model=\"selectedTimeframe\" @change=\"updateCharts\" class=\"timeframe-select\">\n              <option value=\"week\">This Week</option>\n              <option value=\"month\">This Month</option>\n              <option value=\"quarter\">This Quarter</option>\n              <option value=\"year\">This Year</option>\n            </select>\n          </div>\n        </header>\n        \n        <!-- Progress Overview -->\n        <div class=\"progress-overview\">\n          <div class=\"overview-cards\">\n            <div class=\"overview-card\">\n              <div class=\"card-icon\"><i class=\"fas fa-trophy\"></i></div>\n              <div class=\"card-content\">\n                <h3>{{ progressStats.totalXP }}</h3>\n                <p>Total XP Earned</p>\n                <span class=\"change positive\">+{{ progressStats.xpThisWeek }} this week</span>\n              </div>\n            </div>\n            <div class=\"overview-card\">\n              <div class=\"card-icon\"><i class=\"fas fa-fire\"></i></div>\n              <div class=\"card-content\">\n                <h3>{{ progressStats.currentStreak }}</h3>\n                <p>Day Streak</p>\n                <span class=\"change positive\">{{ progressStats.streakStatus }}</span>\n              </div>\n            </div>\n            <div class=\"overview-card\">\n              <div class=\"card-icon\"><i class=\"fas fa-clock\"></i></div>\n              <div class=\"card-content\">\n                <h3>{{ progressStats.totalStudyTime }}h</h3>\n                <p>Study Time</p>\n                <span class=\"change positive\">+{{ progressStats.studyTimeThisWeek }}h this week</span>\n              </div>\n            </div>\n            <div class=\"overview-card\">\n              <div class=\"card-icon\"><i class=\"fas fa-check-circle\"></i></div>\n              <div class=\"card-content\">\n                <h3>{{ progressStats.completedLessons }}</h3>\n                <p>Lessons Completed</p>\n                <span class=\"change positive\">{{ progressStats.completionRate }}% completion rate</span>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- Charts Section -->\n        <div class=\"charts-section\">\n          <div class=\"charts-grid\">\n            <!-- Study Time Chart -->\n            <div class=\"chart-card\">\n              <h3><i class=\"fas fa-chart-area\"></i> Study Time Trend</h3>\n              <div class=\"chart-placeholder\">\n                <div class=\"mock-chart\">\n                  <div class=\"chart-bars\">\n                    <div class=\"bar\" style=\"height: 60%\"></div>\n                    <div class=\"bar\" style=\"height: 80%\"></div>\n                    <div class=\"bar\" style=\"height: 45%\"></div>\n                    <div class=\"bar\" style=\"height: 90%\"></div>\n                    <div class=\"bar\" style=\"height: 70%\"></div>\n                    <div class=\"bar\" style=\"height: 85%\"></div>\n                    <div class=\"bar\" style=\"height: 95%\"></div>\n                  </div>\n                  <div class=\"chart-labels\">\n                    <span>Mon</span>\n                    <span>Tue</span>\n                    <span>Wed</span>\n                    <span>Thu</span>\n                    <span>Fri</span>\n                    <span>Sat</span>\n                    <span>Sun</span>\n                  </div>\n                </div>\n              </div>\n            </div>\n            \n            <!-- Subject Progress Chart -->\n            <div class=\"chart-card\">\n              <h3><i class=\"fas fa-chart-pie\"></i> Subject Progress</h3>\n              <div class=\"subject-progress-list\">\n                <div v-for=\"subject in subjectProgress\" :key=\"subject.id\" class=\"subject-progress-item\">\n                  <div class=\"subject-info\">\n                    <i :class=\"subject.icon\"></i>\n                    <span>{{ subject.name }}</span>\n                  </div>\n                  <div class=\"progress-bar\">\n                    <div class=\"progress-fill\" :style=\"{ width: subject.progress + '%' }\"></div>\n                  </div>\n                  <span class=\"progress-percentage\">{{ subject.progress }}%</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- Achievements Section -->\n        <div class=\"achievements-section\">\n          <h2><i class=\"fas fa-medal\"></i> Recent Achievements</h2>\n          <div class=\"achievements-grid\">\n            <div v-for=\"achievement in recentAchievements\" :key=\"achievement.id\" class=\"achievement-card\">\n              <div class=\"achievement-icon\">\n                <i :class=\"achievement.icon\"></i>\n              </div>\n              <div class=\"achievement-content\">\n                <h4>{{ achievement.title }}</h4>\n                <p>{{ achievement.description }}</p>\n                <span class=\"achievement-date\">{{ achievement.dateEarned }}</span>\n              </div>\n              <div class=\"achievement-badge\">\n                <i class=\"fas fa-star\"></i>\n              </div>\n            </div>\n          </div>\n        </div>\n        \n        <!-- Goals Section -->\n        <div class=\"goals-section\">\n          <h2><i class=\"fas fa-target\"></i> Learning Goals</h2>\n          <div class=\"goals-grid\">\n            <div v-for=\"goal in learningGoals\" :key=\"goal.id\" class=\"goal-card\">\n              <div class=\"goal-header\">\n                <h4>{{ goal.title }}</h4>\n                <span class=\"goal-deadline\">{{ goal.deadline }}</span>\n              </div>\n              <p>{{ goal.description }}</p>\n              <div class=\"goal-progress\">\n                <div class=\"progress-bar\">\n                  <div class=\"progress-fill\" :style=\"{ width: goal.progress + '%' }\"></div>\n                </div>\n                <span class=\"progress-text\">{{ goal.progress }}% Complete</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </template>\n  </div>\n</template>\n\n<script>\nimport { getAccount } from '../api/Account.js';\nimport { getUserProgress } from '../api/UserProgress.js';\nimport { getAllSubjects } from '../api/Subject.js';\nimport { getAchievements } from '../api/Achievement.js';\n\nexport default {\n  name: 'Progress',\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      selectedTimeframe: 'week',\n      progressStats: {\n        totalXP: 0,\n        xpThisWeek: 0,\n        currentStreak: 0,\n        streakStatus: 'Keep it up!',\n        totalStudyTime: 0,\n        studyTimeThisWeek: 0,\n        completedLessons: 0,\n        completionRate: 0\n      },\n      subjectProgress: [],\n      recentAchievements: [],\n      learningGoals: [],\n      loading: true,\n      error: null\n    }\n  },\n  async mounted() {\n    await this.loadProgressData();\n  },\n  methods: {\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    \n    async loadProgressData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        \n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        \n        this.userId = userId;\n        \n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n        \n        // Load progress statistics from UserProgress API\n        try {\n          const progressData = await getUserProgress(userId);\n          this.progressStats = {\n            totalXP: accountData.experience || 0,\n            xpThisWeek: progressData.weeklyXP || 0,\n            currentStreak: progressData.studyStreak || 0,\n            streakStatus: progressData.studyStreak > 0 ? 'Keep it up!' : 'Start your streak!',\n            totalStudyTime: progressData.totalStudyTime || 0,\n            studyTimeThisWeek: progressData.weeklyStudyTime || 0,\n            completedLessons: accountData.completedQuestions?.length || 0,\n            completionRate: progressData.completionRate || 0\n          };\n        } catch (error) {\n          console.warn('Could not load user progress data:', error);\n          this.progressStats = {\n            totalXP: accountData.experience || 0,\n            xpThisWeek: 0,\n            currentStreak: 0,\n            streakStatus: 'Start your streak!',\n            totalStudyTime: 0,\n            studyTimeThisWeek: 0,\n            completedLessons: 0,\n            completionRate: 0\n          };\n        }\n        \n        // Load subject progress from API\n        try {\n          const subjectsData = await getAllSubjects();\n          this.subjectProgress = subjectsData.map(subject => ({\n            id: subject._id,\n            name: subject.name,\n            icon: this.getSubjectIcon(subject.name),\n            progress: Math.floor(Math.random() * 100) // TODO: Calculate actual progress from user data\n          }));\n        } catch (error) {\n          console.warn('Could not load subjects for progress:', error);\n          this.subjectProgress = [];\n        }\n        \n        // Load recent achievements from API\n        try {\n          const achievementsData = await getAchievements();\n          this.recentAchievements = achievementsData.slice(0, 5).map(achievement => ({\n            id: achievement._id,\n            title: achievement.name,\n            description: achievement.description,\n            icon: this.getAchievementIcon(achievement.name),\n            dateEarned: this.formatTimeAgo(new Date(achievement.dateEarned || achievement.createdAt))\n          }));\n        } catch (error) {\n          console.warn('Could not load achievements:', error);\n          this.recentAchievements = [];\n        }\n        \n        // Load learning goals (TODO: Create Goals API)\n        this.learningGoals = [\n          {\n            id: 1,\n            title: 'Complete Calculus Course',\n            description: 'Finish all calculus modules before exam',\n            progress: 75,\n            deadline: 'Dec 15, 2024'\n          },\n          {\n            id: 2,\n            title: 'Physics Lab Completion',\n            description: 'Complete all required physics lab experiments',\n            progress: 60,\n            deadline: 'Jan 10, 2025'\n          },\n          {\n            id: 3,\n            title: 'Programming Project',\n            description: 'Build a full-stack web application',\n            progress: 40,\n            deadline: 'Feb 1, 2025'\n          }\n        ];\n        \n      } catch (error) {\n        console.error('Error loading progress data:', error);\n        this.error = 'Failed to load progress data';\n        \n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    \n    getSubjectIcon(subjectName) {\n      const iconMap = {\n        'Mathematics': 'fas fa-calculator',\n        'Math': 'fas fa-calculator',\n        'Physics': 'fas fa-atom',\n        'Chemistry': 'fas fa-flask',\n        'Biology': 'fas fa-dna',\n        'Computer Science': 'fas fa-laptop-code',\n        'Programming': 'fas fa-code',\n        'History': 'fas fa-landmark',\n        'Geography': 'fas fa-globe',\n        'Literature': 'fas fa-book',\n        'English': 'fas fa-language',\n        'Art': 'fas fa-palette',\n        'Music': 'fas fa-music',\n        'Science': 'fas fa-microscope'\n      };\n      \n      // Exact match\n      if (iconMap[subjectName]) {\n        return iconMap[subjectName];\n      }\n      \n      // Partial match\n      const lowerName = subjectName.toLowerCase();\n      for (const [key, icon] of Object.entries(iconMap)) {\n        if (lowerName.includes(key.toLowerCase()) || key.toLowerCase().includes(lowerName)) {\n          return icon;\n        }\n      }\n      \n      return 'fas fa-book'; // Default icon\n    },\n    \n    getAchievementIcon(achievementName) {\n      const iconMap = {\n        'Week Warrior': 'fas fa-fire',\n        'Math Master': 'fas fa-calculator',\n        'Quick Learner': 'fas fa-bolt',\n        'First Steps': 'fas fa-baby',\n        'Streak Master': 'fas fa-fire',\n        'Problem Solver': 'fas fa-puzzle-piece',\n        'Knowledge Seeker': 'fas fa-search',\n        'Study Champion': 'fas fa-trophy'\n      };\n      \n      // Exact match\n      if (iconMap[achievementName]) {\n        return iconMap[achievementName];\n      }\n      \n      // Partial match based on keywords\n      const lowerName = achievementName.toLowerCase();\n      if (lowerName.includes('streak')) return 'fas fa-fire';\n      if (lowerName.includes('master') || lowerName.includes('champion')) return 'fas fa-trophy';\n      if (lowerName.includes('quick') || lowerName.includes('fast')) return 'fas fa-bolt';\n      if (lowerName.includes('first')) return 'fas fa-star';\n      \n      return 'fas fa-medal'; // Default icon\n    },\n    \n    formatTimeAgo(date) {\n      const now = new Date();\n      const diffInSeconds = Math.floor((now - date) / 1000);\n      \n      if (diffInSeconds < 60) return 'Just now';\n      if (diffInSeconds < 3600) return `${Math.floor(diffInSeconds / 60)} minutes ago`;\n      if (diffInSeconds < 86400) return `${Math.floor(diffInSeconds / 3600)} hours ago`;\n      if (diffInSeconds < 604800) return `${Math.floor(diffInSeconds / 86400)} days ago`;\n      if (diffInSeconds < 2592000) return `${Math.floor(diffInSeconds / 604800)} weeks ago`;\n      \n      return date.toLocaleDateString();\n    },\n    \n    updateCharts() {\n      console.log('Updating charts for timeframe:', this.selectedTimeframe);\n      // Here you would update the chart data based on the selected timeframe\n    },\n    \n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    }\n  }\n}\n</script>\n\n<style scoped>\n.progress-container {\n  display: flex;\n  min-height: 100vh;\n  background: linea