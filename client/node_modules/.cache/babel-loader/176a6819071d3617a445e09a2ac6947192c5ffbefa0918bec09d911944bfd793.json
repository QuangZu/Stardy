class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\r\n          <div class=\"glass-effect p-8 rounded-2xl text-center transition-all duration-300 hover:-translate-y-2 hover:bg-white hover:bg-opacity-15 fade-in-up\" style=\"animation-delay: 0.1s\">\r\n            <div class=\"text-5xl mb-4\">🃏</div>\r\n            <h3 class=\"text-xl font-semibold mb-4\">Smart Flashcards</h3>\r\n            <p class=\"opacity-90\">Create and study with intelligent flashcards that adapt to your learning pace</p>\r\n          </div>\r\n          <div class=\"glass-effect p-8 rounded-2xl text-center transition-all duration-300 hover:-translate-y-2 hover:bg-white hover:bg-opacity-15 fade-in-up\" style=\"animation-delay: 0.2s\">\r\n            <div class=\"text-5xl mb-4\">📝</div>\r\n            <h3 class=\"text-xl font-semibold mb-4\">Practice Exams</h3>\r\n            <p class=\"opacity-90\">Take comprehensive practice exams with detailed analytics and progress tracking</p>\r\n          </div>\r\n          <div class=\"glass-effect p-8 rounded-2xl text-center transition-all duration-300 hover:-translate-y-2 hover:bg-white hover:bg-opacity-15 fade-in-up\" style=\"animation-delay: 0.3s\">\r\n            <div class=\"text-5xl mb-4\">📚</div>\r\n            <h3 class=\"text-xl font-semibold mb-4\">Note Taking</h3>\r\n            <p class=\"opacity-90\">Organize your study materials with our advanced note-taking system</p>\r\n          </div>\r\n          <div class=\"glass-effect p-8 rounded-2xl text-center transition-all duration-300 hover:-translate-y-2 hover:bg-white hover:bg-opacity-15 fade-in-up\" style=\"animation-delay: 0.4s\">\r\n            <div class=\"text-5xl mb-4\">📅</div>\r\n            <h3 class=\"text-xl font-semibold mb-4\">Study Scheduler</h3>\r\n            <p class=\"opacity-90\">Plan your study sessions with intelligent scheduling and reminders</p>\r\n          </div>\r\n          <div class=\"glass-effect p-8 rounded-2xl text-center transition-all duration-300 hover:-translate-y-2 hover:bg-white hover:bg-opacity-15 fade-in-up\" style=\"animation-delay: 0.5s\">\r\n            <div class=\"text-5xl mb-4\">🏆</div>\r\n            <h3 class=\"text-xl font-semibold mb-4\">Achievements</h3>\r\n            <p class=\"opacity-90\">Stay motivated with achievements, streaks, and progress rewards</p>\r\n          </div>\r\n          <div class=\"glass-effect p-8 rounded-2xl text-center transition-all duration-300 hover:-translate-y-2 hover:bg-white hover:bg-opacity-15 fade-in-up\" style=\"animation-delay: 0.6s\">\r\n            <div class=\"text-5xl mb-4\">🤖</div>\r\n            <h3 class=\"text-xl font-semibold mb-4\">AI Assistant</h3>\r\n            <p class=\"opacity-90\">Get personalized study tips and answers with our AI-powered assistant</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'HomeView',\r\n  mounted() {\r\n    this.observeAnimations();\r\n  },\r\n  methods: {\r\n    observeAnimations() {\r\n      const observer = new IntersectionObserver((entries) => {\r\n        entries.forEach(entry => {\r\n          if (entry.isIntersecting) {\r\n            entry.target.classList.add('animate');\r\n          }\r\n        });\r\n      }, { threshold: 0.1 });\r\n      \r\n      document.querySelectorAll('.fade-in-up, .fade-in-left, .fade-in-right').forEach(el => {\r\n        observer.observe(el);\r\n      });\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;AAqIA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,iBAAiB,CAAC,CAAC;EAC1B,CAAC;EACDC,OAAO,EAAE;IACPD,iBAAiBA,CAAA,EAAG;MAClB,MAAME,QAAO,GAAI,IAAIC,oBAAoB,CAAEC,OAAO,IAAK;QACrDA,OAAO,CAACC,OAAO,CAACC,KAAI,IAAK;UACvB,IAAIA,KAAK,CAACC,cAAc,EAAE;YACxBD,KAAK,CAACE,MAAM,CAACC,SAAS,CAACC,GAAG,CAAC,SAAS,CAAC;UACvC;QACF,CAAC,CAAC;MACJ,CAAC,EAAE;QAAEC,SAAS,EAAE;MAAI,CAAC,CAAC;MAEtBC,QAAQ,CAACC,gBAAgB,CAAC,4CAA4C,CAAC,CAACR,OAAO,CAACS,EAAC,IAAK;QACpFZ,QAAQ,CAACa,OAAO,CAACD,EAAE,