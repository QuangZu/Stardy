{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: 'HomeView',\n  mounted() {\n    this.observeAnimations();\n  },\n  methods: {\n    observeAnimations() {\n      const observer = new IntersectionObserver(entries => {\n        entries.forEach(entry => {\n          if (entry.isIntersecting) {\n            entry.target.classList.add('animate');\n          }\n        });\n      }, {\n        threshold: 0.1\n      });\n      document.querySelectorAll('.fade-in-up, .fade-in-left, .fade-in-right').forEach(el => {\n        observer.observe(el);\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","mounted","observeAnimations","methods","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","target","classList","add","threshold","document","querySelectorAll","el","observe"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Home.vue"],"sourcesContent":["<template>\r\n  <div class=\"min-h-screen gradient-bg text-white relative overflow-x-hidden\">\r\n    <!-- Animated Background -->\r\n    <div class=\"animated-background\">\r\n      <div class=\"floating-shape shape-1\"></div>\r\n      <div class=\"floating-shape shape-2\"></div>\r\n      <div class=\"floating-shape shape-3\"></div>\r\n      <div class=\"floating-shape shape-4\"></div>\r\n    </div>\r\n\r\n    <!-- Navigation Header -->\r\n    <header class=\"relative z-50 py-4\">\r\n      <div class=\"max-w-6xl mx-auto flex justify-between items-center px-8\">\r\n        <div class=\"flex items-center gap-2 text-2xl font-bold\">\r\n          <span class=\"text-3xl\">📚</span>\r\n          <span>Stardy</span>\r\n        </div>\r\n        <nav class=\"hidden md:flex items-center gap-4\">\r\n          <router-link to=\"/\" class=\"menu__link\" data-hover=\"Home\">Home</router-link>\r\n          <router-link to=\"/about\" class=\"menu__link\" data-hover=\"About\">About</router-link>\r\n          <router-link to=\"/careers\" class=\"menu__link\" data-hover=\"Careers\">Careers</router-link>\r\n          <router-link to=\"/contact\" class=\"menu__link\" data-hover=\"Contact\">Contact</router-link>\r\n        </nav>\r\n        <div>\r\n          <button class=\"glass-effect px-6 py-2 rounded-full font-medium transition-all duration-300 hover:bg-white hover:bg-opacity-20 hover:-translate-y-1\">\r\n            Sign In\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </header>\r\n\r\n    <!-- Hero Section -->\r\n    <main class=\"max-w-6xl mx-auto px-8 py-16 grid md:grid-cols-2 gap-16 items-center relative z-10\">\r\n      <div class=\"text-left fade-in-up\">\r\n        <h1 class=\"text-5xl md:text-6xl font-bold leading-tight mb-6\">\r\n          The All-In-One Study<br>\r\n          App for <span class=\"text-blue-300 relative\">\r\n            Students\r\n            <span class=\"absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-blue-300 to-purple-400 animate-pulse\"></span>\r\n          </span>\r\n        </h1>\r\n        <p class=\"text-lg mb-8 opacity-90 leading-relaxed\">\r\n          Streamline your learning with the all-in-one study and organization app for<br>\r\n          students. Get started with a free trial today, no credit card needed.\r\n        </p>\r\n        <button class=\"bg-gray-900 text-white px-8 py-4 rounded-full text-lg font-semibold transition-all duration-300 hover:bg-gray-800 hover:-translate-y-1 hover:shadow-xl pulse-animation\">\r\n          Get Started\r\n        </button>\r\n      </div>\r\n      \r\n      <!-- App Preview -->\r\n      <div class=\"relative fade-in-right\">\r\n        <div class=\"bg-white rounded-xl overflow-hidden shadow-2xl transform perspective-1000 rotate-y-[-5deg] rotate-x-[5deg] floating-animation hover:rotate-y-[-2deg] hover:rotate-x-[2deg] hover:scale-105 transition-all duration-300\">\r\n          <div class=\"bg-gray-100 px-4 py-3 border-b