{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nexport default {\n  name: 'LoginView',\n  data() {\n    return {\n      email: '',\n      password: '',\n      showPassword: false,\n      rememberMe: false,\n      loading: false\n    };\n  },\n  mounted() {\n    this.observeAnimations();\n  },\n  methods: {\n    async handleLogin() {\n      this.loading = true;\n\n      // Simulate API call\n      setTimeout(() => {\n        console.log('Login attempt:', {\n          email: this.email,\n          password: this.password,\n          rememberMe: this.rememberMe\n        });\n\n        // Here you would typically make an API call to your backend\n        // For now, just redirect to home\n        this.$router.push('/');\n        this.loading = false;\n      }, 1500);\n    },\n    observeAnimations() {\n      const observer = new IntersectionObserver(entries => {\n        entries.forEach(entry => {\n          if (entry.isIntersecting) {\n            entry.target.classList.add('animate');\n          }\n        });\n      }, {\n        threshold: 0.1\n      });\n      document.querySelectorAll('.fade-in-up').forEach(el => {\n        observer.observe(el);\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","email","password","showPassword","rememberMe","loading","mounted","observeAnimations","methods","handleLogin","setTimeout","console","log","$router","push","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","target","classList","add","threshold","document","querySelectorAll","el","observe"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Login.vue"],"sourcesContent":["<template>\r\n  <div class=\"min-h-screen gradient-bg text-white relative overflow-x-hidden\" style=\"padding-top: 80px;\">\r\n    <!-- Animated Background -->\r\n    <div class=\"animated-background\">\r\n      <div class=\"floating-shape shape-1\"></div>\r\n      <div class=\"floating-shape shape-2\"></div>\r\n      <div class=\"floating-shape shape-3\"></div>\r\n    </div>\r\n\r\n    <!-- Navigation Header -->\r\n    <header class=\"nav-header\">\r\n      <div class=\"nav-container\">\r\n        <div class=\"nav-brand\">\r\n          <span class=\"text-3xl\">📚</span>\r\n          <span>Stardy</span>\r\n        </div>\r\n        <nav class=\"hidden md:flex items-center gap-4 nav-links\">\r\n          <router-link to=\"/\" class=\"menu__link\" data-hover=\"Home\">Home</router-link>\r\n          <router-link to=\"/about\" class=\"menu__link\" data-hover=\"About\">About</router-link>\r\n          <router-link to=\"/careers\" class=\"menu__link\" data-hover=\"Careers\">Careers</router-link>\r\n          <router-link to=\"/contact\" class=\"menu__link\" data-hover=\"Contact\">Contact</router-link>\r\n        </nav>\r\n        <div>\r\n          <router-link to=\"/register\" class=\"sign-in-btn\">\r\n            Sign Up\r\n          </router-link>\r\n        </div>\r\n      </div>\r\n    </header>\r\n\r\n    <!-- Login Content -->\r\n    <main class=\"relative z-10 py-16\">\r\n      <div class=\"max-w-md mx-auto px-8\">\r\n        <div class=\"text-center mb-8 fade-in-up\">\r\n          <div class=\"text-6xl mb-4\">👋</div>\r\n          <h1 class=\"text-4xl font-bold mb-4\">Welcome Back!</h1>\r\n          <p class=\"text-lg opacity-90\">\r\n            Ready to continue your learning journey? Sign in to access your study materials.\r\n          </p>\r\n        </div>\r\n        \r\n        <!-- Login Form -->\r\n        <div class=\"login-form-card fade-in-up\">\r\n          <form @submit.prevent=\"handleLogin\" class=\"space-y-6\">\r\n            <div>\r\n              <label class=\"block text-sm font-medium mb-2\">Email Address</label>\r\n              <div class=\"relative\">\r\n                <span class=\"absolute left-3 top-1/2 transform -translate-y-1/2 text-xl\">📧</span>\r\n                <input \r\n                  type=\"email\" \r\n                  v-model=\"email\"\r\n                  class=\"w-full pl-12 pr-4 py-3 bg-white bg-opacity-10 border border-white border-opacity-20 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all placeholder-white placeholder-opacity-60\"\r\n                  placeholder=\"Enter your email\"\r\n                  required\r\n                >\r\n              </div>\r\n            </div>\r\n            \r\n            <div>\r\n              <label class=\"block text-sm font-medium mb-2\">Password</label>\r\n              <div class=\"relative\">\r\n                <span class=\"absolute left-3 top-1/2 transform -translate-y-1/2 text-xl\">🔒</span>\r\n                <input \r\n                  :type=\"showPassword ? 'text' : 'password'\"\r\n                  v-model=\"password\"\r\n                  class=\"w-full pl-12 pr-12 py-3 bg-white bg-opacity-10 border border-white border-opacity-20 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent transition-all placeholder-white placeholder-opacity-60\"\r\n                  placeholder=\"Enter your password\"\r\n                  required\r\n                >\r\n                <button \r\n                  type=\"button\"\r\n                  @click=\"showPassword = !showPassword\"\r\n                  class=\"absolute right-3 top-1/2 transform -translate-y-1/2 text-xl hover:scale-110 transition-transform\"\r\n                >\r\n                  {{ showPassword ? '🙈' : '👁️' }}\r\n                </button>\r\n              </div>\r\n            </div>\r\n            \r\n            <div class=\"flex items-center justify-between\">\r\n              <label class=\"flex items-center\">\r\n                <input type=\"checkbox\" v-model=\"rememberMe\" class=\"mr-2 rounded\">\r\n                <span class=\"text-sm\">Remember me</span>\r\n              </label>\r\n              <a href=\"#\" class=\"text-sm text-blue-300 hover:text-blue-200 transition-colors\">\r\n                Forgot password?\r\n              </a>\r\n            </div>\r\n            \r\n            <button \r\n              type=\"submit\" \r\n              class=\"w-full bg-white text-gray-900 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg\"\r\n              :disabled=\"loading\"\r\n            >\r\n              <span v-if=\"loading\">Signing in... ⏳</span>\r\n              <span v-else>Sign In 🚀</span>\r\n            </button>\r\n          </form>\r\n          \r\n          <div class=\"mt-6 text-center\">\r\n            <p class=\"text-sm opacity-80\">\r\n              Don't have an account? \r\n              <router-link to=\"/register\" class=\"text-blue-300 hover:text-blue-200 transition-colors font-medium\">\r\n                Sign up here\r\n              </router-link>\r\n            </p>\r\n          </div>\r\n          \r\n          <!-- Social Login -->\r\n          <div class=\"mt-8\">\r\n            <div class=\"relative\">\r\n              <div class=\"absolute inset-0 flex items-center\">\r\n                <div class=\"w-full border-t border-white border-opacity-20\"></div>\r\n              </div>\r\n              <div class=\"relative flex justify-center text-sm\">\r\n                <span class=\"px-2 bg-transparent text-white opacity-80\">Or continue with</span>\r\n              </div>\r\n            </div>\r\n            \r\n            <div class=\"mt-6 grid grid-cols-2 gap-3\">\r\n              <button class=\"social-login-btn\">\r\n                <span class=\"text-xl\">🔵</span>\r\n                <span>Google</span>\r\n              </button>\r\n              <button class=\"social-login-btn\">\r\n                <span class=\"text-xl\">📘</span>\r\n                <span>Facebook</span>\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </main>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'LoginView',\r\n  data() {\r\n    return {\r\n      email: '',\r\n      password: '',\r\n      showPassword: false,\r\n      rememberMe: false,\r\n      loading: false\r\n    }\r\n  },\r\n  mounted() {\r\n    this.observeAnimations();\r\n  },\r\n  methods: {\r\n    async handleLogin() {\r\n      this.loading = true;\r\n      \r\n      // Simulate API call\r\n      setTimeout(() => {\r\n        console.log('Login attempt:', {\r\n          email: this.email,\r\n          password: this.password,\r\n          rememberMe: this.rememberMe\r\n        });\r\n        \r\n        // Here you would typically make an API call to your backend\r\n        // For now, just redirect to home\r\n        this.$router.push('/');\r\n        this.loading = false;\r\n      }, 1500);\r\n    },\r\n    \r\n    observeAnimations() {\r\n      const observer = new IntersectionObserver((entries) => {\r\n        entries.forEach(entry => {\r\n          if (entry.isIntersecting) {\r\n            entry.target.classList.add('animate');\r\n          }\r\n        });\r\n      }, { threshold: 0.1 });\r\n      \r\n      document.querySelectorAll('.fade-in-up').forEach(el => {\r\n        observer.observe(el);\r\n      });\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.login-form-card {\r\n  background: rgba(255, 255, 255, 0.1);\r\n  padding: 2rem;\r\n  border-radius: 16px;\r\n  backdrop-filter: blur(10px);\r\n  border: 1px solid rgba(255, 255, 255, 0.2);\r\n  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);\r\n}\r\n\r\n.login-form-card:hover {\r\n  transform: translateY(-4px);\r\n  background: rgba(255, 255, 255, 0.12);\r\n  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);\r\n  border-color: rgba(255, 255, 255, 0.3);\r\n}\r\n\r\n.social-login-btn {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  gap: 0.5rem;\r\n  padding: 0.75rem;\r\n  background: rgba(255, 255, 255, 0.1);\r\n  border: 1px solid rgba(255, 255, 255, 0.2);\r\n  border-radius: 8px;\r\n  color: white;\r\n  font-weight: 500;\r\n  transition: all 0.3s ease;\r\n  cursor: pointer;\r\n}\r\n\r\n.social-login-btn:hover {\r\n  background: rgba(255, 255, 255, 0.15);\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\r\n}\r\n\r\n.fade-in-up {\r\n  opacity: 0;\r\n  transform: translateY(30px);\r\n  transition: all 0.8s ease;\r\n}\r\n\r\n.fade-in-up.animate {\r\n  opacity: 1;\r\n  transform: translateY(0);\r\n}\r\n</style>"],"mappings":";;;AAyIA,eAAe;EACbA,IAAI,EAAE,WAAW;EACjBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,YAAY,EAAE,KAAK;MACnBC,UAAU,EAAE,KAAK;MACjBC,OAAO,EAAE;IACX;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,iBAAiB,CAAC,CAAC;EAC1B,CAAC;EACDC,OAAO,EAAE;IACP,MAAMC,WAAWA,CAAA,EAAG;MAClB,IAAI,CAACJ,OAAM,GAAI,IAAI;;MAEnB;MACAK,UAAU,CAAC,MAAM;QACfC,OAAO,CAACC,GAAG,CAAC,gBAAgB,EAAE;UAC5BX,KAAK,EAAE,IAAI,CAACA,KAAK;UACjBC,QAAQ,EAAE,IAAI,CAACA,QAAQ;UACvBE,UAAU,EAAE,IAAI,CAACA;QACnB,CAAC,CAAC;;QAEF;QACA;QACA,IAAI,CAACS,OAAO,CAACC,IAAI,CAAC,GAAG,CAAC;QACtB,IAAI,CAACT,OAAM,GAAI,KAAK;MACtB,CAAC,EAAE,IAAI,CAAC;IACV,CAAC;IAEDE,iBAAiBA,CAAA,EAAG;MAClB,MAAMQ,QAAO,GAAI,IAAIC,oBAAoB,CAAEC,OAAO,IAAK;QACrDA,OAAO,CAACC,OAAO,CAACC,KAAI,IAAK;UACvB,IAAIA,KAAK,CAACC,cAAc,EAAE;YACxBD,KAAK,CAACE,MAAM,CAACC,SAAS,CAACC,GAAG,CAAC,SAAS,CAAC;UACvC;QACF,CAAC,CAAC;MACJ,CAAC,EAAE;QAAEC,SAAS,EAAE;MAAI,CAAC,CAAC;MAEtBC,QAAQ,CAACC,gBAAgB,CAAC,aAAa,CAAC,CAACR,OAAO,CAACS,EAAC,IAAK;QACrDZ,QAAQ,CAACa,OAAO,CAACD,EAAE,CAAC;MACtB,CAAC,CAAC;IACJ;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}