.parse(localStorage.getItem('user') || '{}'),\r\n      stats: {\r\n        totalUsers: 0,\r\n        totalAdmins: 0,\r\n        avgLevel: 0,\r\n        avgStreak: 0\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchStats()\r\n  },\r\n  methods: {\r\n    async fetchStats() {\r\n      try {\r\n        const response = await fetch('/api/admin/stats', {\r\n          headers: {\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          }\r\n        })\r\n        if (response.ok) {\r\n          this.stats = await response.json()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error fetching stats:', error)\r\n      }\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";AAgEA,OAAO,0BAAyB;AAChC,OAAOA,WAAU,MAAO,oCAAmC;AAC3D,OAAOC,eAAc,MAAO,wCAAuC;AAEnE,eAAe;EACbC,IAAI,EAAE,YAAY;EAClBC,UAAU,EAAE;IACVH,WAAW;IACXC;EACF,CAAC;EACDG,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,KAAK,EAAE;QACLC,UAAU,EAAE,CAAC;QACbC,WAAW,EAAE,CAAC;QACdC,QAAQ,EAAE,CAAC;QACXC,SAAS,EAAE;MACb;IACF;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,UAAU,CAAC;EAClB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMD,UAAUA,CAAA,EAAG;MACjB,IAAI;QACF,MAAME,QAAO,GAAI,MAAMC,KAAK,CAAC,kBAAkB,EAAE;UAC/CC,OAAO,EAAE;YACP,eAAe,EAAE,UAAUZ,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;UAC1D;QACF,CAAC;QACD,IAAIS,QAAQ,CAACG,EAAE,EAAE;UACf,IAAI,CAACX,KAAI,GAAI,MAAMQ,QAAQ,CAACI,IAAI,CAAC;QACnC;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,uBAAuB,EAAEA,KAAK;MAC9C;IACF,CAAC;IACDE,MAAMA,CAAA,EAAG;MACPjB,YAAY,CAACkB,UAAU,CAAC,OAAO;MAC/BlB,YAAY,CAACkB,UAAU,CAAC,MAAM;MAC9B,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,QAAQ;IAC5B;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}