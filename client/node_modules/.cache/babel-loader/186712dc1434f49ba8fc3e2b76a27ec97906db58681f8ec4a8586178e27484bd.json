{"ast":null,"code":"export default {\n  name: 'App'\n};","map":{"version":3,"names":["name"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\App.vue"],"sourcesContent":["<template>\n  <div id=\"app\" class=\"min-h-screen text-white relative overflow-x-hidden space-fade-in\">\n    <!-- Space Theme Background Elements -->\n    <div class=\"nebula-overlay\"></div>\n    <div class=\"shooting-star\" style=\"animation-delay: 2s;\"></div>\n    <div class=\"shooting-star\" style=\"animation-delay: 8s; top: 30%;\"></div>\n    <div class=\"shooting-star\" style=\"animation-delay: 15s; top: 70%;\"></div>\n    \n    <transition name=\"page\" mode=\"out-in\">\n      <router-view />\n    </transition>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'App'\n}\n</script>\n\n<style>\n@import url('https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css');\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  line-height: 1.6;\n  color: #fff;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n#app {\n  min-height: 100vh;\n}\n\n/* Smooth Page Transitions with Space Theme */\n.page-enter-active, .page-leave-active {\n  transition: all 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);\n}\n\n.page-enter-from {\n  opacity: 0;\n  transform: translateY(30px) scale(0.95);\n  filter: blur(5px);\n}\n\n.page-leave-to {\n  opacity: 0;\n  transform: translateY(-30px) scale(1.05);\n  filter: blur(5px);\n}\n\n.page-enter-to, .page-leave-from {\n  opacity: 1;\n  transform: translateY(0) scale(1);\n  filter: blur(0);\n}\n</style>"],"mappings":"AAeA,eAAe;EACbA,IAAI,EAAE;AACR","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}