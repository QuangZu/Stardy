{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport '../styles/home.css';\nexport default {\n  name: 'Homepage',\n  mounted() {\n    this.observeAnimations();\n  },\n  methods: {\n    observeAnimations() {\n      const observer = new IntersectionObserver(entries => {\n        entries.forEach(entry => {\n          if (entry.isIntersecting) {\n            entry.target.classList.add('animate');\n          }\n        });\n      }, {\n        threshold: 0.1\n      });\n      document.querySelectorAll('.fade-in-up, .fade-in-left, .fade-in-right').forEach(el => {\n        observer.observe(el);\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","mounted","observeAnimations","methods","observer","IntersectionObserver","entries","forEach","entry","isIntersecting","target","classList","add","threshold","document","querySelectorAll","el","observe"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Home.vue"],"sourcesContent":["<template>\r\n  <div class=\"relative z-10\" style=\"padding-top: 80px;\">\r\n    <!-- Animated Background -->\r\n    <div class=\"animated-background\">\r\n      <div class=\"floating-shape shape-1\"></div>\r\n      <div class=\"floating-shape shape-2\"></div>\r\n      <div class=\"floating-shape shape-3\"></div>\r\n      <div class=\"floating-shape shape-4\"></div>\r\n      <div class=\"floating-shape shape-5\"></div>\r\n      <div class=\"floating-shape shape-6\"></div>\r\n      <div class=\"floating-shape shape-7\"></div>\r\n      <div class=\"floating-shape shape-8\"></div>\r\n    </div>\r\n    <!-- Navigation Header -->\r\n    <header class=\"nav-header\">\r\n      <div class=\"nav-container\">\r\n        <div class=\"nav-brand\">\r\n          <span class=\"text-3xl\">📚</span>\r\n          <span>Stardy</span>\r\n        </div>\r\n        <nav class=\"hidden md:flex items-center gap-4 nav-links\">\r\n          <router-link to=\"/\" class=\"menu__link\" data-hover=\"Home\">Home</router-link>\r\n          <router-link to=\"/about\" class=\"menu__link\" data-hover=\"About\">About</router-link>\r\n          <router-link to=\"/careers\" class=\"menu__link\" data-hover=\"Careers\">Careers</router-link>\r\n          <router-link to=\"/contact\" class=\"menu__link\" data-hover=\"Contact\">Contact</router-link>\r\n        </nav>\r\n          <router-link to=\"/login\" class=\"sign-in-btn\">\r\n            Sign In\r\n          </router-link>\r\n      </div>\r\n    </header>\r\n\r\n    <!-- Hero Section -->\r\n    <main class=\"max-w-6xl mx-auto px-8 py-16 grid md:grid-cols-2 gap-16 items-center hero-section\">\r\n      <div class=\"text-left fade-in-up\">\r\n        <h1 class=\"hero-title\">\r\n          The All-In-One Study<br>\r\n          App for <span class=\"highlight\">\r\n            Students\r\n          </span>\r\n        </h1>\r\n        <p class=\"text-lg mb-8 opacity-90 leading-relaxed\">\r\n          Streamline your learning with the all-in-one study and organization app for<br>\r\n          students. Get started with a free trial today, no credit card needed.\r\n        </p>\r\n          <router-link to=\"/login\">\r\n          <button class=\"cta-button pulse-animation\">\r\n            Get Started\r\n          </button>\r\n          </router-link>\r\n      </div>\r\n      \r\n      <!-- App Preview -->\r\n      <div class=\"relative fade-in-right\">\r\n        <div class=\"bg-white rounded-xl overflow-hidden shadow-2xl transform perspective-1000 rotate-y-[-5deg] rotate-x-[5deg] floating-animation hover:rotate-y-[-2deg] hover:rotate-x-[2deg] hover:scale-105 transition-all duration-300\">\r\n          <div class=\"bg-gray-100 px-4 py-3 border-b border-gray-200\">\r\n            <div class=\"flex gap-2\">\r\n              <span class=\"w-3 h-3 bg-red-500 rounded-full\"></span>\r\n              <span class=\"w-3 h-3 bg-yellow-500 rounded-full\"></span>\r\n              <span class=\"w-3 h-3 bg-green-500 rounded-full\"></span>\r\n            </div>\r\n          </div>\r\n          <div class=\"h-80 bg-gray-50 flex\">\r\n            <div class=\"w-64 bg-indigo-600 text-white p-6\">\r\n              <div class=\"flex items-center gap-2 text-xl font-bold mb-4\">\r\n                <span class=\"text-2xl\">📚</span>\r\n                <span>Stardy</span>\r\n              </div>\r\n              <div class=\"text-lg mb-1\">Hi, James!</div>\r\n              <div class=\"text-sm opacity-80\">Let's study and finish your goals!</div>\r\n            </div>\r\n            <div class=\"flex-1 p-4\">\r\n              <div class=\"flex justify-between items-center\">\r\n                <div class=\"flex gap-4\">\r\n                  <span class=\"text-xl\">📅</span>\r\n                  <span class=\"text-xl\">📊</span>\r\n                  <span class=\"text-xl\">💬</span>\r\n                </div>\r\n                <div class=\"flex items-center gap-2 text-gray-700\">\r\n                  <span>Yamaha Oliva</span>\r\n                  <div class=\"w-8 h-8 bg-red-400 rounded-full\"></div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"absolute -bottom-8 right-0 flex items-center gap-2 text-sm opacity-80\">\r\n          <span>Built With</span>\r\n          <span class=\"glass-effect px-3 py-1 rounded-full font-medium\">Vue.js</span>\r\n        </div>\r\n      </div>\r\n    </main>\r\n\r\n    <!-- Features Section -->\r\n    <section class=\"py-24 glass-effect relative z-10\">\r\n      <div class=\"max-w-6xl mx-auto px-8\">\r\n        <h2 class=\"text-4xl font-bold text-center mb-12 fade-in-up\">Powerful Study Features</h2>\r\n        <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\r\n          <div class=\"feature-card fade-in-up\" style=\"animation-delay: 0.1s\">\r\n            <div class=\"feature-icon\">🃏</div>\r\n            <h3>Smart Flashcards</h3>\r\n            <p>Create and study with intelligent flashcards that adapt to your learning pace</p>\r\n          </div>\r\n          <div class=\"feature-card fade-in-up\" style=\"animation-delay: 0.2s\">\r\n            <div class=\"feature-icon\">📝</div>\r\n            <h3>Practice Exams</h3>\r\n            <p>Take comprehensive practice exams with detailed analytics and progress tracking</p>\r\n          </div>\r\n          <div class=\"feature-card fade-in-up\" style=\"animation-delay: 0.3s\">\r\n            <div class=\"feature-icon\">📚</div>\r\n            <h3>Note Taking</h3>\r\n            <p>Organize your study materials with our advanced note-taking system</p>\r\n          </div>\r\n          <div class=\"feature-card fade-in-up\" style=\"animation-delay: 0.4s\">\r\n            <div class=\"feature-icon\">📅</div>\r\n            <h3>Study Scheduler</h3>\r\n            <p>Plan your study sessions with intelligent scheduling and reminders</p>\r\n          </div>\r\n          <div class=\"feature-card fade-in-up\" style=\"animation-delay: 0.5s\">\r\n            <div class=\"feature-icon\">🏆</div>\r\n            <h3>Achievements</h3>\r\n            <p>Stay motivated with achievements, streaks, and progress rewards</p>\r\n          </div>\r\n          <div class=\"feature-card fade-in-up\" style=\"animation-delay: 0.6s\">\r\n            <div class=\"feature-icon\">🤖</div>\r\n            <h3>AI Assistant</h3>\r\n            <p>Get personalized study tips and answers with our AI-powered assistant</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport '../styles/home.css'\r\n\r\nexport default {\r\n  name: 'Homepage',\r\n  mounted() {\r\n    this.observeAnimations();\r\n  },\r\n  methods: {\r\n    observeAnimations() {\r\n      const observer = new IntersectionObserver((entries) => {\r\n        entries.forEach(entry => {\r\n          if (entry.isIntersecting) {\r\n            entry.target.classList.add('animate');\r\n          }\r\n        });\r\n      }, { threshold: 0.1 });\r\n      \r\n      document.querySelectorAll('.fade-in-up, .fade-in-left, .fade-in-right').forEach(el => {\r\n        observer.observe(el);\r\n      });\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.home {\r\n  min-height: 100vh;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: white;\r\n  position: relative;\r\n  overflow-x: hidden;\r\n}\r\n\r\n/* Animated Background */\r\n.animated-background {\r\n  position: st;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  pointer-events: none;\r\n  z-index: 1;\r\n}\r\n\r\n.floating-shape {\r\n  position: absolute;\r\n  border-radius: 50%;\r\n  background: rgba(255, 255, 255, 0.1);\r\n  animation: float 6s ease-in-out infinite;\r\n}\r\n\r\n.shape-1 {\r\n  width: 80px;\r\n  height: 80px;\r\n  top: 20%;\r\n  left: 10%;\r\n  animation-delay: 0s;\r\n}\r\n\r\n.shape-2 {\r\n  width: 120px;\r\n  height: 120px;\r\n  top: 60%;\r\n  right: 15%;\r\n  animation-delay: 2s;\r\n}\r\n\r\n.shape-3 {\r\n  width: 60px;\r\n  height: 60px;\r\n  top: 80%;\r\n  left: 20%;\r\n  animation-delay: 4s;\r\n}\r\n\r\n.shape-4 {\r\n  width: 100px;\r\n  height: 100px;\r\n  top: 10%;\r\n  right: 30%;\r\n  animation-delay: 1s;\r\n}\r\n\r\n@keyframes float {\r\n  0%, 100% { transform: translateY(0px) rotate(0deg); }\r\n  33% { transform: translateY(-20px) rotate(120deg); }\r\n  66% { transform: translateY(10px) rotate(240deg); }\r\n}\r\n\r\n/* Navigation */\r\n.navbar {\r\n  padding: 1rem 0;\r\n  position: relative;\r\n  z-index: 100;\r\n}\r\n\r\n.nav-container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  padding: 0 2rem;\r\n}\r\n\r\n.nav-brand {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.5rem;\r\n  font-size: 1.5rem;\r\n  font-weight: bold;\r\n  animation: slideInLeft 0.8s ease-out;\r\n}\r\n\r\n.logo-icon {\r\n  font-size: 1.8rem;\r\n}\r\n\r\n.nav-menu {\r\n  display: flex;\r\n  gap: 2rem;\r\n  position: relative;\r\n  animation: slideInDown 0.8s ease-out 0.2s both;\r\n}\r\n\r\n.nav-underline {\r\n  position: absolute;\r\n  bottom: -5px;\r\n  height: 2px;\r\n  background: white;\r\n  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\r\n  border-radius: 1px;\r\n}\r\n\r\n.nav-link {\r\n  color: white;\r\n  text-decoration: none;\r\n  font-weight: 500;\r\n  transition: all 0.3s ease;\r\n  padding: 0.5rem 0;\r\n  position: relative;\r\n}\r\n\r\n.nav-link:hover {\r\n  transform: translateY(-2px);\r\n}\r\n\r\n.nav-auth {\r\n  animation: slideInRight 0.8s ease-out 0.4s both;\r\n}\r\n\r\n.sign-in-btn {\r\n  background: rgba(255, 255, 255, 0.2);\r\n  border: 1px solid rgba(255, 255, 255, 0.3);\r\n  color: white;\r\n  padding: 0.5rem 1.5rem;\r\n  border-radius: 25px;\r\n  cursor: pointer;\r\n  font-weight: 500;\r\n  transition: all 0.3s ease;\r\n  backdrop-filter: blur(10px);\r\n}\r\n\r\n.sign-in-btn:hover {\r\n  background: rgba(255, 255, 255, 0.3);\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);\r\n}\r\n\r\n/* Hero Section */\r\n.hero-section {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 4rem 2rem;\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  gap: 4rem;\r\n  align-items: center;\r\n  position: relative;\r\n  z-index: 10;\r\n}\r\n\r\n.hero-content {\r\n  text-align: left;\r\n}\r\n\r\n.hero-title {\r\n  font-size: 3.5rem;\r\n  font-weight: bold;\r\n  line-height: 1.1;\r\n  margin-bottom: 1.5rem;\r\n}\r\n\r\n.highlight {\r\n  color: #a8b5ff;\r\n  position: relative;\r\n}\r\n\r\n.highlight::after {\r\n  content: '';\r\n  position: absolute;\r\n  bottom: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 3px;\r\n  background: linear-gradient(90deg, #a8b5ff, #667eea);\r\n  animation: highlightGlow 2s ease-in-out infinite alternate;\r\n}\r\n\r\n@keyframes highlightGlow {\r\n  0% { opacity: 0.6; transform: scaleX(0.8); }\r\n  100% { opacity: 1; transform: scaleX(1); }\r\n}\r\n\r\n.hero-description {\r\n  font-size: 1.1rem;\r\n  line-height: 1.6;\r\n  margin-bottom: 2rem;\r\n  opacity: 0.9;\r\n}\r\n\r\n.cta-button {\r\n  background: #1a1a1a;\r\n  color: white;\r\n  border: none;\r\n  padding: 1rem 2rem;\r\n  border-radius: 25px;\r\n  font-size: 1.1rem;\r\n  font-weight: 600;\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n  position: relative;\r\n  overflow: hidden;\r\n}\r\n\r\n.cta-button:hover {\r\n  background: #333;\r\n  transform: translateY(-2px);\r\n  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);\r\n}\r\n\r\n.pulse-animation {\r\n  animation: pulse 2s infinite;\r\n}\r\n\r\n@keyframes pulse {\r\n  0% { box-shadow: 0 0 0 0 rgba(26, 26, 26, 0.7); }\r\n  70% { box-shadow: 0 0 0 10px rgba(26, 26, 26, 0); }\r\n  100% { box-shadow: 0 0 0 0 rgba(26, 26, 26, 0); }\r\n}\r\n\r\n/* App Preview */\r\n.app-preview {\r\n  position: relative;\r\n}\r\n\r\n.preview-window {\r\n  background: white;\r\n  border-radius: 12px;\r\n  overflow: hidden;\r\n  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);\r\n  transform: perspective(1000px) rotateY(-5deg) rotateX(5deg);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.preview-window:hover {\r\n  transform: perspective(1000px) rotateY(-2deg) rotateX(2deg) scale(1.02);\r\n}\r\n\r\n.floating-animation {\r\n  animation: floating 3s ease-in-out infinite;\r\n}\r\n\r\n@keyframes floating {\r\n  0%, 100% { transform: perspective(1000px) rotateY(-5deg) rotateX(5deg) translateY(0px); }\r\n  50% { transform: perspective(1000px) rotateY(-5deg) rotateX(5deg) translateY(-10px); }\r\n}\r\n\r\n.window-header {\r\n  background: #f5f5f5;\r\n  padding: 0.75rem 1rem;\r\n  border-bottom: 1px solid #e0e0e0;\r\n}\r\n\r\n.window-controls {\r\n  display: flex;\r\n  gap: 0.5rem;\r\n}\r\n\r\n.control {\r\n  width: 12px;\r\n  height: 12px;\r\n  border-radius: 50%;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.control:hover {\r\n  transform: scale(1.2);\r\n}\r\n\r\n.control.red { background: #ff5f57; }\r\n.control.yellow { background: #ffbd2e; }\r\n.control.green { background: #28ca42; }\r\n\r\n.window-content {\r\n  height: 300px;\r\n  background: #fafafa;\r\n}\r\n\r\n.app-interface {\r\n  display: flex;\r\n  height: 100%;\r\n}\r\n\r\n.sidebar {\r\n  width: 250px;\r\n  background: #4f46e5;\r\n  color: white;\r\n  padding: 1.5rem;\r\n}\r\n\r\n.sidebar-brand {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.5rem;\r\n  font-size: 1.2rem;\r\n  font-weight: bold;\r\n  margin-bottom: 1rem;\r\n}\r\n\r\n.sidebar-logo {\r\n  font-size: 1.5rem;\r\n}\r\n\r\n.sidebar-subtitle {\r\n  font-size: 1.1rem;\r\n  margin-bottom: 0.25rem;\r\n}\r\n\r\n.sidebar-subtitle-sub {\r\n  font-size: 0.9rem;\r\n  opacity: 0.8;\r\n}\r\n\r\n.main-content {\r\n  flex: 1;\r\n  padding: 1rem;\r\n}\r\n\r\n.content-header {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.header-icons {\r\n  display: flex;\r\n  gap: 1rem;\r\n}\r\n\r\n.icon {\r\n  font-size: 1.2rem;\r\n  color: #666;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n.icon:hover {\r\n  transform: scale(1.2);\r\n}\r\n\r\n.user-profile {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.5rem;\r\n  color: #333;\r\n}\r\n\r\n.user-avatar {\r\n  width: 32px;\r\n  height: 32px;\r\n  background: #ff6b6b;\r\n  border-radius: 50%;\r\n  animation: avatarPulse 2s ease-in-out infinite;\r\n}\r\n\r\n@keyframes avatarPulse {\r\n  0%, 100% { transform: scale(1); }\r\n  50% { transform: scale(1.1); }\r\n}\r\n\r\n.built-with {\r\n  position: absolute;\r\n  bottom: -2rem;\r\n  right: 0;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 0.5rem;\r\n  font-size: 0.9rem;\r\n  opacity: 0.8;\r\n}\r\n\r\n.tech-badge {\r\n  background: rgba(255, 255, 255, 0.2);\r\n  padding: 0.25rem 0.75rem;\r\n  border-radius: 12px;\r\n  font-weight: 500;\r\n  backdrop-filter: blur(10px);\r\n}\r\n\r\n/* Features Section */\r\n.features-section {\r\n  padding: 6rem 0;\r\n  background: rgba(255, 255, 255, 0.05);\r\n  backdrop-filter: blur(10px);\r\n  position: relative;\r\n  z-index: 10;\r\n}\r\n\r\n.container {\r\n  max-width: 1200px;\r\n  margin: 0 auto;\r\n  padding: 0 2rem;\r\n}\r\n\r\n.section-title {\r\n  text-align: center;\r\n  font-size: 2.5rem;\r\n  margin-bottom: 3rem;\r\n  font-weight: bold;\r\n}\r\n\r\n.features-grid {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\r\n  gap: 2rem;\r\n}\r\n\r\n/* Enhanced Feature Cards with Hover Scale Effect */\r\n.feature-card {\r\n  background: rgba(255, 255, 255, 0.1);\r\n  padding: 2rem;\r\n  border-radius: 16px;\r\n  text-align: center;\r\n  backdrop-filter: blur(10px);\r\n  border: 1px solid rgba(255, 255, 255, 0.2);\r\n  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);\r\n  cursor: pointer;\r\n  transform-origin: center;\r\n}\r\n\r\n.feature-card:hover {\r\n  transform: translateY(-8px) scale(1.05);\r\n  background: rgba(255, 255, 255, 0.15);\r\n  box-shadow: \r\n    0 20px 40px rgba(0, 0, 0, 0.3),\r\n    0 0 0 1px rgba(255, 255, 255, 0.3),\r\n    0 0 20px rgba(99, 102, 241, 0.2);\r\n  border-color: rgba(255, 255, 255, 0.4);\r\n}\r\n\r\n.feature-icon {\r\n  font-size: 3rem;\r\n  margin-bottom: 1rem;\r\n  transition: all 0.3s ease;\r\n  display: inline-block;\r\n}\r\n\r\n.feature-card:hover .feature-icon {\r\n  transform: scale(1.1) translateY(-2px);\r\n  filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.2));\r\n}\r\n\r\n.feature-card h3 {\r\n  font-size: 1.5rem;\r\n  margin-bottom: 1rem;\r\n  font-weight: 600;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.feature-card:hover h3 {\r\n  color: #a8b5ff;\r\n  transform: translateY(-1px);\r\n}\r\n\r\n.feature-card p {\r\n  opacity: 0.9;\r\n  line-height: 1.6;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.feature-card:hover p {\r\n  opacity: 1;\r\n  transform: translateY(-1px);\r\n}\r\n\r\n/* Progress Section */\r\n.progress-section {\r\n  padding: 6rem 0;\r\n  position: relative;\r\n  z-index: 10;\r\n}\r\n\r\n.progress-content {\r