{"ast":null,"code":"import AdminSidebar from '@/components/admin/AdminSidebar.vue';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport { getAllSubjects, createSubject, deleteSubject } from '@/api/Subject.js';\nexport default {\n  name: 'SubjectsAdmin',\n  components: {\n    AdminSidebar,\n    AdminHeader\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      subjects: [],\n      searchQuery: '',\n      showCreateSubjectModal: false,\n      newSubject: {\n        name: '',\n        category: '',\n        difficulty: 'easy',\n        featured: false\n      }\n    };\n  },\n  computed: {\n    filteredSubjects() {\n      if (!this.subjects || !Array.isArray(this.subjects)) return [];\n      if (!this.searchQuery) return this.subjects;\n      return this.subjects.filter(subject => subject && subject.name && subject.category && (subject.name.toLowerCase().includes(this.searchQuery.toLowerCase()) || subject.category.toLowerCase().includes(this.searchQuery.toLowerCase())));\n    }\n  },\n  mounted() {\n    this.fetchSubjects();\n  },\n  methods: {\n    async fetchSubjects() {\n      try {\n        this.subjects = await getAllSubjects();\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n      }\n    },\n    async createSubject() {\n      try {\n        await createSubject(this.newSubject);\n        await this.fetchSubjects();\n        this.showCreateSubjectModal = false;\n        this.newSubject = {\n          name: '',\n          category: '',\n          difficulty: 'easy',\n          featured: false\n        };\n      } catch (error) {\n        console.error('Error creating subject:', error);\n      }\n    },\n    editSubject(subject) {\n      // Implementation for edit functionality\n      console.log('Edit subject:', subject);\n    },\n    async deleteSubject(subjectId) {\n      if (confirm('Are you sure you want to delete this subject?')) {\n        try {\n          await deleteSubject(subjectId);\n          await this.fetchSubjects();\n        } catch (error) {\n          console.error('Error deleting subject:', error);\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    getDifficultyBadgeClass(difficulty) {\n      const classes = {\n        'easy': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-200',\n        'medium': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200',\n        'hard': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-200'\n      };\n      return classes[difficulty] || 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200';\n    },\n    getFeaturedBadgeClass(featured) {\n      return featured ? 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200' : 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200';\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminSidebar","AdminHeader","getAllSubjects","createSubject","deleteSubject","name","components","data","currentUser","JSON","parse","localStorage","getItem","subjects","searchQuery","showCreateSubjectModal","newSubject","category","difficulty","featured","computed","filteredSubjects","Array","isArray","filter","subject","toLowerCase","includes","mounted","fetchSubjects","methods","error","console","editSubject","log","subjectId","confirm","formatDate","date","Date","toLocaleDateString","getDifficultyBadgeClass","classes","getFeaturedBadgeClass","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\SubjectsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-page\">\r\n    <AdminSidebar />\r\n\r\n    <AdminHeader \r\n      title=\"Subjects\" \r\n      icon-class=\"fas fa-book\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n    <main class=\"admin-content\">\r\n      <!-- Content Area -->\r\n    <div class=\"space-y-6\">\r\n      <!-- Header Section -->\r\n      <div class=\"bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6\">\r\n        <div class=\"flex flex-col sm:flex-row sm:items-center sm:justify-between space-y-4 sm:space-y-0\">\r\n          <div>\r\n            <h2 class=\"text-section-header text-gray-900 dark:text-white\">Subjects Management</h2>\r\n            <p class=\"text-body text-gray-600 dark:text-gray-400 mt-1\">Manage educational subjects and categories</p>\r\n          </div>\r\n          <div class=\"flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-3\">\r\n            <!-- Search Bar -->\r\n            <div class=\"relative\">\r\n              <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\r\n                <i class=\"fas fa-search text-gray-400 text-sm\"></i>\r\n              </div>\r\n              <input \r\n                v-model=\"searchQuery\" \r\n                type=\"text\" \r\n                placeholder=\"Search subjects...\"\r\n                class=\"w-full sm:w-64 pl-10 pr-4 py-2 text-body border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent\"\r\n              >\r\n            </div>\r\n            <!-- Add Subject Button -->\r\n            <button \r\n              @click=\"showCreateSubjectModal = true\" \r\n              class=\"btn-primary inline-flex items-center\"\r\n            >\r\n              <i class=\"fas fa-plus mr-2\"></i>\r\n              Add Subject\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Subjects Table -->\r\n      <div class=\"chart-container overflow-hidden\">\r\n        <div class=\"overflow-x-auto\">\r\n          <table class=\"w-full\">\r\n            <thead class=\"bg-gray-50 dark:bg-gray-700\">\r\n              <tr>\r\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">ID</th>\r\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Name</th>\r\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Category</th>\r\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Difficulty</th>\r\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Featured</th>\r\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Created</th>\r\n                <th class=\"px-6 py-3 text-left text-small font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider\">Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody class=\"bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700\">\r\n              <tr v-for=\"subject in filteredSubjects\" :key=\"subject._id\" class=\"hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200\">\r\n                <td class=\"px-6 py-4 whitespace-nowrap text-body font-mono text-gray-500 dark:text-gray-400\">\r\n                  {{ subject._id ? subject._id.slice(-6) : 'N/A' }}\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                  <div class=\"text-body font-medium text-gray-900 dark:text-white\">{{ subject.name || 'N/A' }}</div>\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                  <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200\">\r\n                    {{ subject.category || 'N/A' }}\r\n                  </span>\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                  <span :class=\"getDifficultyBadgeClass(subject.difficulty)\">\r\n                    {{ subject.difficulty ? subject.difficulty.toUpperCase() : 'N/A' }}\r\n                  </span>\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap\">\r\n                  <span :class=\"getFeaturedBadgeClass(subject.featured)\">\r\n                    <i :class=\"subject.featured ? 'fas fa-star' : 'far fa-star'\" class=\"mr-1\"></i>\r\n                    {{ subject.featured ? 'Featured' : 'Standard' }}\r\n                  </span>\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap text-body text-gray-500 dark:text-gray-400\">\r\n                  {{ formatDate(subject.createdAt) }}\r\n                </td>\r\n                <td class=\"px-6 py-4 whitespace-nowrap text-body font-medium\">\r\n                  <div class=\"flex space-x-2\">\r\n                    <button \r\n                      @click=\"editSubject(subject)\" \r\n                      class=\"inline-flex items-center p-2 text-primary hover:bg-blue-100 dark:hover:bg-blue-900/20 rounded-lg transition-colors duration-200\"\r\n                      title=\"Edit Subject\"\r\n                    >\r\n                      <i class=\"fas fa-edit text-sm\"></i>\r\n                    </button>\r\n                    <button \r\n                      @click=\"deleteSubject(subject._id)\" \r\n                      class=\"inline-flex items-center p-2 text-error hover:bg-red-100 dark:hover:bg-red-900/20 rounded-lg transition-colors duration-200\"\r\n                      title=\"Delete Subject\"\r\n                    >\r\n                      <i class=\"fas fa-trash text-sm\"></i>\r\n                    </button>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n              <tr v-if=\"filteredSubjects.length === 0\">\r\n                <td colspan=\"7\" class=\"px-6 py-12 text-center\">\r\n                  <div class=\"flex flex-col items-center\">\r\n                    <i class=\"fas fa-book text-4xl text-gray-300 dark:text-gray-600 mb-4\"></i>\r\n                    <p class=\"text-gray-500 dark:text-gray-400 text-lg font-medium\">No subjects found</p>\r\n                    <p class=\"text-gray-400 dark:text-gray-500 text-sm mt-1\">Get started by creating your first subject</p>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Create Subject Modal -->\r\n    <div v-if=\"showCreateSubjectModal\" class=\"modal-overlay\">\r\n      <div class=\"flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0\">\r\n        <div class=\"fixed inset-0 transition-opacity bg-gray-500 bg-opacity-75 dark:bg-gray-900 dark:bg-opacity-75\" @click=\"showCreateSubjectModal = false\"></div>\r\n        \r\n        <div class=\"modal-content max-w-md w-full p-6 my-8\">\r\n          <div class=\"flex items-center justify-between mb-6\">\r\n            <h3 class=\"text-section-header text-gray-900 dark:text-white\">Create New Subject</h3>\r\n            <button \r\n              @click=\"showCreateSubjectModal = false\" \r\n              class=\"p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors duration-200\"\r\n            >\r\n              <i class=\"fas fa-times\"></i>\r\n            </button>\r\n          </div>\r\n          \r\n          <form @submit.prevent=\"createSubject\" class=\"space-y-4\">\r\n            <div>\r\n              <label class=\"block text-body font-medium text-gray-700 dark:text-gray-300 mb-2\">Subject Name</label>\r\n              <input \r\n                v-model=\"newSubject.name\" \r\n                type=\"text\" \r\n                required\r\n                class=\"w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-body\"\r\n                placeholder=\"Enter subject name\"\r\n              >\r\n            </div>\r\n            \r\n            <div>\r\n              <label class=\"block text-body font-medium text-gray-700 dark:text-gray-300 mb-2\">Category</label>\r\n              <input \r\n                v-model=\"newSubject.category\" \r\n                type=\"text\" \r\n                required\r\n                class=\"w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-body\"\r\n                placeholder=\"Enter category\"\r\n              >\r\n            </div>\r\n            \r\n            <div>\r\n              <label class=\"block text-body font-medium text-gray-700 dark:text-gray-300 mb-2\">Difficulty Level</label>\r\n              <select \r\n                v-model=\"newSubject.difficulty\" \r\n                class=\"w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-body\"\r\n              >\r\n                <option value=\"easy\">Easy</option>\r\n                <option value=\"medium\">Medium</option>\r\n                <option value=\"hard\">Hard</option>\r\n              </select>\r\n            </div>\r\n            \r\n            <div class=\"flex items-center\">\r\n              <input \r\n                v-model=\"newSubject.featured\" \r\n                type=\"checkbox\" \r\n                id=\"featured\"\r\n                class=\"w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600\"\r\n              >\r\n              <label for=\"featured\" class=\"ml-2 text-body font-medium text-gray-700 dark:text-gray-300\">\r\n                Featured Subject\r\n              </label>\r\n            </div>\r\n            \r\n            <div class=\"flex space-x-3 pt-4\">\r\n              <button \r\n                type=\"button\" \r\n                @click=\"showCreateSubjectModal = false\" \r\n                class=\"btn-secondary flex-1\"\r\n              >\r\n                Cancel\r\n              </button>\r\n              <button \r\n                type=\"submit\" \r\n                class=\"btn-primary flex-1\"\r\n              >\r\n                Create Subject\r\n              </button>\r\n            </div>\r\n          </form>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    </main>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport AdminSidebar from '@/components/admin/AdminSidebar.vue'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\nimport { getAllSubjects, createSubject, deleteSubject } from '@/api/Subject.js'\r\n\r\nexport default {\r\n  name: 'SubjectsAdmin',\r\n  components: {\r\n    AdminSidebar,\r\n    AdminHeader\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      subjects: [],\r\n      searchQuery: '',\r\n      showCreateSubjectModal: false,\r\n      newSubject: {\r\n        name: '',\r\n        category: '',\r\n        difficulty: 'easy',\r\n        featured: false\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredSubjects() {\r\n      if (!this.subjects || !Array.isArray(this.subjects)) return []\r\n      if (!this.searchQuery) return this.subjects\r\n      return this.subjects.filter(subject => \r\n        subject && subject.name && subject.category &&\r\n        (subject.name.toLowerCase().includes(this.searchQuery.toLowerCase()) ||\r\n        subject.category.toLowerCase().includes(this.searchQuery.toLowerCase()))\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchSubjects()\r\n  },\r\n  methods: {\r\n    async fetchSubjects() {\r\n      try {\r\n        this.subjects = await getAllSubjects()\r\n      } catch (error) {\r\n        console.error('Error fetching subjects:', error)\r\n      }\r\n    },\r\n    async createSubject() {\r\n      try {\r\n        await createSubject(this.newSubject)\r\n        await this.fetchSubjects()\r\n        this.showCreateSubjectModal = false\r\n        this.newSubject = { name: '', category: '', difficulty: 'easy', featured: false }\r\n      } catch (error) {\r\n        console.error('Error creating subject:', error)\r\n      }\r\n    },\r\n    editSubject(subject) {\r\n      // Implementation for edit functionality\r\n      console.log('Edit subject:', subject)\r\n    },\r\n    async deleteSubject(subjectId) {\r\n      if (confirm('Are you sure you want to delete this subject?')) {\r\n        try {\r\n          await deleteSubject(subjectId)\r\n          await this.fetchSubjects()\r\n        } catch (error) {\r\n          console.error('Error deleting subject:', error)\r\n        }\r\n      }\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    getDifficultyBadgeClass(difficulty) {\r\n      const classes = {\r\n        'easy': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/20 text-green-800 dark:text-green-200',\r\n        'medium': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200',\r\n        'hard': 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/20 text-red-800 dark:text-red-200'\r\n      }\r\n      return classes[difficulty] || 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200'\r\n    },\r\n    getFeaturedBadgeClass(featured) {\r\n      return featured \r\n        ? 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 dark:bg-yellow-900/20 text-yellow-800 dark:text-yellow-200'\r\n        : 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200'\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n@import '@/styles/admin/design-system.css';\r\n</style>"],"mappings":"AAgNA,OAAOA,YAAW,MAAO,qCAAoC;AAC7D,OAAOC,WAAU,MAAO,oCAAmC;AAC3D,SAASC,cAAc,EAAEC,aAAa,EAAEC,aAAY,QAAS,kBAAiB;AAE9E,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACVN,YAAY;IACZC;EACF,CAAC;EACDM,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,QAAQ,EAAE,EAAE;MACZC,WAAW,EAAE,EAAE;MACfC,sBAAsB,EAAE,KAAK;MAC7BC,UAAU,EAAE;QACVX,IAAI,EAAE,EAAE;QACRY,QAAQ,EAAE,EA