{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport '@/styles/admin/admin.css';\nimport '@/styles/admin/admin-modal.css';\nexport default {\n  name: 'QuestionsAdmin',\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      questions: [],\n      subjects: [],\n      searchQuery: '',\n      showCreateQuestionModal: false,\n      newQuestion: {\n        question: '',\n        subjectId: '',\n        levelId: 1,\n        type: 'multiple-choice'\n      }\n    };\n  },\n  computed: {\n    filteredQuestions() {\n      if (!this.searchQuery) return this.questions;\n      return this.questions.filter(question => question.question.toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchQuestions();\n    this.fetchSubjects();\n  },\n  methods: {\n    async fetchQuestions() {\n      try {\n        const response = await fetch('/api/admin/questions', {\n          headers: {\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          }\n        });\n        if (response.ok) {\n          this.questions = await response.json();\n        }\n      } catch (error) {\n        console.error('Error fetching questions:', error);\n      }\n    },\n    async fetchSubjects() {\n      try {\n        const response = await fetch('/api/admin/subjects', {\n          headers: {\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          }\n        });\n        if (response.ok) {\n          this.subjects = await response.json();\n        }\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n      }\n    },\n    getSubjectName(subjectId) {\n      const subject = this.subjects.find(s => s._id === subjectId);\n      return subject ? subject.name : 'Unknown';\n    },\n    async createQuestion() {\n      try {\n        const response = await fetch('/api/admin/questions', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          },\n          body: JSON.stringify(this.newQuestion)\n        });\n        if (response.ok) {\n          await this.fetchQuestions();\n          this.showCreateQuestionModal = false;\n          this.newQuestion = {\n            question: '',\n            subjectId: '',\n            levelId: 1,\n            type: 'multiple-choice'\n          };\n        }\n      } catch (error) {\n        console.error('Error creating question:', error);\n      }\n    },\n    editQuestion(question) {\n      console.log('Edit question:', question);\n    },\n    async deleteQuestion(questionId) {\n      if (confirm('Are you sure you want to delete this question?')) {\n        try {\n          const response = await fetch(`/api/admin/questions/${questionId}`, {\n            method: 'DELETE',\n            headers: {\n              'Authorization': `Bearer ${localStorage.getItem('token')}`\n            }\n          });\n          if (response.ok) {\n            await this.fetchQuestions();\n          }\n        } catch (error) {\n          console.error('Error deleting question:', error);\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["name","data","currentUser","JSON","parse","localStorage","getItem","questions","subjects","searchQuery","showCreateQuestionModal","newQuestion","question","subjectId","levelId","type","computed","filteredQuestions","filter","toLowerCase","includes","mounted","fetchQuestions","fetchSubjects","methods","response","fetch","headers","ok","json","error","console","getSubjectName","subject","find","s","_id","createQuestion","method","body","stringify","editQuestion","log","deleteQuestion","questionId","confirm","formatDate","date","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\QuestionsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-dashboard admin-space-background\">\r\n    <!-- Animated particles -->\r\n    <div class=\"admin-particles\"></div>\r\n    \r\n    <!-- Header -->\r\n    <div class=\"admin-header\">\r\n      <h1 class=\"admin-title\">\r\n        <i class=\"fas fa-question-circle\"></i>\r\n        Question Management\r\n      </h1>\r\n      <div class=\"admin-user-info\">\r\n        <span>Welcome, {{ currentUser.username }}</span>\r\n        <button @click=\"logout\" class=\"logout-btn\">\r\n          <i class=\"fas fa-sign-out-alt\"></i>\r\n          Logout\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Navigation Tabs -->\r\n    <div class=\"admin-nav\">\r\n      <router-link to=\"/admin/users\" class=\"nav-tab\">\r\n        <i class=\"fas fa-users\"></i>\r\n        Users\r\n      </router-link>\r\n      <router-link to=\"/admin/subjects\" class=\"nav-tab\">\r\n        <i class=\"fas fa-book\"></i>\r\n        Subjects\r\n      </router-link>\r\n      <router-link to=\"/admin/questions\" class=\"nav-tab active\">\r\n        <i class=\"fas fa-question-circle\"></i>\r\n        Questions\r\n      </router-link>\r\n      <router-link to=\"/admin/exams\" class=\"nav-tab\">\r\n        <i class=\"fas fa-clipboard-list\"></i>\r\n        Exams\r\n      </router-link>\r\n      <router-link to=\"/admin/ai-health\" class=\"nav-tab\">\r\n        <i class=\"fas fa-robot\"></i>\r\n        AI Health\r\n      </router-link>\r\n      <router-link to=\"/admin/stats\" class=\"nav-tab\">\r\n        <i class=\"fas fa-chart-bar\"></i>\r\n        Statistics\r\n      </router-link>\r\n      <router-link to=\"/admin/system\" class=\"nav-tab\">\r\n        <i class=\"fas fa-cog\"></i>\r\n        System\r\n      </router-link>\r\n    </div>\r\n\r\n    <!-- Content Area -->\r\n    <div class=\"admin-content\">\r\n      <div class=\"tab-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Question Management</h2>\r\n          <div class=\"header-actions\">\r\n            <div class=\"search-bar\">\r\n              <input \r\n                v-model=\"searchQuery\" \r\n                type=\"text\" \r\n                placeholder=\"Search questions...\"\r\n                class=\"search-input\"\r\n              >\r\n              <i class=\"fas fa-search search-icon\"></i>\r\n            </div>\r\n            <button @click=\"showCreateQuestionModal = true\" class=\"btn-create\">\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add Question\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"table-container\">\r\n          <table class=\"admin-table\">\r\n            <thead>\r\n              <tr>\r\n                <th>ID</th>\r\n                <th>Question</th>\r\n                <th>Subject</th>\r\n                <th>Level</th>\r\n                <th>Type</th>\r\n                <th>Created</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"question in filteredQuestions\" :key=\"question._id\">\r\n                <td>{{ question._id.slice(-6) }}</td>\r\n                <td>{{ question.question.substring(0, 50) }}...</td>\r\n                <td>{{ getSubjectName(question.subjectId) }}</td>\r\n                <td>{{ question.levelId }}</td>\r\n                <td>{{ question.type }}</td>\r\n                <td>{{ formatDate(question.createdAt) }}</td>\r\n                <td>\r\n                  <div class=\"action-buttons\">\r\n                    <button @click=\"editQuestion(question)\" class=\"btn-edit\">\r\n                      <i class=\"fas fa-edit\"></i>\r\n                    </button>\r\n                    <button @click=\"deleteQuestion(question._id)\" class=\"btn-delete\">\r\n                      <i class=\"fas fa-trash\"></i>\r\n                    </button>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Create Question Modal -->\r\n    <div v-if=\"showCreateQuestionModal\" class=\"modal-overlay\" @click=\"showCreateQuestionModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Create New Question</h3>\r\n          <button @click=\"showCreateQuestionModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Question</label>\r\n            <textarea v-model=\"newQuestion.question\" class=\"form-input\" rows=\"3\" required></textarea>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Subject</label>\r\n            <select v-model=\"newQuestion.subjectId\" class=\"form-select\" required>\r\n              <option value=\"\">Select Subject</option>\r\n              <option v-for=\"subject in subjects\" :key=\"subject._id\" :value=\"subject._id\">\r\n                {{ subject.name }}\r\n              </option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Level</label>\r\n            <input v-model=\"newQuestion.levelId\" type=\"number\" min=\"1\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Type</label>\r\n            <select v-model=\"newQuestion.type\" class=\"form-select\">\r\n              <option value=\"multiple-choice\">Multiple Choice</option>\r\n              <option value=\"true-false\">True/False</option>\r\n              <option value=\"short-answer\">Short Answer</option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showCreateQuestionModal = false\" class=\"btn-cancel\">Cancel</button>\r\n          <button @click=\"createQuestion\" class=\"btn-save\">Create Question</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport '@/styles/admin/admin.css'\r\nimport '@/styles/admin/admin-modal.css'\r\n\r\nexport default {\r\n  name: 'QuestionsAdmin',\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      questions: [],\r\n      subjects: [],\r\n      searchQuery: '',\r\n      showCreateQuestionModal: false,\r\n      newQuestion: {\r\n        question: '',\r\n        subjectId: '',\r\n        levelId: 1,\r\n        type: 'multiple-choice'\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredQuestions() {\r\n      if (!this.searchQuery) return this.questions\r\n      return this.questions.filter(question => \r\n        question.question.toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchQuestions()\r\n    this.fetchSubjects()\r\n  },\r\n  methods: {\r\n    async fetchQuestions() {\r\n      try {\r\n        const response = await fetch('/api/admin/questions', {\r\n          headers: {\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          }\r\n        })\r\n        if (response.ok) {\r\n          this.questions = await response.json()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error fetching questions:', error)\r\n      }\r\n    },\r\n    async fetchSubjects() {\r\n      try {\r\n        const response = await fetch('/api/admin/subjects', {\r\n          headers: {\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          }\r\n        })\r\n        if (response.ok) {\r\n          this.subjects = await response.json()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error fetching subjects:', error)\r\n      }\r\n    },\r\n    getSubjectName(subjectId) {\r\n      const subject = this.subjects.find(s => s._id === subjectId)\r\n      return subject ? subject.name : 'Unknown'\r\n    },\r\n    async createQuestion() {\r\n      try {\r\n        const response = await fetch('/api/admin/questions', {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          },\r\n          body: JSON.stringify(this.newQuestion)\r\n        })\r\n        if (response.ok) {\r\n          await this.fetchQuestions()\r\n          this.showCreateQuestionModal = false\r\n          this.newQuestion = { question: '', subjectId: '', levelId: 1, type: 'multiple-choice' }\r\n        }\r\n      } catch (error) {\r\n        console.error('Error creating question:', error)\r\n      }\r\n    },\r\n    editQuestion(question) {\r\n      console.log('Edit question:', question)\r\n    },\r\n    async deleteQuestion(questionId) {\r\n      if (confirm('Are you sure you want to delete this question?')) {\r\n        try {\r\n          const response = await fetch(`/api/admin/questions/${questionId}`, {\r\n            method: 'DELETE',\r\n            headers: {\r\n              'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n            }\r\n          })\r\n          if (response.ok) {\r\n            await this.fetchQuestions()\r\n          }\r\n        } catch (error) {\r\n          console.error('Error deleting question:', error)\r\n        }\r\n      }\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;;AA8JA,OAAO,0BAAyB;AAChC,OAAO,gCAA+B;AAEtC,eAAe;EACbA,IAAI,EAAE,gBAAgB;EACtBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,SAAS,EAAE,EAAE;MACbC,QAAQ,EAAE,EAAE;MACZC,WAAW,EAAE,EAAE;MACfC,uBAAuB,EAAE,KAAK;MAC9BC,WAAW,EAAE;QACXC,QAAQ,EAAE,EAAE;QACZC,SAAS,EAAE,EAAE;QACbC,OAAO,EAAE,CAAC;QACVC,IAAI,EAAE;MACR;IACF;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,iBAAiBA,CAAA,EAAG;MAClB,IAAI,CAAC,IAAI,CAACR,WAAW,EAAE,OAAO,IAAI,CAACF,SAAQ;MAC3C,OAAO,IAAI,CAACA,SAAS,CAACW,MAAM,CAACN,QAAO,IAClCA,QAAQ,CAACA,QAAQ,CAACO,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAACX,WAAW,CAACU,WAAW,CAAC,CAAC,CACzE;IACF;EACF,CAAC;EACDE,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,cAAc,CAAC;IACpB,IAAI,CAACC,aAAa,CAAC;EACrB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMF,cAAcA,CAAA,EAAG;MACrB,IAAI;QACF,MAAMG,QAAO,GAAI,MAAMC,KAAK,CAAC,sBAAsB,EAAE;UACnDC,OAAO,EAAE;YACP,eAAe,EAAE,UAAUtB,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;UAC1D;QACF,CAAC;QACD,IAAImB,QAAQ,CAACG,EAAE,EAAE;UACf,IAAI,CAACrB,SAAQ,GAAI,MAAMkB,QAAQ,CAACI,IAAI,CAAC;QACvC;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,2BAA2B,EAAEA,KAAK;MAClD;IACF,CAAC;IACD,MAAMP,aAAaA,CAAA,EAAG;MACpB,IAAI;QACF,MAAME,QAAO,GAAI,MAAMC,KAAK,CAAC,qBAAqB,EAAE;UAClDC,OAAO,EAAE;YACP,eAAe,EAAE,UAAUtB,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;UAC1D;QACF,CAAC;QACD,IAAImB,QAAQ,CAACG,EAAE,EAAE;UACf,IAAI,CAACpB,QAAO,GAAI,MAAMiB,QAAQ,CAACI,IAAI,CAAC;QACtC;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,0BAA0B,EAAEA,KAAK;MACjD;IACF,CAAC;IACDE,cAAcA,CAACnB,SAAS,EAAE;MACxB,MAAMoB,OAAM,GAAI,IAAI,CAACzB,QAAQ,CAAC0B,IAAI,CAACC,CAAA,IAAKA,CAAC,CAACC,GAAE,KAAMvB,SAAS;MAC3D,OAAOoB,OAAM,GAAIA,OAAO,CAACjC,IAAG,GAAI,SAAQ;IAC1C,CAAC;IACD,MAAMqC,cAAcA,CAAA,EAAG;MACrB,IAAI;QACF,MAAMZ,QAAO,GAAI,MAAMC,KAAK,CAAC,sBAAsB,EAAE;UACnDY,MAAM,EAAE,MAAM;UACdX,OAAO,EAAE;YACP,cAAc,EAAE,kBAAkB;YAClC,eAAe,EAA