{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.map.js\";\nimport \"core-js/modules/web.dom-exception.stack.js\";\nimport { getAccount } from '../api/Account.js';\nimport { getQuickPracticeExams, getAvailableExams, getExamResults, getUpcomingExams } from '../api/Exams.js';\nimport Sidebar from '../components/Sidebar.vue';\nexport default {\n  name: 'Exams',\n  components: {\n    Sidebar\n  },\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      examStats: {\n        completedExams: 0,\n        averageScore: 0,\n        totalTime: 0\n      },\n      quickPractice: [],\n      availableExams: [],\n      recentResults: [],\n      upcomingExams: [],\n      loading: true,\n      error: null\n    };\n  },\n  async mounted() {\n    await this.loadExamsData();\n  },\n  methods: {\n    getParticleSize(index) {\n      const sizes = ['small', 'medium', 'large'];\n      return sizes[index % 3];\n    },\n    getParticleColor(index) {\n      const colors = ['blue', 'purple', 'pink', 'cyan'];\n      return colors[index % 4];\n    },\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    async loadExamsData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        this.userId = userId;\n\n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n\n        // Load exam statistics\n        this.examStats = {\n          completedExams: accountData.completedExams || 0,\n          averageScore: accountData.averageExamScore || 0,\n          totalTime: accountData.totalExamTime || 0\n        };\n\n        // Load quick practice options from API\n        try {\n          const practiceData = await getQuickPracticeExams();\n          this.quickPractice = practiceData.map(practice => ({\n            ...practice,\n            icon: this.getSubjectIcon(practice.subject)\n          }));\n        } catch (practiceError) {\n          console.warn('Could not load quick practice data:', practiceError);\n          this.quickPractice = this.getDefaultQuickPractice();\n        }\n\n        // Load available exams from API\n        try {\n          const examsData = await getAvailableExams(userId);\n          this.availableExams = examsData.map(exam => ({\n            ...exam,\n            subjectIcon: this.getSubjectIcon(exam.subject)\n          }));\n        } catch (examsError) {\n          console.warn('Could not load available exams:', examsError);\n          this.availableExams = this.getDefaultAvailableExams();\n        }\n\n        // Load recent exam results from API\n        try {\n          const resultsData = await getExamResults(userId);\n          this.recentResults = resultsData.slice(0, 5).map(result => ({\n            ...result,\n            completedAt: new Date(result.completedAt),\n            grade: this.calculateGrade(result.score)\n          }));\n        } catch (resultsError) {\n          console.warn('Could not load exam results:', resultsError);\n          this.recentResults = [];\n        }\n\n        // Load upcoming scheduled exams from API\n        try {\n          const upcomingData = await getUpcomingExams(userId);\n          this.upcomingExams = upcomingData.map(exam => ({\n            ...exam,\n            scheduledDate: new Date(exam.scheduledDate)\n          }));\n        } catch (upcomingError) {\n          console.warn('Could not load upcoming exams:', upcomingError);\n          this.upcomingExams = [];\n        }\n      } catch (error) {\n        console.error('Error loading exams data:', error);\n        this.error = 'Failed to load exams data';\n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    startPractice(practice) {\n      console.log('Starting practice:', practice.title);\n      alert(`Starting ${practice.title} practice session`);\n    },\n    startExam(exam) {\n      if (!exam.available) {\n        alert('This exam is not available yet. Please complete the requirements first.');\n        return;\n      }\n      console.log('Starting exam:', exam.title);\n      alert(`Starting exam: ${exam.title}`);\n    },\n    viewExamDetails(exam) {\n      console.log('Viewing exam details:', exam.title);\n      alert(`Viewing details for: ${exam.title}`);\n    },\n    viewResultDetails(result) {\n      console.log('Viewing result details:', result.examTitle);\n      alert(`Viewing detailed results for: ${result.examTitle}`);\n    },\n    retakeExam(result) {\n      console.log('Retaking exam:', result.examTitle);\n      alert(`Retaking exam: ${result.examTitle}`);\n    },\n    setReminder(upcoming) {\n      upcoming.reminderSet = !upcoming.reminderSet;\n      console.log('Reminder set for:', upcoming.title, upcoming.reminderSet);\n    },\n    formatDate(date) {\n      return date.toLocaleDateString('en-US', {\n        year: 'numeric',\n        month: 'short',\n        day: 'numeric'\n      });\n    },\n    formatDay(date) {\n      return date.getDate().toString().padStart(2, '0');\n    },\n    formatMonth(date) {\n      return date.toLocaleDateString('en-US', {\n        month: 'short'\n      }).toUpperCase();\n    },\n    getScoreClass(score) {\n      if (score >= 90) return 'excellent';\n      if (score >= 80) return 'good';\n      if (score >= 70) return 'average';\n      return 'poor';\n    },\n    getGradeClass(grade) {\n      if (grade.startsWith('A')) return 'grade-a';\n      if (grade.startsWith('B')) return 'grade-b';\n      if (grade.startsWith('C')) return 'grade-c';\n      return 'grade-d';\n    },\n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    },\n    getSubjectIcon(subject) {\n      const iconMap = {\n        'Programming': 'fab fa-js-square',\n        'Database': 'fas fa-database',\n        'Web Development': 'fas fa-globe',\n        'Computer Science': 'fas fa-laptop-code',\n        'Mathematics': 'fas fa-calculator',\n        'Science': 'fas fa-flask'\n      };\n      return iconMap[subject] || 'fas fa-book';\n    },\n    calculateGrade(score) {\n      if (score >= 97) return 'A+';\n      if (score >= 93) return 'A';\n      if (score >= 90) return 'A-';\n      if (score >= 87) return 'B+';\n      if (score >= 83) return 'B';\n      if (score >= 80) return 'B-';\n      if (score >= 77) return 'C+';\n      if (score >= 73) return 'C';\n      if (score >= 70) return 'C-';\n      if (score >= 67) return 'D+';\n      if (score >= 65) return 'D';\n      return 'F';\n    },\n    getDefaultQuickPractice() {\n      return [{\n        id: 1,\n        title: 'JavaScript Basics',\n        description: 'Quick review of JavaScript fundamentals',\n        subject: 'Programming',\n        duration: 10,\n        questions: 15\n      }, {\n        id: 2,\n        title: 'Database Queries',\n        description: 'Practice SQL queries and database concepts',\n        subject: 'Database',\n        duration: 15,\n        questions: 20\n      }, {\n        id: 3,\n        title: 'Web Development',\n        description: 'HTML, CSS, and web development principles',\n        subject: 'Web Development',\n        duration: 12,\n        questions: 18\n      }];\n    },\n    getDefaultAvailableExams() {\n      return [{\n        id: 1,\n        title: 'JavaScript Advanced Concepts',\n        subject: 'Programming',\n        description: 'Comprehensive exam covering advanced JavaScript topics.',\n        duration: 90,\n        questions: 50,\n        points: 100,\n        difficulty: 'Advanced',\n        available: true,\n        requirements: ['Complete JavaScript Fundamentals course']\n      }];\n    }\n  }\n};","map":{"version":3,"names":["getAccount","getQuickPracticeExams","getAvailableExams","getExamResults","getUpcomingExams","Sidebar","name","components","data","userName","userLevel","userId","examStats","completedExams","averageScore","totalTime","quickPractice","availableExams","recentResults","upcomingExams","loading","error","mounted","loadExamsData","methods","getParticleSize","index","sizes","getParticleColor","colors","getUserIdFromToken","token","localStorage","getItem","payload","JSON","parse","atob","split","id","console","Error","accountData","username","currentLevel","averageExamScore","totalExamTime","practiceData","map","practice","icon","getSubjectIcon","subject","practiceError","warn","getDefaultQuickPractice","examsData","exam","subjectIcon","examsError","getDefaultAvailableExams","resultsData","slice","result","completedAt","Date","grade","calculateGrade","score","resultsError","upcomingData","scheduledDate","upcomingError","message","includes","response","status","removeItem","$router","push","startPractice","log","title","alert","startExam","available","viewExamDetails","viewResultDetails","examTitle","retakeExam","setReminder","upcoming","reminderSet","formatDate","date","toLocaleDateString","year","month","day","formatDay","getDate","toString","padStart","formatMonth","toUpperCase","getScoreClass","getGradeClass","startsWith","logout","iconMap","description","duration","questions","points","difficulty","requirements"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\Exams.vue"],"sourcesContent":["<template>\n  <div class=\"exams-container space-background\">\n    <!-- Space Particles -->\n    <div class=\"space-particles\">\n      <div v-for=\"i in 20\" :key=\"i\" \n           :class=\"`particle particle-${i} ${getParticleSize(i)} ${getParticleColor(i)}`\">\n      </div>\n    </div>\n    <!-- Loading State -->\n    <div v-if=\"loading\" class=\"loading-container\">\n      <div class=\"loading-spinner\"><i class=\"fas fa-spinner fa-spin\"></i></div>\n      <p>Loading exams...</p>\n    </div>\n    \n    <!-- Error State -->\n    <div v-else-if=\"error\" class=\"error-container\">\n      <div class=\"error-icon\"><i class=\"fas fa-exclamation-triangle\"></i></div>\n      <p>{{ error }}</p>\n      <button @click=\"loadExamsData\" class=\"retry-btn\">Try Again</button>\n    </div>\n    \n    <!-- Main Exams Content -->\n    <template v-else>\n      <!-- Sidebar -->\n      <Sidebar \n        :user-name=\"userName\" \n        :user-level=\"userLevel\" \n        current-page=\"exams\"\n        @logout=\"logout\"\n      />\n      \n      <!-- Main Content -->\n      <div class=\"main-content\">\n        <header class=\"exams-header\">\n          <div class=\"header-content space-glow\">\n            <h1><i class=\"fas fa-file-alt\"></i> Exams & Assessments</h1>\n            <p>Test your knowledge and track your progress</p>\n          </div>\n          <div class=\"exam-stats\">\n            <div class=\"stat-item\">\n              <i class=\"fas fa-trophy\"></i>\n              <span>{{ examStats.completedExams }} completed</span>\n            </div>\n            <div class=\"stat-item\">\n              <i class=\"fas fa-percentage\"></i>\n              <span>{{ examStats.averageScore }}% avg score</span>\n            </div>\n            <div class=\"stat-item\">\n              <i class=\"fas fa-clock\"></i>\n              <span>{{ examStats.totalTime }} min studied</span>\n            </div>\n          </div>\n        </header>\n        \n        <!-- Exam Sections -->\n        <div class=\"exam-sections\">\n          <!-- Quick Practice -->\n          <div class=\"exam-section\">\n            <h2><i class=\"fas fa-bolt\"></i> Quick Practice</h2>\n            <div class=\"quick-practice-grid\">\n              <div v-for=\"practice in quickPractice\" :key=\"practice.id\" class=\"practice-card\">\n                <div class=\"practice-icon\">\n                  <i :class=\"practice.icon\"></i>\n                </div>\n                <div class=\"practice-content\">\n                  <h3>{{ practice.title }}</h3>\n                  <p>{{ practice.description }}</p>\n                  <div class=\"practice-meta\">\n                    <span><i class=\"fas fa-clock\"></i> {{ practice.duration }} min</span>\n                    <span><i class=\"fas fa-question-circle\"></i> {{ practice.questions }} questions</span>\n                  </div>\n                </div>\n                <button @click=\"startPractice(practice)\" class=\"practice-btn\">\n                  <i class=\"fas fa-play\"></i> Start\n                </button>\n              </div>\n            </div>\n          </div>\n          \n          <!-- Available Exams -->\n          <div class=\"exam-section\">\n            <h2><i class=\"fas fa-clipboard-list\"></i> Available Exams</h2>\n            <div class=\"exams-grid\">\n              <div v-for=\"exam in availableExams\" :key=\"exam.id\" class=\"exam-card\">\n                <div class=\"exam-header\">\n                  <div class=\"exam-subject\">\n                    <i :class=\"exam.subjectIcon\"></i>\n                    <span>{{ exam.subject }}</span>\n                  </div>\n                  <div class=\"exam-difficulty\" :class=\"exam.difficulty.toLowerCase()\">\n                    {{ exam.difficulty }}\n                  </div>\n                </div>\n                <div class=\"exam-content\">\n                  <h3>{{ exam.title }}</h3>\n                  <p>{{ exam.description }}</p>\n                  <div class=\"exam-details\">\n                    <div class=\"detail-item\">\n                      <i class=\"fas fa-clock\"></i>\n                      <span>{{ exam.duration }} minutes</span>\n                    </div>\n                    <div class=\"detail-item\">\n                      <i class=\"fas fa-question-circle\"></i>\n                      <span>{{ exam.questions }} questions</span>\n                    </div>\n                    <div class=\"detail-item\">\n                      <i class=\"fas fa-star\"></i>\n                      <span>{{ exam.points }} points</span>\n                    </div>\n                  </div>\n                  <div class=\"exam-requirements\" v-if=\"exam.requirements\">\n                    <h4>Requirements:</h4>\n                    <ul>\n                      <li v-for=\"req in exam.requirements\" :key=\"req\">{{ req }}</li>\n                    </ul>\n                  </div>\n                </div>\n                <div class=\"exam-actions\">\n                  <button @click=\"startExam(exam)\" class=\"start-exam-btn\" :disabled=\"!exam.available\">\n                    <i class=\"fas fa-play\"></i> {{ exam.available ? 'Start Exam' : 'Locked' }}\n                  </button>\n                  <button @click=\"viewExamDetails(exam)\" class=\"details-btn\">\n                    <i class=\"fas fa-info-circle\"></i> Details\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <!-- Recent Results -->\n          <div class=\"exam-section\">\n            <h2><i class=\"fas fa-chart-bar\"></i> Recent Results</h2>\n            <div class=\"results-list\">\n              <div v-for=\"result in recentResults\" :key=\"result.id\" class=\"result-item\">\n                <div class=\"result-info\">\n                  <div class=\"result-header\">\n                    <h3>{{ result.examTitle }}</h3>\n                    <span class=\"result-date\">{{ formatDate(result.completedAt) }}</span>\n                  </div>\n                  <div class=\"result-details\">\n                    <span class=\"subject\">{{ result.subject }}</span>\n                    <span class=\"duration\"><i class=\"fas fa-clock\"></i> {{ result.duration }} min</span>\n                  </div>\n                </div>\n                <div class=\"result-score\">\n                  <div class=\"score-circle\" :class=\"getScoreClass(result.score)\">\n                    <span class=\"score-value\">{{ result.score }}%</span>\n                  </div>\n                  <div class=\"score-details\">\n                    <span>{{ result.correctAnswers }}/{{ result.totalQuestions }} correct</span>\n                    <span class=\"grade\" :class=\"getGradeClass(result.grade)\">{{ result.grade }}</span>\n                  </div>\n                </div>\n                <div class=\"result-actions\">\n                  <button @click=\"viewResultDetails(result)\" class=\"view-btn\">\n                    <i class=\"fas fa-eye\"></i> View\n                  </button>\n                  <button @click=\"retakeExam(result)\" class=\"retake-btn\">\n                    <i class=\"fas fa-redo\"></i> Retake\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n          \n          <!-- Upcoming Exams -->\n          <div class=\"exam-section\">\n            <h2><i class=\"fas fa-calendar\"></i> Upcoming Exams</h2>\n            <div class=\"upcoming-exams\">\n              <div v-for=\"upcoming in upcomingExams\" :key=\"upcoming.id\" class=\"upcoming-item\">\n                <div class=\"upcoming-date\">\n                  <div class=\"date-day\">{{ formatDay(upcoming.scheduledDate) }}</div>\n                  <div class=\"date-month\">{{ formatMonth(upcoming.scheduledDate) }}</div>\n                </div>\n                <div class=\"upcoming-info\">\n                  <h3>{{ upcoming.title }}</h3>\n                  <p>{{ upcoming.subject }}</p>\n                  <div class=\"upcoming-meta\">\n                    <span><i class=\"fas fa-clock\"></i> {{ upcoming.duration }} min</span>\n                    <span><i class=\"fas fa-users\"></i> {{ upcoming.participants }} students</span>\n                  </div>\n                </div>\n                <div class=\"upcoming-actions\">\n                  <button @click=\"setReminder(upcoming)\" class=\"reminder-btn\" :class=\"{ active: upcoming.reminderSet }\">\n                    <i class=\"fas fa-bell\"></i> {{ upcoming.reminderSet ? 'Reminder Set' : 'Set Reminder' }}\n                  </button>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </template>\n  </div>\n</template>\n\n<script>\nimport { getAccount } from '../api/Account.js';\nimport { getQuickPracticeExams, getAvailableExams, getExamResults, getUpcomingExams } from '../api/Exams.js';\nimport Sidebar from '../components/Sidebar.vue';\n\nexport default {\n  name: 'Exams',\n  components: {\n    Sidebar\n  },\n  data() {\n    return {\n      userName: 'Loading...',\n      userLevel: 1,\n      userId: null,\n      examStats: {\n        completedExams: 0,\n        averageScore: 0,\n        totalTime: 0\n      },\n      quickPractice: [],\n      availableExams: [],\n      recentResults: [],\n      upcomingExams: [],\n      loading: true,\n      error: null\n    }\n  },\n  async mounted() {\n    await this.loadExamsData();\n  },\n  methods: {\n    getParticleSize(index) {\n      const sizes = ['small', 'medium', 'large'];\n      return sizes[index % 3];\n    },\n    getParticleColor(index) {\n      const colors = ['blue', 'purple', 'pink', 'cyan'];\n      return colors[index % 4];\n    },\n    getUserIdFromToken() {\n      try {\n        const token = localStorage.getItem('token');\n        if (!token) return null;\n        const payload = JSON.parse(atob(token.split('.')[1]));\n        return payload.id;\n      } catch (error) {\n        console.error('Error decoding token:', error);\n        return null;\n      }\n    },\n    \n    async loadExamsData() {\n      try {\n        this.loading = true;\n        this.error = null;\n        \n        const userId = this.getUserIdFromToken();\n        if (!userId) {\n          throw new Error('No valid user token found');\n        }\n        \n        this.userId = userId;\n        \n        // Load user account data\n        const accountData = await getAccount(userId);\n        this.userName = accountData.username || 'User';\n        this.userLevel = accountData.currentLevel || 1;\n        \n        // Load exam statistics\n        this.examStats = {\n          completedExams: accountData.completedExams || 0,\n          averageScore: accountData.averageExamScore || 0,\n          totalTime: accountData.totalExamTime || 0\n        };\n        \n        // Load quick practice options from API\n        try {\n          const practiceData = await getQuickPracticeExams();\n          this.quickPractice = practiceData.map(practice => ({\n            ...practice,\n            icon: this.getSubjectIcon(practice.subject)\n          }));\n        } catch (practiceError) {\n          console.warn('Could not load quick practice data:', practiceError);\n          this.quickPractice = this.getDefaultQuickPractice();\n        }\n        \n        // Load available exams from API\n        try {\n          const examsData = await getAvailableExams(userId);\n          this.availableExams = examsData.map(exam => ({\n            ...exam,\n            subjectIcon: this.getSubjectIcon(exam.subject)\n          }));\n        } catch (examsError) {\n          console.warn('Could not load available exams:', examsError);\n          this.availableExams = this.getDefaultAvailableExams();\n        }\n        \n        // Load recent exam results from API\n        try {\n          const resultsData = await getExamResults(userId);\n          this.recentResults = resultsData.slice(0, 5).map(result => ({\n            ...result,\n            completedAt: new Date(result.completedAt),\n            grade: this.calculateGrade(result.score)\n          }));\n        } catch (resultsError) {\n          console.warn('Could not load exam results:', resultsError);\n          this.recentResults = [];\n        }\n        \n        // Load upcoming scheduled exams from API\n        try {\n          const upcomingData = await getUpcomingExams(userId);\n          this.upcomingExams = upcomingData.map(exam => ({\n            ...exam,\n            scheduledDate: new Date(exam.scheduledDate)\n          }));\n        } catch (upcomingError) {\n          console.warn('Could not load upcoming exams:', upcomingError);\n          this.upcomingExams = [];\n        }\n        \n      } catch (error) {\n        console.error('Error loading exams data:', error);\n        this.error = 'Failed to load exams data';\n        \n        if (error.message.includes('token') || error.response?.status === 401) {\n          localStorage.removeItem('token');\n          this.$router.push('/login');\n        }\n      } finally {\n        this.loading = false;\n      }\n    },\n    \n    startPractice(practice) {\n      console.log('Starting practice:', practice.title);\n      alert(`Starting ${practice.title} practice session`);\n    },\n    \n    startExam(exam) {\n      if (!exam.available) {\n        alert('This exam is not available yet. Please complete the requirements first.');\n        return;\n      }\n      console.log('Starting exam:', exam.title);\n      alert(`Starting exam: ${exam.title}`);\n    },\n    \n    viewExamDetails(exam) {\n      console.log('Viewing exam details:', exam.title);\n      alert(`Viewing details for: ${exam.title}`);\n    },\n    \n    viewResultDetails(result) {\n      console.log('Viewing result details:', result.examTitle);\n      alert(`Viewing detailed results for: ${result.examTitle}`);\n    },\n    \n    retakeExam(result) {\n      console.log('Retaking exam:', result.examTitle);\n      alert(`Retaking exam: ${result.examTitle}`);\n    },\n    \n    setReminder(upcoming) {\n      upcoming.reminderSet = !upcoming.reminderSet;\n      console.log('Reminder set for:', upcoming.title, upcoming.reminderSet);\n    },\n    \n    formatDate(date) {\n      return date.toLocaleDateString('en-US', {\n        year: 'numeric',\n        month: 'short',\n        day: 'numeric'\n      });\n    },\n    \n    formatDay(date) {\n      return date.getDate().toString().padStart(2, '0');\n    },\n    \n    formatMonth(date) {\n      return date.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();\n    },\n    \n    getScoreClass(score) {\n      if (score >= 90) return 'excellent';\n      if (score >= 80) return 'good';\n      if (score >= 70) return 'average';\n      return 'poor';\n    },\n    \n    getGradeClass(grade) {\n      if (grade.startsWith('A')) return 'grade-a';\n      if (grade.startsWith('B')) return 'grade-b';\n      if (grade.startsWith('C')) return 'grade-c';\n      return 'grade-d';\n    },\n    \n    logout() {\n      localStorage.removeItem('token');\n      this.$router.push('/login');\n    },\n    \n    getSubjectIcon(subject) {\n      const iconMap = {\n        'Programming': 'fab fa-js-square',\n        'Database': 'fas fa-database',\n        'Web Development': 'fas fa-globe',\n        'Computer Science': 'fas fa-laptop-code',\n        'Mathematics': 'fas fa-calculator',\n        'Science': 'fas fa-flask'\n      };\n      return iconMap[subject] || 'fas fa-book';\n    },\n    \n    calculateGrade(score) {\n      if (score >= 97) return 'A+';\n      if (score >= 93) return 'A';\n      if (score >= 90) return 'A-';\n      if (score >= 87) return 'B+';\n      if (score >= 83) return 'B';\n      if (score >= 80) return 'B-';\n      if (score >= 77) return 'C+';\n      if (score >= 73) return 'C';\n      if (score >= 70) return 'C-';\n      if (score >= 67) return 'D+';\n      if (score >= 65) return 'D';\n      return 'F';\n    },\n    \n    getDefaultQuickPractice() {\n      return [\n        {\n          id: 1,\n          title: 'JavaScript Basics',\n          description: 'Quick review of JavaScript fundamentals',\n          subject: 'Programming',\n          duration: 10,\n          questions: 15\n        },\n        {\n          id: 2,\n          title: 'Database Queries',\n          description: 'Practice SQL queries and database concepts',\n          subject: 'Database',\n          duration: 15,\n          questions: 20\n        },\n        {\n          id: 3,\n          title: 'Web Development',\n          description: 'HTML, CSS, and web development principles',\n          subject: 'Web Development',\n          duration: 12,\n          questions: 18\n        }\n      ];\n    },\n    \n    getDefaultAvailableExams() {\n      return [\n        {\n          id: 1,\n          title: 'JavaScript Advanced Concepts',\n          subject: 'Programming',\n          description: 'Comprehensive exam covering advanced JavaScript topics.',\n          duration: 90,\n          questions: 50,\n          points: 100,\n          difficulty: 'Advanced',\n          available: true,\n          requirements: ['Complete JavaScript Fundamentals course']\n        }\n      ];\n    }\n  }\n}\n</script>\n\n<style scoped>\n.exams-container {\n  display: flex;\n  min-height: 100vh;\n  position: relative;\n}\n\n/* Sidebar Styles */\n.sidebar {\n  width: 280px;\n  display: flex;\n  flex-direction: column;\n  position: fixed;\n  height: 100vh;\n  z-index: 100;\n}\n\n.sidebar-header {\n  font-size: 1.5rem;\n  padding: 2rem;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.user-profile {\n  display: flex;\n  align-items: center;\n  gap: 1rem;\n  margin-top: 1.5rem;\n  margin-left: 0.5rem;\n  border-radius: 12px;\n  transition: all 0.3s ease;\n  text-decoration