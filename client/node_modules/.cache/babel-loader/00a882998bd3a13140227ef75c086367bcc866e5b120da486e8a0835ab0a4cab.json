{"ast":null,"code":"export default {\n  name: 'AdminHeader',\n  props: {\n    title: {\n      type: String,\n      default: 'Admin Dashboard'\n    },\n    iconClass: {\n      type: String,\n      default: 'fas fa-tachometer-alt'\n    },\n    currentUser: {\n      type: Object,\n      default: () => ({})\n    }\n  },\n  data() {\n    return {\n      searchQuery: '',\n      showNotifications: false,\n      showUserMenu: false,\n      notificationCount: 3,\n      notifications: [{\n        id: 1,\n        title: 'New user registered',\n        message: 'John Doe has created a new account',\n        time: '2 minutes ago',\n        icon: 'fas fa-user-plus'\n      }, {\n        id: 2,\n        title: 'System update',\n        message: 'System maintenance scheduled for tonight',\n        time: '1 hour ago',\n        icon: 'fas fa-tools'\n      }, {\n        id: 3,\n        title: 'New exam submitted',\n        message: 'Mathematics exam has been submitted for review',\n        time: '3 hours ago',\n        icon: 'fas fa-clipboard-check'\n      }]\n    };\n  },\n  computed: {\n    pageDescription() {\n      const descriptionMap = {\n        'Statistics': 'View system statistics and analytics',\n        'Account Management': 'Manage user accounts and permissions',\n        'Subject Management': 'Manage subjects and categories',\n        'Question Management': 'Manage questions and Q&A content',\n        'Exam Management': 'Manage exams and assessments',\n        'AI Health Monitor': 'Monitor AI system health and performance',\n        'System Settings': 'Configure system settings and preferences'\n      };\n      return descriptionMap[this.title] || 'Manage your application';\n    }\n  },\n  methods: {\n    toggleMobileMenu() {\n      this.$emit('toggle-mobile-menu');\n    },\n    toggleNotifications() {\n      this.showNotifications = !this.showNotifications;\n      this.showUserMenu = false;\n    },\n    toggleUserMenu() {\n      this.showUserMenu = !this.showUserMenu;\n      this.showNotifications = false;\n    },\n    toggleTheme() {\n      document.documentElement.classList.toggle('dark');\n    },\n    handleSearch() {\n      console.log('Searching for:', this.searchQuery);\n    },\n    handleLogout() {\n      this.$emit('logout');\n    }\n  },\n  mounted() {\n    // Get current user from localStorage if not provided\n    if (!this.currentUser.username) {\n      const user = JSON.parse(localStorage.getItem('user') || '{}');\n      this.$emit('update-user', user);\n    }\n\n    // Close dropdowns when clicking outside\n    document.addEventListener('click', e => {\n      if (!this.$el.contains(e.target)) {\n        this.showNotifications = false;\n        this.showUserMenu = false;\n      }\n    });\n  }\n};","map":{"version":3,"names":["name","props","title","type","String","default","iconClass","currentUser","Object","data","searchQuery","showNotifications","showUserMenu","notificationCount","notifications","id","message","time","icon","computed","pageDescription","descriptionMap","methods","toggleMobileMenu","$emit","toggleNotifications","toggleUserMenu","toggleTheme","document","documentElement","classList","toggle","handleSearch","console","log","handleLogout","mounted","username","user","JSON","parse","localStorage","getItem","addEventListener","e","$el","contains","target"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\components\\admin\\AdminHeader.vue"],"sourcesContent":["<template>\n  <header class=\"admin-header w-full bg-white border-b border-gray-200\">\n    <div class=\"flex items-center justify-between px-4 md:px-6 h-32\">\n      <!-- Left Section -->\n      <div class=\"flex items-center space-x-4\">\n        <!-- Mobile Menu Button -->\n        <button\n          class=\"lg:hidden p-2 text-gray-500 hover:text-gray-700 hover:bg-hover rounded-lg transition-colors duration-200\"\n          @click=\"toggleMobileMenu\"\n        >\n          <i class=\"fas fa-bars w-5 h-5\"></i>\n        </button>\n\n        <!-- Page Title -->\n        <div>\n          <h1 class=\"text-section-header text-gray-900 flex items-center space-x-2\">\n            <i :class=\"iconClass\" class=\"text-primary\"></i>\n            <span>{{ title }}</span>\n          </h1>\n          <p class=\"text-body text-gray-500\">\n            {{ pageDescription }}\n          </p>\n        </div>\n      </div>\n\n      <!-- Right Section -->\n      <div class=\"flex items-center space-x-4\">\n        <!-- Search Bar -->\n        <div class=\"hidden md:block relative\">\n          <div class=\"absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none\">\n            <i class=\"fas fa-search text-gray-400 text-sm\"></i>\n          </div>\n          <input\n            type=\"text\"\n            placeholder=\"Search...\"\n            class=\"w-64 pl-10 pr-4 py-2 text-body border border-gray-300 rounded-lg bg-card text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-colors duration-200\"\n            v-model=\"searchQuery\"\n            @input=\"handleSearch\"\n          />\n        </div>\n\n        <!-- Notifications -->\n        <div class=\"relative\">\n          <button\n            class=\"p-2 text-gray-500 hover:text-gray-700 hover:bg-hover rounded-lg transition-colors duration-200 relative\"\n            @click=\"toggleNotifications\"\n          >\n            <i class=\"fas fa-bell w-5 h-5\"></i>\n            <span class=\"absolute -top-1 -right-1 w-3 h-3 bg-error rounded-full flex items-center justify-center\">\n              <span class=\"text-xs text-white font-bold\">{{ notificationCount }}</span>\n            </span>\n          </button>\n\n          <!-- Notifications Dropdown -->\n          <div\n            v-if=\"showNotifications\"\n            class=\"absolute right-0 mt-2 w-80 bg-card rounded-lg shadow-md border border-gray-200 z-50\"\n          >\n            <div class=\"p-4 border-b border-gray-200\">\n              <h3 class=\"text-small font-semibold text-gray-900\">Notifications</h3>\n            </div>\n            <div class=\"max-h-64 overflow-y-auto\">\n              <div\n                v-for=\"notification in notifications\"\n                :key=\"notification.id\"\n                class=\"p-4 border-b border-gray-100 hover:bg-hover transition-colors duration-200\"\n              >\n                <div class=\"flex items-start space-x-3\">\n                  <div class=\"flex-shrink-0\">\n                    <div class=\"w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center\">\n                      <i :class=\"notification.icon\" class=\"text-primary text-sm\"></i>\n                    </div>\n                  </div>\n                  <div class=\"flex-1 min-w-0\">\n                    <p class=\"text-body font-medium text-gray-900\">\n                      {{ notification.title }}\n                    </p>\n                    <p class=\"text-small text-gray-500 mt-1\">\n                      {{ notification.message }}\n                    </p>\n                    <p class=\"text-small text-gray-400 mt-1\">\n                      {{ notification.time }}\n                    </p>\n                  </div>\n                </div>\n              </div>\n            </div>\n            <div class=\"p-4 border-t border-gray-200\">\n              <button class=\"text-body text-primary hover:text-blue-800 font-medium\">\n                View all notifications\n              </button>\n            </div>\n          </div>\n        </div>\n\n        <!-- Theme Toggle -->\n        <button\n          class=\"p-2 text-gray-500 hover:text-gray-700 hover:bg-hover rounded-lg transition-colors duration-200\"\n          @click=\"toggleTheme\"\n        >\n          <i class=\"fas fa-moon w-5 h-5 dark:hidden\"></i>\n          <i class=\"fas fa-sun w-5 h-5 hidden dark:block\"></i>\n        </button>\n\n        <!-- User Menu -->\n        <div class=\"relative\">\n          <button\n            class=\"flex items-center space-x-2 p-2 text-navigation hover:text-gray-700 hover:bg-hover rounded-lg transition-colors duration-200\"\n            @click=\"toggleUserMenu\"\n          >\n            <div class=\"w-8 h-8 bg-gradient-to-br from-purple-400 to-pink-500 rounded-full flex items-center justify-center\">\n              <i class=\"fas fa-user text-white text-sm\"></i>\n            </div>\n            <span class=\"hidden md:block text-navigation font-medium text-gray-900\">\n              {{ currentUser.username || 'Admin' }}\n            </span>\n            <i class=\"fas fa-chevron-down w-3 h-3\"></i>\n          </button>\n\n          <!-- User Dropdown -->\n          <div\n            v-if=\"showUserMenu\"\n            class=\"absolute right-0 mt-2 w-48 bg-card rounded-lg shadow-md border border-gray-200 z-50\"\n          >\n            <div class=\"p-4 border-b border-gray-200\">\n              <p class=\"text-body font-medium text-gray-900\">\n                {{ currentUser.username || 'Admin User' }}\n              </p>\n              <p class=\"text-small text-gray-500\">\n                {{ currentUser.email || 'admin@example.com' }}\n              </p>\n            </div>\n            <div class=\"py-2\">\n              <a href=\"#\" class=\"block px-4 py-2 text-body text-gray-700 hover:bg-hover\">\n                <i class=\"fas fa-user-circle w-4 h-4 mr-2\"></i>\n                Profile\n              </a>\n              <a href=\"#\" class=\"block px-4 py-2 text-body text-gray-700 hover:bg-hover\">\n                <i class=\"fas fa-cog w-4 h-4 mr-2\"></i>\n                Settings\n              </a>\n              <hr class=\"my-2 border-gray-200\">\n              <button\n                @click=\"handleLogout\"\n                class=\"w-full text-left px-4 py-2 text-body text-error hover:bg-red-50\"\n              >\n                <i class=\"fas fa-sign-out-alt w-4 h-4 mr-2\"></i>\n                Logout\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n</template>\n\n<script>\nexport default {\n  name: 'AdminHeader',\n  props: {\n    title: {\n      type: String,\n      default: 'Admin Dashboard'\n    },\n    iconClass: {\n      type: String,\n      default: 'fas fa-tachometer-alt'\n    },\n    currentUser: {\n      type: Object,\n      default: () => ({})\n    }\n  },\n  data() {\n    return {\n      searchQuery: '',\n      showNotifications: false,\n      showUserMenu: false,\n      notificationCount: 3,\n      notifications: [\n        {\n          id: 1,\n          title: 'New user registered',\n          message: 'John Doe has created a new account',\n          time: '2 minutes ago',\n          icon: 'fas fa-user-plus'\n        },\n        {\n          id: 2,\n          title: 'System update',\n          message: 'System maintenance scheduled for tonight',\n          time: '1 hour ago',\n          icon: 'fas fa-tools'\n        },\n        {\n          id: 3,\n          title: 'New exam submitted',\n          message: 'Mathematics exam has been submitted for review',\n          time: '3 hours ago',\n          icon: 'fas fa-clipboard-check'\n        }\n      ]\n    }\n  },\n  computed: {\n    pageDescription() {\n      const descriptionMap = {\n        'Statistics': 'View system statistics and analytics',\n        'Account Management': 'Manage user accounts and permissions',\n        'Subject Management': 'Manage subjects and categories',\n        'Question Management': 'Manage questions and Q&A content',\n        'Exam Management': 'Manage exams and assessments',\n        'AI Health Monitor': 'Monitor AI system health and performance',\n        'System Settings': 'Configure system settings and preferences'\n      }\n      return descriptionMap[this.title] || 'Manage your application'\n    }\n  },\n  methods: {\n    toggleMobileMenu() {\n      this.$emit('toggle-mobile-menu')\n    },\n    toggleNotifications() {\n      this.showNotifications = !this.showNotifications\n      this.showUserMenu = false\n    },\n    toggleUserMenu() {\n      this.showUserMenu = !this.showUserMenu\n      this.showNotifications = false\n    },\n    toggleTheme() {\n      document.documentElement.classList.toggle('dark')\n    },\n    handleSearch() {\n      console.log('Searching for:', this.searchQuery)\n    },\n    handleLogout() {\n      this.$emit('logout')\n    }\n  },\n  mounted() {\n    // Get current user from localStorage if not provided\n    if (!this.currentUser.username) {\n      const user = JSON.parse(localStorage.getItem('user') || '{}')\n      this.$emit('update-user', user)\n    }\n    \n    // Close dropdowns when clicking outside\n    document.addEventListener('click', (e) => {\n      if (!this.$el.contains(e.target)) {\n        this.showNotifications = false\n        this.showUserMenu = false\n      }\n    })\n  }\n}\n</script>\n\n<style scoped>\n.admin-header {\n  width: 100% !important;\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\n/* Ensure the inner container spans full width */\n.admin-header > div {\n  width: 100%;\n  max-width: none;\n}\n\n/* Remove any inherited margins */\n.admin-page {\n  margin: 0;\n  padding: 0;\n}\n</style>"],"mappings":"AA8JA,eAAe;EACbA,IAAI,EAAE,aAAa;EACnBC,KAAK,EAAE;IACLC,KAAK,EAAE;MACLC,IAAI,EAAEC,MAAM;MACZC,OAAO,EAAE;IACX,CAAC;IACDC,SAAS,EAAE;MACTH,IAAI,EAAEC,MAAM;MACZC,OAAO,EAAE;IACX,CAAC;IACDE,WAAW,EAAE;MACXJ,IAAI,EAAEK,MAAM;MACZH,OAAO,EAAEA,CAAA,MAAO,CAAC,CAAC;IACpB;EACF,CAAC;EACDI,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAE,EAAE;MACfC,iBAAiB,EAAE,KAAK;MACxBC,YAAY,EAAE,KAAK;MACnBC,iBAAiB,EAAE,CAAC;MACpBC,aAAa,EAAE,CACb;QACEC,EAAE,EAAE,CAAC;QACLb,KAAK,EAAE,qBAAqB;QAC5Bc,OAAO,EAAE,oCAAoC;QAC7CC,IAAI,EAAE,eAAe;QACrBC,IAAI,EAAE;MACR,CAAC,EACD;QACEH,EAAE,EAAE,CAAC;QACLb,KAAK,EAAE,eAAe;QACtBc,OAAO,EAAE,0CAA0C;QACnDC,IAAI,EAAE,YAAY;QAClBC,IAAI,EAAE;MACR,CAAC,EACD;QACEH,EAAE,EAAE,CAAC;QACLb,