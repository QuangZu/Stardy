{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport '@/styles/admin/admin.css';\nimport '@/styles/admin/admin-modal.css';\nexport default {\n  name: 'ExamsAdmin',\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      exams: [],\n      subjects: [],\n      searchQuery: '',\n      showCreateExamModal: false,\n      newExam: {\n        title: '',\n        subjectId: '',\n        difficulty: 'easy',\n        duration: 60\n      }\n    };\n  },\n  computed: {\n    filteredExams() {\n      if (!this.searchQuery) return this.exams;\n      return this.exams.filter(exam => exam.title.toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchExams();\n    this.fetchSubjects();\n  },\n  methods: {\n    async fetchExams() {\n      try {\n        const response = await fetch('/api/admin/exams', {\n          headers: {\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          }\n        });\n        if (response.ok) {\n          this.exams = await response.json();\n        }\n      } catch (error) {\n        console.error('Error fetching exams:', error);\n      }\n    },\n    async fetchSubjects() {\n      try {\n        const response = await fetch('/api/admin/subjects', {\n          headers: {\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          }\n        });\n        if (response.ok) {\n          this.subjects = await response.json();\n        }\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n      }\n    },\n    getSubjectName(subjectId) {\n      const subject = this.subjects.find(s => s._id === subjectId);\n      return subject ? subject.name : 'Unknown';\n    },\n    async createExam() {\n      try {\n        const response = await fetch('/api/admin/exams', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          },\n          body: JSON.stringify(this.newExam)\n        });\n        if (response.ok) {\n          await this.fetchExams();\n          this.showCreateExamModal = false;\n          this.newExam = {\n            title: '',\n            subjectId: '',\n            difficulty: 'easy',\n            duration: 60\n          };\n        }\n      } catch (error) {\n        console.error('Error creating exam:', error);\n      }\n    },\n    editExam(exam) {\n      console.log('Edit exam:', exam);\n    },\n    async deleteExam(examId) {\n      if (confirm('Are you sure you want to delete this exam?')) {\n        try {\n          const response = await fetch(`/api/admin/exams/${examId}`, {\n            method: 'DELETE',\n            headers: {\n              'Authorization': `Bearer ${localStorage.getItem('token')}`\n            }\n          });\n          if (response.ok) {\n            await this.fetchExams();\n          }\n        } catch (error) {\n          console.error('Error deleting exam:', error);\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["name","data","currentUser","JSON","parse","localStorage","getItem","exams","subjects","searchQuery","showCreateExamModal","newExam","title","subjectId","difficulty","duration","computed","filteredExams","filter","exam","toLowerCase","includes","mounted","fetchExams","fetchSubjects","methods","response","fetch","headers","ok","json","error","console","getSubjectName","subject","find","s","_id","createExam","method","body","stringify","editExam","log","deleteExam","examId","confirm","formatDate","date","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\ExamsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-dashboard admin-space-background\">\r\n    <!-- Animated particles -->\r\n    <div class=\"admin-particles\"></div>\r\n    \r\n    <!-- Header -->\r\n    <AdminHeader \r\n      title=\"Exam Management\" \r\n      icon-class=\"fas fa-clipboard-list\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n\r\n    <!-- Navigation Tabs -->\r\n    <AdminNavigation current-route=\"exams\" />\r\n\r\n    <!-- Content Area -->\r\n    <div class=\"admin-content\">\r\n      <div class=\"tab-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Exam Management</h2>\r\n          <div class=\"header-actions\">\r\n            <div class=\"search-bar\">\r\n              <input \r\n                v-model=\"searchQuery\" \r\n                type=\"text\" \r\n                placeholder=\"Search exams...\"\r\n                class=\"search-input\"\r\n              >\r\n              <i class=\"fas fa-search search-icon\"></i>\r\n            </div>\r\n            <button @click=\"showCreateExamModal = true\" class=\"btn-create\">\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add Exam\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"table-container\">\r\n          <table class=\"admin-table\">\r\n            <thead>\r\n              <tr>\r\n                <th>ID</th>\r\n                <th>Title</th>\r\n                <th>Subject</th>\r\n                <th>Difficulty</th>\r\n                <th>Duration</th>\r\n                <th>Questions</th>\r\n                <th>Created</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"exam in filteredExams\" :key=\"exam._id\">\r\n                <td>{{ exam._id.slice(-6) }}</td>\r\n                <td>{{ exam.title }}</td>\r\n                <td>{{ getSubjectName(exam.subjectId) }}</td>\r\n                <td>\r\n                  <span :class=\"['difficulty-badge', exam.difficulty]\">\r\n                    {{ exam.difficulty.toUpperCase() }}\r\n                  </span>\r\n                </td>\r\n                <td>{{ exam.duration }} min</td>\r\n                <td>{{ exam.questions ? exam.questions.length : 0 }}</td>\r\n                <td>{{ formatDate(exam.createdAt) }}</td>\r\n                <td>\r\n                  <div class=\"action-buttons\">\r\n                    <button @click=\"editExam(exam)\" class=\"btn-edit\">\r\n                      <i class=\"fas fa-edit\"></i>\r\n                    </button>\r\n                    <button @click=\"deleteExam(exam._id)\" class=\"btn-delete\">\r\n                      <i class=\"fas fa-trash\"></i>\r\n                    </button>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Create Exam Modal -->\r\n    <div v-if=\"showCreateExamModal\" class=\"modal-overlay\" @click=\"showCreateExamModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Create New Exam</h3>\r\n          <button @click=\"showCreateExamModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Title</label>\r\n            <input v-model=\"newExam.title\" type=\"text\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Subject</label>\r\n            <select v-model=\"newExam.subjectId\" class=\"form-select\" required>\r\n              <option value=\"\">Select Subject</option>\r\n              <option v-for=\"subject in subjects\" :key=\"subject._id\" :value=\"subject._id\">\r\n                {{ subject.name }}\r\n              </option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Difficulty</label>\r\n            <select v-model=\"newExam.difficulty\" class=\"form-select\">\r\n              <option value=\"easy\">Easy</option>\r\n              <option value=\"medium\">Medium</option>\r\n              <option value=\"hard\">Hard</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Duration (minutes)</label>\r\n            <input v-model=\"newExam.duration\" type=\"number\" min=\"1\" class=\"form-input\" required>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showCreateExamModal = false\" class=\"btn-cancel\">Cancel</button>\r\n          <button @click=\"createExam\" class=\"btn-save\">Create Exam</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport '@/styles/admin/admin.css'\r\nimport '@/styles/admin/admin-modal.css'\r\n\r\nexport default {\r\n  name: 'ExamsAdmin',\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      exams: [],\r\n      subjects: [],\r\n      searchQuery: '',\r\n      showCreateExamModal: false,\r\n      newExam: {\r\n        title: '',\r\n        subjectId: '',\r\n        difficulty: 'easy',\r\n        duration: 60\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredExams() {\r\n      if (!this.searchQuery) return this.exams\r\n      return this.exams.filter(exam => \r\n        exam.title.toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchExams()\r\n    this.fetchSubjects()\r\n  },\r\n  methods: {\r\n    async fetchExams() {\r\n      try {\r\n        const response = await fetch('/api/admin/exams', {\r\n          headers: {\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          }\r\n        })\r\n        if (response.ok) {\r\n          this.exams = await response.json()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error fetching exams:', error)\r\n      }\r\n    },\r\n    async fetchSubjects() {\r\n      try {\r\n        const response = await fetch('/api/admin/subjects', {\r\n          headers: {\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          }\r\n        })\r\n        if (response.ok) {\r\n          this.subjects = await response.json()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error fetching subjects:', error)\r\n      }\r\n    },\r\n    getSubjectName(subjectId) {\r\n      const subject = this.subjects.find(s => s._id === subjectId)\r\n      return subject ? subject.name : 'Unknown'\r\n    },\r\n    async createExam() {\r\n      try {\r\n        const response = await fetch('/api/admin/exams', {\r\n          method: 'POST',\r\n          headers: {\r\n            'Content-Type': 'application/json',\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          },\r\n          body: JSON.stringify(this.newExam)\r\n        })\r\n        if (response.ok) {\r\n          await this.fetchExams()\r\n          this.showCreateExamModal = false\r\n          this.newExam = { title: '', subjectId: '', difficulty: 'easy', duration: 60 }\r\n        }\r\n      } catch (error) {\r\n        console.error('Error creating exam:', error)\r\n      }\r\n    },\r\n    editExam(exam) {\r\n      console.log('Edit exam:', exam)\r\n    },\r\n    async deleteExam(examId) {\r\n      if (confirm('Are you sure you want to delete this exam?')) {\r\n        try {\r\n          const response = await fetch(`/api/admin/exams/${examId}`, {\r\n            method: 'DELETE',\r\n            headers: {\r\n              'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n            }\r\n          })\r\n          if (response.ok) {\r\n            await this.fetchExams()\r\n          }\r\n        } catch (error) {\r\n          console.error('Error deleting exam:', error)\r\n        }\r\n      }\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;;AAgIA,OAAO,0BAAyB;AAChC,OAAO,gCAA+B;AAEtC,eAAe;EACbA,IAAI,EAAE,YAAY;EAClBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,KAAK,EAAE,EAAE;MACTC,QAAQ,EAAE,EAAE;MACZC,WAAW,EAAE,EAAE;MACfC,mBAAmB,EAAE,KAAK;MAC1BC,OAAO,EAAE;QACPC,KAAK,EAAE,EAAE;QACTC,SAAS,EAAE,EAAE;QACbC,UAAU,EAAE,MAAM;QAClBC,QAAQ,EAAE;MACZ;IACF;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,aAAaA,CAAA,EAAG;MACd,IAAI,CAAC,IAAI,CAACR,WAAW,EAAE,OAAO,IAAI,CAACF,KAAI;MACvC,OAAO,IAAI,CAACA,KAAK,CAACW,MAAM,CAACC,IAAG,IAC1BA,IAAI,CAACP,KAAK,CAACQ,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAACZ,WAAW,CAACW,WAAW,CAAC,CAAC,CAClE;IACF;EACF,CAAC;EACDE,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,UAAU,CAAC;IAChB,IAAI,CAACC,aAAa,CAAC;EACrB,CAAC;EACDC,OAAO,EAAE;IACP,MAAMF,UAAUA,CAAA,EAAG;MACjB,IAAI;QACF,MAAMG,QAAO,GAAI,MAAMC,KAAK,CAAC,kBAAkB,EAAE;UAC/CC,OAAO,EAAE;YACP,eAAe,EAAE,UAAUvB,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;UAC1D;QACF,CAAC;QACD,IAAIoB,QAAQ,CAACG,EAAE,EAAE;UACf,IAAI,CAACtB,KAAI,GAAI,MAAMmB,QAAQ,CAACI,IAAI,CAAC;QACnC;MACF,EAAE,OAAOC,KAAK,EAAE;QACdC,OAAO,CAACD,KAAK,CAAC,uBAAuB,EAAEA,KAAK;MAC9C;IACF,CAAC;IACD,MAAMP,aAAaA,CAAA,EAAG;MACpB,IAAI;QACF,MAAME,QAAO,GAAI,MAAMC,KAAK,CAAC,qBAAqB,EAAE;UAClDC,OAAO,EAAE;YACP,eAAe,EAAE,UAAUvB,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC;UAC1D;QACF,CAAC;QACD,IAAIoB,QAAQ,CAACG,EAAE,EAAE;UACf,IAAI,CAACrB,QAAO,GAAI