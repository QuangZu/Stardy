{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport '@/styles/admin/admin.css';\nimport '@/styles/admin/admin-modal.css';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport AdminNavigation from '@/components/admin/AdminNavigation.vue';\nimport { getAllQAs, createQA, updateQA, deleteQA } from '@/api/QA.js';\nimport { getAllSubjects } from '@/api/Subject.js';\nexport default {\n  name: 'QuestionsAdmin',\n  components: {\n    AdminHeader,\n    AdminNavigation\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      questions: [],\n      subjects: [],\n      searchQuery: '',\n      showCreateQuestionModal: false,\n      newQuestion: {\n        question: '',\n        subjectId: '',\n        levelId: 1,\n        type: 'multiple-choice'\n      }\n    };\n  },\n  computed: {\n    filteredQuestions() {\n      if (!this.searchQuery) return this.questions;\n      return this.questions.filter(question => question.question.toLowerCase().includes(this.searchQuery.toLowerCase()));\n    }\n  },\n  mounted() {\n    this.fetchQuestions();\n    this.fetchSubjects();\n  },\n  methods: {\n    async fetchQuestions() {\n      try {\n        this.questions = await getAllQAs();\n      } catch (error) {\n        console.error('Error fetching questions:', error);\n      }\n    },\n    async fetchSubjects() {\n      try {\n        this.subjects = await getAllSubjects();\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n      }\n    },\n    getSubjectName(subjectId) {\n      const subject = this.subjects.find(s => s._id === subjectId);\n      return subject ? subject.name : 'Unknown';\n    },\n    async createQuestion() {\n      try {\n        await createQA(this.newQuestion);\n        await this.fetchQuestions();\n        this.showCreateQuestionModal = false;\n        this.newQuestion = {\n          question: '',\n          subjectId: '',\n          levelId: 1,\n          type: 'multiple-choice'\n        };\n      } catch (error) {\n        console.error('Error creating question:', error);\n      }\n    },\n    editQuestion(question) {\n      console.log('Edit question:', question);\n    },\n    async deleteQuestion(questionId) {\n      if (confirm('Are you sure you want to delete this question?')) {\n        try {\n          await deleteQA(questionId);\n          await this.fetchQuestions();\n        } catch (error) {\n          console.error('Error deleting question:', error);\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminHeader","AdminNavigation","getAllQAs","createQA","updateQA","deleteQA","getAllSubjects","name","components","data","currentUser","JSON","parse","localStorage","getItem","questions","subjects","searchQuery","showCreateQuestionModal","newQuestion","question","subjectId","levelId","type","computed","filteredQuestions","filter","toLowerCase","includes","mounted","fetchQuestions","fetchSubjects","methods","error","console","getSubjectName","subject","find","s","_id","createQuestion","editQuestion","log","deleteQuestion","questionId","confirm","formatDate","date","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\QuestionsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-dashboard admin-space-background\">\r\n    <!-- Animated particles -->\r\n    <div class=\"admin-particles\"></div>\r\n    \r\n    <!-- Header -->\r\n    <AdminHeader \r\n      title=\"Question Management\" \r\n      icon-class=\"fas fa-question-circle\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n\r\n    <!-- Navigation Tabs -->\r\n    <AdminNavigation current-route=\"questions\" />\r\n\r\n    <!-- Content Area -->\r\n    <div class=\"admin-content\">\r\n      <div class=\"tab-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Question Management</h2>\r\n          <div class=\"header-actions\">\r\n            <div class=\"search-bar\">\r\n              <input \r\n                v-model=\"searchQuery\" \r\n                type=\"text\" \r\n                placeholder=\"Search questions...\"\r\n                class=\"search-input\"\r\n              >\r\n              <i class=\"fas fa-search search-icon\"></i>\r\n            </div>\r\n            <button @click=\"showCreateQuestionModal = true\" class=\"btn-create\">\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add Question\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"table-container\">\r\n          <table class=\"admin-table\">\r\n            <thead>\r\n              <tr>\r\n                <th>ID</th>\r\n                <th>Question</th>\r\n                <th>Subject</th>\r\n                <th>Level</th>\r\n                <th>Type</th>\r\n                <th>Created</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"question in filteredQuestions\" :key=\"question._id\">\r\n                <td>{{ question._id.slice(-6) }}</td>\r\n                <td>{{ question.question.substring(0, 50) }}...</td>\r\n                <td>{{ getSubjectName(question.subjectId) }}</td>\r\n                <td>{{ question.levelId }}</td>\r\n                <td>{{ question.type }}</td>\r\n                <td>{{ formatDate(question.createdAt) }}</td>\r\n                <td>\r\n                  <div class=\"action-buttons\">\r\n                    <button @click=\"editQuestion(question)\" class=\"btn-edit\">\r\n                      <i class=\"fas fa-edit\"></i>\r\n                    </button>\r\n                    <button @click=\"deleteQuestion(question._id)\" class=\"btn-delete\">\r\n                      <i class=\"fas fa-trash\"></i>\r\n                    </button>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Create Question Modal -->\r\n    <div v-if=\"showCreateQuestionModal\" class=\"modal-overlay\" @click=\"showCreateQuestionModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Create New Question</h3>\r\n          <button @click=\"showCreateQuestionModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Question</label>\r\n            <textarea v-model=\"newQuestion.question\" class=\"form-input\" rows=\"3\" required></textarea>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Subject</label>\r\n            <select v-model=\"newQuestion.subjectId\" class=\"form-select\" required>\r\n              <option value=\"\">Select Subject</option>\r\n              <option v-for=\"subject in subjects\" :key=\"subject._id\" :value=\"subject._id\">\r\n                {{ subject.name }}\r\n              </option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Level</label>\r\n            <input v-model=\"newQuestion.levelId\" type=\"number\" min=\"1\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Type</label>\r\n            <select v-model=\"newQuestion.type\" class=\"form-select\">\r\n              <option value=\"multiple-choice\">Multiple Choice</option>\r\n              <option value=\"true-false\">True/False</option>\r\n              <option value=\"short-answer\">Short Answer</option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showCreateQuestionModal = false\" class=\"btn-cancel\">Cancel</button>\r\n          <button @click=\"createQuestion\" class=\"btn-save\">Create Question</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport '@/styles/admin/admin.css'\r\nimport '@/styles/admin/admin-modal.css'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\nimport AdminNavigation from '@/components/admin/AdminNavigation.vue'\r\nimport { getAllQAs, createQA, updateQA, deleteQA } from '@/api/QA.js'\r\nimport { getAllSubjects } from '@/api/Subject.js'\r\n\r\nexport default {\r\n  name: 'QuestionsAdmin',\r\n  components: {\r\n    AdminHeader,\r\n    AdminNavigation\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      questions: [],\r\n      subjects: [],\r\n      searchQuery: '',\r\n      showCreateQuestionModal: false,\r\n      newQuestion: {\r\n        question: '',\r\n        subjectId: '',\r\n        levelId: 1,\r\n        type: 'multiple-choice'\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredQuestions() {\r\n      if (!this.searchQuery) return this.questions\r\n      return this.questions.filter(question => \r\n        question.question.toLowerCase().includes(this.searchQuery.toLowerCase())\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchQuestions()\r\n    this.fetchSubjects()\r\n  },\r\n  methods: {\r\n    async fetchQuestions() {\r\n      try {\r\n        this.questions = await getAllQAs()\r\n      } catch (error) {\r\n        console.error('Error fetching questions:', error)\r\n      }\r\n    },\r\n    async fetchSubjects() {\r\n      try {\r\n        this.subjects = await getAllSubjects()\r\n      } catch (error) {\r\n        console.error('Error fetching subjects:', error)\r\n      }\r\n    },\r\n    getSubjectName(subjectId) {\r\n      const subject = this.subjects.find(s => s._id === subjectId)\r\n      return subject ? subject.name : 'Unknown'\r\n    },\r\n    async createQuestion() {\r\n      try {\r\n        await createQA(this.newQuestion)\r\n        await this.fetchQuestions()\r\n        this.showCreateQuestionModal = false\r\n        this.newQuestion = { question: '', subjectId: '', levelId: 1, type: 'multiple-choice' }\r\n      } catch (error) {\r\n        console.error('Error creating question:', error)\r\n      }\r\n    },\r\n    editQuestion(question) {\r\n      console.log('Edit question:', question)\r\n    },\r\n    async deleteQuestion(questionId) {\r\n      if (confirm('Are you sure you want to delete this question?')) {\r\n        try {\r\n          await deleteQA(questionId)\r\n          await this.fetchQuestions()\r\n        } catch (error) {\r\n          console.error('Error deleting question:', error)\r\n        }\r\n      }\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;;AA0HA,OAAO,0BAAyB;AAChC,OAAO,gCAA+B;AACtC,OAAOA,WAAU,MAAO,oCAAmC;AAC3D,OAAOC,eAAc,MAAO,wCAAuC;AACnE,SAASC,SAAS,EAAEC,QAAQ,EAAEC,QAAQ,EAAEC,QAAO,QAAS,aAAY;AACpE,SAASC,cAAa,QAAS,kBAAiB;AAEhD,eAAe;EACbC,IAAI,EAAE,gBAAgB;EACtBC,UAAU,EAAE;IACVR,WAAW;IACXC;EACF,CAAC;EACDQ,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,SAAS,EAAE,EAAE;MACbC,QAAQ,EAAE,EAAE;MACZC,WAAW,EAAE,EAAE;MACfC,uBAAuB,EAAE,KAAK;MAC9BC,WAAW,EAAE;QACXC,QAAQ,EAAE,EAAE;QACZC,SAAS,EAAE,EAAE;QACbC,OAAO