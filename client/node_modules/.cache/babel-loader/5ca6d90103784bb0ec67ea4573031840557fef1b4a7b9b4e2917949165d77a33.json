{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport '@/styles/admin/admin.css';\nimport '@/styles/admin/admin-modal.css';\nimport AdminHeader from '@/components/admin/AdminHeader.vue';\nimport AdminNavigation from '@/components/admin/AdminNavigation.vue';\nimport { getAllSubjects, createSubject, deleteSubject } from '@/api/Subject.js';\nexport default {\n  name: 'SubjectsAdmin',\n  components: {\n    AdminHeader,\n    AdminNavigation\n  },\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      subjects: [],\n      searchQuery: '',\n      showCreateSubjectModal: false,\n      newSubject: {\n        name: '',\n        category: '',\n        difficulty: 'easy',\n        featured: false\n      }\n    };\n  },\n  computed: {\n    filteredSubjects() {\n      if (!this.subjects || !Array.isArray(this.subjects)) return [];\n      if (!this.searchQuery) return this.subjects;\n      return this.subjects.filter(subject => subject && subject.name && subject.category && (subject.name.toLowerCase().includes(this.searchQuery.toLowerCase()) || subject.category.toLowerCase().includes(this.searchQuery.toLowerCase())));\n    }\n  },\n  mounted() {\n    this.fetchSubjects();\n  },\n  methods: {\n    async fetchSubjects() {\n      try {\n        this.subjects = await getAllSubjects();\n      } catch (error) {\n        console.error('Error fetching subjects:', error);\n      }\n    },\n    async createSubject() {\n      try {\n        await createSubject(this.newSubject);\n        await this.fetchSubjects();\n        this.showCreateSubjectModal = false;\n        this.newSubject = {\n          name: '',\n          category: '',\n          difficulty: 'easy',\n          featured: false\n        };\n      } catch (error) {\n        console.error('Error creating subject:', error);\n      }\n    },\n    editSubject(subject) {\n      // Implementation for edit functionality\n      console.log('Edit subject:', subject);\n    },\n    async deleteSubject(subjectId) {\n      if (confirm('Are you sure you want to delete this subject?')) {\n        try {\n          await deleteSubject(subjectId);\n          await this.fetchSubjects();\n        } catch (error) {\n          console.error('Error deleting subject:', error);\n        }\n      }\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["AdminHeader","AdminNavigation","getAllSubjects","createSubject","deleteSubject","name","components","data","currentUser","JSON","parse","localStorage","getItem","subjects","searchQuery","showCreateSubjectModal","newSubject","category","difficulty","featured","computed","filteredSubjects","Array","isArray","filter","subject","toLowerCase","includes","mounted","fetchSubjects","methods","error","console","editSubject","log","subjectId","confirm","formatDate","date","Date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\SubjectsAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-dashboard admin-space-background\">\r\n    <!-- Animated particles -->\r\n    <div class=\"admin-particles\"></div>\r\n    \r\n    <!-- Header -->\r\n    <AdminHeader \r\n      title=\"Subject Management\" \r\n      icon-class=\"fas fa-book\" \r\n      :current-user=\"currentUser\" \r\n      @logout=\"logout\" \r\n    />\r\n\r\n    <!-- Navigation Tabs -->\r\n    <AdminNavigation current-route=\"subjects\" />\r\n\r\n    <!-- Content Area -->\r\n    <div class=\"admin-content\">\r\n      <div class=\"tab-content\">\r\n        <div class=\"content-header\">\r\n          <h2>Subject Management</h2>\r\n          <div class=\"header-actions\">\r\n            <div class=\"search-bar\">\r\n              <input \r\n                v-model=\"searchQuery\" \r\n                type=\"text\" \r\n                placeholder=\"Search subjects...\"\r\n                class=\"search-input\"\r\n              >\r\n              <i class=\"fas fa-search search-icon\"></i>\r\n            </div>\r\n            <button @click=\"showCreateSubjectModal = true\" class=\"btn-create\">\r\n              <i class=\"fas fa-plus\"></i>\r\n              Add Subject\r\n            </button>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"table-container\">\r\n          <table class=\"admin-table\">\r\n            <thead>\r\n              <tr>\r\n                <th>ID</th>\r\n                <th>Name</th>\r\n                <th>Category</th>\r\n                <th>Difficulty</th>\r\n                <th>Featured</th>\r\n                <th>Created</th>\r\n                <th>Actions</th>\r\n              </tr>\r\n            </thead>\r\n            <tbody>\r\n              <tr v-for=\"subject in filteredSubjects\" :key=\"subject._id\">\r\n                <td>{{ subject._id ? subject._id.slice(-6) : 'N/A' }}</td>\r\n                <td>{{ subject.name || 'N/A' }}</td>\r\n                <td>{{ subject.category || 'N/A' }}</td>\r\n                <td>\r\n                  <span :class=\"['difficulty-badge', subject.difficulty]\">\r\n                    {{ subject.difficulty ? subject.difficulty.toUpperCase() : 'N/A' }}\r\n                  </span>\r\n                </td>\r\n                <td>\r\n                  <span :class=\"['featured-badge', { featured: subject.featured }]\">\r\n                    {{ subject.featured ? 'YES' : 'NO' }}\r\n                  </span>\r\n                </td>\r\n                <td>{{ formatDate(subject.createdAt) }}</td>\r\n                <td>\r\n                  <div class=\"action-buttons\">\r\n                    <button @click=\"editSubject(subject)\" class=\"btn-edit\">\r\n                      <i class=\"fas fa-edit\"></i>\r\n                    </button>\r\n                    <button @click=\"deleteSubject(subject._id)\" class=\"btn-delete\">\r\n                      <i class=\"fas fa-trash\"></i>\r\n                    </button>\r\n                  </div>\r\n                </td>\r\n              </tr>\r\n            </tbody>\r\n          </table>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Create Subject Modal -->\r\n    <div v-if=\"showCreateSubjectModal\" class=\"modal-overlay\" @click=\"showCreateSubjectModal = false\">\r\n      <div class=\"modal-content\" @click.stop>\r\n        <div class=\"modal-header\">\r\n          <h3>Create New Subject</h3>\r\n          <button @click=\"showCreateSubjectModal = false\" class=\"close-btn\">\r\n            <i class=\"fas fa-times\"></i>\r\n          </button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>Name</label>\r\n            <input v-model=\"newSubject.name\" type=\"text\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Category</label>\r\n            <input v-model=\"newSubject.category\" type=\"text\" class=\"form-input\" required>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>Difficulty</label>\r\n            <select v-model=\"newSubject.difficulty\" class=\"form-select\">\r\n              <option value=\"easy\">Easy</option>\r\n              <option value=\"medium\">Medium</option>\r\n              <option value=\"hard\">Hard</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>\r\n              <input v-model=\"newSubject.featured\" type=\"checkbox\">\r\n              Featured Subject\r\n            </label>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"showCreateSubjectModal = false\" class=\"btn-cancel\">Cancel</button>\r\n          <button @click=\"createSubject\" class=\"btn-save\">Create Subject</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport '@/styles/admin/admin.css'\r\nimport '@/styles/admin/admin-modal.css'\r\nimport AdminHeader from '@/components/admin/AdminHeader.vue'\r\nimport AdminNavigation from '@/components/admin/AdminNavigation.vue'\r\nimport { getAllSubjects, createSubject, deleteSubject } from '@/api/Subject.js'\r\n\r\nexport default {\r\n  name: 'SubjectsAdmin',\r\n  components: {\r\n    AdminHeader,\r\n    AdminNavigation\r\n  },\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      subjects: [],\r\n      searchQuery: '',\r\n      showCreateSubjectModal: false,\r\n      newSubject: {\r\n        name: '',\r\n        category: '',\r\n        difficulty: 'easy',\r\n        featured: false\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    filteredSubjects() {\r\n      if (!this.subjects || !Array.isArray(this.subjects)) return []\r\n      if (!this.searchQuery) return this.subjects\r\n      return this.subjects.filter(subject => \r\n        subject && subject.name && subject.category &&\r\n        (subject.name.toLowerCase().includes(this.searchQuery.toLowerCase()) ||\r\n        subject.category.toLowerCase().includes(this.searchQuery.toLowerCase()))\r\n      )\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchSubjects()\r\n  },\r\n  methods: {\r\n    async fetchSubjects() {\r\n      try {\r\n        this.subjects = await getAllSubjects()\r\n      } catch (error) {\r\n        console.error('Error fetching subjects:', error)\r\n      }\r\n    },\r\n    async createSubject() {\r\n      try {\r\n        await createSubject(this.newSubject)\r\n        await this.fetchSubjects()\r\n        this.showCreateSubjectModal = false\r\n        this.newSubject = { name: '', category: '', difficulty: 'easy', featured: false }\r\n      } catch (error) {\r\n        console.error('Error creating subject:', error)\r\n      }\r\n    },\r\n    editSubject(subject) {\r\n      // Implementation for edit functionality\r\n      console.log('Edit subject:', subject)\r\n    },\r\n    async deleteSubject(subjectId) {\r\n      if (confirm('Are you sure you want to delete this subject?')) {\r\n        try {\r\n          await deleteSubject(subjectId)\r\n          await this.fetchSubjects()\r\n        } catch (error) {\r\n          console.error('Error deleting subject:', error)\r\n        }\r\n      }\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;AA+HA,OAAO,0BAAyB;AAChC,OAAO,gCAA+B;AACtC,OAAOA,WAAU,MAAO,oCAAmC;AAC3D,OAAOC,eAAc,MAAO,wCAAuC;AACnE,SAASC,cAAc,EAAEC,aAAa,EAAEC,aAAY,QAAS,kBAAiB;AAE9E,eAAe;EACbC,IAAI,EAAE,eAAe;EACrBC,UAAU,EAAE;IACVN,WAAW;IACXC;EACF,CAAC;EACDM,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,QAAQ,EAAE,EAAE;MACZC,WAAW,EAAE,EAAE;MACfC,sBAAsB,EAAE,KAAK;MAC7BC,UAAU,EAAE;QACVX,IAAI,EAAE,EAAE;QACRY,QAAQ,EAAE,EAAE;QACZC,UAAU,EAAE,MAAM;QAClBC,QAAQ,EAAE;MACZ;IACF;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,gBAAgBA,CAAA,EAAG;MACjB,IAAI,CAAC,IAAI,CAACR,QAAO,IAAK,CAACS,KAAK,CAACC,OAAO,CAAC,IAAI,CAACV,QAAQ,CAAC,EAAE,OAAO,EAAC;MAC7D,IAAI,CAAC,IAAI,CAACC,WAAW,EAAE,OAAO,IAAI,CAACD,QAAO;MAC1C,OAAO,IAAI,CAACA,QAAQ,CAACW,MAAM,CAACC,OAAM,IAChCA,OAAM,IAAKA,OAAO,CAACpB,IAAG,IAAKoB,OAAO,CAACR,QAAO,KACzCQ,OAAO,CAACpB,IAAI,CAACqB,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAACb,WAAW,CAACY,WAAW,CAAC,CAAC,KACnED,OAAO,CAACR,QAAQ,CAACS,WAAW,CAAC,CAAC,CAACC,QAAQ,CAAC,IAAI,CAACb,WAAW,CAACY,WAAW,CAAC,CAAC,CAAC,CACzE;IACF;EACF,CAAC;EACDE,OAAOA,CAAA,EAAG;IACR,