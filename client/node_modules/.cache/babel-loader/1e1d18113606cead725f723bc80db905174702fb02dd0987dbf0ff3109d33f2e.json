{"ast":null,"code":"import Chatbot from './components/Chatbot.vue';\nimport NotificationContainer from './components/NotificationContainer.vue';\nexport default {\n  name: 'App',\n  components: {\n    Chatbot,\n    NotificationContainer\n  },\n  computed: {\n    showChatbot() {\n      const hiddenRoutes = ['/login', '/register', '/'];\n      return !hiddenRoutes.includes(this.$route.path);\n    }\n  }\n};","map":{"version":3,"names":["Chatbot","NotificationContainer","name","components","computed","showChatbot","hiddenRoutes","includes","$route","path"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\App.vue"],"sourcesContent":["<template>\n  <div id=\"app\" class=\"min-h-screen gradient-bg text-white relative overflow-x-hidden\">\n    <!-- Persistent Animated Background -->    \n    <transition name=\"page\" mode=\"out-in\">\n      <router-view />\n    </transition>\n    \n    <!-- Global AI Chatbot -->\n    <Chatbot v-if=\"showChatbot\" />\n    \n    <!-- Global Notification Container -->\n    <NotificationContainer />\n  </div>\n</template>\n\n<script>\nimport Chatbot from './components/Chatbot.vue';\nimport NotificationContainer from './components/NotificationContainer.vue';\n\nexport default {\n  name: 'App',\n  components: {\n    Chatbot,\n    NotificationContainer\n  },\n  computed: {\n    showChatbot() {\n      const hiddenRoutes = ['/login', '/register', '/'];\n      return !hiddenRoutes.includes(this.$route.path);\n    }\n  }\n}\n</script>\n\n<style>\n@import url('https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css');\n@import './styles/animations.css';\n@import './styles/navigation.css';\n@import './styles/background.css';\n\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  line-height: 1.6;\n  color: #333;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n#app {\n  min-height: 100vh;\n}\n\n/* Smooth Page Transitions */\n.page-enter-active, .page-leave-active {\n  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);\n}\n\n.page-enter-from {\n  opacity: 0;\n  transform: translateY(20px);\n}\n\n.page-leave-to {\n  opacity: 0;\n  transform: translateY(-20px);\n}\n\n.page-enter-to, .page-leave-from {\n  opacity: 1;\n  transform: translateY(0);\n}\n</style>"],"mappings":"AAgBA,OAAOA,OAAM,MAAO,0BAA0B;AAC9C,OAAOC,qBAAoB,MAAO,wCAAwC;AAE1E,eAAe;EACbC,IAAI,EAAE,KAAK;EACXC,UAAU,EAAE;IACVH,OAAO;IACPC;EACF,CAAC;EACDG,QAAQ,EAAE;IACRC,WAAWA,CAAA,EAAG;MACZ,MAAMC,YAAW,GAAI,CAAC,QAAQ,EAAE,WAAW,EAAE,GAAG,CAAC;MACjD,OAAO,CAACA,YAAY,CAACC,QAAQ,CAAC,IAAI,CAACC,MAAM,CAACC,IAAI,CAAC;IACjD;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}