{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport '@/styles//admin.css';\nimport '@/styles/admin-modal.css';\nexport default {\n  name: 'AIHealthAdmin',\n  data() {\n    return {\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\n      aiHealth: {\n        status: 'healthy',\n        responseTime: 150,\n        lastCheck: new Date(),\n        uptime: '99.9%'\n      },\n      aiRequests: [],\n      aiConfig: {\n        model: 'gpt-3.5-turbo',\n        maxTokens: 2048,\n        temperature: 0.7\n      },\n      showAIConfigModal: false\n    };\n  },\n  computed: {\n    recentAIRequests() {\n      return this.aiRequests.slice(0, 10);\n    }\n  },\n  mounted() {\n    this.fetchAIRequests();\n    this.checkAIHealth();\n  },\n  methods: {\n    async fetchAIRequests() {\n      try {\n        const response = await fetch('/api/admin/ai-requests', {\n          headers: {\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          }\n        });\n        if (response.ok) {\n          this.aiRequests = await response.json();\n        }\n      } catch (error) {\n        console.error('Error fetching AI requests:', error);\n      }\n    },\n    async checkAIHealth() {\n      try {\n        const response = await fetch('/api/admin/ai-health', {\n          headers: {\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\n          }\n        });\n        if (response.ok) {\n          this.aiHealth = await response.json();\n        }\n      } catch (error) {\n        console.error('Error checking AI health:', error);\n      }\n    },\n    getTodayRequests() {\n      const today = new Date().toDateString();\n      return this.aiRequests.filter(req => new Date(req.timestamp).toDateString() === today).length;\n    },\n    getWeekRequests() {\n      const weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);\n      return this.aiRequests.filter(req => new Date(req.timestamp) > weekAgo).length;\n    },\n    getSuccessRate() {\n      if (this.aiRequests.length === 0) return 100;\n      const successful = this.aiRequests.filter(req => req.status === 'success').length;\n      return Math.round(successful / this.aiRequests.length * 100);\n    },\n    formatDate(date) {\n      return new Date(date).toLocaleDateString();\n    },\n    logout() {\n      localStorage.removeItem('token');\n      localStorage.removeItem('user');\n      this.$router.push('/login');\n    }\n  }\n};","map":{"version":3,"names":["name","data","currentUser","JSON","parse","localStorage","getItem","aiHealth","status","responseTime","lastCheck","Date","uptime","aiRequests","aiConfig","model","maxTokens","temperature","showAIConfigModal","computed","recentAIRequests","slice","mounted","fetchAIRequests","checkAIHealth","methods","response","fetch","headers","ok","json","error","console","getTodayRequests","today","toDateString","filter","req","timestamp","length","getWeekRequests","weekAgo","now","getSuccessRate","successful","Math","round","formatDate","date","toLocaleDateString","logout","removeItem","$router","push"],"sources":["C:\\Users\\minhq\\Desktop\\COMP1842\\CourseworkCOMP1842\\client\\src\\views\\admin\\AIHealthAdmin.vue"],"sourcesContent":["<template>\r\n  <div class=\"admin-dashboard admin-space-background\">\r\n    <!-- Animated particles -->\r\n    <div class=\"admin-particles\"></div>\r\n    \r\n    <!-- Header -->\r\n    <div class=\"admin-header\">\r\n      <h1 class=\"admin-title\">\r\n        <i class=\"fas fa-robot\"></i>\r\n        AI Health & Configuration\r\n      </h1>\r\n      <div class=\"admin-user-info\">\r\n        <span>Welcome, {{ currentUser.username }}</span>\r\n        <button @click=\"logout\" class=\"logout-btn\">\r\n          <i class=\"fas fa-sign-out-alt\"></i>\r\n          Logout\r\n        </button>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Navigation Tabs -->\r\n    <div class=\"admin-nav\">\r\n      <router-link to=\"/admin/users\" class=\"nav-tab\">\r\n        <i class=\"fas fa-users\"></i>\r\n        Users\r\n      </router-link>\r\n      <router-link to=\"/admin/subjects\" class=\"nav-tab\">\r\n        <i class=\"fas fa-book\"></i>\r\n        Subjects\r\n      </router-link>\r\n      <router-link to=\"/admin/questions\" class=\"nav-tab\">\r\n        <i class=\"fas fa-question-circle\"></i>\r\n        Questions\r\n      </router-link>\r\n      <router-link to=\"/admin/exams\" class=\"nav-tab\">\r\n        <i class=\"fas fa-clipboard-list\"></i>\r\n        Exams\r\n      </router-link>\r\n      <router-link to=\"/admin/ai-health\" class=\"nav-tab active\">\r\n        <i class=\"fas fa-robot\"></i>\r\n        AI Health\r\n      </router-link>\r\n      <router-link to=\"/admin/stats\" class=\"nav-tab\">\r\n        <i class=\"fas fa-chart-bar\"></i>\r\n        Statistics\r\n      </router-link>\r\n      <router-link to=\"/admin/system\" class=\"nav-tab\">\r\n        <i class=\"fas fa-cog\"></i>\r\n        System\r\n      </router-link>\r\n    </div>\r\n\r\n    <!-- Content Area -->\r\n    <div class=\"admin-content\">\r\n      <div class=\"tab-content\">\r\n        <div class=\"content-header\">\r\n          <h2>AI Health & Configuration</h2>\r\n          <button @click=\"checkAIHealth\" class=\"btn-refresh\">\r\n            <i class=\"fas fa-sync-alt\"></i>\r\n            Refresh Status\r\n          </button>\r\n        </div>\r\n\r\n        <div class=\"ai-status-grid\">\r\n          <div class=\"status-card\">\r\n            <div class=\"status-header\">\r\n              <h3>AI Service Status</h3>\r\n              <span :class=\"['status-indicator', aiHealth.status]\">\r\n                {{ aiHealth.status === 'healthy' ? '🟢 Online' : '🔴 Offline' }}\r\n              </span>\r\n            </div>\r\n            <div class=\"status-details\">\r\n              <p><strong>Response Time:</strong> {{ aiHealth.responseTime }}ms</p>\r\n              <p><strong>Last Check:</strong> {{ formatDate(aiHealth.lastCheck) }}</p>\r\n              <p><strong>Uptime:</strong> {{ aiHealth.uptime }}</p>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"status-card\">\r\n            <div class=\"status-header\">\r\n              <h3>AI Requests</h3>\r\n              <span class=\"request-count\">{{ aiRequests.length }} total</span>\r\n            </div>\r\n            <div class=\"status-details\">\r\n              <p><strong>Today:</strong> {{ getTodayRequests() }}</p>\r\n              <p><strong>This Week:</strong> {{ getWeekRequests() }}</p>\r\n              <p><strong>Success Rate:</strong> {{ getSuccessRate() }}%</p>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"status-card\">\r\n            <div class=\"status-header\">\r\n              <h3>Configuration</h3>\r\n              <button @click=\"showAIConfigModal = true\" class=\"btn-config\">\r\n                <i class=\"fas fa-cog\"></i>\r\n                Configure\r\n              </button>\r\n            </div>\r\n            <div class=\"status-details\">\r\n              <p><strong>Model:</strong> {{ aiConfig.model }}</p>\r\n              <p><strong>Max Tokens:</strong> {{ aiConfig.maxTokens }}</p>\r\n              <p><strong>Temperature:</strong> {{ aiConfig.temperature }}</p>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- AI Requests Table -->\r\n        <div class=\"ai-requests-section\">\r\n          <h3>Recent AI Requests</h3>\r\n          <div class=\"table-container\">\r\n            <table class=\"admin-table\">\r\n              <thead>\r\n                <tr>\r\n                  <th>User</th>\r\n                  <th>Request Type</th>\r\n                  <th>Status</th>\r\n                  <th>Response Time</th>\r\n                  <th>Timestamp</th>\r\n                </tr>\r\n              </thead>\r\n              <tbody>\r\n                <tr v-for=\"request in recentAIRequests\" :key=\"request._id\">\r\n                  <td>{{ request.username || 'Anonymous' }}</td>\r\n                  <td>{{ request.type }}</td>\r\n                  <td>\r\n                    <span :class=\"['status-badge', request.status]\">\r\n                      {{ request.status.toUpperCase() }}\r\n                    </span>\r\n                  </td>\r\n                  <td>{{ request.responseTime }}ms</td>\r\n                  <td>{{ formatDate(request.timestamp) }}</td>\r\n                </tr>\r\n              </tbody>\r\n            </table>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport '@/styles//admin.css'\r\nimport '@/styles/admin-modal.css'\r\n\r\nexport default {\r\n  name: 'AIHealthAdmin',\r\n  data() {\r\n    return {\r\n      currentUser: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      aiHealth: {\r\n        status: 'healthy',\r\n        responseTime: 150,\r\n        lastCheck: new Date(),\r\n        uptime: '99.9%'\r\n      },\r\n      aiRequests: [],\r\n      aiConfig: {\r\n        model: 'gpt-3.5-turbo',\r\n        maxTokens: 2048,\r\n        temperature: 0.7\r\n      },\r\n      showAIConfigModal: false\r\n    }\r\n  },\r\n  computed: {\r\n    recentAIRequests() {\r\n      return this.aiRequests.slice(0, 10)\r\n    }\r\n  },\r\n  mounted() {\r\n    this.fetchAIRequests()\r\n    this.checkAIHealth()\r\n  },\r\n  methods: {\r\n    async fetchAIRequests() {\r\n      try {\r\n        const response = await fetch('/api/admin/ai-requests', {\r\n          headers: {\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          }\r\n        })\r\n        if (response.ok) {\r\n          this.aiRequests = await response.json()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error fetching AI requests:', error)\r\n      }\r\n    },\r\n    async checkAIHealth() {\r\n      try {\r\n        const response = await fetch('/api/admin/ai-health', {\r\n          headers: {\r\n            'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n          }\r\n        })\r\n        if (response.ok) {\r\n          this.aiHealth = await response.json()\r\n        }\r\n      } catch (error) {\r\n        console.error('Error checking AI health:', error)\r\n      }\r\n    },\r\n    getTodayRequests() {\r\n      const today = new Date().toDateString()\r\n      return this.aiRequests.filter(req => \r\n        new Date(req.timestamp).toDateString() === today\r\n      ).length\r\n    },\r\n    getWeekRequests() {\r\n      const weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000)\r\n      return this.aiRequests.filter(req => \r\n        new Date(req.timestamp) > weekAgo\r\n      ).length\r\n    },\r\n    getSuccessRate() {\r\n      if (this.aiRequests.length === 0) return 100\r\n      const successful = this.aiRequests.filter(req => req.status === 'success').length\r\n      return Math.round((successful / this.aiRequests.length) * 100)\r\n    },\r\n    formatDate(date) {\r\n      return new Date(date).toLocaleDateString()\r\n    },\r\n    logout() {\r\n      localStorage.removeItem('token')\r\n      localStorage.removeItem('user')\r\n      this.$router.push('/login')\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";;;AA8IA,OAAO,qBAAoB;AAC3B,OAAO,0BAAyB;AAEhC,eAAe;EACbA,IAAI,EAAE,eAAe;EACrBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,WAAW,EAAEC,IAAI,CAACC,KAAK,CAACC,YAAY,CAACC,OAAO,CAAC,MAAM,KAAK,IAAI,CAAC;MAC7DC,QAAQ,EAAE;QACRC,MAAM,EAAE,SAAS;QACjBC,YAAY,EAAE,GAAG;QACjBC,SAAS,EAAE,IAAIC,IAAI,CAAC,CAAC;QACrBC,MAAM,EAAE;MACV,CAAC;MACDC,UAAU,EAAE,EAAE;MACdC,QAAQ,EAAE;QACRC,KAAK,EAAE,eAAe;QACtBC,SAAS,EAAE,IAAI;QACfC,WAAW,EAAE;MACf,CAAC;MACDC,iBAAiB,EAAE;IACrB;EACF,CAAC;EACDC,QAAQ,EAAE;IACRC,gBAAgBA,CAAA,EAAG;MACjB,OAAO,IAAI,CAACP,UAAU,CAACQ,KAAK,CAAC,CAAC,EAAE,EAAE;IACpC;EACF,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,eAAe,CAAC;IACrB,IAAI,CAACC,aAAa,CAAC;EACrB,CAA